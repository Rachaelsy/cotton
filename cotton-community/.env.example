NODE_ENV=development
PORT=3100

# 与 cotton-app 填写同一套 MySQL 连接信息。
DB_HOST=127.0.0.1
DB_PORT=3306
DB_NAME=cotton
DB_USER=root
DB_PASS=

# 必须与 cotton-app 的 JWT_SECRET 一致，两个项目才能识别同一账号签发的令牌。
JWT_SECRET=replace-with-the-same-secret-as-cotton-app
JWT_EXPIRES=7d

# 原业务平台地址，用于“返回平台”链接。独立开发填写本地地址，同域部署留空。
PLATFORM_BASE_URL=http://localhost:3000

# 本机课程素材上传上限（MB）；大视频建议使用 COS/OSS 后填写 HTTPS 地址。
KNOWLEDGE_LOCAL_UPLOAD_MAX_MB=250

# 课程 AI 问答，按优先级选择一个可用服务。
DEEPSEEK_API_KEY=
GROQ_API_KEY=
SILICONFLOW_API_KEY=
