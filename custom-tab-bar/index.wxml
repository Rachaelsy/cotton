<!-- custom-tab-bar/index.wxml -->
<view class="tbar">

  <view class="titem {{selected === 0 ? 'on' : ''}}" bindtap="switchTab" data-index="0">
    <text class="ticon">🏠</text>
    <text class="tlbl">首页</text>
  </view>

  <view class="titem ai-item" bindtap="switchTab" data-index="1">
    <view class="ai-circle">
      <text class="ai-emoji">🤖</text>
      <view class="ai-dot"></view>
    </view>
    <text class="ai-lbl">AI问答</text>
  </view>

  <view class="titem {{selected === 2 ? 'on' : ''}}" bindtap="switchTab" data-index="2">
    <text class="ticon">👤</text>
    <text class="tlbl">我的</text>
  </view>

</view>
