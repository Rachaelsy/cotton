.mbar {
  flex-shrink: 0;
  width: 750rpx;
  height: 140rpx;
  background: #ffffff;
  border-top: 1rpx solid #EEEEEE;
  display: flex;
  flex-direction: row;
  align-items: flex-start;
  justify-content: space-around;
  padding-top: 14rpx;
  padding-bottom: env(safe-area-inset-bottom);
  box-shadow: 0 -2rpx 16rpx rgba(0, 0, 0, 0.06);
}

.mitem {
  flex: 1;
  display: flex;
  flex-direction: column;
  align-items: center;
  gap: 4rpx;
}

.micon {
  font-size: 40rpx;
  line-height: 1.2;
}

.mlbl {
  font-size: 18rpx;
  color: #999999;
  font-weight: 500;
}

.on .mlbl {
  color: #C8902E;
  font-weight: 700;
}
