# 数据库配置
DB_HOST=localhost
DB_PORT=3306
DB_NAME=cotton_db
DB_USER=root
DB_PASS=your_password

# JWT 密钥（生产环境请换为随机长字符串）
JWT_SECRET=cotton_jwt_secret_change_in_production
JWT_EXPIRES=7d

# 服务端口
PORT=3000

# 对外访问域名，用于把上传视频/图片的相对路径转成小程序可播放的 HTTPS 地址。
PUBLIC_BASE_URL=https://TODO_DOMAIN

# 微信物流助手（继续联调前先在小程序后台确认已绑定的快递公司/月结账号）
WECHAT_LOGISTICS_SENDER_NAME=TODO_DEFAULT_SENDER_NAME
WECHAT_LOGISTICS_SENDER_MOBILE=TODO_DEFAULT_SENDER_MOBILE
WECHAT_LOGISTICS_SENDER_COMPANY=TODO_COMPANY_NAME
WECHAT_LOGISTICS_SENDER_ADDRESS=TODO_FULL_SENDER_ADDRESS
WECHAT_LOGISTICS_DEFAULT_WEIGHT_KG=1
WECHAT_LOGISTICS_DEFAULT_SIZE_CM=20
WECHAT_LOGISTICS_TIMEOUT_MS=10000

# 地块气象真实数据源
# qweather = 和风天气格点接口；open-meteo-cma = 旧 Open-Meteo CMA 备用
WEATHER_PROVIDER=qweather
# 在和风控制台「设置」查看你自己的 API Host，例如 abc1234xyz.def.qweatherapi.com
QWEATHER_API_HOST=TODO_QWEATHER_API_HOST
# 认证方式二选一：
# 方式 A：API KEY，开发期最简单。和风 API KEY 支持请求头 X-QW-Api-Key。
QWEATHER_API_KEY=TODO_QWEATHER_API_KEY
# 方式 B：JWT，生产推荐。public.pem 上传到和风控制台，后端填写 private.pem。
# QWEATHER_JWT_KID=TODO_QWEATHER_CREDENTIAL_ID
# QWEATHER_JWT_SUB=TODO_QWEATHER_PROJECT_ID
# QWEATHER_JWT_PRIVATE_KEY_PATH=TODO_ABSOLUTE_PATH_TO_ED25519_PRIVATE_PEM
# QWEATHER_JWT_PRIVATE_KEY=TODO_PRIVATE_KEY_WITH_BACKSLASH_N_LINE_BREAKS
# QWEATHER_TIMEOUT_MS=8000
# 每小时按地块中心采集真实实况，用于积温和近 30 天降水统计。
WEATHER_OBSERVATION_COLLECTOR_ENABLED=true
# 单轮最多采集多少个地块，避免意外消耗过多接口额度。
WEATHER_OBSERVATION_MAX_PLOTS=100

# 微信小程序配置
# 在微信公众平台 mp.weixin.qq.com 的小程序后台获取：
# 开发 -> 开发管理 -> 开发设置 -> 开发者ID
WX_APPID=TODO_MINIPROGRAM_APPID
WX_SECRET=TODO_MINIPROGRAM_APPSECRET

# 农户实名认证敏感数据 AES-GCM 加密密钥。请使用密码管理器生成至少 32 位随机字符串，生产环境不得更换或提交到 Git。
IDENTITY_DATA_KEY=TODO_RANDOM_IDENTITY_DATA_ENCRYPTION_KEY_AT_LEAST_32_CHARS

# AI 服务（按优先级使用，填第一个即可）
# 1. Groq（完全免费，推荐）：https://console.groq.com → API Keys
GROQ_API_KEY=gsk_xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
# 2. Siliconflow（图片分析用视觉模型）：https://cloud.siliconflow.cn
SILICONFLOW_API_KEY=sk-xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
# 3. DeepSeek 直连（需充值）：https://platform.deepseek.com
DEEPSEEK_API_KEY=sk-xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx

# 微信支付服务商模式
# TODO: 公司通过微信支付服务商审核后填写。
# 服务商 AppID。通常与当前小程序 WX_APPID 相同。
WECHAT_PAY_SP_APPID=TODO_SERVICE_PROVIDER_APPID
# 服务商商户号 sp_mchid。
WECHAT_PAY_SP_MCH_ID=TODO_SERVICE_PROVIDER_MCH_ID
# API 证书序列号。
WECHAT_PAY_SERIAL_NO=TODO_API_CERT_SERIAL_NO
# 微信支付回调地址，必须是微信可访问的 HTTPS 地址。
WECHAT_PAY_NOTIFY_URL=https://TODO_DOMAIN/api/pay/wechat/notify
# 微信退款结果回调地址；不填时会由 WECHAT_PAY_NOTIFY_URL 自动推导为 /api/pay/wechat/refund-notify。
WECHAT_PAY_REFUND_NOTIFY_URL=https://TODO_DOMAIN/api/pay/wechat/refund-notify
# 可选：指定退款资金来源账户。一般留空由微信支付按规则处理；需要指定时再填 AVAILABLE/UNAVAILABLE 等微信支持值。
WECHAT_PAY_REFUND_FUNDS_ACCOUNT=

# 私钥配置二选一。
# 推荐：把 apiclient_key.pem 放在仓库外，填写绝对路径。
WECHAT_PAY_PRIVATE_KEY_PATH=TODO_ABSOLUTE_PATH_TO_APICLIENT_KEY_PEM
# 备选：直接粘贴私钥，把换行替换为 \n。
# WECHAT_PAY_PRIVATE_KEY=TODO_PRIVATE_KEY_WITH_BACKSLASH_N_LINE_BREAKS

# API v3 密钥，微信支付商户平台设置，长度必须为 32 个字符。
WECHAT_PAY_API_V3_KEY=TODO_32_CHAR_API_V3_KEY

# 是否启用微信支付分账。正式分账测试前需要服务商和特约商户开通/授权分账产品。
# 如仅测试基础支付，可先填 false；分账权限开通后改为 true。
WECHAT_PAY_PROFIT_SHARING_ENABLED=true
# 分账接收方商户号：留空时默认使用服务商商户号收取平台佣金。
WECHAT_PAY_PROFIT_SHARING_RECEIVER_MCH_ID=
# 分账接收方全称：MERCHANT_ID 接收方必填，必须与微信支付商户平台里的商户全称完全一致。
WECHAT_PAY_PROFIT_SHARING_RECEIVER_NAME=TODO_SERVICE_PROVIDER_FULL_NAME
# 确认收货后等待多少天再自动分账；测试可填 0，正式环境建议 7。
WECHAT_PAY_PROFIT_SHARING_FREEZE_DAYS=7

# 微信支付进件结算规则由营业执照主体类型自动选择：个体户719、企业716、其他组织727。
# 如微信支付后续调整规则，应同步修改 server/utils/applyment-registration.js。

# 微信支付测试模式：
# 留空 = 正常按订单原金额支付
# small_amount = 真实微信环境小额测试，后端会强制按下面的分金额下单/验单
# mock = 本地模拟支付，不调用微信；还必须同时设置 WECHAT_PAY_MOCK_ENABLED=true，生产环境强制禁用
WECHAT_PAY_TEST_MODE=
WECHAT_PAY_FORCE_TEST_FEN=1
WECHAT_PAY_MOCK_ENABLED=false

# 服务商自营测试店铺使用的子商户号。
# 注意：服务商支付接口也必须传 sub_mchid，不能直接用服务商商户号收款。
# 可先在服务商平台给公司主体/测试店铺申请或绑定一个特约商户号，再填这里。
SELF_MERCHANT_SUB_MCHID=TODO_SELF_OPERATED_SUB_MCHID

# 微信支付公钥模式（新商户推荐）：在微信支付服务商平台「账户中心 -> 账户设置 -> API安全 -> 管理公钥」下载。
WECHAT_PAY_PUBLIC_KEY_ID=TODO_WECHAT_PAY_PUBLIC_KEY_ID
WECHAT_PAY_PUBLIC_KEY_PATH=TODO_ABSOLUTE_PATH_TO_WECHATPAY_PUBLIC_KEY_PEM
# WECHAT_PAY_PUBLIC_KEY=TODO_WECHATPAY_PUBLIC_KEY_WITH_BACKSLASH_N_LINE_BREAKS

# 微信支付平台证书模式（旧方式），用于回调验签和敏感字段加密。
WECHAT_PAY_PLATFORM_SERIAL_NO=TODO_PLATFORM_CERT_SERIAL_NO
WECHAT_PAY_PLATFORM_CERT_PATH=TODO_ABSOLUTE_PATH_TO_WECHATPAY_PLATFORM_CERT_PEM
# 备选：直接粘贴平台证书，把换行替换为 \n。
# WECHAT_PAY_PLATFORM_CERT=TODO_PLATFORM_CERT_WITH_BACKSLASH_N_LINE_BREAKS
