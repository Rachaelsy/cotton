.page { height: 100vh; display: flex; flex-direction: column; background: #F5F7F3; color: #1B261E; }
.nav { flex-shrink: 0; display: flex; align-items: center; padding-left: 28rpx; padding-bottom: 20rpx; background: #FFFFFF; border-bottom: 1rpx solid #E4EAE1; }
.back { width: 64rpx; height: 64rpx; display: flex; align-items: center; justify-content: center; background: #F1F4EF; border-radius: 50%; }
.back-icon { font-size: 48rpx; line-height: 1; }
.title { flex: 1; text-align: center; font-size: 34rpx; font-weight: 800; }
.nav-space { width: 64rpx; }
.tabs { display: flex; flex-shrink: 0; padding: 0 28rpx; background: #FFFFFF; border-bottom: 1rpx solid #E7ECE5; }
.tab { position: relative; flex: 1; padding: 26rpx 0 22rpx; text-align: center; color: #69736C; font-size: 28rpx; font-weight: 600; }
.tab-on { color: #176B45; }
.tab-on::after { content: ''; position: absolute; left: 50%; bottom: 0; width: 52rpx; height: 6rpx; transform: translateX(-50%); border-radius: 3rpx; background: #176B45; }
.content { flex: 1; height: 0; padding-top: 20rpx; box-sizing: border-box; }
.coupon { position: relative; margin: 0 28rpx 20rpx; min-height: 196rpx; display: flex; align-items: stretch; overflow: hidden; background: #FFFFFF; border: 1rpx solid #DFE7DC; border-radius: 12rpx; box-shadow: 0 5rpx 18rpx rgba(27, 55, 36, .06); }
.coupon-value { width: 190rpx; flex-shrink: 0; display: flex; flex-direction: column; align-items: center; justify-content: center; padding: 20rpx 10rpx; color: #B74232; background: #FFF4ED; border-right: 1rpx dashed #E6BFB3; box-sizing: border-box; }
.value { font-size: 52rpx; font-weight: 900; }
.unit { margin-left: 4rpx; font-size: 24rpx; font-weight: 700; }
.condition { margin-top: 8rpx; color: #895D51; font-size: 20rpx; text-align: center; }
.coupon-main { min-width: 0; flex: 1; display: flex; flex-direction: column; justify-content: center; padding: 22rpx 16rpx 22rpx 22rpx; }
.coupon-name { overflow: hidden; text-overflow: ellipsis; white-space: nowrap; font-size: 28rpx; font-weight: 800; }
.merchant { margin-top: 10rpx; overflow: hidden; text-overflow: ellipsis; white-space: nowrap; color: #566159; font-size: 22rpx; }
.validity { margin-top: 8rpx; color: #8B938D; font-size: 19rpx; }
.coupon-action { align-self: center; width: 104rpx; margin-right: 18rpx; padding: 13rpx 0; text-align: center; color: #FFFFFF; background: #176B45; border-radius: 30rpx; font-size: 22rpx; font-weight: 700; }
.coupon-action-off { color: #7D857F; background: #E8ECE7; }
.coupon-disabled { opacity: .62; }
.state { padding: 160rpx 30rpx; text-align: center; color: #89918B; font-size: 26rpx; }
.bottom-space { height: calc(40rpx + env(safe-area-inset-bottom)); }
