<!-- subpkg-supplies/supplies-review/index.wxml — 买家评价 -->
<view class="page">

  <!-- 顶部 -->
  <view class="header" style="padding-top: {{statusBarHeight}}px">
    <view class="topbar" style="padding-right: {{capsuleSafeRight}}px">
      <view class="back-btn" bindtap="onBack">
        <text class="back-icon">‹</text>
      </view>
      <text class="header-title">{{copy.title}}</text>
      <view style="width: 64rpx"></view>
    </view>
  </view>

  <scroll-view class="scroll" scroll-y>
    <view class="body">

      <!-- 提交成功态 -->
      <view wx:if="{{submitted}}" class="success-wrap">
        <text class="success-emoji">🎉</text>
        <text class="success-title">{{copy.success}}</text>
        <text class="success-sub">{{copy.thanks}}</text>
        <view class="done-btn" bindtap="onDone">
          <text class="done-text">{{copy.backOrder}}</text>
        </view>
      </view>

      <!-- 评价表单 -->
      <view wx:else>

        <!-- 订单商品预览 -->
        <view class="items-card">
          <text class="items-title">{{copy.order}} {{orderNo}}</text>
          <view class="item-row" wx:for="{{items}}" wx:key="index">
            <view class="item-icon-wrap">
              <text class="item-icon">{{item.icon || '📦'}}</text>
            </view>
            <text class="item-name">{{item.name}}</text>
          </view>
        </view>

        <!-- 星级评分 -->
        <view class="rate-card">
          <text class="rate-label">{{copy.overall}}</text>
          <view class="stars-row">
            <view
              class="star-btn"
              wx:for="{{[1,2,3,4,5]}}"
              wx:key="*this"
              data-val="{{item}}"
              bindtap="onStarTap"
            >
              <text class="star {{rating >= item ? 'star-on' : 'star-off'}}">★</text>
            </view>
          </view>
          <text class="rate-hint">{{ratingHint}}</text>
        </view>

        <!-- 文字评价 -->
        <view class="content-card">
          <text class="content-label">{{copy.content}}</text>
          <textarea
            class="content-input"
            placeholder="{{copy.placeholder}}"
            maxlength="300"
            bindinput="onContentInput"
            value="{{content}}"
          ></textarea>
          <text class="content-count">{{content.length}}/300</text>
        </view>

        <!-- 匿名评价 -->
        <view class="anon-row">
          <text class="anon-label">{{copy.anonymous}}</text>
          <switch checked="{{isAnonymous}}" bindchange="onAnonymousChange" color="#C8902E" />
        </view>

        <!-- 提交按钮 -->
        <view
          class="submit-btn {{!rating || submitting ? 'submit-disabled' : ''}}"
          bindtap="onSubmit"
        >
          <text class="submit-text">{{submitting ? copy.submitting : copy.submit}}</text>
        </view>

      </view>

      <view style="height: 60rpx"></view>
    </view>
  </scroll-view>

</view>
