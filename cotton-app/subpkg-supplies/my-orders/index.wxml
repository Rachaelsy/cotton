<!-- my-orders/index.wxml — 我的订单（农资 + 农机 统一） -->
<view class="page">

  <view class="header" style="padding-top: {{statusBarHeight}}px">
    <view class="topbar" style="padding-right: {{capsuleSafeRight}}px">
      <view class="back-btn" bindtap="onBack"><text class="back-icon">‹</text></view>
      <text class="header-title">{{copy.title}}</text>
      <view style="width: 64rpx"></view>
    </view>
    <view class="tabs">
      <view class="tab {{activeTab === item.key ? 'tab-active' : ''}}"
        wx:for="{{tabs}}" wx:key="key" data-key="{{item.key}}" bindtap="onTabTap">
        <text class="tab-text">{{item.label}}</text>
      </view>
    </view>
  </view>

  <scroll-view class="scroll" scroll-y>
  <view wx:if="{{loading}}" class="loading-wrap"><text class="loading-text">{{copy.loading}}</text></view>
    <view wx:elif="{{empty}}" class="empty-wrap">
      <text class="empty-icon">📋</text>
      <text class="empty-title">{{copy.empty}}</text>
      <text class="empty-sub">{{copy.emptySub}}</text>
    </view>

    <view wx:else class="list">
      <block wx:for="{{orders}}" wx:key="id" wx:for-item="item">

        <!-- 农资订单 -->
        <view wx:if="{{item.type === 'supplies'}}" class="order-card" data-order="{{item}}" bindtap="onOrderTap">
          <view class="card-head">
            <view class="type-badge badge-supplies"><text class="type-badge-text">{{copy.supplies}}</text></view>
            <text class="order-no">{{item.raw.order_no}}</text>
            <view class="status-tag {{item.statusCls}}"><text class="status-text">{{item.statusLabel}}</text></view>
          </view>
          <view class="goods-row">
            <view class="goods-icon-wrap">
              <image wx:if="{{item.firstItem.image_url}}" class="goods-img" src="{{item.firstItem.image_url}}" mode="aspectFill"/>
              <text wx:else class="goods-icon">{{item.firstItem.icon || '📦'}}</text>
            </view>
            <view class="goods-info">
              <text class="goods-name">{{item.firstItem.name || copy.goods}}</text>
              <text class="goods-spec">{{item.firstItem.spec}} × {{item.firstItem.qty}}</text>
            </view>
              <text wx:if="{{item.moreCount > 0}}" class="goods-more">+{{item.moreCount}}{{copy.piece}}</text>
          </view>
          <view wx:if="{{item.logisticsNo && (item.status === 'shipped' || item.status === 'completed')}}" class="logistics-preview">
            <text class="logistics-preview-icon">🚚</text>
            <view class="logistics-preview-info">
              <text class="logistics-preview-status">{{item.logisticsStatus || copy.shipped}}</text>
              <text class="logistics-preview-text">{{item.logisticsLatest || item.logisticsFallback}}</text>
            </view>
            <text class="logistics-preview-arrow">›</text>
          </view>
          <view class="card-foot">
            <text class="order-time">{{item.createDate}}</text>
            <view class="amount-row">
            <text class="amount-label">{{item.status === 'pending_payment' ? copy.due : copy.paid}}</text>
              <text class="amount-val">¥{{item.total}}</text>
            </view>
          </view>
          <view wx:if="{{item.status === 'pending_payment'}}" class="action-row">
            <view class="action-btn cancel-btn" catchtap="onCancelOrder" data-order="{{item}}"><text class="action-btn-text cancel-text">{{copy.cancel}}</text></view>
            <view class="action-btn pay-btn" catchtap="onPayOrder" data-order="{{item}}"><text class="action-btn-text pay-text">{{copy.pay}}</text></view>
          </view>
          <view wx:elif="{{item.canDelete}}" class="action-row">
            <view class="action-btn cancel-btn" catchtap="onDeleteOrder" data-id="{{item.id}}"><text class="action-btn-text cancel-text">{{copy.delete}}</text></view>
          </view>
        </view>

        <!-- 农机预约 -->
        <view wx:else class="order-card" data-id="{{item.id}}" bindtap="onMachineTap">
          <view class="card-head">
            <view class="type-badge badge-machine"><text class="type-badge-text">{{copy.machine}}</text></view>
            <text class="order-no">{{item.raw.order_no}}</text>
            <view class="status-tag {{item.statusCls}}"><text class="status-text">{{item.statusLabel}}</text></view>
          </view>
          <view class="goods-row">
            <view class="goods-icon-wrap machine-icon-wrap"><text class="goods-icon">{{item.machineIcon}}</text></view>
            <view class="goods-info">
              <text class="goods-name">{{item.machineName}}</text>
              <text class="goods-spec">{{item.plotName || copy.noPlot}} · {{item.workArea}}{{copy.mu}} · {{item.workDate}}</text>
              <text wx:if="{{item.workAddress}}" class="goods-addr">📍 {{item.workAddress}}</text>
            </view>
          </view>
          <view class="card-foot">
            <text class="order-time">{{item.createDate}}</text>
            <view class="amount-row">
            <text class="amount-label">{{copy.total}}</text>
              <text class="amount-val">¥{{item.total}}</text>
            </view>
          </view>
          <view wx:if="{{item.canDelete}}" class="action-row">
            <view class="action-btn cancel-btn" catchtap="onMachineDelete" data-id="{{item.id}}"><text class="action-btn-text cancel-text">{{copy.delete}}</text></view>
          </view>
        </view>

      </block>
    </view>

    <view style="height: 40rpx"></view>
  </scroll-view>
</view>
