/* pages/supplies-order/index.wxss — 订单详情 */
.text-green  { color: #2F8A52; }
.text-red    { color: #C93D35; }
.text-orange { color: #D97706; }

.page {
  display: flex;
  flex-direction: column;
  height: 100vh;
  background: #F6F8F3;
  position: relative;
}

/* ===== 顶部 ===== */
.ord-header {
  background: linear-gradient(160deg, #92400e, #B9852F);
  padding-left: 28rpx;
  padding-right: 28rpx;
  padding-bottom: 32rpx;
  flex-shrink: 0;
}

.ord-topbar {
  display: flex;
  flex-direction: row;
  align-items: center;
  padding-top: 10rpx;
  padding-bottom: 20rpx;
}

.ord-back {
  width: 64rpx;
  height: 64rpx;
  background: rgba(255, 255, 255, 0.2);
  border-radius: 50%;
  display: flex;
  align-items: center;
  justify-content: center;
  flex-shrink: 0;
}

.ord-back-icon {
  color: #ffffff;
  font-size: 44rpx;
}

.ord-nav-title {
  flex: 1;
  text-align: center;
  font-size: 32rpx;
  font-weight: 800;
  color: #ffffff;
}

.ord-status-block {
  display: flex;
  flex-direction: row;
  align-items: center;
  gap: 20rpx;
}

.ord-status-icon { font-size: 56rpx; }

.ord-status-info {
  display: flex;
  flex-direction: column;
  gap: 6rpx;
}

.ord-status-label {
  font-size: 40rpx;
  font-weight: 900;
  color: #ffffff;
}

.ord-status-sub {
  font-size: 24rpx;
  color: rgba(255, 255, 255, 0.8);
}

/* ===== 步骤条 ===== */
.steps-bar {
  background: #ffffff;
  padding: 28rpx 20rpx;
  display: flex;
  flex-direction: row;
  align-items: flex-start;
  flex-shrink: 0;
  box-shadow: 0 4rpx 16rpx rgba(33, 61, 42, 0.05);
}

.step {
  flex: 1;
  display: flex;
  flex-direction: column;
  align-items: center;
  position: relative;
}

.step-dot {
  width: 44rpx;
  height: 44rpx;
  border-radius: 50%;
  background: #E5E5E5;
  display: flex;
  align-items: center;
  justify-content: center;
  margin-bottom: 10rpx;
}

.step-dot-done {
  background: #45A565;
}

.step-dot-active {
  background: #B9852F;
  box-shadow: 0 0 0 6rpx rgba(200, 144, 46, 0.2);
}

.step-check {
  font-size: 24rpx;
  color: #ffffff;
  font-weight: 900;
}

.step-num {
  font-size: 22rpx;
  color: #ffffff;
  font-weight: 800;
}

.step-label {
  font-size: 20rpx;
  color: #C5CCC5;
  font-weight: 600;
  text-align: center;
}

.step-label-on { color: #18231A; }

.step-line {
  position: absolute;
  top: 22rpx;
  left: 72%;
  right: -28%;
  height: 4rpx;
  background: #E5E5E5;
  border-radius: 2rpx;
  overflow: hidden;
}

.step-line-fill {
  height: 100%;
  background: #45A565;
  transition: width 0.3s;
}

/* ===== 滚动区 ===== */
.ord-scroll {
  flex: 1;
  height: 0;
}

.ord-body {
  padding: 20rpx 28rpx 0;
}

/* ===== 内容卡片 ===== */
.section-card {
  background: #ffffff;
  border-radius: 22rpx;
  padding: 28rpx 24rpx;
  margin-bottom: 16rpx;
}

.section-head {
  display: flex;
  flex-direction: row;
  align-items: center;
  gap: 12rpx;
  margin-bottom: 20rpx;
  padding-bottom: 16rpx;
  border-bottom: 1rpx solid #EAF0E6;
}

.section-icon { font-size: 32rpx; }

.section-title {
  font-size: 26rpx;
  font-weight: 800;
  color: #18231A;
}

/* ===== 真实物流 ===== */
.logistics-card { padding-bottom: 20rpx; }
.logistics-head { justify-content: space-between; }
.logistics-title-wrap { display: flex; align-items: center; gap: 12rpx; }
.logistics-refresh { font-size: 22rpx; color: #2F8A52; padding: 8rpx 12rpx; }
.logistics-refresh.disabled { color: #9CA3AF; }
.logistics-summary { padding: 4rpx 0 20rpx; }
.logistics-status-row { display: flex; align-items: center; justify-content: space-between; gap: 16rpx; margin-bottom: 10rpx; }
.logistics-status { font-size: 30rpx; font-weight: 800; color: #23844A; }
.logistics-arrival { font-size: 21rpx; color: #B9852F; }
.logistics-latest { display: block; font-size: 25rpx; line-height: 1.55; color: #26352B; }
.logistics-updated { display: block; margin-top: 8rpx; font-size: 20rpx; color: #9AA49B; }
.logistics-number-row { display: flex; align-items: center; min-width: 0; padding: 18rpx 0; border-top: 1rpx solid #EAF0E6; }
.logistics-company { font-size: 23rpx; color: #58655B; margin-right: 14rpx; flex-shrink: 0; }
.logistics-number { min-width: 0; flex: 1; font-size: 23rpx; color: #18231A; overflow: hidden; text-overflow: ellipsis; white-space: nowrap; }
.logistics-copy { font-size: 21rpx; color: #2F8A52; padding-left: 14rpx; }
.logistics-notice { padding: 16rpx 18rpx; margin-bottom: 12rpx; border-radius: 10rpx; background: #FFF7E8; color: #9A6700; font-size: 22rpx; line-height: 1.5; }
.logistics-timeline { padding-top: 10rpx; border-top: 1rpx solid #EAF0E6; }
.logistics-event { display: flex; align-items: stretch; min-height: 108rpx; }
.logistics-axis { width: 30rpx; display: flex; flex-direction: column; align-items: center; flex-shrink: 0; }
.logistics-dot { width: 14rpx; height: 14rpx; margin-top: 9rpx; border-radius: 50%; background: #C7CEC8; border: 4rpx solid #F1F4F1; }
.logistics-event.current .logistics-dot { background: #2F8A52; border-color: #DDF2E4; }
.logistics-line { width: 2rpx; flex: 1; background: #E1E6E2; }
.logistics-event-body { flex: 1; min-width: 0; padding: 0 0 24rpx 12rpx; }
.logistics-event-context { display: block; font-size: 23rpx; line-height: 1.5; color: #687468; }
.logistics-event.current .logistics-event-context { color: #18231A; font-weight: 600; }
.logistics-event-time { display: block; margin-top: 8rpx; font-size: 20rpx; line-height: 1.4; color: #A1AAA2; }
.logistics-empty { padding: 30rpx 0; text-align: center; font-size: 23rpx; color: #8A948B; }
.logistics-expand { display: flex; align-items: center; justify-content: center; gap: 12rpx; padding-top: 16rpx; color: #2F8A52; font-size: 23rpx; font-weight: 600; }

/* ===== 地址 ===== */
.addr-row {
  display: flex;
  flex-direction: column;
  gap: 8rpx;
}

.addr-name-row {
  display: flex;
  flex-direction: row;
  align-items: center;
  gap: 16rpx;
}

.addr-name {
  font-size: 28rpx;
  font-weight: 700;
  color: #18231A;
}

.addr-phone {
  font-size: 24rpx;
  color: #8A948B;
}

.addr-detail {
  font-size: 24rpx;
  color: #58655B;
  line-height: 1.5;
}

/* ===== 商品 ===== */
.ord-item {
  display: flex;
  flex-direction: row;
  align-items: center;
  gap: 20rpx;
  padding: 16rpx 0;
  border-bottom: 1rpx solid #EAF0E6;
}

.ord-item:last-child { border-bottom: none; }

.ord-item-img {
  width: 88rpx;
  height: 88rpx;
  border-radius: 16rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  flex-shrink: 0;
}

.ord-item-icon { font-size: 44rpx; }

.ord-item-info {
  flex: 1;
  display: flex;
  flex-direction: column;
  gap: 6rpx;
}

.ord-item-name {
  font-size: 26rpx;
  font-weight: 600;
  color: #18231A;
  line-height: 1.4;
}

.ord-item-spec {
  font-size: 22rpx;
  color: #8A948B;
}

.ord-item-price {
  font-size: 28rpx;
  font-weight: 800;
  color: #FF3B30;
}

/* ===== 订单信息 KV ===== */
.kv-row {
  display: flex;
  flex-direction: row;
  align-items: center;
  justify-content: space-between;
  padding: 14rpx 0;
  border-bottom: 1rpx solid #F8F3ED;
}

.kv-row:last-child { border-bottom: none; }

.kv-row-total { padding-top: 20rpx; }

.kv-k {
  font-size: 24rpx;
  color: #8A948B;
}

.kv-k-bold {
  font-size: 26rpx;
  font-weight: 700;
  color: #18231A;
}

.kv-v {
  font-size: 24rpx;
  font-weight: 600;
  color: #18231A;
}

.kv-no-wrap {
  display: flex;
  flex-direction: row;
  align-items: center;
  gap: 12rpx;
}

.kv-copy {
  font-size: 20rpx;
  color: #45A565;
  font-weight: 700;
  background: #f0fdf4;
  padding: 4rpx 12rpx;
  border-radius: 999rpx;
}

.kv-v-red {
  font-size: 32rpx;
  font-weight: 900;
  color: #FF3B30;
}

/* ===== 底部操作栏 ===== */
.ord-bottom {
  background: #ffffff;
  border-top: 1rpx solid #EAF0E6;
  padding: 20rpx 28rpx;
  padding-bottom: calc(20rpx + env(safe-area-inset-bottom));
  display: flex;
  flex-direction: column;
  gap: 16rpx;
  flex-shrink: 0;
}

.confirm-receipt-btn {
  background: linear-gradient(135deg, #2F8A52, #22C55E);
  border-radius: 999rpx;
  padding: 26rpx 0;
  display: flex;
  align-items: center;
  justify-content: center;
  box-shadow: 0 6rpx 24rpx rgba(22, 163, 74, 0.35);
}

.confirm-receipt-text {
  font-size: 30rpx;
  font-weight: 800;
  color: #ffffff;
}

.action-row {
  display: flex;
  flex-direction: row;
  gap: 16rpx;
}

.action-btn {
  flex: 1;
  border-radius: 20rpx;
  padding: 20rpx 8rpx;
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
  gap: 6rpx;
  border: 2rpx solid #E3E9DE;
}

.action-contact { border-color: #D4EDDA; background: #F0FDF4; }
.action-refund  { border-color: #FCE8D4; background: #FFF7F0; }
.action-logistics { border-color: #D4E8FA; background: #EFF7FF; }

.action-disabled {
  opacity: 0.38;
}

.action-icon { font-size: 36rpx; }

.action-label {
  font-size: 24rpx;
  font-weight: 700;
  color: #333333;
}

.action-sub {
  font-size: 18rpx;
  color: #B7C0B8;
  margin-top: -4rpx;
}

/* ===== 已完成三大入口 ===== */
.ord-bottom-row {
  flex-direction: row;
  gap: 0;
  padding: 16rpx 0;
  padding-bottom: calc(16rpx + env(safe-area-inset-bottom));
}

.c3btn {
  flex: 1;
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
  gap: 8rpx;
  padding: 12rpx 0;
}

.c3btn-icon { font-size: 40rpx; }

.c3btn-label {
  font-size: 22rpx;
  font-weight: 700;
}

.c3btn-review  .c3btn-label { color: #B9852F; }
.c3btn-contact .c3btn-label { color: #2F8A52; }
.c3btn-aftersale .c3btn-label { color: #D6453D; }

/* ===== 收货成功弹窗 ===== */
.success-overlay {
  position: absolute;
  top: 0;
  left: 0;
  right: 0;
  bottom: 0;
  background: rgba(0, 0, 0, 0.5);
  display: flex;
  align-items: center;
  justify-content: center;
  z-index: 999;
}

.success-popup {
  background: #ffffff;
  border-radius: 40rpx;
  width: 560rpx;
  padding: 60rpx 48rpx 48rpx;
  display: flex;
  flex-direction: column;
  align-items: center;
  gap: 20rpx;
}

.success-icon-wrap {
  width: 120rpx;
  height: 120rpx;
  background: linear-gradient(135deg, #2F8A52, #22C55E);
  border-radius: 50%;
  display: flex;
  align-items: center;
  justify-content: center;
  margin-bottom: 8rpx;
}

.success-checkmark {
  font-size: 56rpx;
  color: #ffffff;
  font-weight: 900;
  line-height: 1;
}

.success-title {
  font-size: 40rpx;
  font-weight: 900;
  color: #18231A;
}

.success-sub {
  font-size: 26rpx;
  color: #8A948B;
  text-align: center;
  line-height: 1.6;
}

.success-close-btn {
  margin-top: 16rpx;
  width: 100%;
  background: linear-gradient(135deg, #2F8A52, #22C55E);
  border-radius: 999rpx;
  padding: 26rpx 0;
  display: flex;
  align-items: center;
  justify-content: center;
}

.success-close-text {
  font-size: 30rpx;
  font-weight: 800;
  color: #ffffff;
}
