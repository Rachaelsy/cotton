<!-- pages/supplies-order/index.wxml — 订单详情 -->
<view class="page">

  <!-- 顶部（橙绿色渐变） -->
  <view class="ord-header" style="padding-top: {{statusBarHeight}}px">
    <view class="ord-topbar" style="padding-right: {{capsuleSafeRight}}px">
      <view class="ord-back" bindtap="onBack">
        <text class="ord-back-icon">‹</text>
      </view>
      <text class="ord-nav-title">{{copy.title}}</text>
      <view style="width: 64rpx"></view>
    </view>
    <!-- 当前状态 -->
    <view class="ord-status-block">
      <text class="ord-status-icon">{{statusIcon}}</text>
      <view class="ord-status-info">
        <text class="ord-status-label">{{statusLabel}}</text>
        <text class="ord-status-sub">{{statusSub}}</text>
      </view>
    </view>
  </view>

  <!-- 状态进度条 -->
  <view class="steps-bar">
    <view class="step" wx:for="{{steps}}" wx:key="index">
      <view class="step-dot {{item.done ? 'step-dot-done' : ''}} {{item.active ? 'step-dot-active' : ''}}">
        <text class="step-check" wx:if="{{item.done}}">✓</text>
        <text class="step-num" wx:else>{{index + 1}}</text>
      </view>
      <text class="step-label {{item.done || item.active ? 'step-label-on' : ''}}">{{item.label}}</text>
      <view class="step-line" wx:if="{{index < steps.length - 1}}">
        <view class="step-line-fill" style="width: {{item.done ? '100%' : '0%'}}"></view>
      </view>
    </view>
  </view>

  <!-- 可滚动内容 -->
  <scroll-view class="ord-scroll" scroll-y>
    <view class="ord-body">

      <!-- 收货地址 -->
      <view class="section-card">
        <view class="section-head">
          <text class="section-icon">📍</text>
          <text class="section-title">{{copy.address}}</text>
        </view>
        <view class="addr-row">
          <view class="addr-name-row">
            <text class="addr-name">{{order.receiverName}}</text>
            <text class="addr-phone">{{order.receiverPhone}}</text>
          </view>
          <text class="addr-detail">{{order.address}}</text>
        </view>
      </view>

      <!-- 订单商品 -->
      <view class="section-card">
        <view class="section-head">
          <text class="section-icon">📦</text>
          <text class="section-title">{{copy.goods}}</text>
        </view>
        <view class="ord-item" wx:for="{{order.items}}" wx:key="id">
          <view class="ord-item-img" style="background: {{item.imgBg || '#FBF5EA'}}">
            <text class="ord-item-icon">{{item.icon || '📦'}}</text>
          </view>
          <view class="ord-item-info">
            <text class="ord-item-name">{{item.name}}</text>
            <text class="ord-item-spec">{{item.spec}} × {{item.qty}}</text>
          </view>
          <text class="ord-item-price">¥{{item.price * item.qty}}</text>
        </view>
      </view>

      <!-- 订单信息 -->
      <view class="section-card">
        <view class="section-head">
          <text class="section-icon">🧾</text>
          <text class="section-title">{{copy.info}}</text>
        </view>
        <view class="kv-row">
          <text class="kv-k">{{copy.orderNo}}</text>
          <view class="kv-no-wrap" bindtap="onCopyNo">
            <text class="kv-v">{{orderNo}}</text>
            <text class="kv-copy">{{copy.copy}}</text>
          </view>
        </view>
        <view class="kv-row">
          <text class="kv-k">{{copy.payMethod}}</text>
          <text class="kv-v">{{payMethodLabel}}</text>
        </view>
        <view wx:if="{{order.logisticsNo}}" class="kv-row">
          <text class="kv-k">{{copy.logisticsNo}}</text>
          <text class="kv-v">{{order.logisticsNo}}</text>
        </view>
        <view class="kv-row">
          <text class="kv-k">{{copy.subtotal}}</text>
          <text class="kv-v">¥{{order.originalSubtotal || order.subtotal}}</text>
        </view>
        <view wx:if="{{order.merchantDiscount > 0}}" class="kv-row">
          <text class="kv-k">{{copy.discount}}</text>
          <text class="kv-v" style="color:#B74232">-¥{{order.merchantDiscount}}</text>
        </view>
        <view class="kv-row">
          <text class="kv-k">{{copy.freight}}</text>
          <text class="kv-v">¥{{order.deliveryFee || 0}}</text>
        </view>
        <view class="kv-row kv-row-total">
          <text class="kv-k-bold">{{copy.paid}}</text>
          <text class="kv-v-red">¥{{order.total}}</text>
        </view>
      </view>

      <!-- 真实物流动态 -->
      <view wx:if="{{shipped && order.logisticsNo}}" class="section-card logistics-card">
        <view class="section-head logistics-head">
          <view class="logistics-title-wrap">
            <text class="section-icon">🚚</text>
            <text class="section-title">{{copy.logistics}}</text>
          </view>
          <view class="logistics-refresh {{logisticsLoading ? 'disabled' : ''}}" bindtap="onRefreshLogistics">
            <text>{{logisticsLoading ? copy.querying : copy.refresh}}</text>
          </view>
        </view>

        <view class="logistics-summary">
          <view class="logistics-status-row">
            <text class="logistics-status">{{logistics.state_label || order.logisticsStatus || copy.waitingPickup}}</text>
            <text wx:if="{{logistics.arrival_time}}" class="logistics-arrival">{{copy.arrivalPrefix}}{{logistics.arrival_time}}{{copy.arrivalSuffix}}</text>
          </view>
          <text class="logistics-latest">{{logistics.latestText || order.logisticsLatest || copy.shippedWaiting}}</text>
          <text wx:if="{{logistics.updatedText}}" class="logistics-updated">{{copy.updatedAt}}{{logistics.updatedText}}</text>
        </view>

        <view class="logistics-number-row" bindtap="onCopyLogisticsNo">
          <text class="logistics-company">{{logistics.company_name || order.logisticsCompanyName}}</text>
          <text class="logistics-number">{{order.logisticsNo}}</text>
          <text class="logistics-copy">{{copy.copy}}</text>
        </view>

        <view wx:if="{{logistics && !logistics.enabled}}" class="logistics-notice">
          <text>{{copy.logisticsDisabled}}</text>
        </view>
        <view wx:elif="{{logistics && logistics.error && logistics.events.length === 0}}" class="logistics-notice">
          <text>{{logistics.error}}</text>
        </view>

        <view wx:if="{{logisticsExpanded}}" class="logistics-timeline">
          <view wx:if="{{logisticsLoading && !logistics}}" class="logistics-empty">{{copy.queryingTrack}}</view>
          <view wx:elif="{{!logistics || logistics.events.length === 0}}" class="logistics-empty">{{copy.noTrack}}</view>
          <block wx:else>
            <view class="logistics-event {{item.current ? 'current' : ''}}" wx:for="{{logistics.events}}" wx:key="event_hash">
              <view class="logistics-axis">
                <view class="logistics-dot"></view>
                <view wx:if="{{index < logistics.events.length - 1}}" class="logistics-line"></view>
              </view>
              <view class="logistics-event-body">
                <text class="logistics-event-context">{{item.context}}</text>
                <text class="logistics-event-time">{{item.timeText}}{{item.location ? ' · ' + item.location : ''}}</text>
              </view>
            </view>
          </block>
        </view>

        <view class="logistics-expand" bindtap="onLogistics">
          <text>{{logisticsExpanded ? copy.collapseTrack : copy.expandTrack}}</text>
          <text>{{logisticsExpanded ? '⌃' : '⌄'}}</text>
        </view>
      </view>

      <!-- Bug2: 售后处理结果 -->
      <view wx:if="{{aftersale}}" class="section-card">
        <view class="section-head">
          <text class="section-icon">🔄</text>
          <text class="section-title">{{copy.aftersaleDetail}}</text>
        </view>
        <view class="kv-row">
          <text class="kv-k">{{copy.aftersaleType}}</text>
          <text class="kv-v">{{aftersale.aftersale_type_display}}</text>
        </view>
        <view class="kv-row">
          <text class="kv-k">{{copy.reason}}</text>
          <text class="kv-v">{{aftersale.reason_display}}</text>
        </view>
        <view wx:if="{{aftersale.description}}" class="kv-row">
          <text class="kv-k">{{copy.description}}</text>
          <text class="kv-v">{{aftersale.description}}</text>
        </view>
        <view class="kv-row">
          <text class="kv-k">{{copy.handleStatus}}</text>
          <text class="kv-v {{aftersale.displayStatus === 'approved' ? 'text-green' : aftersale.displayStatus === 'rejected' ? 'text-red' : 'text-orange'}}">{{aftersale.statusLabel}}</text>
        </view>
        <view wx:if="{{aftersale.handle_note}}" class="kv-row">
          <text class="kv-k">{{copy.merchantReply}}</text>
          <text class="kv-v">{{aftersale.handle_note}}</text>
        </view>
      </view>

      <view style="height: 40rpx"></view>
    </view>
  </scroll-view>

  <!-- 已完成底部：仅三大入口 -->
  <view wx:if="{{isCompleted}}" class="ord-bottom ord-bottom-row">
    <view class="c3btn c3btn-review" bindtap="onReview">
      <text class="c3btn-icon">{{hasReviewed ? '✅' : '⭐'}}</text>
      <text class="c3btn-label">{{hasReviewed ? copy.reviewed : copy.review}}</text>
    </view>
    <view class="c3btn c3btn-contact" bindtap="onContact">
      <text class="c3btn-icon">💬</text>
      <text class="c3btn-label">{{copy.contactMerchant}}</text>
    </view>
    <view class="c3btn c3btn-aftersale" bindtap="onAfterSale">
      <text class="c3btn-icon">🔄</text>
      <text class="c3btn-label">{{copy.applyAftersale}}</text>
    </view>
  </view>

  <!-- 未完成底部：确认收货 + 三图标 -->
  <view wx:else class="ord-bottom">
    <view wx:if="{{canConfirmReceipt}}" class="confirm-receipt-btn" bindtap="onConfirmReceipt">
      <text class="confirm-receipt-text">✓ {{copy.confirmReceipt}}</text>
    </view>
    <view class="action-row">
      <view class="action-btn action-contact" bindtap="onContact">
        <text class="action-icon">💬</text>
        <text class="action-label">{{copy.contactSeller}}</text>
      </view>
      <view class="action-btn action-refund" bindtap="onAfterSale">
        <text class="action-icon">🔄</text>
        <text class="action-label">{{copy.refundAftersale}}</text>
      </view>
      <view class="action-btn action-logistics {{!shipped ? 'action-disabled' : ''}}" bindtap="onLogistics">
        <text class="action-icon">🚚</text>
        <text class="action-label">{{copy.viewLogistics}}</text>
        <text class="action-sub" wx:if="{{!shipped}}">{{copy.notShipped}}</text>
        <text class="action-sub" wx:elif="{{order.logisticsStatus}}">{{order.logisticsStatus}}</text>
      </view>
    </view>
  </view>

  <!-- 收货成功弹窗 -->
  <view wx:if="{{showSuccessPopup}}" class="success-overlay" bindtap="onCloseSuccessPopup">
    <view class="success-popup" catchtap="">
      <view class="success-icon-wrap">
        <text class="success-checkmark">✓</text>
      </view>
      <text class="success-title">{{copy.receiptSuccess}}</text>
      <text class="success-sub">{{copy.receiptThanks}}</text>
      <view class="success-close-btn" bindtap="onCloseSuccessPopup">
        <text class="success-close-text">{{copy.finish}}</text>
      </view>
    </view>
  </view>

</view>
