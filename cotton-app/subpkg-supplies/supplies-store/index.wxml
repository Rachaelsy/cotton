<!-- pages/supplies-store/index.wxml — 店铺详情页 -->
<view class="page">

  <!-- ① 顶部 Header -->
  <view class="header" style="padding-top:{{statusBarHeight + 8}}px">
    <view class="header-row" style="padding-right: {{capsuleSafeRight}}px">
      <view class="back-btn" bindtap="onBack">
        <text class="back-icon">‹</text>
      </view>
      <view class="store-info">
        <text class="store-name">{{storeName}}</text>
        <text class="store-sub">{{copy.goodsPrefix}} {{displayProds.length}} {{copy.goodsSuffix}}</text>
      </view>
      <view class="coupon-btn" bindtap="onCoupons">券</view>
      <view class="cart-btn" bindtap="onGoCart">
        <text class="cart-icon">🛒</text>
        <text wx:if="{{cartCount > 0}}" class="cart-badge">{{cartCount > 99 ? '99+' : cartCount}}</text>
      </view>
    </view>

    <!-- 分类 Tab -->
    <scroll-view scroll-x class="cat-scroll" wx:if="{{cats.length > 1}}">
      <view class="cat-row">
        <view
          class="cat-item {{catSel === item.value ? 'cat-active' : ''}}"
          wx:for="{{cats}}"
          wx:key="*this"
          bindtap="onCat"
          data-cat="{{item.value}}"
        >
          <text>{{item.label}}</text>
        </view>
      </view>
    </scroll-view>
  </view>

  <!-- ② 加载中 -->
  <view wx:if="{{loading}}" class="center-wrap">
    <text class="tip-text">{{copy.loading}}</text>
  </view>

  <!-- ③ 暂无商品 -->
  <view wx:elif="{{!displayProds.length}}" class="center-wrap">
    <text class="empty-icon">📦</text>
    <text class="tip-text">{{copy.empty}}</text>
  </view>

  <!-- ④ 商品列表 -->
  <scroll-view wx:else scroll-y class="prod-scroll">
    <view class="prod-grid">
      <view
        class="prod-card"
        wx:for="{{displayProds}}"
        wx:key="id"
        bindtap="onProductTap"
        data-id="{{item.id}}"
      >
        <!-- 商品图 -->
        <view class="prod-img-wrap" style="background:{{item.imgBg}}">
          <image wx:if="{{item.image_url}}" class="prod-photo" src="{{item.image_url}}" mode="aspectFill"></image>
          <text wx:else class="prod-icon">{{item.icon || '📦'}}</text>
        </view>
        <!-- 商品信息 -->
        <view class="prod-info">
          <text class="prod-name">{{item.name}}</text>
          <text wx:if="{{item.unit}}" class="prod-unit">{{item.unit}}</text>
          <view class="prod-bottom">
            <view class="price-wrap">
              <text class="price-symbol">¥</text>
              <text class="price-main">{{item.has_promotion ? item.display_price : item.price}}</text>
              <text wx:if="{{item.has_promotion}}" class="price-old">¥{{item.original_price}}</text>
            </view>
            <view wx:if="{{item.cartQty > 0}}" class="qty-stepper">
              <view class="qty-step-btn qty-step-minus" catchtap="onQtyMinus" data-id="{{item.id}}"><text class="qty-step-icon">−</text></view>
              <text class="qty-step-num">{{item.cartQty}}</text>
              <view class="qty-step-btn" catchtap="onAddToCart" data-id="{{item.id}}"><text class="qty-step-icon">＋</text></view>
            </view>
            <view wx:else class="add-btn" catchtap="onAddToCart" data-id="{{item.id}}">
              <text class="add-icon">+</text>
            </view>
          </view>
        </view>
      </view>
    </view>
    <view style="height:40rpx"></view>
  </scroll-view>

  <view wx:if="{{cartCount > 0}}" class="quick-cart">
    <view class="quick-cart-summary" bindtap="onGoCart">
      <view class="quick-cart-icon-wrap">
        <text class="quick-cart-icon">🛒</text>
        <text class="quick-cart-count">{{cartCount > 99 ? '99+' : cartCount}}</text>
      </view>
      <view class="quick-cart-copy">
        <text class="quick-cart-selected">
          {{copy.selected}} {{cartCount}} {{copy.piece}}
          <text wx:if="{{cartCouponDiscount > 0}}"> · {{copy.bestCoupon}} ¥{{cartCouponDiscount}}</text>
          <text wx:elif="{{cartQuoteError}}" class="quick-cart-error"> · {{cartQuoteError}}</text>
        </text>
        <view class="quick-cart-price-row">
          <text class="quick-cart-estimate">{{copy.estimate}}</text>
          <text class="quick-cart-price">¥{{cartTotal}}</text>
        </view>
      </view>
    </view>
    <view class="quick-cart-action" bindtap="onCheckout">
      <text class="quick-cart-action-text">{{copy.checkout}}</text>
    </view>
  </view>

</view>
