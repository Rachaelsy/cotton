.page {
  display: flex;
  flex-direction: column;
  height: 100vh;
  color: #18231A;
  background: #F6F8F3;
}

.header {
  flex-shrink: 0;
  padding: 0 28rpx 14rpx;
  background: linear-gradient(155deg, #2F7D4B 0%, #215C38 100%);
}

.topbar {
  min-height: 80rpx;
  display: flex;
  align-items: center;
}

.header-action {
  min-width: 76rpx;
  height: 56rpx;
  padding: 0 15rpx;
  border-radius: 999rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  color: #FFFFFF;
  background: rgba(255, 255, 255, .16);
  border: 1rpx solid rgba(255, 255, 255, .24);
  font-size: 22rpx;
  font-weight: 700;
  box-sizing: border-box;
}

.header-edit {
  color: #B9852F;
  background: #FFFFFF;
}

.header-title {
  flex: 1;
  padding: 0 18rpx;
  overflow: hidden;
  white-space: nowrap;
  text-overflow: ellipsis;
  color: #FFFFFF;
  font-size: 31rpx;
  font-weight: 900;
  text-align: center;
}

.scroll { flex: 1; height: 0; }
.body { padding: 20rpx 24rpx 0; }

.map-card {
  position: relative;
  height: 330rpx;
  overflow: hidden;
  border-radius: 22rpx;
  background: #EAF0E6;
  box-shadow: 0 5rpx 18rpx rgba(33, 61, 42, .09);
}

.detail-map { width: 100%; height: 100%; }

.no-map-tip {
  position: absolute;
  top: 0;
  right: 0;
  bottom: 0;
  left: 0;
  display: flex;
  align-items: center;
  justify-content: center;
  color: #8A948B;
  background: #F8FAF5;
  font-size: 23rpx;
}

.map-layer-btn {
  position: absolute;
  right: 18rpx;
  bottom: 18rpx;
  z-index: 3;
  padding: 13rpx 22rpx;
  border-radius: 999rpx;
  color: #FFFFFF;
  background: rgba(43, 37, 31, .82);
  font-size: 20rpx;
  font-weight: 700;
}

.overview-card {
  margin-top: 16rpx;
  padding: 26rpx;
  border-radius: 26rpx;
  display: flex;
  align-items: center;
  gap: 24rpx;
  background: #FFFFFF;
  border-left: 8rpx solid #2F8A52;
  box-shadow: 0 5rpx 18rpx rgba(33, 61, 42, .07);
}

.overview-attention { border-left-color: #D97918; }

.score-block {
  width: 170rpx;
  display: flex;
  flex-direction: column;
  align-items: center;
}

.score-row { display: flex; align-items: baseline; gap: 4rpx; }
.score-value { color: #2F8A52; font-size: 66rpx; font-weight: 900; line-height: 1; }
.overview-attention .score-value { color: #D97918; }
.score-unit { color: #82786F; font-size: 23rpx; }
.score-label { margin-top: 7rpx; color: #8A948B; font-size: 18rpx; }
.overview-divider { width: 1rpx; height: 92rpx; background: #E3E9DE; }

.overview-main {
  flex: 1;
  min-width: 0;
  display: flex;
  flex-direction: column;
  align-items: flex-start;
}

.growth-tag {
  padding: 7rpx 14rpx;
  border-radius: 999rpx;
  display: flex;
  align-items: center;
  gap: 8rpx;
  color: #2F7D4B;
  background: #EAF6EF;
  font-size: 20rpx;
  font-weight: 800;
}

.growth-tag-warn { color: #D97918; background: #FFF3E3; }

.overview-line {
  width: 100%;
  margin-top: 10rpx;
  overflow: hidden;
  white-space: nowrap;
  text-overflow: ellipsis;
  color: #58655B;
  font-size: 21rpx;
}

.section-card {
  margin-top: 16rpx;
  padding: 24rpx;
  border-radius: 26rpx;
  background: #FFFFFF;
  box-shadow: 0 5rpx 18rpx rgba(33, 61, 42, .06);
}

.section-head {
  display: flex;
  align-items: baseline;
  justify-content: space-between;
  gap: 15rpx;
  margin-bottom: 18rpx;
}

.section-title { color: #18231A; font-size: 27rpx; font-weight: 900; }
.section-sub { color: #8A948B; font-size: 19rpx; }

.reference-detail-card {
  padding-bottom: 20rpx;
}

.reference-detail-scroll {
  width: 100%;
  white-space: nowrap;
}

.reference-detail-row {
  display: inline-flex;
  gap: 14rpx;
  min-width: 100%;
}

.reference-detail-img {
  width: 190rpx;
  height: 142rpx;
  border-radius: 18rpx;
  display: block;
  background: #EAF0E6;
}

.module-grid {
  display: flex;
  flex-wrap: wrap;
  justify-content: space-between;
  gap: 14rpx 0;
}

.module-item {
  width: calc(50% - 7rpx);
  box-sizing: border-box;
  padding: 22rpx;
  border-radius: 20rpx;
  display: flex;
  flex-direction: column;
  background: #F8FAF5;
  border: 1rpx solid #E3E9DE;
}

.module-item:active { background: #EAF0E6; }
.module-name { color: #18231A; font-size: 24rpx; font-weight: 800; }
.module-desc { margin-top: 6rpx; color: #8A948B; font-size: 19rpx; }

.kv-row {
  min-height: 74rpx;
  display: flex;
  align-items: center;
  justify-content: space-between;
  gap: 24rpx;
  border-bottom: 1rpx solid #EAF0E6;
}

.kv-row:last-child { border-bottom: none; }
.kv-row-note { align-items: flex-start; padding: 18rpx 0; }
.kv-key { flex-shrink: 0; color: #58655B; font-size: 23rpx; }
.kv-value { color: #18231A; font-size: 23rpx; font-weight: 700; text-align: right; line-height: 1.5; }
.kv-empty { color: #B7C0B8; font-weight: 400; }

.record-row {
  min-height: 86rpx;
  display: flex;
  align-items: center;
  gap: 14rpx;
  border-bottom: 1rpx solid #EAF0E6;
}

.record-type {
  min-width: 74rpx;
  padding: 8rpx 11rpx;
  border-radius: 12rpx;
  color: #B9852F;
  background: #FFF8EA;
  font-size: 19rpx;
  font-weight: 800;
  text-align: center;
  box-sizing: border-box;
}

.record-main { flex: 1; min-width: 0; display: flex; flex-direction: column; }
.record-title { overflow: hidden; white-space: nowrap; text-overflow: ellipsis; color: #18231A; font-size: 22rpx; font-weight: 700; }
.record-meta { margin-top: 4rpx; color: #8A948B; font-size: 18rpx; }
.record-more { color: #B9852F; font-size: 19rpx; font-weight: 700; }
.record-empty { padding: 24rpx 0; color: #8A948B; font-size: 22rpx; text-align: center; }

.section-link {
  margin-top: 18rpx;
  height: 68rpx;
  border-radius: 17rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  color: #B9852F;
  background: #FFF8EA;
  font-size: 22rpx;
  font-weight: 800;
}

.danger-zone {
  margin-top: 20rpx;
  padding: 24rpx;
  border-radius: 22rpx;
  background: #FFF5F2;
  border: 1rpx solid #F3C7BE;
}

.danger-title { display: block; color: #D6453D; font-size: 24rpx; font-weight: 900; }
.danger-desc { display: block; margin-top: 7rpx; color: #9A7C76; font-size: 19rpx; line-height: 1.5; }

.delete-btn {
  margin-top: 18rpx;
  height: 72rpx;
  border-radius: 18rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  color: #D6453D;
  background: #FFFFFF;
  border: 1rpx solid #F0B4AC;
  font-size: 23rpx;
  font-weight: 800;
}

.bottom-space { height: 44rpx; }

.state-wrap {
  flex: 1;
  padding: 120rpx 40rpx 0;
  display: flex;
  flex-direction: column;
  align-items: center;
}

.state-title { margin-top: 18rpx; color: #18231A; font-size: 28rpx; font-weight: 800; }
.state-desc { margin-top: 9rpx; color: #8A948B; font-size: 22rpx; text-align: center; }
.state-action { margin-top: 28rpx; padding: 17rpx 38rpx; border-radius: 999rpx; color: #FFFFFF; background: #2F7D4B; font-size: 23rpx; font-weight: 800; }

.modal-mask {
  position: fixed;
  top: 0;
  right: 0;
  bottom: 0;
  left: 0;
  z-index: 20;
  background: rgba(31, 26, 22, .46);
}

.modal {
  position: fixed;
  right: 0;
  bottom: 0;
  left: 0;
  z-index: 21;
  max-height: 82vh;
  padding: 0 30rpx 30rpx;
  border-radius: 30rpx 30rpx 0 0;
  display: flex;
  flex-direction: column;
  background: #FFFFFF;
}

.modal-handle { width: 74rpx; height: 8rpx; margin: 18rpx auto 0; border-radius: 999rpx; background: #D8E1D5; }
.modal-head { flex-shrink: 0; padding: 20rpx 0; display: flex; align-items: center; border-bottom: 1rpx solid #EAF0E6; }
.modal-title { flex: 1; color: #18231A; font-size: 29rpx; font-weight: 900; }
.modal-close { width: 56rpx; height: 56rpx; border-radius: 50%; display: flex; align-items: center; justify-content: center; background: #F8FAF5; }
.modal-scroll { flex: 1; min-height: 0; }

.field-row {
  min-height: 84rpx;
  display: flex;
  align-items: center;
  gap: 18rpx;
  border-bottom: 1rpx solid #EAF0E6;
}

.field-label { width: 170rpx; flex-shrink: 0; color: #58655B; font-size: 23rpx; font-weight: 700; }
.req { color: #D6453D; }
.field-input { flex: 1; color: #18231A; font-size: 23rpx; text-align: right; }
.field-picker { min-width: 300rpx; display: flex; align-items: center; justify-content: flex-end; gap: 14rpx; }
.picker-value, .picker-empty, .picker-change { font-size: 22rpx; }
.picker-value { color: #18231A; }
.picker-empty { color: #B7C0B8; }
.picker-change { color: #B9852F; font-weight: 800; }
.field-note { min-height: 150rpx; padding: 20rpx 0; align-items: flex-start; }
.field-textarea { flex: 1; height: 110rpx; color: #18231A; font-size: 22rpx; line-height: 1.5; text-align: right; }
.modal-bottom-space { height: 20rpx; }

.modal-save {
  flex-shrink: 0;
  height: 84rpx;
  border-radius: 999rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  color: #FFFFFF;
  background: #2F7D4B;
  font-size: 27rpx;
  font-weight: 900;
}

.modal-save-disabled { opacity: .55; pointer-events: none; }
