.page {
  display: flex;
  flex-direction: column;
  height: 100vh;
  background: #F6F8F3;
  color: #18231A;
}

.header {
  flex-shrink: 0;
  padding: 0 28rpx 18rpx;
  background: linear-gradient(155deg, #2F7D4B 0%, #215C38 100%);
}

.topbar {
  display: flex;
  align-items: center;
  min-height: 84rpx;
}

.back-btn,
.manage-btn {
  min-width: 76rpx;
  height: 56rpx;
  padding: 0 16rpx;
  border-radius: 999rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  background: rgba(255, 255, 255, .16);
  border: 1rpx solid rgba(255, 255, 255, .24);
  box-sizing: border-box;
}

.back-text,
.manage-btn text {
  color: #FFFFFF;
  font-size: 23rpx;
  font-weight: 700;
}

.manage-btn-active {
  background: #FFFFFF;
}

.manage-btn-active text {
  color: #7A5A26;
}

.header-center {
  flex: 1;
  display: flex;
  flex-direction: column;
  align-items: center;
}

.header-title {
  color: #FFFFFF;
  font-size: 34rpx;
  font-weight: 800;
  line-height: 1.2;
}

.header-sub {
  margin-top: 3rpx;
  color: rgba(255, 255, 255, .65);
  font-size: 17rpx;
  letter-spacing: 4rpx;
}

.stats-bar {
  display: flex;
  align-items: center;
  margin: 4rpx 0 20rpx;
  padding: 20rpx 0;
  border-radius: 22rpx;
  background: rgba(255, 255, 255, .12);
}

.stat-item {
  flex: 1;
  display: flex;
  flex-direction: column;
  align-items: center;
}

.stat-value-row {
  display: flex;
  align-items: baseline;
  gap: 5rpx;
}

.stat-val {
  color: #FFFFFF;
  font-size: 45rpx;
  font-weight: 900;
  line-height: 1;
}

.stat-unit,
.stat-desc {
  color: rgba(255, 255, 255, .68);
  font-size: 20rpx;
}

.stat-desc {
  margin-top: 7rpx;
}

.attention-stat .stat-val {
  color: #FFD275;
}

.stat-div {
  width: 1rpx;
  height: 62rpx;
  background: rgba(255, 255, 255, .22);
}

.tabs {
  display: flex;
  padding: 6rpx;
  border-radius: 20rpx;
  background: rgba(255, 255, 255, .16);
}

.tab {
  flex: 1;
  padding: 16rpx 0;
  border-radius: 15rpx;
  color: rgba(255, 255, 255, .72);
  font-size: 25rpx;
  font-weight: 700;
  text-align: center;
}

.tab-active {
  color: #7A5A26;
  background: #FFFFFF;
  box-shadow: 0 4rpx 12rpx rgba(33, 61, 42, .10);
}

.manage-tip {
  flex-shrink: 0;
  padding: 14rpx 28rpx;
  color: #7A5A26;
  background: #FFF8EA;
  border-bottom: 1rpx solid #EFE0BE;
  font-size: 22rpx;
  text-align: center;
}

.filter-panel {
  flex-shrink: 0;
  padding: 16rpx 28rpx 14rpx;
  background: #FFFFFF;
  box-shadow: 0 4rpx 18rpx rgba(33, 61, 42, .06);
}

.search-box {
  height: 70rpx;
  padding: 0 22rpx;
  border-radius: 18rpx;
  display: flex;
  align-items: center;
  gap: 14rpx;
  background: #F7F9F4;
  border: 1rpx solid #E3E9DE;
}

.search-input {
  flex: 1;
  height: 70rpx;
  color: #18231A;
  font-size: 24rpx;
}

.filter-row {
  display: flex;
  align-items: center;
  gap: 12rpx;
  margin-top: 12rpx;
}

.filter-picker {
  flex-shrink: 0;
}

.filter-pill {
  min-width: 150rpx;
  height: 58rpx;
  padding: 0 18rpx;
  border-radius: 15rpx;
  display: flex;
  align-items: center;
  justify-content: space-between;
  gap: 12rpx;
  color: #58655B;
  background: #F8FAF5;
  border: 1rpx solid #E3E9DE;
  font-size: 22rpx;
  box-sizing: border-box;
}

.filter-pill-active {
  color: #B9852F;
  background: #FFF8EA;
  border-color: #EFE0BE;
}

.filter-caret {
  color: #8A948B;
  font-size: 22rpx;
}

.reset-filter {
  color: #B9852F;
  font-size: 22rpx;
  font-weight: 700;
}

.result-count {
  margin-left: auto;
  color: #8A948B;
  font-size: 21rpx;
}

.scroll {
  flex: 1;
  height: 0;
}

.field-section {
  padding-top: 6rpx;
}

.section-header {
  display: flex;
  align-items: center;
  gap: 10rpx;
  padding: 18rpx 28rpx 12rpx;
}

.section-mark {
  width: 7rpx;
  height: 30rpx;
  border-radius: 999rpx;
}

.section-mark-warn { background: #D97918; }
.section-mark-ok { background: #2F8A52; }

.section-title {
  color: #18231A;
  font-size: 25rpx;
  font-weight: 800;
}

.section-count {
  padding: 3rpx 12rpx;
  border-radius: 999rpx;
  color: #8A948B;
  background: #EAF0E6;
  font-size: 19rpx;
}

.field-card {
  position: relative;
  margin: 0 24rpx 16rpx;
  padding: 20rpx;
  border-radius: 22rpx;
  display: flex;
  gap: 18rpx;
  background: #FFFFFF;
  border-left: 7rpx solid transparent;
  box-shadow: 0 5rpx 18rpx rgba(74, 52, 31, .07);
  transition: transform .15s, background-color .15s;
}

.field-card:active { transform: scale(.988); }
.field-card-warn { border-left-color: #D97918; }
.field-card-ok { border-left-color: #2F8A52; }
.field-card-selected { background: #FFF8EA; border-left-color: #B9852F; }

.preview-wrap {
  position: relative;
  width: 112rpx;
  height: 112rpx;
  flex-shrink: 0;
  border-radius: 20rpx;
  overflow: hidden;
  background: #EAF0E6;
}

.preview-map {
  width: 112rpx;
  height: 112rpx;
}

.preview-image {
  width: 112rpx;
  height: 112rpx;
  display: block;
}

.preview-empty {
  width: 100%;
  height: 100%;
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
  color: #7A5A26;
  background: #EAF0E6;
  font-size: 20rpx;
}

.preview-empty text:first-child {
  font-size: 31rpx;
  font-weight: 900;
  line-height: 1;
}

.select-badge {
  position: absolute;
  inset: 0;
  display: flex;
  align-items: center;
  justify-content: center;
  background: rgba(255, 255, 255, .64);
  border: 3rpx solid rgba(164, 104, 54, .45);
  border-radius: 20rpx;
  box-sizing: border-box;
}

.select-badge-active {
  background: rgba(164, 104, 54, .88);
  border-color: #B9852F;
}

.card-body {
  flex: 1;
  min-width: 0;
  display: flex;
  flex-direction: column;
  justify-content: center;
}

.card-title-row,
.card-foot,
.score-wrap,
.status-tag,
.foot-right {
  display: flex;
  align-items: center;
}

.card-title-row,
.card-foot {
  justify-content: space-between;
  gap: 12rpx;
}

.field-name {
  flex: 1;
  min-width: 0;
  overflow: hidden;
  white-space: nowrap;
  text-overflow: ellipsis;
  color: #18231A;
  font-size: 29rpx;
  font-weight: 800;
}

.score-wrap { align-items: baseline; }

.score {
  font-size: 38rpx;
  font-weight: 900;
  line-height: 1;
}

.score.excel { color: #2F7D4B; }
.score.good { color: #A26A2F; }
.score.warn { color: #D6453D; }

.score-unit {
  color: #B7C0B8;
  font-size: 17rpx;
}

.field-meta {
  margin: 12rpx 0 11rpx;
  overflow: hidden;
  white-space: nowrap;
  text-overflow: ellipsis;
  color: #58655B;
  font-size: 21rpx;
}

.status-tag {
  max-width: 210rpx;
  gap: 7rpx;
  padding: 5rpx 12rpx;
  border-radius: 999rpx;
  font-size: 19rpx;
  font-weight: 700;
}

.status-tag text {
  overflow: hidden;
  white-space: nowrap;
  text-overflow: ellipsis;
}

.status-tag-warn { color: #D97918; background: #FFF3E3; }
.status-tag-ok { color: #2F7D4B; background: #EAF6EF; }

.field-date {
  color: #B7C0B8;
  font-size: 18rpx;
  white-space: nowrap;
}

.foot-right {
  flex-shrink: 0;
  justify-content: flex-end;
  gap: 10rpx;
}

.weather-mini-btn {
  min-width: 58rpx;
  height: 40rpx;
  padding: 0 12rpx;
  border-radius: 999rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  color: #2D86B8;
  background: #EDF7FB;
  border: 1rpx solid #CDE5F0;
  font-size: 18rpx;
  font-weight: 800;
  box-sizing: border-box;
}

.loading-wrap,
.state-wrap {
  padding: 52rpx 28rpx;
  display: flex;
  flex-direction: column;
  align-items: center;
}

.loading-card {
  width: 100%;
  height: 150rpx;
  margin-bottom: 16rpx;
  border-radius: 22rpx;
  background: #EAF0E6;
  animation: pulse 1.2s ease-in-out infinite alternate;
}

@keyframes pulse {
  from { opacity: .55; }
  to { opacity: 1; }
}

.loading-text {
  margin-top: 16rpx;
  color: #8A948B;
  font-size: 22rpx;
}

.state-title {
  margin-top: 20rpx;
  color: #18231A;
  font-size: 29rpx;
  font-weight: 800;
}

.state-desc {
  max-width: 540rpx;
  margin-top: 10rpx;
  color: #8A948B;
  font-size: 22rpx;
  line-height: 1.6;
  text-align: center;
}

.state-action {
  margin-top: 28rpx;
  padding: 18rpx 42rpx;
  border-radius: 999rpx;
  color: #FFFFFF;
  background: #2F7D4B;
  font-size: 24rpx;
  font-weight: 800;
}

.state-action-light {
  color: #B9852F;
  background: #FFFFFF;
  border: 1rpx solid #EFE0BE;
}

.empty-state { padding-top: 86rpx; }

.empty-monogram {
  width: 92rpx;
  height: 92rpx;
  border-radius: 22rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  color: #B9852F;
  background: #EFE0BE;
  font-size: 45rpx;
  font-weight: 900;
}

.scroll-bottom-space { height: 170rpx; }

.add-fab {
  position: fixed;
  right: 28rpx;
  bottom: 40rpx;
  z-index: 12;
  padding: 21rpx 32rpx;
  border-radius: 999rpx;
  color: #FFFFFF;
  background: #B9852F;
  box-shadow: 0 8rpx 26rpx rgba(120, 72, 32, .32);
  font-size: 25rpx;
  font-weight: 800;
}

.manage-bar {
  flex-shrink: 0;
  padding: 18rpx 28rpx 28rpx;
  display: flex;
  gap: 16rpx;
  background: #FFFFFF;
  border-top: 1rpx solid #E3E9DE;
  box-shadow: 0 -6rpx 22rpx rgba(60, 42, 25, .10);
}

.select-all-btn,
.batch-delete-btn {
  height: 82rpx;
  border-radius: 20rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  font-size: 25rpx;
  font-weight: 800;
}

.select-all-btn {
  width: 190rpx;
  color: #58655B;
  background: #F7F9F4;
  border: 1rpx solid #E3E9DE;
}

.batch-delete-btn {
  flex: 1;
  color: #FFFFFF;
  background: #D6453D;
}

.batch-delete-disabled {
  color: #B7C0B8;
  background: #EAE6E2;
  pointer-events: none;
}
