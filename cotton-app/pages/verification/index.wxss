.page{height:100vh;background:#f5f7f2;color:#183b2a}.nav{display:flex;align-items:center;justify-content:space-between;padding:0 24rpx 18rpx;background:#fff;font-size:32rpx;font-weight:800}.back,.nav-space{width:64rpx}.back{height:64rpx;display:flex;align-items:center;justify-content:center;border-radius:50%;background:#edf4ed;font-size:46rpx}.content{height:calc(100vh - 100rpx);padding:24rpx;box-sizing:border-box}.intro,.form-card,.state{background:#fff;border-radius:16rpx;padding:28rpx;margin-bottom:22rpx}.intro{display:flex;align-items:center;gap:18rpx;font-size:24rpx;line-height:1.6;color:#637267}.shield,.state-icon{display:flex;align-items:center;justify-content:center;border-radius:50%;background:#e2f3e8;color:#198754;font-weight:900}.shield{width:64rpx;height:64rpx}.label{display:block;margin:24rpx 0 10rpx;font-size:25rpx;font-weight:700}.form-card input{height:86rpx;padding:0 22rpx;background:#f7f9f5;border:1rpx solid #dce6db;border-radius:10rpx;font-size:26rpx}.photos{display:flex;gap:16rpx;margin-top:24rpx}.photo{flex:1;min-width:0;font-size:21rpx;color:#68766b}.photo image,.photo-empty{width:100%;height:210rpx;border-radius:10rpx;background:#eef3eb}.photo-empty{display:flex;align-items:center;justify-content:center;border:2rpx dashed #a9b9aa;font-size:56rpx;color:#6b876e}.photo text{display:block;margin-top:10rpx;line-height:1.4}.primary{margin-top:30rpx;background:#23834f!important;color:#fff!important;border-radius:10rpx;font-size:28rpx;font-weight:800}.state{text-align:center;padding:70rpx 32rpx}.state-icon{width:100rpx;height:100rpx;margin:0 auto 24rpx;font-size:40rpx}.state-icon.pending{background:#fff3d8;color:#b77816}.state-title,.state-sub{display:block}.state-title{font-size:34rpx;font-weight:800}.state-sub{margin-top:14rpx;font-size:24rpx;line-height:1.7;color:#6f7b72}.reject{padding:24rpx;margin-bottom:18rpx;border-radius:12rpx;background:#fff1ef;color:#a63d31}.reject text{display:block;margin-bottom:8rpx}.reject button{margin-top:12rpx;font-size:24rpx}
