<view class="page">
  <view class="rec-hd" style="padding-top: {{statusBarHeight}}px">
    <view class="rec-nav" style="padding-right: {{capsuleSafeRight}}px">
      <view class="back-btn" bindtap="onBack"><text class="back-icon">‹</text></view>
      <view class="rec-title-wrap">
        <text class="rec-title">{{copy.title}}</text>
        <text class="rec-subtitle">FARM RECORDS</text>
      </view>
      <view class="manage-btn {{manageMode ? 'done' : ''}}" bindtap="onToggleManage">
        <text class="manage-text">{{manageMode ? copy.done : copy.manage}}</text>
      </view>
    </view>

    <view class="rec-stats">
      <view class="rec-stat">
        <text class="rs-v">{{stats.recordCount}}</text>
        <text class="rs-l">{{copy.countUnit}}</text>
      </view>
      <view class="rec-sdiv"></view>
      <view class="rec-stat">
        <text class="rs-v">{{stats.fieldCount}}</text>
        <text class="rs-l">{{copy.plotUnit}}</text>
      </view>
      <view class="rec-sdiv"></view>
      <view class="rec-stat">
        <text class="rs-v">{{stats.costText}}</text>
        <text class="rs-l">{{copy.costUnit}}</text>
      </view>
    </view>

    <view class="view-toggle">
      <view class="vt-btn {{viewMode === 'list' ? 'on' : ''}}" bindtap="onViewMode" data-mode="list">
        <text class="vt-text">{{copy.list}}</text>
      </view>
      <view class="vt-btn {{viewMode === 'calendar' ? 'on' : ''}}" bindtap="onViewMode" data-mode="calendar">
        <text class="vt-text">{{copy.calendar}}</text>
      </view>
    </view>
  </view>

  <view wx:if="{{manageMode}}" class="edit-mode-tip">
    <text class="edit-tip-text">{{copy.manageTip}}</text>
  </view>

  <view wx:if="{{viewMode === 'list' && !manageMode}}" class="filters">
    <picker mode="selector" range="{{fieldDisplayOptions}}" value="{{fieldPickerIndex}}" bindchange="onFieldPickerChange">
      <view class="field-picker-filter">
        <view class="field-picker-main">
          <text class="field-picker-label">{{copy.viewPlot}}</text>
          <text class="field-picker-value">{{fieldFilterLabel}}</text>
        </view>
        <text class="field-picker-action">{{copy.switch}}</text>
      </view>
    </picker>
    <scroll-view class="filter-row" scroll-x enhanced show-scrollbar="{{false}}">
      <view
        class="filter-chip {{typeFilter === item.value ? 'on' : ''}}"
        wx:for="{{typeFilters}}"
        wx:key="value"
        bindtap="onTypeFilter"
        data-type="{{item.value}}"
      >
        <text class="filter-text">{{item.label}}</text>
      </view>
    </scroll-view>
    <scroll-view class="filter-row field-row" scroll-x enhanced show-scrollbar="{{false}}">
      <view
        class="field-chip {{fieldFilter === item.value ? 'on' : ''}}"
        wx:for="{{fieldFilters}}"
        wx:key="value"
        bindtap="onFieldFilter"
        data-field="{{item.value}}"
      >
        <text class="field-text">{{item.label}}</text>
      </view>
    </scroll-view>
  </view>

  <scroll-view wx:if="{{viewMode === 'list'}}" class="rec-scroll" scroll-y enhanced show-scrollbar="{{false}}">
    <view wx:if="{{loading}}" class="empty">
      <text class="empty-icon">⏳</text>
      <text class="empty-title">{{copy.loading}}</text>
    </view>
    <view wx:elif="{{displayRecords.length === 0}}" class="empty">
      <text class="empty-icon">📋</text>
      <text class="empty-title">{{typeFilter === '全部' && fieldFilter === '全部地块' ? copy.emptyAll : copy.emptyMatch}}</text>
      <text class="empty-desc">{{typeFilter === '全部' && fieldFilter === '全部地块' ? copy.emptyAllDesc : copy.emptyMatchDesc}}</text>
    </view>

    <view
      class="tl-item {{manageMode && item.selected ? 'selected' : ''}}"
      wx:for="{{displayRecords}}"
      wx:key="id"
      bindtap="onRecordTap"
      data-id="{{item.id}}"
    >
      <view wx:if="{{manageMode}}" class="select-dot {{item.selected ? 'on' : ''}}">
        <text class="select-check">✓</text>
      </view>
      <view class="tl-dot" style="background:{{item.bg}}">
        <text class="tl-dot-emoji">{{item.icon}}</text>
      </view>
      <view class="tl-body">
        <view class="tl-title-row">
          <text class="tl-title">{{item.title}}</text>
          <view class="tl-field-tag"><text class="tl-field-text">{{item.field}}</text></view>
        </view>
        <text class="tl-meta">{{item.metaText}}</text>
        <text class="tl-detail">{{item.note}}</text>
        <view class="record-tags">
          <text class="record-tag">{{item.amount}}</text>
          <text class="record-tag cost">{{item.costText}}</text>
        </view>
      </view>
    </view>
    <view class="bottom-space"></view>
  </scroll-view>

  <scroll-view wx:if="{{viewMode === 'calendar'}}" class="rec-scroll calendar-scroll" scroll-y enhanced show-scrollbar="{{false}}">
    <view class="calendar-card">
      <view class="cal-nav">
        <view class="cal-arr" bindtap="onCalendarPrev"><text>‹</text></view>
        <text class="cal-month">{{calendarLabel}}</text>
        <view class="cal-arr" bindtap="onCalendarNext"><text>›</text></view>
      </view>
      <view class="cal-grid">
        <text class="cal-dow" wx:for="{{weekDays}}" wx:key="*this">{{item}}</text>
        <view
          class="cal-day {{!item.date ? 'is-blank' : ''}} {{item.hasRecords ? 'has-records' : ''}} {{item.isToday ? 'today' : ''}} {{item.date && selectedDate === item.date ? 'selected' : ''}}"
          wx:for="{{calendarDays}}"
          wx:key="key"
          bindtap="onCalendarDay"
          data-date="{{item.date}}"
        >
          <text class="cal-day-num">{{item.day}}</text>
          <text wx:if="{{item.count > 1}}" class="cal-count">{{item.count}}</text>
        </view>
      </view>
    </view>

    <view class="calendar-list-title">{{calendarListTitle}}</view>
    <view wx:if="{{calendarRecords.length === 0}}" class="empty compact">
      <text class="empty-icon">📅</text>
      <text class="empty-title">{{copy.noRecords}}</text>
    </view>
    <view
      class="tl-item"
      wx:for="{{calendarRecords}}"
      wx:key="id"
      bindtap="onRecordTap"
      data-id="{{item.id}}"
    >
      <view class="tl-dot" style="background:{{item.bg}}">
        <text class="tl-dot-emoji">{{item.icon}}</text>
      </view>
      <view class="tl-body">
        <view class="tl-title-row">
          <text class="tl-title">{{item.title}}</text>
          <view class="tl-field-tag"><text class="tl-field-text">{{item.field}}</text></view>
        </view>
        <text class="tl-meta">{{item.metaText}}</text>
        <text class="tl-detail">{{item.note}}</text>
      </view>
    </view>
    <view class="bottom-space"></view>
  </scroll-view>

  <view wx:if="{{!manageMode}}" class="rec-fab" bindtap="onOpenAddRecord">
    <text class="rec-fab-icon">＋</text>
  </view>

  <view wx:if="{{manageMode}}" class="edit-act-bar">
    <view class="select-all-btn" bindtap="onSelectAll">
      <text>{{selectedIds.length > 0 && selectedIds.length === displayRecords.length ? copy.cancelSelectAll : copy.selectAll}}</text>
    </view>
    <view class="delete-btn {{selectedIds.length === 0 ? 'off' : ''}}" bindtap="onDeleteSelected">
      <text>{{copy.delete}}{{selectedIds.length > 0 ? ' ' + selectedIds.length : ''}}</text>
    </view>
  </view>

  <view wx:if="{{showAddModal}}" class="modal-mask" bindtap="onCloseAddModal">
    <view class="record-modal" catchtap="noop">
      <view class="modal-step-bar">
        <view class="step-dot {{modalStep >= 1 ? 'on' : ''}}"></view>
        <view class="step-dot {{modalStep >= 2 ? 'on' : ''}}"></view>
      </view>

      <view wx:if="{{modalStep === 1}}">
        <text class="modal-title">{{editingId ? copy.editRecord : copy.addRecord}}</text>
        <text class="modal-subtitle">{{copy.chooseType}}</text>
        <view class="type-grid">
          <view
            class="type-card {{selectedTypeIndex === index ? 'on' : ''}}"
            wx:for="{{typeOptions}}"
            wx:key="type"
            bindtap="onSelectRecordType"
            data-index="{{index}}"
          >
            <text class="type-icon">{{item.icon}}</text>
            <text class="type-name">{{item.label}}</text>
          </view>
        </view>
        <view class="modal-cancel" bindtap="onCloseAddModal"><text>{{copy.cancel}}</text></view>
      </view>

      <view wx:if="{{modalStep === 2}}">
        <text class="modal-title">{{selectedType.icon}} {{selectedType.label}}</text>
        <text class="modal-subtitle">{{copy.fillDetails}}</text>

        <view class="form-row">
          <text class="form-label">{{copy.plot}}</text>
          <picker mode="selector" range="{{fieldDisplayOptions}}" value="{{form.fieldIndex}}" bindchange="onFieldChange">
            <view class="form-picker">{{fieldDisplayOptions[form.fieldIndex]}}</view>
          </picker>
        </view>
        <view class="form-row two">
          <view class="form-half">
            <text class="form-label">{{copy.date}}</text>
            <picker mode="date" value="{{form.date}}" bindchange="onDateChange">
              <view class="form-picker">{{form.date}}</view>
            </picker>
          </view>
          <view class="form-half">
            <text class="form-label">{{copy.time}}</text>
            <picker mode="time" value="{{form.time}}" bindchange="onTimeChange">
              <view class="form-picker">{{form.time}}</view>
            </picker>
          </view>
        </view>
        <view class="form-row">
          <text class="form-label">{{copy.amount}}</text>
          <input class="form-input" placeholder="{{copy.amountPh}}" value="{{form.amount}}" bindinput="onAmountInput" />
        </view>
        <view class="form-row two">
          <view class="form-half">
            <text class="form-label">{{copy.cost}}</text>
            <input class="form-input" type="number" placeholder="{{copy.costUnit}}" value="{{form.cost}}" bindinput="onCostInput" />
          </view>
          <view class="form-half">
            <text class="form-label">{{copy.worker}}</text>
            <input class="form-input" placeholder="{{copy.me}}" value="{{form.worker}}" bindinput="onWorkerInput" />
          </view>
        </view>
        <view class="form-row">
          <text class="form-label">{{copy.note}}</text>
          <textarea class="form-textarea" placeholder="{{copy.notePh}}" value="{{form.note}}" bindinput="onNoteInput"></textarea>
        </view>

        <view class="modal-actions">
          <view class="modal-btn secondary" bindtap="onPrevModalStep"><text>{{copy.prev}}</text></view>
          <view class="modal-btn primary" bindtap="onSaveRecord"><text>{{editingId ? copy.update : copy.save}}</text></view>
        </view>
      </view>
    </view>
  </view>

  <view wx:if="{{showDetail}}" class="modal-mask" bindtap="onCloseDetail">
    <view class="detail-modal" catchtap="noop">
      <view class="detail-head">
        <view class="detail-icon" style="background:{{currentRecord.bg}}">
          <text>{{currentRecord.icon}}</text>
        </view>
        <view class="detail-title-wrap">
          <text class="detail-title">{{currentRecord.title}}</text>
          <text class="detail-sub">{{currentRecord.fieldFull}}</text>
        </view>
        <view class="detail-close" bindtap="onCloseDetail"><text>×</text></view>
      </view>
      <view class="detail-grid">
        <view class="detail-kv"><text class="kv-label">{{copy.type}}</text><text class="kv-value">{{currentRecord.displayType}}</text></view>
        <view class="detail-kv"><text class="kv-label">{{copy.time}}</text><text class="kv-value">{{currentRecord.dateText}}</text></view>
        <view class="detail-kv"><text class="kv-label">{{copy.amount}}</text><text class="kv-value">{{currentRecord.amount}}</text></view>
        <view class="detail-kv"><text class="kv-label">{{copy.cost}}</text><text class="kv-value">{{currentRecord.costText}}</text></view>
        <view class="detail-kv"><text class="kv-label">{{copy.worker}}</text><text class="kv-value">{{currentRecord.worker}}</text></view>
      </view>
      <view class="detail-note">
        <text class="kv-label">{{copy.note}}</text>
        <text class="note-text">{{currentRecord.note}}</text>
      </view>
      <view class="detail-actions">
        <view class="detail-btn danger" bindtap="onDeleteCurrentRecord"><text>{{copy.deleteOne}}</text></view>
        <view class="detail-btn primary" bindtap="onEditRecord"><text>{{copy.edit}}</text></view>
      </view>
    </view>
  </view>
</view>
