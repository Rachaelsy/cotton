<view class="page wf-fert">
  <view class="wf-head" style="padding-top: {{statusBarHeight}}px">
    <view class="wf-nav">
      <view class="wf-back" bindtap="onBack"><text>‹</text></view>
      <text class="wf-title">{{copy.title}}</text>
      <view class="wf-action" bindtap="onReminder"><text>🔔</text></view>
    </view>
    <view class="wf-hero">
      <picker mode="selector" range="{{plotOptions}}" value="{{plotIndex}}" bindchange="onPlotChange">
        <view class="wf-field-sel">📍 {{plotOptions[plotIndex] || copy.selectPlot}} ▼</view>
      </picker>
      <view class="wf-stat-row">
        <view class="wf-stat"><text class="wf-stat-v">{{model.stage}}</text><text class="wf-stat-l">{{copy.growthStage}}</text></view>
        <view class="wf-stat"><text class="wf-stat-v">{{model.count}}</text><text class="wf-stat-l">{{copy.seasonCount}}</text></view>
        <view class="wf-stat"><text class="wf-stat-v {{model.stateClass}}">{{model.state}}</text><text class="wf-stat-l">{{copy.nutritionState}}</text></view>
      </view>
    </view>
  </view>

  <scroll-view class="wf-scroll" scroll-y enhanced show-scrollbar="{{false}}">
    <view wx:if="{{loading}}" class="wf-empty">{{copy.loading}}</view>
    <block wx:else>
      <view class="wf-card">
        <view class="wf-sec-hd">{{copy.soilNutrition}}</view>
        <view class="wf-nutrient-item" wx:for="{{model.nutrients}}" wx:key="name">
          <text class="wf-nutrient-lbl">{{item.name}}</text>
          <view class="wf-progress-bar nutrient"><view class="wf-progress-fill fert {{item.cls}}" style="width: {{item.value}}%"></view></view>
          <text class="wf-nutrient-val">{{item.value}}%</text>
          <text class="wf-nutrient-state {{item.cls}}">{{item.state}}</text>
        </view>
      </view>

      <view class="wf-card">
        <view class="wf-sec-hd">{{copy.advice}}</view>
        <view class="wf-ai-box fert-box">
          <text class="wf-ai-tag fert-tag">{{copy.analysis}}</text>
          <text class="wf-ai-txt">{{model.advice}}</text>
        </view>
        <view class="wf-product" wx:for="{{model.products}}" wx:key="name">
          <view class="wf-product-icon">{{item.icon}}</view>
          <view class="wf-product-main"><text class="wf-product-name">{{item.name}}</text><text class="wf-product-meta">{{item.meta}}</text></view>
          <view class="wf-product-price"><text>{{item.price}}</text><text class="wf-product-unit">{{item.unit}}</text></view>
        </view>
        <view class="wf-quick-row">
          <view class="wf-quick-btn primary" bindtap="onRecord">{{copy.record}}</view>
          <view class="wf-quick-btn sec" bindtap="onBuy">{{copy.buy}}</view>
        </view>
      </view>

      <view class="wf-card">
        <view class="wf-sec-hd">{{copy.plan}}</view>
        <view class="wf-plan-item" wx:for="{{model.plans}}" wx:key="name">
          <view class="wf-plan-dot fert-dot"><text>{{item.icon}}</text></view>
          <view class="wf-plan-main"><text class="wf-plan-name">{{item.name}}</text><text class="wf-plan-meta">{{item.meta}}</text><text class="wf-status {{item.cls}}">{{item.status}}</text></view>
          <view class="wf-plan-val"><text>{{item.value}}</text><text class="wf-plan-sub">{{item.sub}}</text></view>
        </view>
      </view>

      <view class="wf-card">
        <view class="wf-sec-hd">{{copy.tips}}</view>
        <view class="wf-tip-row"><text class="wf-tip-icon fert">🌱</text><view><text class="wf-tip-title">{{copy.tip1}}</text><text class="wf-tip-desc">{{copy.tip1d}}</text></view></view>
        <view class="wf-tip-row"><text class="wf-tip-icon fert">🧪</text><view><text class="wf-tip-title">{{copy.tip2}}</text><text class="wf-tip-desc">{{copy.tip2d}}</text></view></view>
        <view class="wf-tip-row"><text class="wf-tip-icon warn">⏰</text><view><text class="wf-tip-title">{{copy.tip3}}</text><text class="wf-tip-desc">{{copy.tip3d}}</text></view></view>
      </view>
    </block>
    <view class="wf-bottom"></view>
  </scroll-view>
</view>
