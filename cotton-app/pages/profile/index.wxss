/* pages/profile/index.wxss */

.page {
  display: flex;
  flex-direction: column;
  height: 100vh;
  background: #F6F8F3;
}

/* ===== 导航 ===== */
.pf-nav {
  background: #ffffff;
  display: flex;
  flex-direction: row;
  align-items: center;
  padding-left: 16rpx;
  padding-right: 24rpx;
  padding-bottom: 16rpx;
  box-shadow: 0 2rpx 12rpx rgba(33,61,42,0.05);
}

.nav-back-btn {
  width: 64rpx;
  height: 64rpx;
  display: flex;
  align-items: center;
  justify-content: center;
}

.back-icon {
  font-size: 52rpx;
  color: #333333;
  font-weight: 300;
  line-height: 1;
}

.pf-title {
  flex: 1;
  text-align: center;
  font-size: 32rpx;
  font-weight: 700;
  color: #18231A;
}

/* ===== 滚动区 ===== */
.pf-scroll {
  flex: 1;
  height: 0;
}

/* ===== 头像区 ===== */
.avatar-section {
  display: flex;
  flex-direction: column;
  align-items: center;
  padding-top: 48rpx;
  padding-bottom: 32rpx;
}

.avatar-circle {
  width: 144rpx;
  height: 144rpx;
  border-radius: 50%;
  background: linear-gradient(135deg, #2F7D4B, #45A565);
  display: flex;
  align-items: center;
  justify-content: center;
  margin-bottom: 16rpx;
  box-shadow: 0 8rpx 28rpx rgba(21,128,61,0.30);
  position: relative;
  overflow: visible;
}

.avatar-img {
  width: 144rpx;
  height: 144rpx;
  border-radius: 50%;
}

.avatar-text {
  font-size: 64rpx;
  font-weight: 800;
  color: #ffffff;
  line-height: 1;
}

.avatar-edit-badge {
  position: absolute;
  bottom: 0;
  right: 0;
  width: 48rpx;
  height: 48rpx;
  background: #fff;
  border-radius: 50%;
  display: flex;
  align-items: center;
  justify-content: center;
  box-shadow: 0 2rpx 8rpx rgba(0,0,0,0.15);
}

.avatar-edit-icon { font-size: 26rpx; }

.avatar-hint {
  font-size: 24rpx;
  color: #B7C0B8;
}

/* ===== 表单卡片 ===== */
.form-card {
  background: #ffffff;
  border-radius: 22rpx;
  margin: 0 28rpx 32rpx;
  padding: 0 32rpx;
  box-shadow: 0 4rpx 20rpx rgba(33,61,42,0.05);
}

.field-row {
  display: flex;
  flex-direction: row;
  align-items: center;
  min-height: 96rpx;
  padding: 20rpx 0;
}

.field-label {
  font-size: 28rpx;
  color: #58655B;
  width: 160rpx;
  flex-shrink: 0;
}

.field-input {
  flex: 1;
  font-size: 28rpx;
  color: #18231A;
  text-align: right;
}

.field-ph {
  color: #CCCCCC;
}

.field-readonly {
  flex: 1;
  font-size: 28rpx;
  color: #B7C0B8;
  text-align: right;
}

.field-input-wrap {
  flex: 1;
  display: flex;
  flex-direction: row;
  align-items: center;
  justify-content: flex-end;
  gap: 8rpx;
}

.field-unit {
  font-size: 26rpx;
  color: #8A948B;
  flex-shrink: 0;
}

.field-picker {
  display: flex;
  flex-direction: row;
  align-items: center;
  gap: 8rpx;
}

.field-picker-val {
  font-size: 28rpx;
  color: #18231A;
}

.field-picker-arr {
  font-size: 32rpx;
  color: #CCCCCC;
}

.field-div {
  height: 1rpx;
  background: #F6F8F3;
}

/* ===== 保存按钮 ===== */
.save-btn {
  background: linear-gradient(135deg, #2F7D4B, #45A565);
  border-radius: 999rpx;
  margin: 0 28rpx;
  padding: 32rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  box-shadow: 0 6rpx 20rpx rgba(21,128,61,0.30);
}

.save-btn-off {
  opacity: 0.6;
}

.save-btn-text {
  font-size: 32rpx;
  font-weight: 800;
  color: #ffffff;
}
