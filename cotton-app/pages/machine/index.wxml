<!-- pages/machine/index.wxml — 农机租赁列表页 -->
<view class="page">

  <!-- ===== 青色渐变头部 ===== -->
  <view class="mach-header" style="padding-top: {{statusBarHeight}}px">
    <view class="topbar" style="padding-right: {{capsuleSafeRight}}px">
      <view class="back-btn" bindtap="onBack"><text class="back-icon">‹</text></view>
      <view class="topbar-titles">
        <text class="page-title">{{copy.title}}</text>
        <text class="page-subtitle">{{copy.subtitle}}</text>
      </view>
      <view class="orders-btn" bindtap="onMyOrders"><text class="orders-btn-text">{{copy.myOrders}}</text></view>
    </view>

    <!-- 定位栏 -->
    <view class="location-row">
      <picker class="locate-picker" mode="selector" range="{{regionNames}}" value="{{selectedRegionIndex}}" bindchange="onRegionPickerChange">
        <view class="locate-bar">
          <text class="locate-icon">📍</text>
          <text class="locate-text">{{locName}}</text>
          <text wx:if="{{outOfService}}" class="locate-warn">{{copy.outOfService}}</text>
          <text wx:elif="{{locByGps && !locating}}" class="locate-tag">{{copy.currentLocation}}</text>
          <text class="locate-action">{{copy.changeRegion}}</text>
        </view>
      </picker>
      <view class="gps-btn {{locating ? 'loading' : ''}}" bindtap="onUseGps">
        <text class="gps-btn-text">{{copy.gpsRefresh}}</text>
      </view>
    </view>

    <!-- 分类筛选 -->
    <scroll-view class="filter-tabs" scroll-x enhanced show-scrollbar="{{false}}">
      <view
        class="filter-tab {{catSel === item.value ? 'filter-tab-on' : ''}}"
        wx:for="{{categories}}"
        wx:key="*this"
        bindtap="onCategory"
        data-name="{{item.value}}"
      >
        <text class="filter-tab-text">{{item.label}}</text>
      </view>
    </scroll-view>
  </view>

  <!-- 排序栏 -->
  <view class="sort-bar">
    <view
      class="sort-item {{sortSel === item.key ? 'sort-item-on' : ''}}"
      wx:for="{{sorts}}"
      wx:key="key"
      bindtap="onSort"
      data-key="{{item.key}}"
    >
      <text class="sort-text">{{item.label}}</text>
    </view>
  </view>

  <!-- ===== 列表 ===== -->
  <scroll-view class="scroll-content" scroll-y enable-back-to-top style="flex:1; height:0;">

    <view wx:if="{{loading}}" class="empty-tip">
      <text class="empty-icon">⏳</text>
      <text class="empty-text">{{copy.loading}}</text>
    </view>

    <view wx:elif="{{machines.length === 0}}" class="empty-tip">
      <text class="empty-icon">🚜</text>
      <text wx:if="{{outOfService}}" class="empty-text">{{copy.outOfServiceEmpty}}</text>
      <text wx:if="{{outOfService}}" class="empty-sub">{{copy.chooseKashgar}}</text>
      <text wx:else class="empty-text">{{copy.empty}}</text>
    </view>

    <view class="machine-list">
      <view
        class="machine-card"
        wx:for="{{machines}}"
        wx:key="id"
        bindtap="onMachine"
        data-id="{{item.id}}"
      >
        <view class="card-icon-wrap">
          <text class="card-icon">{{item.icon}}</text>
        </view>

        <view class="card-body">
          <view class="card-name-row">
            <text class="card-name">{{item.name}}</text>
            <view class="status-badge {{item.status === 'busy' ? 'badge-orange' : 'badge-green'}}">
              <text class="badge-text">{{item.statusText}}</text>
            </view>
          </view>

          <view class="card-org-row">
            <text class="card-org">🏢 {{item.org_name}}</text>
            <text wx:if="{{item.distText}}" class="card-dist {{item.out_of_range ? 'card-dist-out' : ''}}">📍 {{item.distText}}{{item.out_of_range ? ' · ' + copy.outRange : ''}}</text>
          </view>

          <view class="card-params">
            <view
              class="param-item"
              wx:for="{{item.spec_badges}}"
              wx:key="*this"
              wx:for-item="b"
            >
              <text class="param-badge">{{b}}</text>
            </view>
          </view>

          <view class="card-bottom">
            <view class="price-wrap">
              <text class="price-main">¥{{item.priceText}}</text>
              <text class="price-unit">/{{item.unit}}</text>
            </view>
            <text class="card-rating">⭐{{item.ratingText}} · {{item.order_count}}{{copy.orderUnit}}</text>
            <view class="book-btn {{item.payment_ready ? '' : 'disabled'}}">
              <text class="book-btn-text">{{item.payment_ready ? copy.book : copy.paymentPending}}</text>
            </view>
          </view>
        </view>
      </view>
    </view>

    <view class="list-bottom"></view>
  </scroll-view>
</view>
