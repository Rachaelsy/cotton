<!-- pages/machine/review.wxml — 服务评价 -->
<view class="page">
  <view class="nav" style="padding-top: {{statusBarHeight}}px">
    <view class="back-btn" bindtap="onBack"><text class="back-icon">‹</text></view>
    <text class="nav-title">{{copy.title}}</text>
    <view style="width:60rpx"></view>
  </view>

  <scroll-view class="scroll" scroll-y style="flex:1;height:0;">
    <view class="rev-card">
      <view class="dim" wx:for="{{dims}}" wx:key="key" wx:for-item="d">
        <text class="dim-label">{{d.label}}</text>
        <view class="stars">
          <text
            class="star {{s <= d.score ? 'on' : ''}}"
            wx:for="{{stars}}" wx:key="*this" wx:for-item="s"
            bindtap="onStar" data-dim="{{d.key}}" data-val="{{s}}"
          >★</text>
        </view>
      </view>
    </view>

    <view class="content-card">
      <text class="cc-label">{{copy.content}}</text>
      <textarea class="cc-input" placeholder="{{copy.placeholder}}" value="{{content}}" bindinput="onContent" maxlength="200" />
    </view>

    <view style="height:160rpx"></view>
  </scroll-view>

  <view class="action-bar">
    <view class="bar-btn {{submitting ? 'disabled' : ''}}" bindtap="onSubmit">
      <text class="bar-btn-text">{{submitting ? copy.submitting : copy.submit}}</text>
    </view>
  </view>
</view>
