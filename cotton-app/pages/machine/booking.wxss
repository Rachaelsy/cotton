/* pages/machine/booking.wxss — 农机预约 */
.page { display: flex; flex-direction: column; height: 100vh; background: #F6F8F3; }
.nav { display: flex; flex-direction: row; align-items: center; justify-content: space-between;
  background: linear-gradient(160deg, #1F6F63, #4AAFA7); padding: 0 24rpx 16rpx; flex-shrink: 0; }
.back-btn { width: 60rpx; height: 60rpx; background: rgba(255,255,255,0.18); border-radius: 50%;
  display: flex; align-items: center; justify-content: center; }
.back-icon { color: #fff; font-size: 44rpx; line-height: 1; }
.nav-title { color: #fff; font-size: 32rpx; font-weight: 800; }
.scroll { flex: 1; height: 0; }

.m-summary { background: #fff; margin: 20rpx; border-radius: 20rpx; padding: 24rpx;
  display: flex; flex-direction: row; align-items: center; gap: 18rpx; }
.m-icon { width: 90rpx; height: 90rpx; background: #E9F6F2; border-radius: 20rpx;
  display: flex; align-items: center; justify-content: center; font-size: 50rpx; flex-shrink: 0; }
.m-info { flex: 1; display: flex; flex-direction: column; gap: 6rpx; min-width: 0; }
.m-name { font-size: 28rpx; font-weight: 800; color: #18231A; }
.m-org { font-size: 22rpx; color: #8A948B; }
.m-price { display: flex; flex-direction: row; align-items: baseline; }
.mp-num { font-size: 32rpx; font-weight: 900; color: #1F6F63; }
.mp-unit { font-size: 20rpx; color: #8A948B; }

.form-card { background: #fff; margin: 0 20rpx; border-radius: 20rpx; padding: 8rpx 24rpx; }
.form-row { display: flex; flex-direction: row; align-items: center; justify-content: space-between;
  padding: 26rpx 0; border-bottom: 1rpx solid #EAF0E6; gap: 20rpx; }
.form-row:last-child { border-bottom: none; }
.form-row-col { flex-direction: column; align-items: flex-start; gap: 14rpx; }
.form-label { font-size: 28rpx; color: #333; font-weight: 600; flex-shrink: 0; }
.form-picker { font-size: 28rpx; color: #1F6F63; font-weight: 600; }
.form-input { font-size: 28rpx; color: #18231A; text-align: right; flex: 1; }
.area-input-wrap { display: flex; flex-direction: row; align-items: center; gap: 8rpx; flex: 1; justify-content: flex-end; }
.area-unit { font-size: 26rpx; color: #8A948B; }
.form-textarea { width: 100%; height: 120rpx; font-size: 26rpx; color: #18231A;
  background: #F8FAF5; border-radius: 12rpx; padding: 16rpx; box-sizing: border-box; }
.addr-label-row { display: flex; flex-direction: row; align-items: center; justify-content: space-between; width: 100%; }
.req-star { color: #BF641A; }
.addr-map-btn { background: #E9F6F2; border-radius: 999rpx; padding: 8rpx 20rpx; }
.addr-map-text { font-size: 22rpx; color: #1F6F63; font-weight: 700; }
.form-input-full { width: 100%; font-size: 26rpx; color: #18231A; background: #F8FAF5;
  border-radius: 12rpx; padding: 18rpx 16rpx; box-sizing: border-box; }
.addr-detail { font-size: 22rpx; color: #2B8377; line-height: 1.5; display: block; }

.cost-card { background: #fff; margin: 20rpx; border-radius: 20rpx; padding: 24rpx; }
.cost-row { display: flex; flex-direction: row; align-items: center; justify-content: space-between; padding: 10rpx 0; }
.cost-label { font-size: 26rpx; color: #58655B; }
.cost-val { font-size: 26rpx; color: #18231A; font-weight: 600; }
.cost-total { font-size: 30rpx; color: #18231A; font-weight: 800; }
.cost-deposit { font-size: 34rpx; color: #BF641A; font-weight: 900; }
.cost-tip { font-size: 22rpx; color: #2B8377; background: #F0F7F7; border-radius: 12rpx;
  padding: 14rpx 18rpx; margin-top: 14rpx; line-height: 1.6; }

.action-bar { position: absolute; left: 0; right: 0; bottom: 0; background: #fff;
  display: flex; flex-direction: row; align-items: center; gap: 24rpx;
  padding: 18rpx 28rpx 40rpx; box-shadow: 0 -4rpx 20rpx rgba(33,61,42,0.05); }
.bar-cost { display: flex; flex-direction: column; }
.bar-label { font-size: 20rpx; color: #8A948B; }
.bar-num { font-size: 38rpx; font-weight: 900; color: #BF641A; }
.bar-btn { flex: 1; background: linear-gradient(135deg, #1F6F63, #4AAFA7); border-radius: 999rpx;
  padding: 24rpx 0; display: flex; align-items: center; justify-content: center; }
.bar-btn.disabled { opacity: 0.6; }
.bar-btn-text { font-size: 30rpx; font-weight: 800; color: #fff; }
