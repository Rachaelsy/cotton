# 复制此文件为 .env 并填写真实值
# cp .env.example .env

# ── 数据库密码（MySQL root 密码，自定义） ──────────
DB_PASS=your_strong_password_here
DB_NAME=cotton

# ── JWT 密钥（运行下面命令生成：openssl rand -hex 32） ──
JWT_SECRET=your_jwt_secret_at_least_32_chars
JWT_EXPIRES=7d
# 微信游客身份有效期；过期后小程序会自动重新执行 wx.login
GUEST_JWT_EXPIRES=30d

# 对外访问域名，用于小程序播放上传的视频/图片。
PUBLIC_BASE_URL=https://TODO_DOMAIN
# 独立开发可填写社区地址；根目录同域部署时留空。
COMMUNITY_BASE_URL=https://learn.TODO_DOMAIN

# ── AI 功能（可选，不填则 AI 问答不可用） ──────────
# GROQ_API_KEY=gsk_xxxxxxxxxxxx
# SILICONFLOW_API_KEY=sk_xxxxxxxxxxxx
# DEEPSEEK_API_KEY=sk_xxxxxxxxxxxx

# 地块气象：和风天气 QWeather（生产推荐）
WEATHER_PROVIDER=qweather
QWEATHER_API_HOST=TODO_QWEATHER_API_HOST
# API KEY 开发期可用；生产推荐改用下面的 JWT 配置。
QWEATHER_API_KEY=TODO_QWEATHER_API_KEY
# QWEATHER_JWT_KID=TODO_QWEATHER_CREDENTIAL_ID
# QWEATHER_JWT_SUB=TODO_QWEATHER_PROJECT_ID
# QWEATHER_JWT_PRIVATE_KEY_PATH=TODO_ABSOLUTE_PATH_TO_ED25519_PRIVATE_PEM
# QWEATHER_JWT_PRIVATE_KEY=TODO_PRIVATE_KEY_WITH_BACKSLASH_N_LINE_BREAKS
# QWEATHER_TIMEOUT_MS=8000
