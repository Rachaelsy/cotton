/* pages/supplies-order/index.wxss — 订单详情 */
.text-green  { color: #16A34A; }
.text-red    { color: #DC2626; }
.text-orange { color: #D97706; }

.page {
  display: flex;
  flex-direction: column;
  height: 100vh;
  background: #F5EEE6;
  position: relative;
}

/* ===== 顶部 ===== */
.ord-header {
  background: linear-gradient(160deg, #92400e, #C8902E);
  padding-left: 28rpx;
  padding-right: 28rpx;
  padding-bottom: 32rpx;
  flex-shrink: 0;
}

.ord-topbar {
  display: flex;
  flex-direction: row;
  align-items: center;
  padding-top: 10rpx;
  padding-bottom: 20rpx;
}

.ord-back {
  width: 64rpx;
  height: 64rpx;
  background: rgba(255, 255, 255, 0.2);
  border-radius: 50%;
  display: flex;
  align-items: center;
  justify-content: center;
  flex-shrink: 0;
}

.ord-back-icon {
  color: #ffffff;
  font-size: 44rpx;
}

.ord-nav-title {
  flex: 1;
  text-align: center;
  font-size: 32rpx;
  font-weight: 800;
  color: #ffffff;
}

.ord-status-block {
  display: flex;
  flex-direction: row;
  align-items: center;
  gap: 20rpx;
}

.ord-status-icon { font-size: 56rpx; }

.ord-status-info {
  display: flex;
  flex-direction: column;
  gap: 6rpx;
}

.ord-status-label {
  font-size: 40rpx;
  font-weight: 900;
  color: #ffffff;
}

.ord-status-sub {
  font-size: 24rpx;
  color: rgba(255, 255, 255, 0.8);
}

/* ===== 步骤条 ===== */
.steps-bar {
  background: #ffffff;
  padding: 28rpx 20rpx;
  display: flex;
  flex-direction: row;
  align-items: flex-start;
  flex-shrink: 0;
  box-shadow: 0 4rpx 16rpx rgba(0, 0, 0, 0.06);
}

.step {
  flex: 1;
  display: flex;
  flex-direction: column;
  align-items: center;
  position: relative;
}

.step-dot {
  width: 44rpx;
  height: 44rpx;
  border-radius: 50%;
  background: #E5E5E5;
  display: flex;
  align-items: center;
  justify-content: center;
  margin-bottom: 10rpx;
}

.step-dot-done {
  background: #22c55e;
}

.step-dot-active {
  background: #C8902E;
  box-shadow: 0 0 0 6rpx rgba(200, 144, 46, 0.2);
}

.step-check {
  font-size: 24rpx;
  color: #ffffff;
  font-weight: 900;
}

.step-num {
  font-size: 22rpx;
  color: #ffffff;
  font-weight: 800;
}

.step-label {
  font-size: 20rpx;
  color: #BBBBBB;
  font-weight: 600;
  text-align: center;
}

.step-label-on { color: #1A1A1A; }

.step-line {
  position: absolute;
  top: 22rpx;
  left: 72%;
  right: -28%;
  height: 4rpx;
  background: #E5E5E5;
  border-radius: 2rpx;
  overflow: hidden;
}

.step-line-fill {
  height: 100%;
  background: #22c55e;
  transition: width 0.3s;
}

/* ===== 滚动区 ===== */
.ord-scroll {
  flex: 1;
  height: 0;
}

.ord-body {
  padding: 20rpx 28rpx 0;
}

/* ===== 内容卡片 ===== */
.section-card {
  background: #ffffff;
  border-radius: 28rpx;
  padding: 28rpx 24rpx;
  margin-bottom: 16rpx;
}

.section-head {
  display: flex;
  flex-direction: row;
  align-items: center;
  gap: 12rpx;
  margin-bottom: 20rpx;
  padding-bottom: 16rpx;
  border-bottom: 1rpx solid #F2EBE0;
}

.section-icon { font-size: 32rpx; }

.section-title {
  font-size: 26rpx;
  font-weight: 800;
  color: #1A1A1A;
}

/* ===== 地址 ===== */
.addr-row {
  display: flex;
  flex-direction: column;
  gap: 8rpx;
}

.addr-name-row {
  display: flex;
  flex-direction: row;
  align-items: center;
  gap: 16rpx;
}

.addr-name {
  font-size: 28rpx;
  font-weight: 700;
  color: #1A1A1A;
}

.addr-phone {
  font-size: 24rpx;
  color: #888888;
}

.addr-detail {
  font-size: 24rpx;
  color: #555555;
  line-height: 1.5;
}

/* ===== 商品 ===== */
.ord-item {
  display: flex;
  flex-direction: row;
  align-items: center;
  gap: 20rpx;
  padding: 16rpx 0;
  border-bottom: 1rpx solid #F2EBE0;
}

.ord-item:last-child { border-bottom: none; }

.ord-item-img {
  width: 88rpx;
  height: 88rpx;
  border-radius: 16rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  flex-shrink: 0;
}

.ord-item-icon { font-size: 44rpx; }

.ord-item-info {
  flex: 1;
  display: flex;
  flex-direction: column;
  gap: 6rpx;
}

.ord-item-name {
  font-size: 26rpx;
  font-weight: 600;
  color: #1A1A1A;
  line-height: 1.4;
}

.ord-item-spec {
  font-size: 22rpx;
  color: #888888;
}

.ord-item-price {
  font-size: 28rpx;
  font-weight: 800;
  color: #FF3B30;
}

/* ===== 订单信息 KV ===== */
.kv-row {
  display: flex;
  flex-direction: row;
  align-items: center;
  justify-content: space-between;
  padding: 14rpx 0;
  border-bottom: 1rpx solid #F8F3ED;
}

.kv-row:last-child { border-bottom: none; }

.kv-row-total { padding-top: 20rpx; }

.kv-k {
  font-size: 24rpx;
  color: #888888;
}

.kv-k-bold {
  font-size: 26rpx;
  font-weight: 700;
  color: #1A1A1A;
}

.kv-v {
  font-size: 24rpx;
  font-weight: 600;
  color: #1A1A1A;
}

.kv-no-wrap {
  display: flex;
  flex-direction: row;
  align-items: center;
  gap: 12rpx;
}

.kv-copy {
  font-size: 20rpx;
  color: #22c55e;
  font-weight: 700;
  background: #f0fdf4;
  padding: 4rpx 12rpx;
  border-radius: 999rpx;
}

.kv-v-red {
  font-size: 32rpx;
  font-weight: 900;
  color: #FF3B30;
}

/* ===== 底部操作栏 ===== */
.ord-bottom {
  background: #ffffff;
  border-top: 1rpx solid #F2EBE0;
  padding: 20rpx 28rpx;
  padding-bottom: calc(20rpx + env(safe-area-inset-bottom));
  display: flex;
  flex-direction: column;
  gap: 16rpx;
  flex-shrink: 0;
}

.confirm-receipt-btn {
  background: linear-gradient(135deg, #16A34A, #22C55E);
  border-radius: 999rpx;
  padding: 26rpx 0;
  display: flex;
  align-items: center;
  justify-content: center;
  box-shadow: 0 6rpx 24rpx rgba(22, 163, 74, 0.35);
}

.confirm-receipt-text {
  font-size: 30rpx;
  font-weight: 800;
  color: #ffffff;
}

.action-row {
  display: flex;
  flex-direction: row;
  gap: 16rpx;
}

.action-btn {
  flex: 1;
  border-radius: 20rpx;
  padding: 20rpx 8rpx;
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
  gap: 6rpx;
  border: 2rpx solid #EEE5D8;
}

.action-contact { border-color: #D4EDDA; background: #F0FDF4; }
.action-refund  { border-color: #FCE8D4; background: #FFF7F0; }
.action-logistics { border-color: #D4E8FA; background: #EFF7FF; }

.action-disabled {
  opacity: 0.38;
}

.action-icon { font-size: 36rpx; }

.action-label {
  font-size: 24rpx;
  font-weight: 700;
  color: #333333;
}

.action-sub {
  font-size: 18rpx;
  color: #AAAAAA;
  margin-top: -4rpx;
}

/* ===== 已完成三大入口 ===== */
.ord-bottom-row {
  flex-direction: row;
  gap: 0;
  padding: 16rpx 0;
  padding-bottom: calc(16rpx + env(safe-area-inset-bottom));
}

.c3btn {
  flex: 1;
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
  gap: 8rpx;
  padding: 12rpx 0;
}

.c3btn-icon { font-size: 40rpx; }

.c3btn-label {
  font-size: 22rpx;
  font-weight: 700;
}

.c3btn-review  .c3btn-label { color: #C8902E; }
.c3btn-contact .c3btn-label { color: #16A34A; }
.c3btn-aftersale .c3btn-label { color: #E53935; }

/* ===== 收货成功弹窗 ===== */
.success-overlay {
  position: absolute;
  top: 0;
  left: 0;
  right: 0;
  bottom: 0;
  background: rgba(0, 0, 0, 0.5);
  display: flex;
  align-items: center;
  justify-content: center;
  z-index: 999;
}

.success-popup {
  background: #ffffff;
  border-radius: 40rpx;
  width: 560rpx;
  padding: 60rpx 48rpx 48rpx;
  display: flex;
  flex-direction: column;
  align-items: center;
  gap: 20rpx;
}

.success-icon-wrap {
  width: 120rpx;
  height: 120rpx;
  background: linear-gradient(135deg, #16A34A, #22C55E);
  border-radius: 50%;
  display: flex;
  align-items: center;
  justify-content: center;
  margin-bottom: 8rpx;
}

.success-checkmark {
  font-size: 56rpx;
  color: #ffffff;
  font-weight: 900;
  line-height: 1;
}

.success-title {
  font-size: 40rpx;
  font-weight: 900;
  color: #1A1A1A;
}

.success-sub {
  font-size: 26rpx;
  color: #888888;
  text-align: center;
  line-height: 1.6;
}

.success-close-btn {
  margin-top: 16rpx;
  width: 100%;
  background: linear-gradient(135deg, #16A34A, #22C55E);
  border-radius: 999rpx;
  padding: 26rpx 0;
  display: flex;
  align-items: center;
  justify-content: center;
}

.success-close-text {
  font-size: 30rpx;
  font-weight: 800;
  color: #ffffff;
}
