/* pages/supplies-pay-success/index.wxss */

.page {
  display: flex;
  flex-direction: column;
  min-height: 100vh;
  background: #F6F8F3;
}

/* ===== 顶部成功区 ===== */
.hero {
  background: linear-gradient(160deg, #2F7D4B, #45A565);
  padding-left: 40rpx;
  padding-right: 40rpx;
  padding-bottom: 60rpx;
  display: flex;
  flex-direction: column;
  align-items: center;
}

.check-wrap {
  margin-top: 40rpx;
  margin-bottom: 28rpx;
}

.check-circle {
  width: 140rpx;
  height: 140rpx;
  border-radius: 50%;
  background: rgba(255, 255, 255, 0.25);
  border: 6rpx solid rgba(255, 255, 255, 0.6);
  display: flex;
  align-items: center;
  justify-content: center;
}

.check-icon {
  font-size: 72rpx;
  color: #ffffff;
  font-weight: 900;
  line-height: 1;
}

.success-title {
  font-size: 52rpx;
  font-weight: 900;
  color: #ffffff;
  margin-bottom: 12rpx;
}

.success-sub {
  font-size: 26rpx;
  color: rgba(255, 255, 255, 0.8);
}

/* ===== 多订单列表 ===== */
.orders-list {
  margin: -32rpx 28rpx 0;
  display: flex;
  flex-direction: column;
  gap: 16rpx;
}

.order-card {
  background: #ffffff;
  border-radius: 22rpx;
  padding: 28rpx 28rpx 16rpx;
  box-shadow: 0 6rpx 30rpx rgba(33, 61, 42, 0.07);
}

.store-row {
  display: flex;
  flex-direction: row;
  align-items: center;
  gap: 10rpx;
  margin-bottom: 18rpx;
}

.store-tag { font-size: 28rpx; }

.store-name {
  font-size: 26rpx;
  font-weight: 700;
  color: #18231A;
}

.order-subtotal {
  font-size: 30rpx;
  font-weight: 800;
  color: #FF3B30;
  flex-shrink: 0;
}

/* ===== 摘要卡片 ===== */
.summary-card {
  background: #ffffff;
  border-radius: 26rpx;
  margin: 16rpx 28rpx 0;
  padding: 24rpx 32rpx;
  box-shadow: 0 8rpx 40rpx rgba(33, 61, 42, 0.09);
}

.item-row {
  display: flex;
  flex-direction: row;
  align-items: center;
  gap: 20rpx;
  margin-bottom: 20rpx;
}

.item-thumb {
  width: 96rpx;
  height: 96rpx;
  border-radius: 20rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  flex-shrink: 0;
}

.item-thumb-icon { font-size: 52rpx; }

.item-info {
  flex: 1;
  display: flex;
  flex-direction: column;
  gap: 6rpx;
}

.item-name {
  font-size: 28rpx;
  font-weight: 700;
  color: #18231A;
  line-height: 1.4;
}

.item-more {
  font-size: 22rpx;
  color: #B9852F;
}

.item-spec {
  font-size: 22rpx;
  color: #8A948B;
}

.divider {
  height: 1rpx;
  background: #EAF0E6;
  margin-bottom: 20rpx;
}

.kv-row {
  display: flex;
  flex-direction: row;
  align-items: center;
  justify-content: space-between;
  padding: 12rpx 0;
}

.kv-k {
  font-size: 26rpx;
  color: #8A948B;
}

.kv-v {
  font-size: 26rpx;
  font-weight: 600;
  color: #18231A;
}

.kv-no-wrap {
  display: flex;
  flex-direction: row;
  align-items: center;
  gap: 12rpx;
}

.kv-no {
  font-size: 24rpx;
  color: #58655B;
  font-weight: 500;
}

.kv-copy {
  font-size: 22rpx;
  color: #45A565;
  font-weight: 700;
  background: #f0fdf4;
  padding: 4rpx 14rpx;
  border-radius: 999rpx;
}

.kv-v-red {
  font-size: 34rpx;
  font-weight: 900;
  color: #FF3B30;
}

/* ===== 按钮组 ===== */
.btn-group {
  margin: 40rpx 28rpx 0;
  display: flex;
  flex-direction: column;
  gap: 20rpx;
}

.btn-primary {
  background: linear-gradient(135deg, #2F7D4B, #45A565);
  border-radius: 999rpx;
  padding: 30rpx;
  display: flex;
  align-items: center;
  justify-content: center;
}

.btn-ghost {
  border-radius: 999rpx;
  padding: 28rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  border: 3rpx solid #D4C4AE;
  background: #ffffff;
}

.btn-text-white {
  font-size: 30rpx;
  font-weight: 800;
  color: #ffffff;
}

.btn-text-gray {
  font-size: 30rpx;
  font-weight: 700;
  color: #687468;
}

/* ===== 提示 ===== */
.tips-row {
  display: flex;
  align-items: center;
  justify-content: center;
  margin-top: 32rpx;
  padding-bottom: 40rpx;
}

.tips-text {
  font-size: 24rpx;
  color: #B7C0B8;
}
