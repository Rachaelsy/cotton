<!-- pages/supplies-pay-success/index.wxml -->
<view class="page">

  <!-- 顶部成功区域 -->
  <view class="hero" style="padding-top: {{statusBarHeight}}px">
    <view class="check-wrap">
      <view class="check-circle">
        <text class="check-icon">✓</text>
      </view>
    </view>
    <text class="success-title">支付成功</text>
    <text class="success-sub" wx:if="{{multiStore}}">已为您拆分为{{orders.length}}个商家订单</text>
    <text class="success-sub" wx:else>商家已收到您的订单，正在备货中</text>
  </view>

  <!-- 每个商家订单卡片 -->
  <view class="orders-list">
    <view class="order-card" wx:for="{{orders}}" wx:key="orderNo">
      <!-- 店铺名 -->
      <view class="store-row">
        <text class="store-tag">🏪</text>
        <text class="store-name">{{item.store}}</text>
      </view>

      <!-- 商品缩略 -->
      <view class="item-row">
        <view class="item-thumb" style="background: {{item.firstItem.imgBg || '#FBF5EA'}}">
          <text class="item-thumb-icon">{{item.firstItem.icon || '📦'}}</text>
        </view>
        <view class="item-info">
          <text class="item-name">{{item.firstItem.name}}</text>
          <text class="item-more" wx:if="{{item.itemCount > 1}}">等共 {{item.itemCount}} 件商品</text>
          <text class="item-spec" wx:else>{{item.firstItem.spec}}</text>
        </view>
        <text class="order-subtotal">¥{{item.total}}</text>
      </view>

      <view class="divider"></view>

      <!-- 订单号 -->
      <view class="kv-row" wx:if="{{item.orderNo}}">
        <text class="kv-k">订单号</text>
        <view class="kv-no-wrap">
          <text class="kv-v kv-no">{{item.orderNo}}</text>
          <text class="kv-copy" bindtap="onCopyNo" data-no="{{item.orderNo}}">复制</text>
        </view>
      </view>
    </view>
  </view>

  <!-- 合计 & 时间 -->
  <view class="summary-card">
    <view class="kv-row">
      <text class="kv-k">下单时间</text>
      <text class="kv-v">{{createTimeStr}}</text>
    </view>
    <view class="kv-row">
      <text class="kv-k">支付方式</text>
      <text class="kv-v">微信支付</text>
    </view>
    <view class="kv-row">
      <text class="kv-k">合计实付</text>
      <text class="kv-v-red">¥{{grandTotal}}</text>
    </view>
  </view>

  <!-- 操作按钮 -->
  <view class="btn-group">
    <view class="btn-primary" bindtap="onViewOrder">
      <text class="btn-text-white">查看全部订单</text>
    </view>
    <view class="btn-ghost" bindtap="onHome">
      <text class="btn-text-gray">返回首页</text>
    </view>
  </view>

  <!-- 温馨提示 -->
  <view class="tips-row">
    <text class="tips-text">📌 商家确认发货后，您将收到通知</text>
  </view>

</view>
