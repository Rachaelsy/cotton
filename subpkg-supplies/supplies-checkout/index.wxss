/* pages/supplies-checkout/index.wxss — 确认订单样式 */

.page {
  display: flex;
  flex-direction: column;
  height: 100vh;
  background: #F6F8F3;
}

/* ===== 顶部导航 ===== */
.co-nav {
  background: #ffffff;
  padding-left: 28rpx;
  padding-right: 28rpx;
  padding-bottom: 24rpx;
  border-bottom: 1rpx solid #EAF0E6;
  display: flex;
  flex-direction: row;
  align-items: center;
  gap: 0;
  flex-shrink: 0;
}

.nav-back-btn {
  width: 64rpx;
  height: 64rpx;
  background: #F6F8F3;
  border-radius: 50%;
  display: flex;
  align-items: center;
  justify-content: center;
}

.back-icon {
  font-size: 44rpx;
  color: #18231A;
}

.co-title {
  flex: 1;
  font-size: 34rpx;
  font-weight: 800;
  color: #18231A;
  text-align: center;
}

/* ===== 滚动区 ===== */
.co-scroll {
  flex: 1;
  height: 0;
}

/* ===== 卡片通用 ===== */
.co-card {
  background: #ffffff;
  border-radius: 22rpx;
  margin: 20rpx 28rpx 0;
  padding: 24rpx;
  box-shadow: 0 4rpx 24rpx rgba(33, 61, 42, 0.06);
}

.co-card-title {
  display: flex;
  flex-direction: row;
  align-items: center;
  gap: 12rpx;
  margin-bottom: 20rpx;
}

.co-card-title-bar {
  width: 6rpx;
  height: 28rpx;
  background: #B9852F;
  border-radius: 4rpx;
}

.co-card-title-text {
  font-size: 28rpx;
  font-weight: 700;
  color: #18231A;
}

/* ===== 收货地址 ===== */

/* 显示模式 */
.addr-display-row {
  display: flex;
  flex-direction: row;
  gap: 16rpx;
  align-items: flex-start;
}

.addr-display-info {
  flex: 1;
  display: flex;
  flex-direction: column;
  gap: 8rpx;
}

.addr-display-name-row {
  display: flex;
  flex-direction: row;
  align-items: center;
  gap: 16rpx;
}

.addr-display-name {
  font-size: 30rpx;
  font-weight: 700;
  color: #18231A;
}

.addr-display-phone {
  font-size: 26rpx;
  color: #58655B;
}

.addr-display-detail {
  font-size: 26rpx;
  color: #58655B;
  line-height: 1.5;
}

.addr-empty {
  display: flex;
  flex-direction: row;
  align-items: center;
  gap: 12rpx;
  padding: 8rpx 0;
}

.addr-empty-icon { font-size: 36rpx; }

.addr-empty-text {
  font-size: 28rpx;
  color: #C5CCC5;
}

.addr-edit-btn {
  margin-top: 20rpx;
  border: 2rpx solid #B9852F;
  border-radius: 999rpx;
  padding: 14rpx 0;
  display: flex;
  align-items: center;
  justify-content: center;
}

.addr-edit-text {
  font-size: 26rpx;
  font-weight: 600;
  color: #B9852F;
}

/* 编辑模式 */
.addr-edit-form { }

.addr-confirm-btn {
  margin-top: 20rpx;
  background: linear-gradient(135deg, #B9852F, #C9973A);
  border-radius: 999rpx;
  padding: 18rpx 0;
  display: flex;
  align-items: center;
  justify-content: center;
}

.addr-confirm-text {
  font-size: 28rpx;
  font-weight: 700;
  color: #fff;
}

.addr-row {
  display: flex;
  flex-direction: row;
  gap: 16rpx;
}

.addr-icon { font-size: 40rpx; flex-shrink: 0; }

.addr-info {
  flex: 1;
  display: flex;
  flex-direction: column;
  gap: 6rpx;
}

.addr-input {
  background: #F8F4EF;
  border-radius: 12rpx;
  padding: 14rpx 18rpx;
  font-size: 26rpx;
  color: #18231A;
}

.addr-name-row {
  display: flex;
  flex-direction: row;
  gap: 12rpx;
  margin-bottom: 12rpx;
}

.addr-name-input { flex: 1; }
.addr-phone-input { flex: 1; }
.addr-detail-input { width: 100%; }

.addr-location-row {
  min-height: 64rpx;
  margin-top: 12rpx;
  display: flex;
  align-items: center;
  justify-content: space-between;
  gap: 12rpx;
}

.addr-location-btn {
  min-height: 60rpx;
  padding: 0 18rpx;
  box-sizing: border-box;
  border: 2rpx solid #B9852F;
  border-radius: 8rpx;
  display: flex;
  align-items: center;
  gap: 8rpx;
}

.addr-location-icon {
  color: #8A6A25;
  font-size: 30rpx;
  font-weight: 700;
}

.addr-location-text {
  color: #8A6A25;
  font-size: 23rpx;
  font-weight: 700;
}

.addr-location-ready {
  min-width: 0;
  color: #2F7D4A;
  font-size: 21rpx;
  text-align: right;
}

/* ===== 订单商品 ===== */
.co-item {
  display: flex;
  flex-direction: row;
  align-items: center;
  gap: 20rpx;
  padding: 16rpx 0;
  border-bottom: 1rpx solid #EAF0E6;
}

.co-item:last-child { border-bottom: none; }

.co-item-img {
  width: 104rpx;
  height: 104rpx;
  border-radius: 16rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  flex-shrink: 0;
}

.co-item-photo {
  width: 104rpx;
  height: 104rpx;
  border-radius: 16rpx;
}

.co-item-icon { font-size: 52rpx; }

.co-item-info {
  flex: 1;
  display: flex;
  flex-direction: column;
  gap: 6rpx;
}

.co-item-name {
  font-size: 24rpx;
  font-weight: 600;
  color: #18231A;
  line-height: 1.4;
}

.co-item-spec {
  font-size: 22rpx;
  color: #8A948B;
}

.co-item-price {
  font-size: 26rpx;
  font-weight: 800;
  color: #FF3B30;
  flex-shrink: 0;
}

.discount-shop { padding: 6rpx 0 14rpx; border-bottom: 1rpx solid #EAF0E6; }
.discount-shop:last-of-type { border-bottom: none; }
.discount-shop-head { display: flex; align-items: center; justify-content: space-between; margin-bottom: 16rpx; }
.discount-store { max-width: 440rpx; overflow: hidden; color: #28332B; font-size: 24rpx; font-weight: 700; text-overflow: ellipsis; white-space: nowrap; }
.discount-saving { color: #B74232; font-size: 23rpx; font-weight: 700; }
.discount-row { display: flex; align-items: center; gap: 16rpx; }
.discount-label { flex-shrink: 0; color: #6E786F; font-size: 24rpx; }
.coupon-picker { min-width: 0; flex: 1; }
.coupon-selected { min-height: 62rpx; padding: 0 16rpx; display: flex; align-items: center; justify-content: space-between; gap: 8rpx; box-sizing: border-box; color: #455047; background: #F5F7F3; border-radius: 8rpx; font-size: 22rpx; }
.coupon-selected text:first-child { min-width: 0; overflow: hidden; text-overflow: ellipsis; white-space: nowrap; }
.coupon-arrow { flex-shrink: 0; color: #929A94; font-size: 32rpx; }
.marketing-loading { padding: 14rpx 0 4rpx; color: #8A948B; text-align: center; font-size: 22rpx; }

/* ===== 配送 ===== */
.delivery-row {
  display: flex;
  flex-direction: row;
  justify-content: space-between;
  align-items: center;
}

.delivery-label {
  font-size: 26rpx;
  color: #18231A;
}

.delivery-fee {
  font-size: 26rpx;
  font-weight: 700;
  color: #58655B;
}

/* ===== 支付方式 ===== */
.pay-opt {
  display: flex;
  flex-direction: row;
  align-items: center;
  gap: 24rpx;
  padding: 26rpx 0;
  border-bottom: 1rpx solid #EAF0E6;
}

.pay-opt:last-child { border-bottom: none; }

.pay-ico {
  width: 72rpx;
  height: 72rpx;
  border-radius: 20rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  font-size: 36rpx;
  flex-shrink: 0;
}

.pay-info {
  flex: 1;
  display: flex;
  flex-direction: column;
  gap: 4rpx;
}

.pay-name {
  font-size: 28rpx;
  font-weight: 700;
  color: #18231A;
}

.pay-sub {
  font-size: 22rpx;
  color: #8A948B;
}

.pay-radio {
  width: 40rpx;
  height: 40rpx;
  border-radius: 50%;
  border: 3rpx solid #E3E9DE;
  flex-shrink: 0;
}

.pay-radio-on {
  background: #B9852F;
  border-color: #B9852F;
}

/* ===== 备注 ===== */
.remark-row {
  display: flex;
  flex-direction: row;
  justify-content: space-between;
  align-items: center;
}

.remark-placeholder {
  font-size: 26rpx;
  color: #C5CCC5;
}

.remark-arr {
  font-size: 28rpx;
  color: #C5CCC5;
}

/* ===== 底部结算 ===== */
.co-bottom {
  background: #ffffff;
  border-top: 1rpx solid #EAF0E6;
  padding: 20rpx 28rpx;
  padding-bottom: calc(20rpx + env(safe-area-inset-bottom));
  flex-shrink: 0;
}

.co-total-rows {
  margin-bottom: 16rpx;
}

.co-total-row {
  display: flex;
  flex-direction: row;
  justify-content: space-between;
  align-items: center;
  padding: 4rpx 0;
}

.co-total-label {
  font-size: 26rpx;
  color: #58655B;
}

.co-total-val {
  font-size: 28rpx;
  font-weight: 700;
  color: #18231A;
}

.co-discount-val { color: #B74232; }

.co-pay-btn {
  background: linear-gradient(135deg, #D97918, #FF3B30);
  border-radius: 999rpx;
  padding: 28rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  box-shadow: 0 8rpx 32rpx rgba(255, 107, 0, 0.4);
}

.co-pay-text {
  font-size: 30rpx;
  font-weight: 800;
  color: #ffffff;
}
