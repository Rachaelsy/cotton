<!-- pages/supplies-checkout/index.wxml — 确认订单 -->
<view class="page">

  <!-- 顶部导航 -->
  <view class="co-nav" style="padding-top: {{statusBarHeight}}px; padding-right: calc(28rpx + {{capsuleSafeRight}}px)">
    <view class="nav-back-btn" bindtap="onBack">
      <text class="back-icon">‹</text>
    </view>
    <text class="co-title">{{copy.title}}</text>
    <view style="width: 64rpx"></view>
  </view>

  <!-- 内容滚动区 -->
  <scroll-view class="co-scroll" scroll-y>

    <!-- 收货信息 -->
    <view class="co-card">
      <view class="co-card-title">
        <text class="co-card-title-bar"></text>
      <text class="co-card-title-text">{{copy.shipping}}</text>
      </view>

      <!-- ① 显示模式 -->
      <view wx:if="{{!editingAddr}}">
        <view wx:if="{{receiverName}}" class="addr-display-row">
          <text class="addr-icon">📍</text>
          <view class="addr-display-info">
            <view class="addr-display-name-row">
              <text class="addr-display-name">{{receiverName}}</text>
              <text class="addr-display-phone">{{receiverPhone}}</text>
            </view>
            <text class="addr-display-detail">{{address}}</text>
          </view>
        </view>
        <view wx:else class="addr-empty">
          <text class="addr-empty-icon">📍</text>
          <text class="addr-empty-text">{{copy.fill}}</text>
        </view>
        <view class="addr-edit-btn" bindtap="onEditAddr">
        <text class="addr-edit-text">{{receiverName ? copy.edit : copy.fillAddress}}</text>
        </view>
      </view>

      <!-- ② 编辑模式 -->
      <view wx:else class="addr-edit-form">
        <view class="addr-row">
          <text class="addr-icon">📍</text>
          <view class="addr-info">
            <view class="addr-name-row">
          <input class="addr-input addr-name-input" value="{{receiverName}}" placeholder="{{copy.name}}" bindinput="onNameInput"/>
          <input class="addr-input addr-phone-input" value="{{receiverPhone}}" placeholder="{{copy.phone}}" type="number" bindinput="onPhoneInput"/>
            </view>
        <input class="addr-input addr-detail-input" value="{{address}}" placeholder="{{copy.address}}" bindinput="onAddrInput"/>
        <view class="addr-location-row">
          <view class="addr-location-btn" bindtap="onChooseLocation">
            <text class="addr-location-icon">⌖</text>
            <text class="addr-location-text">{{copy.chooseLocation}}</text>
          </view>
          <text wx:if="{{addressLatitude !== null && addressLongitude !== null}}" class="addr-location-ready">{{copy.locationSelected}}</text>
        </view>
          </view>
        </view>
        <view class="addr-confirm-btn" bindtap="onConfirmAddr">
          <text class="addr-confirm-text">{{copy.confirm}}</text>
        </view>
      </view>
    </view>

    <!-- 订单商品 -->
    <view class="co-card">
      <view class="co-card-title">
        <text class="co-card-title-bar"></text>
      <text class="co-card-title-text">{{copy.goods}}</text>
      </view>
      <view class="co-item" wx:for="{{cartItems}}" wx:key="id">
        <view class="co-item-img" style="background: {{item.imgBg || '#FBF5EA'}}">
          <image wx:if="{{item.image_url}}" class="co-item-photo" src="{{item.image_url}}" mode="aspectFill"/>
          <text wx:else class="co-item-icon">{{item.icon || '📦'}}</text>
        </view>
        <view class="co-item-info">
          <text class="co-item-name">{{item.name}}</text>
          <text class="co-item-spec">{{item.spec}} × {{item.qty}}</text>
        </view>
        <text class="co-item-price">¥{{item.price * item.qty}}</text>
      </view>
    </view>

    <view class="co-card">
      <view class="co-card-title">
        <text class="co-card-title-bar"></text>
        <text class="co-card-title-text">{{copy.discount}}</text>
      </view>
      <view class="discount-shop" wx:for="{{orderGroups}}" wx:key="key">
        <view class="discount-shop-head">
          <text class="discount-store">{{item.store}}</text>
          <text wx:if="{{item.promotion_discount > 0}}" class="discount-saving">-¥{{item.promotion_discount}}</text>
        </view>
        <view class="discount-row">
          <text class="discount-label">{{copy.coupon}}</text>
          <picker class="coupon-picker" mode="selector" range="{{item.couponOptions}}" range-key="label" value="{{item.selectedCouponIndex}}" data-index="{{index}}" bindchange="onCouponChange">
            <view class="coupon-selected">
              <text>{{item.selectedCouponLabel}}</text>
              <text class="coupon-arrow">›</text>
            </view>
          </picker>
        </view>
        <text wx:if="{{item.couponHint}}" class="coupon-hint">{{item.couponHint}}</text>
        <text wx:if="{{item.marketingError}}" class="coupon-error">{{item.marketingError}}</text>
      </view>
      <view wx:if="{{marketingLoading}}" class="marketing-loading">正在计算可用优惠...</view>
    </view>

    <!-- 配送方式 -->
    <view class="co-card">
      <view class="co-card-title">
        <text class="co-card-title-bar"></text>
      <text class="co-card-title-text">{{copy.delivery}}</text>
      </view>
      <view class="delivery-row">
      <text class="delivery-label">{{copy.deliveryWay}}</text>
        <text class="delivery-fee">¥{{deliveryFee}}</text>
      </view>
    </view>

    <!-- 支付方式 -->
    <view class="co-card">
      <view class="co-card-title">
        <text class="co-card-title-bar"></text>
      <text class="co-card-title-text">{{copy.payment}}</text>
      </view>
      <view class="pay-opt">
        <view class="pay-ico" style="background: #E8F5E9">
          <text>💚</text>
        </view>
        <view class="pay-info">
          <text class="pay-name">{{copy.wechat}}</text>
          <text class="pay-sub">{{copy.safe}}</text>
        </view>
        <view class="pay-radio pay-radio-on"></view>
      </view>
    </view>

    <!-- 备注 -->
    <view class="co-card" style="margin-bottom: 0">
      <view class="co-card-title">
        <text class="co-card-title-bar"></text>
      <text class="co-card-title-text">{{copy.remark}}</text>
      </view>
      <view class="remark-row">
        <text class="remark-placeholder">{{copy.remarkPh}}</text>
        <text class="remark-arr">›</text>
      </view>
    </view>

    <view style="height: 200rpx"></view>
  </scroll-view>

  <!-- 底部结算栏 -->
  <view class="co-bottom">
    <view class="co-total-rows">
      <view class="co-total-row">
        <text class="co-total-label">{{copy.subtotal}}</text>
        <text class="co-total-val">¥{{cartTotal}}</text>
      </view>
      <view wx:if="{{merchantDiscount > 0}}" class="co-total-row">
        <text class="co-total-label">{{copy.saved}}</text>
        <text class="co-total-val co-discount-val">-¥{{merchantDiscount}}</text>
      </view>
      <view class="co-total-row">
        <text class="co-total-label">{{copy.fee}}</text>
        <text class="co-total-val">¥{{deliveryFee}}</text>
      </view>
    </view>
    <view class="co-pay-btn" bindtap="onPay">
      <text class="co-pay-text" wx:if="{{!submitting}}">{{copy.submit}} · ¥{{totalWithFee}}</text>
      <text class="co-pay-text" wx:else>{{copy.submitting}}</text>
    </view>
  </view>

</view>
