<!-- pages/supplies-checkout/index.wxml — 确认订单 -->
<view class="page">

  <!-- 顶部导航 -->
  <view class="co-nav" style="padding-top: {{statusBarHeight}}px">
    <view class="nav-back-btn" bindtap="onBack">
      <text class="back-icon">‹</text>
    </view>
    <text class="co-title">确认订单</text>
    <view style="width: 64rpx"></view>
  </view>

  <!-- 内容滚动区 -->
  <scroll-view class="co-scroll" scroll-y>

    <!-- 收货信息 -->
    <view class="co-card">
      <view class="co-card-title">
        <text class="co-card-title-bar"></text>
        <text class="co-card-title-text">收货信息</text>
      </view>

      <!-- ① 显示模式 -->
      <view wx:if="{{!editingAddr}}">
        <view wx:if="{{receiverName}}" class="addr-display-row">
          <text class="addr-icon">📍</text>
          <view class="addr-display-info">
            <view class="addr-display-name-row">
              <text class="addr-display-name">{{receiverName}}</text>
              <text class="addr-display-phone">{{receiverPhone}}</text>
            </view>
            <text class="addr-display-detail">{{address}}</text>
          </view>
        </view>
        <view wx:else class="addr-empty">
          <text class="addr-empty-icon">📍</text>
          <text class="addr-empty-text">请填写收货信息</text>
        </view>
        <view class="addr-edit-btn" bindtap="onEditAddr">
          <text class="addr-edit-text">{{receiverName ? '编辑' : '+ 填写地址'}}</text>
        </view>
      </view>

      <!-- ② 编辑模式 -->
      <view wx:else class="addr-edit-form">
        <view class="addr-row">
          <text class="addr-icon">📍</text>
          <view class="addr-info">
            <view class="addr-name-row">
              <input class="addr-input addr-name-input" value="{{receiverName}}" placeholder="收货人姓名" bindinput="onNameInput"/>
              <input class="addr-input addr-phone-input" value="{{receiverPhone}}" placeholder="手机号" type="number" bindinput="onPhoneInput"/>
            </view>
            <input class="addr-input addr-detail-input" value="{{address}}" placeholder="省市区乡镇 详细地址" bindinput="onAddrInput"/>
          </view>
        </view>
        <view class="addr-confirm-btn" bindtap="onConfirmAddr">
          <text class="addr-confirm-text">确定</text>
        </view>
      </view>
    </view>

    <!-- 订单商品 -->
    <view class="co-card">
      <view class="co-card-title">
        <text class="co-card-title-bar"></text>
        <text class="co-card-title-text">订单商品</text>
      </view>
      <view class="co-item" wx:for="{{cartItems}}" wx:key="id">
        <view class="co-item-img" style="background: {{item.imgBg || '#FBF5EA'}}">
          <image wx:if="{{item.image_url}}" class="co-item-photo" src="{{item.image_url}}" mode="aspectFill"/>
          <text wx:else class="co-item-icon">{{item.icon || '📦'}}</text>
        </view>
        <view class="co-item-info">
          <text class="co-item-name">{{item.name}}</text>
          <text class="co-item-spec">{{item.spec}} × {{item.qty}}</text>
        </view>
        <text class="co-item-price">¥{{item.price * item.qty}}</text>
      </view>
    </view>

    <!-- 配送方式 -->
    <view class="co-card">
      <view class="co-card-title">
        <text class="co-card-title-bar"></text>
        <text class="co-card-title-text">配送方式</text>
      </view>
      <view class="delivery-row">
        <text class="delivery-label">🚚 送货到地头</text>
        <text class="delivery-fee">¥10</text>
      </view>
    </view>

    <!-- 支付方式 -->
    <view class="co-card">
      <view class="co-card-title">
        <text class="co-card-title-bar"></text>
        <text class="co-card-title-text">支付方式</text>
      </view>
      <view class="pay-opt">
        <view class="pay-ico" style="background: #E8F5E9">
          <text>💚</text>
        </view>
        <view class="pay-info">
          <text class="pay-name">微信支付</text>
          <text class="pay-sub">快捷安全</text>
        </view>
        <view class="pay-radio pay-radio-on"></view>
      </view>
    </view>

    <!-- 备注 -->
    <view class="co-card" style="margin-bottom: 0">
      <view class="co-card-title">
        <text class="co-card-title-bar"></text>
        <text class="co-card-title-text">订单备注</text>
      </view>
      <view class="remark-row">
        <text class="remark-placeholder">如有特殊要求请填写...</text>
        <text class="remark-arr">›</text>
      </view>
    </view>

    <view style="height: 200rpx"></view>
  </scroll-view>

  <!-- 底部结算栏 -->
  <view class="co-bottom">
    <view class="co-total-rows">
      <view class="co-total-row">
        <text class="co-total-label">商品合计</text>
        <text class="co-total-val">¥{{cartTotal}}</text>
      </view>
      <view class="co-total-row">
        <text class="co-total-label">运费</text>
        <text class="co-total-val">¥10</text>
      </view>
    </view>
    <view class="co-pay-btn" bindtap="onPay">
      <text class="co-pay-text" wx:if="{{!submitting}}">提交订单</text>
      <text class="co-pay-text" wx:else>提交中...</text>
    </view>
  </view>

</view>
