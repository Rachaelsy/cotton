<!-- pages/supplies/index.wxml — 农资商城首页 -->
<view class="page">

  <!-- ===== 顶部渐变头部 ===== -->
  <view class="sup-header" style="padding-top: {{statusBarHeight}}px">
    <view class="topbar" style="padding-right: {{capsuleSafeRight}}px">
      <text class="page-title">{{copy.title}}</text>
    </view>
    <!-- 搜索栏 + 购物车 -->
    <view class="search-row">
      <view class="search-bar">
        <text class="search-icon">🔍</text>
        <input
          class="search-input"
          value="{{searchKeyword}}"
          placeholder="{{copy.search}}"
          placeholder-style="color:#BBBBBB;font-size:28rpx"
          confirm-type="search"
          bindinput="onSearchInput"
          bindconfirm="onSearchConfirm"
        />
        <view wx:if="{{searchKeyword}}" class="search-clear" catchtap="onSearchClear">
          <text style="color:#BBBBBB;font-size:28rpx">✕</text>
        </view>
      </view>
      <view class="cart-btn" bindtap="goCart">
        <text class="cart-icon">🛒</text>
        <view wx:if="{{cartCount > 0}}" class="cart-badge">
          <text class="cart-badge-text">{{cartCount > 99 ? '99+' : cartCount}}</text>
        </view>
      </view>
    </view>
  </view>

  <!-- ===== 可滚动内容区 ===== -->
  <scroll-view class="scroll-content" scroll-y enable-back-to-top>

    <!-- 分类导航 -->
    <view class="cats-section">
      <view
        class="cat-item"
        wx:for="{{cats}}"
        wx:key="name"
        bindtap="onCat"
        data-name="{{item.name}}"
      >
        <view class="cat-icon-wrap" style="background: {{item.bg}}">
          <text class="cat-icon">{{item.icon}}</text>
        </view>
        <text class="cat-name {{catSel === item.name ? 'cat-name-on' : ''}}">{{item.label}}</text>
      </view>
    </view>

    <!-- 活动横幅 -->
    <view class="banners-row">
      <view class="banner banner-spring" bindtap="onBanner">
        <text class="banner-tag">{{copy.spring}}</text>
        <text class="banner-title">{{copy.seedFert}}</text>
        <text class="banner-sub">{{copy.discount}}</text>
      </view>
      <view class="banner banner-cert" bindtap="onQualityBanner">
        <text class="banner-tag">{{copy.quality}}</text>
        <text class="banner-title">{{copy.certified}}</text>
        <text class="banner-sub">{{copy.compensation}}</text>
      </view>
    </view>

    <view class="coupon-entry" bindtap="goCoupons">
      <view class="coupon-entry-mark">券</view>
      <view class="coupon-entry-copy">
        <text class="coupon-entry-title">{{copy.coupons}}</text>
        <text class="coupon-entry-sub">{{copy.couponSub}}</text>
      </view>
      <text class="coupon-entry-arrow">›</text>
    </view>

    <!-- 商品列表 -->
    <view class="sec-header">
      <text class="sec-title">{{copy.popular}}</text>
      <text class="sec-more">{{copy.more}}</text>
    </view>

    <view class="prod-grid">
      <view
        class="prod-card"
        wx:for="{{displayProds}}"
        wx:key="id"
        bindtap="onProduct"
        data-id="{{item.id}}"
      >
        <view class="prod-img" style="background: {{item.imgBg}}">
          <block wx:if="{{item.image_url}}">
            <image class="prod-photo" src="{{item.image_url}}" mode="aspectFill" lazy-load></image>
          </block>
          <block wx:else>
            <text class="prod-icon">{{item.icon || '📦'}}</text>
          </block>
          <text wx:if="{{item.isNew}}" class="tag tag-new">{{copy.new}}</text>
          <text wx:elif="{{item.hot}}" class="tag tag-hot">{{copy.hot}}</text>
        </view>
        <view class="prod-body">
          <text class="prod-name">{{item.name}}</text>
          <text class="prod-store">{{item.company_name || item.store || copy.merchant}}</text>
          <text class="prod-spec">{{item.unit ? item.unit : item.spec}}</text>
          <view class="prod-bottom">
            <view class="prod-price-wrap">
              <text wx:if="{{item.has_promotion}}" class="promo-label">{{item.promotion_label}}</text>
              <view class="price-line">
                <text class="prod-price">¥{{item.has_promotion ? item.display_price : item.price}}</text>
                <text wx:if="{{item.has_promotion}}" class="prod-price-old">¥{{item.original_price}}</text>
                <text class="prod-unit">/{{item.unit || item.unit}}</text>
              </view>
            </view>
            <view wx:if="{{item.cartQty > 0}}" class="qty-stepper">
              <view class="qty-step-btn qty-step-minus" catchtap="onQtyMinus" data-id="{{item.id}}">
                <text class="qty-step-icon">−</text>
              </view>
              <text class="qty-step-num">{{item.cartQty}}</text>
              <view class="qty-step-btn" catchtap="onAddToCart" data-id="{{item.id}}">
                <text class="qty-step-icon">＋</text>
              </view>
            </view>
            <view wx:else class="add-btn" catchtap="onAddToCart" data-id="{{item.id}}">
              <text class="add-btn-icon">＋</text>
            </view>
          </view>
        </view>
      </view>
    </view>

    <!-- 无商品提示 -->
    <view wx:if="{{displayProds.length === 0}}" class="empty-tip">
      <text class="empty-icon">🔍</text>
      <text class="empty-text">{{searchKeyword ? copy.notFound : copy.empty}}</text>
    </view>

    <view class="list-bottom"></view>
  </scroll-view>

  <view wx:if="{{cartCount > 0}}" class="quick-cart">
    <view class="quick-cart-summary" bindtap="goCart">
      <view class="quick-cart-icon-wrap">
        <text class="quick-cart-icon">🛒</text>
        <text class="quick-cart-count">{{cartCount > 99 ? '99+' : cartCount}}</text>
      </view>
      <view class="quick-cart-copy">
        <text class="quick-cart-selected">
          {{copy.selected}} {{cartCount}} {{copy.piece}}
          <text wx:if="{{cartCouponDiscount > 0}}"> · {{copy.bestCoupon}} ¥{{cartCouponDiscount}}</text>
        </text>
        <view class="quick-cart-price-row">
          <text class="quick-cart-estimate">{{copy.estimate}}</text>
          <text class="quick-cart-price">¥{{cartTotal}}</text>
        </view>
      </view>
    </view>
    <view class="quick-cart-action" bindtap="goCheckout">
      <text class="quick-cart-action-text">{{copy.checkout}}</text>
    </view>
  </view>

  <!-- 质量保证弹窗 -->
  <view wx:if="{{showQualityPopup}}" class="cs-overlay" bindtap="onCloseQualityPopup">
    <view class="cs-popup" catchtap="">
      <view class="cs-header">
      <text class="cs-title">{{copy.quality}}</text>
        <view class="cs-close" bindtap="onCloseQualityPopup"><text class="cs-close-icon">✕</text></view>
      </view>
      <view class="quality-item"><text class="quality-icon">✅</text><view><text class="quality-title">{{copy.genuine}}</text><text class="quality-desc">{{copy.genuineDesc}}</text></view></view>
      <view class="quality-item"><text class="quality-icon">🔄</text><view><text class="quality-title">{{copy.return7}}</text><text class="quality-desc">{{copy.returnDesc}}</text></view></view>
      <view class="quality-item"><text class="quality-icon">🚚</text><view><text class="quality-title">{{copy.transport}}</text><text class="quality-desc">{{copy.transportDesc}}</text></view></view>
      <view class="quality-item"><text class="quality-icon">📋</text><view><text class="quality-title">{{copy.compliance}}</text><text class="quality-desc">{{copy.complianceDesc}}</text></view></view>
      <view class="cs-copy-btn" bindtap="onCloseQualityPopup">
        <text class="cs-copy-text">{{copy.know}}</text>
      </view>
    </view>
  </view>

</view>
