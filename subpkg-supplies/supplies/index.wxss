/* pages/supplies/index.wxss — 农资商城首页样式 */

.page {
  display: flex;
  flex-direction: column;
  height: 100vh;
  background: #F6F8F3;
  box-sizing: border-box;
}

/* ===== 头部 ===== */
.sup-header {
  background: linear-gradient(160deg, #BF641A, #FF8F00);
  flex-shrink: 0;
  padding-left: 28rpx;
  padding-right: 28rpx;
  padding-bottom: 20rpx;
}

.topbar {
  padding-top: 10rpx;
  padding-bottom: 4rpx;
}

.page-title {
  font-size: 34rpx;
  font-weight: 800;
  color: #ffffff;
}

.cart-btn {
  position: relative;
  width: 80rpx;
  height: 80rpx;
  background: rgba(255, 255, 255, 0.25);
  border-radius: 50%;
  display: flex;
  align-items: center;
  justify-content: center;
  flex-shrink: 0;
}

.cart-icon {
  font-size: 36rpx;
}

.cart-badge {
  position: absolute;
  top: -4rpx;
  right: -4rpx;
  min-width: 32rpx;
  height: 32rpx;
  background: #D6453D;
  border-radius: 16rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  border: 3rpx solid #BF641A;
  padding: 0 6rpx;
}

.cart-badge-text {
  color: #ffffff;
  font-size: 18rpx;
  font-weight: 700;
}

.search-row {
  display: flex;
  flex-direction: row;
  align-items: center;
  gap: 16rpx;
  margin-top: 16rpx;
}

.search-bar {
  flex: 1;
  background: #ffffff;
  border-radius: 999rpx;
  padding: 16rpx 28rpx;
  display: flex;
  flex-direction: row;
  align-items: center;
  gap: 12rpx;
}

.search-icon { font-size: 28rpx; flex-shrink: 0; }

.search-input {
  flex: 1;
  font-size: 28rpx;
  color: #18231A;
  height: 56rpx;
  line-height: 56rpx;
}

.search-clear {
  flex-shrink: 0;
  padding: 0 8rpx;
  display: flex;
  align-items: center;
  justify-content: center;
}

.search-placeholder {
  font-size: 24rpx;
  color: #8A948B;
}

/* ===== 滚动区 ===== */
.scroll-content {
  flex: 1;
  height: 0;
}

/* ===== 分类 ===== */
.cats-section {
  background: #ffffff;
  display: flex;
  flex-direction: row;
  justify-content: space-around;
  padding: 28rpx 8rpx;
  margin-bottom: 16rpx;
}

.cat-item {
  display: flex;
  flex-direction: column;
  align-items: center;
  gap: 10rpx;
}

.cat-icon-wrap {
  width: 88rpx;
  height: 88rpx;
  border-radius: 22rpx;
  display: flex;
  align-items: center;
  justify-content: center;
}

.cat-icon { font-size: 44rpx; }

.cat-name {
  font-size: 22rpx;
  color: #58655B;
  font-weight: 600;
}

.cat-name-on {
  color: #B9852F;
}

/* ===== 横幅 ===== */
.banners-row {
  display: flex;
  flex-direction: row;
  gap: 20rpx;
  padding: 0 28rpx;
  margin-bottom: 16rpx;
}

.coupon-entry {
  margin: 0 28rpx 16rpx;
  min-height: 92rpx;
  padding: 16rpx 22rpx;
  display: flex;
  align-items: center;
  box-sizing: border-box;
  background: #FFFFFF;
  border-left: 6rpx solid #B74232;
  border-radius: 10rpx;
}

.coupon-entry-mark {
  width: 58rpx;
  height: 58rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  flex-shrink: 0;
  color: #FFFFFF;
  background: #B74232;
  border-radius: 8rpx;
  font-size: 26rpx;
  font-weight: 800;
}

.coupon-entry-copy { flex: 1; min-width: 0; margin-left: 18rpx; display: flex; flex-direction: column; }
.coupon-entry-title { color: #263129; font-size: 27rpx; font-weight: 800; }
.coupon-entry-sub { margin-top: 3rpx; color: #79827B; font-size: 21rpx; }
.coupon-entry-arrow { color: #A3AAA5; font-size: 40rpx; }
.price-line { display: flex; align-items: baseline; gap: 8rpx; }
.prod-price-old { color: #999F9B; font-size: 19rpx; text-decoration: line-through; }
.promo-label { align-self: flex-start; max-width: 190rpx; margin-bottom: 4rpx; padding: 2rpx 8rpx; overflow: hidden; color: #A5362D; background: #FFF0E9; border-radius: 4rpx; font-size: 18rpx; line-height: 28rpx; white-space: nowrap; text-overflow: ellipsis; }

.banner {
  flex: 1;
  border-radius: 22rpx;
  padding: 24rpx 20rpx;
  display: flex;
  flex-direction: column;
  gap: 6rpx;
}

.banner-spring { background: linear-gradient(135deg, #81C784, #2F7D4B); }
.banner-cert   { background: linear-gradient(135deg, #FFD54F, #BF641A); }

.banner-tag {
  font-size: 18rpx;
  color: rgba(255, 255, 255, 0.85);
  background: rgba(255, 255, 255, 0.2);
  border-radius: 999rpx;
  padding: 2rpx 12rpx;
  align-self: flex-start;
}

.banner-title {
  font-size: 28rpx;
  font-weight: 800;
  color: #ffffff;
}

.banner-sub {
  font-size: 22rpx;
  color: rgba(255, 255, 255, 0.82);
}

/* ===== 商品列表头 ===== */
.sec-header {
  display: flex;
  flex-direction: row;
  align-items: center;
  justify-content: space-between;
  padding: 16rpx 28rpx 16rpx;
}

.sec-title {
  font-size: 30rpx;
  font-weight: 800;
  color: #18231A;
}

.sec-more {
  font-size: 24rpx;
  color: #8A948B;
}

/* ===== 商品网格 ===== */
.prod-grid {
  display: flex;
  flex-direction: row;
  flex-wrap: wrap;
  gap: 16rpx;
  padding: 0 28rpx;
}

.prod-card {
  width: 337rpx;
  background: #ffffff;
  border-radius: 22rpx;
  overflow: hidden;
  box-shadow: 0 4rpx 24rpx rgba(33, 61, 42, 0.06);
}

.prod-img {
  height: 220rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  position: relative;
}

.prod-icon { font-size: 96rpx; }

.prod-photo {
  width: 100%;
  height: 100%;
  display: block;
}

.tag {
  position: absolute;
  top: 16rpx;
  left: 16rpx;
  font-size: 18rpx;
  font-weight: 800;
  padding: 4rpx 12rpx;
  border-radius: 8rpx;
  color: #ffffff;
}

.tag-new { background: #FF3B30; }
.tag-hot { background: #D97918; }

.prod-body {
  padding: 16rpx 20rpx 20rpx;
  display: flex;
  flex-direction: column;
  gap: 4rpx;
}

.prod-name {
  font-size: 24rpx;
  font-weight: 700;
  color: #18231A;
  line-height: 1.4;
  display: -webkit-box;
  -webkit-line-clamp: 2;
  -webkit-box-orient: vertical;
  overflow: hidden;
  min-height: 68rpx;
}

.prod-store {
  font-size: 20rpx;
  color: #B9852F;
  margin-top: 4rpx;
  display: block;
}

.prod-spec {
  font-size: 20rpx;
  color: #8A948B;
}

.prod-sold {
  font-size: 20rpx;
  color: #C5CCC5;
}

.prod-bottom {
  display: flex;
  flex-direction: row;
  align-items: center;
  justify-content: space-between;
  margin-top: 8rpx;
}

.prod-price-wrap {
  display: flex;
  flex-direction: column;
  align-items: flex-start;
  gap: 0;
}

.prod-price {
  font-size: 34rpx;
  font-weight: 900;
  color: #FF3B30;
}

.prod-unit {
  font-size: 20rpx;
  color: #8A948B;
}

.add-btn {
  width: 56rpx;
  height: 56rpx;
  background: #B9852F;
  border-radius: 50%;
  display: flex;
  align-items: center;
  justify-content: center;
}

.add-btn-icon {
  color: #ffffff;
  font-size: 36rpx;
  font-weight: 700;
  line-height: 1;
}

.qty-stepper {
  width: 158rpx;
  height: 56rpx;
  display: flex;
  align-items: center;
  justify-content: space-between;
  flex-shrink: 0;
}

.qty-step-btn {
  width: 52rpx;
  height: 52rpx;
  border-radius: 50%;
  background: #B9852F;
  display: flex;
  align-items: center;
  justify-content: center;
}

.qty-step-minus {
  box-sizing: border-box;
  border: 2rpx solid #D9C292;
  background: #ffffff;
}

.qty-step-icon {
  color: #ffffff;
  font-size: 32rpx;
  font-weight: 700;
  line-height: 1;
}

.qty-step-minus .qty-step-icon { color: #8A6A25; }

.qty-step-num {
  width: 46rpx;
  color: #18231A;
  font-size: 25rpx;
  font-weight: 800;
  text-align: center;
}

/* ===== 无商品 ===== */
.empty-tip {
  display: flex;
  flex-direction: column;
  align-items: center;
  padding: 80rpx 0;
  gap: 16rpx;
}

.empty-icon { font-size: 72rpx; }

.empty-text {
  font-size: 28rpx;
  color: #8A948B;
}

.list-bottom { height: 40rpx; }

/* ===== 实时结算栏 ===== */
.quick-cart {
  min-height: 112rpx;
  padding: 14rpx 24rpx calc(14rpx + env(safe-area-inset-bottom));
  box-sizing: border-box;
  border-top: 1rpx solid #E1E7DD;
  background: #ffffff;
  display: flex;
  align-items: center;
  gap: 18rpx;
  flex-shrink: 0;
  box-shadow: 0 -8rpx 24rpx rgba(33, 61, 42, 0.08);
}

.quick-cart-summary {
  min-width: 0;
  flex: 1;
  display: flex;
  align-items: center;
  gap: 16rpx;
}

.quick-cart-icon-wrap {
  position: relative;
  width: 72rpx;
  height: 72rpx;
  border-radius: 50%;
  background: #EEF4E9;
  display: flex;
  align-items: center;
  justify-content: center;
  flex-shrink: 0;
}

.quick-cart-icon { font-size: 34rpx; }

.quick-cart-count {
  position: absolute;
  top: -6rpx;
  right: -8rpx;
  min-width: 30rpx;
  height: 30rpx;
  padding: 0 5rpx;
  box-sizing: border-box;
  border-radius: 15rpx;
  background: #D6453D;
  color: #ffffff;
  font-size: 18rpx;
  font-weight: 700;
  line-height: 30rpx;
  text-align: center;
}

.quick-cart-copy {
  min-width: 0;
  display: flex;
  flex-direction: column;
  gap: 2rpx;
}

.quick-cart-selected {
  color: #667067;
  font-size: 21rpx;
}

.quick-cart-price-row {
  display: flex;
  align-items: baseline;
  gap: 8rpx;
}

.quick-cart-estimate {
  color: #8A948B;
  font-size: 20rpx;
}

.quick-cart-price {
  color: #D6453D;
  font-size: 34rpx;
  font-weight: 900;
}

.quick-cart-action {
  width: 190rpx;
  height: 72rpx;
  border-radius: 8rpx;
  background: #2F7D4A;
  display: flex;
  align-items: center;
  justify-content: center;
  flex-shrink: 0;
}

.quick-cart-action-text {
  color: #ffffff;
  font-size: 27rpx;
  font-weight: 800;
}

/* ===== 质量保证弹窗 ===== */
.cs-overlay {
  position: fixed;
  top: 0; left: 0; right: 0; bottom: 0;
  background: rgba(0,0,0,0.5);
  display: flex;
  align-items: flex-end;
  justify-content: center;
  z-index: 999;
}
.cs-popup {
  background: #ffffff;
  border-radius: 40rpx 40rpx 0 0;
  width: 100%;
  padding: 36rpx 36rpx 60rpx;
  display: flex;
  flex-direction: column;
  gap: 32rpx;
}
.cs-header {
  display: flex;
  flex-direction: row;
  align-items: center;
  justify-content: space-between;
}
.cs-title { font-size: 32rpx; font-weight: 800; color: #18231A; }
.cs-close {
  width: 56rpx; height: 56rpx;
  background: #F6F8F3;
  border-radius: 50%;
  display: flex; align-items: center; justify-content: center;
}
.cs-close-icon { font-size: 28rpx; color: #8A948B; }
.quality-item { display: flex; align-items: flex-start; padding: 16rpx 0; border-bottom: 1rpx solid #F6F8F3; }
.quality-icon { font-size: 40rpx; margin-right: 20rpx; margin-top: 4rpx; }
.quality-title { display: block; font-size: 28rpx; font-weight: 600; color: #18231A; margin-bottom: 6rpx; }
.quality-desc  { display: block; font-size: 24rpx; color: #8A948B; }
.cs-copy-btn {
  background: linear-gradient(135deg, #B9852F, #C9973A);
  border-radius: 999rpx;
  padding: 28rpx 0;
  display: flex; align-items: center; justify-content: center;
}
.cs-copy-text { font-size: 30rpx; font-weight: 800; color: #ffffff; }
