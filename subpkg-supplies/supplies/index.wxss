/* pages/supplies/index.wxss — 农资商城首页样式 */

.page {
  display: flex;
  flex-direction: column;
  height: 100vh;
  background: #F5EEE6;
  box-sizing: border-box;
}

/* ===== 头部 ===== */
.sup-header {
  background: linear-gradient(160deg, #E65100, #FF8F00);
  flex-shrink: 0;
  padding-left: 28rpx;
  padding-right: 28rpx;
  padding-bottom: 20rpx;
}

.topbar {
  padding-top: 10rpx;
  padding-bottom: 4rpx;
}

.page-title {
  font-size: 34rpx;
  font-weight: 800;
  color: #ffffff;
}

.cart-btn {
  position: relative;
  width: 80rpx;
  height: 80rpx;
  background: rgba(255, 255, 255, 0.25);
  border-radius: 50%;
  display: flex;
  align-items: center;
  justify-content: center;
  flex-shrink: 0;
}

.cart-icon {
  font-size: 36rpx;
}

.cart-badge {
  position: absolute;
  top: -4rpx;
  right: -4rpx;
  min-width: 32rpx;
  height: 32rpx;
  background: #F5222D;
  border-radius: 16rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  border: 3rpx solid #E65100;
  padding: 0 6rpx;
}

.cart-badge-text {
  color: #ffffff;
  font-size: 18rpx;
  font-weight: 700;
}

.search-row {
  display: flex;
  flex-direction: row;
  align-items: center;
  gap: 16rpx;
  margin-top: 16rpx;
}

.search-bar {
  flex: 1;
  background: #ffffff;
  border-radius: 999rpx;
  padding: 16rpx 28rpx;
  display: flex;
  flex-direction: row;
  align-items: center;
  gap: 12rpx;
}

.search-icon { font-size: 28rpx; flex-shrink: 0; }

.search-input {
  flex: 1;
  font-size: 28rpx;
  color: #1A1A1A;
  height: 56rpx;
  line-height: 56rpx;
}

.search-clear {
  flex-shrink: 0;
  padding: 0 8rpx;
  display: flex;
  align-items: center;
  justify-content: center;
}

.search-placeholder {
  font-size: 24rpx;
  color: #888888;
}

/* ===== 滚动区 ===== */
.scroll-content {
  flex: 1;
  height: 0;
}

/* ===== 分类 ===== */
.cats-section {
  background: #ffffff;
  display: flex;
  flex-direction: row;
  justify-content: space-around;
  padding: 28rpx 8rpx;
  margin-bottom: 16rpx;
}

.cat-item {
  display: flex;
  flex-direction: column;
  align-items: center;
  gap: 10rpx;
}

.cat-icon-wrap {
  width: 88rpx;
  height: 88rpx;
  border-radius: 24rpx;
  display: flex;
  align-items: center;
  justify-content: center;
}

.cat-icon { font-size: 44rpx; }

.cat-name {
  font-size: 22rpx;
  color: #555555;
  font-weight: 600;
}

.cat-name-on {
  color: #C8902E;
}

/* ===== 横幅 ===== */
.banners-row {
  display: flex;
  flex-direction: row;
  gap: 20rpx;
  padding: 0 28rpx;
  margin-bottom: 16rpx;
}

.banner {
  flex: 1;
  border-radius: 28rpx;
  padding: 24rpx 20rpx;
  display: flex;
  flex-direction: column;
  gap: 6rpx;
}

.banner-spring { background: linear-gradient(135deg, #81C784, #2E7D32); }
.banner-cert   { background: linear-gradient(135deg, #FFD54F, #E65100); }

.banner-tag {
  font-size: 18rpx;
  color: rgba(255, 255, 255, 0.85);
  background: rgba(255, 255, 255, 0.2);
  border-radius: 999rpx;
  padding: 2rpx 12rpx;
  align-self: flex-start;
}

.banner-title {
  font-size: 28rpx;
  font-weight: 800;
  color: #ffffff;
}

.banner-sub {
  font-size: 22rpx;
  color: rgba(255, 255, 255, 0.82);
}

/* ===== 商品列表头 ===== */
.sec-header {
  display: flex;
  flex-direction: row;
  align-items: center;
  justify-content: space-between;
  padding: 16rpx 28rpx 16rpx;
}

.sec-title {
  font-size: 30rpx;
  font-weight: 800;
  color: #1A1A1A;
}

.sec-more {
  font-size: 24rpx;
  color: #888888;
}

/* ===== 商品网格 ===== */
.prod-grid {
  display: flex;
  flex-direction: row;
  flex-wrap: wrap;
  gap: 16rpx;
  padding: 0 28rpx;
}

.prod-card {
  width: 337rpx;
  background: #ffffff;
  border-radius: 28rpx;
  overflow: hidden;
  box-shadow: 0 4rpx 24rpx rgba(0, 0, 0, 0.07);
}

.prod-img {
  height: 220rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  position: relative;
}

.prod-icon { font-size: 96rpx; }

.prod-photo {
  width: 100%;
  height: 100%;
  display: block;
}

.tag {
  position: absolute;
  top: 16rpx;
  left: 16rpx;
  font-size: 18rpx;
  font-weight: 800;
  padding: 4rpx 12rpx;
  border-radius: 8rpx;
  color: #ffffff;
}

.tag-new { background: #FF3B30; }
.tag-hot { background: #FF6B00; }

.prod-body {
  padding: 16rpx 20rpx 20rpx;
  display: flex;
  flex-direction: column;
  gap: 4rpx;
}

.prod-name {
  font-size: 24rpx;
  font-weight: 700;
  color: #1A1A1A;
  line-height: 1.4;
  display: -webkit-box;
  -webkit-line-clamp: 2;
  -webkit-box-orient: vertical;
  overflow: hidden;
  min-height: 68rpx;
}

.prod-store {
  font-size: 20rpx;
  color: #C8902E;
  margin-top: 4rpx;
  display: block;
}

.prod-spec {
  font-size: 20rpx;
  color: #888888;
}

.prod-sold {
  font-size: 20rpx;
  color: #BBBBBB;
}

.prod-bottom {
  display: flex;
  flex-direction: row;
  align-items: center;
  justify-content: space-between;
  margin-top: 8rpx;
}

.prod-price-wrap {
  display: flex;
  flex-direction: row;
  align-items: baseline;
  gap: 2rpx;
}

.prod-price {
  font-size: 34rpx;
  font-weight: 900;
  color: #FF3B30;
}

.prod-unit {
  font-size: 20rpx;
  color: #888888;
}

.add-btn {
  width: 56rpx;
  height: 56rpx;
  background: #C8902E;
  border-radius: 50%;
  display: flex;
  align-items: center;
  justify-content: center;
}

.add-btn-icon {
  color: #ffffff;
  font-size: 36rpx;
  font-weight: 700;
  line-height: 1;
}

/* ===== 无商品 ===== */
.empty-tip {
  display: flex;
  flex-direction: column;
  align-items: center;
  padding: 80rpx 0;
  gap: 16rpx;
}

.empty-icon { font-size: 72rpx; }

.empty-text {
  font-size: 28rpx;
  color: #888888;
}

.list-bottom { height: 40rpx; }
