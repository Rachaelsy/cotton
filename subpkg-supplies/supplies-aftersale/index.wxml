<!-- pages/supplies-aftersale/index.wxml — 售后申请页 -->
<view class="page">

  <!-- 顶部导航 -->
  <view class="as-header" style="padding-top: {{statusBarHeight}}px">
    <view class="as-topbar" style="padding-right: {{capsuleSafeRight}}px">
      <view class="as-back" bindtap="onBack">
        <text class="as-back-icon">‹</text>
      </view>
      <text class="as-title">{{copy.title}}</text>
      <view style="width: 64rpx"></view>
    </view>
  </view>

  <!-- 可滚动内容 -->
  <scroll-view class="as-scroll" scroll-y>

    <!-- ① 售后类型 -->
    <view class="as-section">
      <view class="as-section-head">
        <text class="as-req">*</text>
        <text class="as-section-title">{{copy.type}}</text>
      </view>
      <view class="type-row">
        <view
          wx:for="{{types}}"
          wx:key="index"
          class="type-item {{aftersaleType === item.value ? 'type-item-on' : ''}}"
          bindtap="onSelectType"
          data-type="{{item.value}}"
        >
          <view class="type-radio {{aftersaleType === item.value ? 'type-radio-on' : ''}}">
            <view wx:if="{{aftersaleType === item.value}}" class="type-radio-dot"></view>
          </view>
          <text class="type-label {{aftersaleType === item.value ? 'type-label-on' : ''}}">{{item.label}}</text>
        </view>
      </view>
    </view>

    <!-- ② 售后原因 -->
    <view class="as-section">
      <view class="as-section-head">
        <text class="as-req">*</text>
        <text class="as-section-title">{{copy.reason}}</text>
      </view>
      <view class="reason-grid">
        <view
          wx:for="{{reasons}}"
          wx:key="index"
          class="reason-item {{reason === item.value ? 'reason-item-on' : ''}}"
          bindtap="onSelectReason"
          data-reason="{{item.value}}"
        >
          <text class="reason-text {{reason === item.value ? 'reason-text-on' : ''}}">{{item.label}}</text>
        </view>
      </view>
    </view>

    <!-- ③ 其他原因输入框（选"其他"时出现） -->
    <view wx:if="{{reason === '其他'}}" class="as-section">
      <view class="as-section-head">
        <text class="as-req">*</text>
        <text class="as-section-title">{{copy.specific}}</text>
      </view>
      <input
        class="other-input"
        placeholder="{{copy.specificPh}}"
        placeholder-class="input-placeholder"
        value="{{otherReason}}"
        bindinput="onOtherReasonInput"
        maxlength="50"
      />
    </view>

    <!-- ④ 问题描述（选填） -->
    <view class="as-section">
      <view class="as-section-head">
        <text class="as-section-title">{{copy.description}}</text>
        <text class="as-optional">{{copy.optional}}</text>
      </view>
      <view class="desc-wrap">
        <textarea
          class="desc-textarea"
          placeholder="{{copy.descPh}}"
          placeholder-class="input-placeholder"
          value="{{description}}"
          bindinput="onDescInput"
          maxlength="200"
          auto-height
        />
        <text class="desc-count">{{description.length}}/200</text>
      </view>
    </view>

    <!-- ⑤ 上传凭证（选填） -->
    <view class="as-section">
      <view class="as-section-head">
        <text class="as-section-title">{{copy.upload}}</text>
        <text class="as-optional">{{copy.uploadOptional}}</text>
      </view>
      <text class="upload-tip">{{copy.uploadTip}}</text>
      <view class="upload-grid">
        <!-- 已上传图片 -->
        <view
          wx:for="{{images}}"
          wx:key="index"
          class="upload-item"
        >
          <image class="upload-img" src="{{item}}" mode="aspectFill"/>
          <view class="upload-del" catchtap="onRemoveImage" data-index="{{index}}">
            <text class="upload-del-icon">✕</text>
          </view>
        </view>
        <!-- 添加按钮 -->
        <view wx:if="{{images.length < 6}}" class="upload-add" bindtap="onChooseImage">
          <text class="upload-add-icon">+</text>
          <text class="upload-add-label">{{copy.uploadImage}}</text>
        </view>
      </view>
    </view>

    <view style="height: 180rpx"></view>
  </scroll-view>

  <!-- 底部提交按钮 -->
  <view class="as-bottom">
    <view
      class="submit-btn {{canSubmit ? 'submit-btn-on' : 'submit-btn-off'}}"
      bindtap="onSubmit"
    >
      <text class="submit-text">{{submitting ? copy.submitting : copy.submit}}</text>
    </view>
  </view>

</view>
