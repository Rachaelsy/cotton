/* pages/supplies-detail/index.wxss — 商品详情页样式 */
.quality-item { display: flex; align-items: flex-start; padding: 16rpx 0; border-bottom: 1rpx solid #F6F8F3; }
.quality-icon { font-size: 40rpx; margin-right: 20rpx; margin-top: 4rpx; }
.quality-title { display: block; font-size: 28rpx; font-weight: 600; color: #18231A; margin-bottom: 6rpx; }
.quality-desc  { display: block; font-size: 24rpx; color: #8A948B; }

.page {
  display: flex;
  flex-direction: column;
  height: 100vh;
  background: #F6F8F3;
  overflow: hidden;
  position: relative;
}

/* ===== 商品图区 ===== */
.prod-hero {
  position: relative;
  height: 520rpx;
  display: flex;
  flex-direction: column;
}

.hero-actions {
  position: absolute;
  top: 0;
  left: 0;
  right: 0;
  padding: 10rpx 28rpx;
  z-index: 10;
}

.hero-back {
  width: 64rpx;
  height: 64rpx;
  background: rgba(0, 0, 0, 0.35);
  border-radius: 50%;
  display: flex;
  align-items: center;
  justify-content: center;
}

.hero-back-icon {
  color: #ffffff;
  font-size: 44rpx;
  font-weight: 300;
}

.hero-img-wrap {
  flex: 1;
  display: flex;
  align-items: center;
  justify-content: center;
}

.hero-icon { font-size: 160rpx; }

.hero-photo {
  width: 100%;
  height: 100%;
  display: block;
}

/* ===== 滚动主体 ===== */
.detail-scroll {
  flex: 1;
  height: 0;
}

/* ===== ② 商品名称区 ===== */
.name-section {
  background: #ffffff;
  padding: 24rpx 28rpx 20rpx;
}

.price-row {
  display: flex;
  flex-direction: row;
  align-items: baseline;
  gap: 2rpx;
  margin-bottom: 16rpx;
}

.price-symbol {
  font-size: 28rpx;
  font-weight: 700;
  color: #FF3B30;
}

.price-main {
  font-size: 60rpx;
  font-weight: 900;
  color: #FF3B30;
  line-height: 1;
}

.price-unit {
  font-size: 24rpx;
  color: #8A948B;
  margin-left: 4rpx;
}

.prod-name {
  font-size: 30rpx;
  font-weight: 800;
  color: #18231A;
  line-height: 1.5;
  margin-bottom: 16rpx;
  display: block;
}

.stats-row {
  display: flex;
  flex-direction: row;
  gap: 28rpx;
  padding-top: 16rpx;
  border-top: 1rpx solid #EAF0E6;
}

.stat-item {
  font-size: 24rpx;
  color: #8A948B;
}

.stat-bold {
  font-weight: 700;
  color: #18231A;
}

/* ===== ③ 商品简介 ===== */
.brief-section {
  background: #FFF8EA;
  margin-top: 2rpx;
  padding: 20rpx 28rpx;
  border-left: 6rpx solid #B9852F;
}

.brief-text {
  font-size: 26rpx;
  color: #5A3A0A;
  line-height: 1.7;
  display: block;
}

/* ===== ④ 送至地址 ===== */
.delivery-card {
  background: #ffffff;
  margin-top: 16rpx;
}

.delivery-row {
  display: flex;
  flex-direction: row;
  align-items: center;
  padding: 20rpx 28rpx;
  gap: 16rpx;
}

.dlv-label {
  font-size: 24rpx;
  color: #8A948B;
  width: 60rpx;
  flex-shrink: 0;
}

.dlv-addr {
  flex: 1;
  font-size: 26rpx;
  color: #18231A;
  font-weight: 600;
}

.dlv-right {
  display: flex;
  flex-direction: row;
  align-items: center;
  gap: 8rpx;
}

.dlv-way {
  font-size: 24rpx;
  color: #58655B;
}

.dlv-arrow {
  font-size: 28rpx;
  color: #C5CCC5;
}

.dlv-tags {
  flex: 1;
  display: flex;
  flex-direction: row;
  flex-wrap: wrap;
  gap: 12rpx;
}

.dlv-tag {
  font-size: 20rpx;
  color: #B9852F;
  background: #FFF8EA;
  padding: 4rpx 14rpx;
  border-radius: 999rpx;
  border: 1rpx solid #E8C87A;
}

.dlv-store-name {
  flex: 1;
  font-size: 26rpx;
  color: #B9852F;
  font-weight: 600;
}

.delivery-line {
  height: 1rpx;
  background: #EAF0E6;
  margin: 0 28rpx;
}

/* ===== 通用区块 ===== */
.section {
  background: #ffffff;
  margin-top: 16rpx;
  padding: 28rpx 28rpx 20rpx;
}

.section-head {
  display: flex;
  flex-direction: row;
  align-items: center;
  justify-content: space-between;
  margin-bottom: 20rpx;
}

.section-title {
  font-size: 28rpx;
  font-weight: 800;
  color: #18231A;
}

.section-more {
  font-size: 24rpx;
  color: #8A948B;
}

/* ===== ⑤ 评价 ===== */
.review-summary {
  display: flex;
  flex-direction: row;
  align-items: center;
  gap: 12rpx;
  padding: 16rpx 0 20rpx;
  border-bottom: 1rpx solid #EAF0E6;
  margin-bottom: 24rpx;
}

.review-score {
  font-size: 52rpx;
  font-weight: 900;
  color: #D97918;
  line-height: 1;
}

.review-stars {
  display: flex;
  flex-direction: row;
}

.star {
  font-size: 28rpx;
  color: #D97918;
}

.review-pct {
  font-size: 22rpx;
  color: #8A948B;
  margin-left: 4rpx;
}

.review-item {
  padding: 4rpx 0 16rpx;
}

.review-top {
  display: flex;
  flex-direction: row;
  align-items: center;
  gap: 16rpx;
  margin-bottom: 12rpx;
}

.reviewer-avatar {
  width: 60rpx;
  height: 60rpx;
  background: linear-gradient(135deg, #B9852F, #C9973A);
  border-radius: 50%;
  display: flex;
  align-items: center;
  justify-content: center;
  font-size: 26rpx;
  color: #ffffff;
  font-weight: 700;
  flex-shrink: 0;
}

.reviewer-info {
  flex: 1;
  display: flex;
  flex-direction: column;
  gap: 4rpx;
}

.reviewer-name {
  font-size: 26rpx;
  font-weight: 600;
  color: #18231A;
}

.review-stars-row {
  font-size: 22rpx;
  color: #D97918;
}

.review-date {
  font-size: 22rpx;
  color: #C5CCC5;
}

.review-content {
  font-size: 26rpx;
  color: #333333;
  line-height: 1.7;
  display: block;
  margin-bottom: 8rpx;
}

.review-spec {
  font-size: 22rpx;
  color: #B7C0B8;
  display: block;
}

.review-divider {
  height: 1rpx;
  background: #EAF0E6;
  margin: 16rpx 0;
}

.review-reply {
  background: #FFF8EA;
  border-radius: 12rpx;
  padding: 14rpx 18rpx;
  margin-top: 12rpx;
}

.review-reply-text {
  font-size: 22rpx;
  color: #8B6914;
  line-height: 1.6;
}

.review-no-content {
  color: #C5CCC5;
  font-style: italic;
}

.review-empty {
  padding: 32rpx 0 16rpx;
  display: flex;
  align-items: center;
  justify-content: center;
}

.review-empty-text {
  font-size: 24rpx;
  color: #B7C0B8;
}

/* ===== ⑥ 商品介绍：规格 ===== */
.spec-row {
  display: flex;
  flex-direction: row;
  justify-content: space-between;
  padding: 16rpx 0;
  border-bottom: 1rpx solid #EAF0E6;
}

.spec-label {
  font-size: 26rpx;
  color: #8A948B;
}

.spec-val {
  font-size: 26rpx;
  color: #18231A;
  font-weight: 600;
}

.desc-block {
  margin-top: 24rpx;
}

.desc-divider {
  height: 1rpx;
  background: #EAF0E6;
  margin-bottom: 24rpx;
}

.desc-text {
  font-size: 26rpx;
  color: #444444;
  line-height: 1.9;
  white-space: pre-wrap;
  display: block;
}

.desc-placeholder {
  display: flex;
  flex-direction: column;
  align-items: center;
  padding: 40rpx 0 20rpx;
  gap: 12rpx;
}

.desc-placeholder-icon { font-size: 120rpx; }

.desc-placeholder-name {
  font-size: 28rpx;
  font-weight: 700;
  color: #18231A;
}

.desc-placeholder-sub {
  font-size: 22rpx;
  color: #8A948B;
}

/* ===== 底部操作栏 ===== */
.action-bar {
  flex-shrink: 0;
  background: #ffffff;
  border-top: 1rpx solid #EAF0E6;
  padding: 16rpx 24rpx;
  padding-bottom: calc(16rpx + env(safe-area-inset-bottom));
  display: flex;
  flex-direction: row;
  align-items: center;
  gap: 8rpx;
}

.action-icon {
  display: flex;
  flex-direction: column;
  align-items: center;
  gap: 4rpx;
  padding: 0 12rpx;
}

.ai-icon {
  font-size: 40rpx;
  color: #58655B;
}

.icon-fav {
  color: #FF3B30;
}

.ai-label {
  font-size: 18rpx;
  color: #8A948B;
}

.action-divider {
  width: 1rpx;
  height: 64rpx;
  background: #EAF0E6;
  flex-shrink: 0;
  margin: 0 4rpx;
}

.btn-cart {
  flex: 1;
  background: #FFF8EA;
  border: 3rpx solid #B9852F;
  border-radius: 999rpx;
  padding: 20rpx 0;
  display: flex;
  align-items: center;
  justify-content: center;
}

.btn-buy {
  flex: 1;
  background: linear-gradient(135deg, #D97918, #FF3B30);
  border-radius: 999rpx;
  padding: 20rpx 0;
  display: flex;
  align-items: center;
  justify-content: center;
}

.btn-cart .btn-text {
  font-size: 26rpx;
  font-weight: 800;
  color: #B9852F;
}

.btn-buy .btn-text {
  font-size: 26rpx;
  font-weight: 800;
  color: #ffffff;
}

/* ===== 客服弹窗 ===== */
.cs-overlay {
  position: absolute;
  top: 0;
  left: 0;
  right: 0;
  bottom: 0;
  background: rgba(0, 0, 0, 0.5);
  display: flex;
  align-items: flex-end;
  justify-content: center;
  z-index: 999;
}

.cs-popup {
  background: #ffffff;
  border-radius: 40rpx 40rpx 0 0;
  width: 100%;
  padding: 36rpx 36rpx 60rpx;
  display: flex;
  flex-direction: column;
  gap: 32rpx;
}

.cs-header {
  display: flex;
  flex-direction: row;
  align-items: center;
  justify-content: space-between;
}

.cs-title {
  font-size: 32rpx;
  font-weight: 800;
  color: #18231A;
}

.cs-close {
  width: 56rpx;
  height: 56rpx;
  background: #F6F8F3;
  border-radius: 50%;
  display: flex;
  align-items: center;
  justify-content: center;
}

.cs-close-icon {
  font-size: 28rpx;
  color: #8A948B;
}

.cs-avatar-row {
  display: flex;
  flex-direction: row;
  align-items: center;
  gap: 24rpx;
}

.cs-avatar {
  width: 96rpx;
  height: 96rpx;
  background: linear-gradient(135deg, #B9852F, #C9973A);
  border-radius: 22rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  flex-shrink: 0;
}

.cs-avatar-icon { font-size: 48rpx; }

.cs-store-info {
  display: flex;
  flex-direction: column;
  gap: 8rpx;
}

.cs-store-name {
  font-size: 30rpx;
  font-weight: 700;
  color: #18231A;
}

.cs-store-sub {
  font-size: 24rpx;
  color: #8A948B;
}

.cs-wechat-card {
  background: #F8F4EF;
  border-radius: 20rpx;
  padding: 28rpx 32rpx;
  display: flex;
  flex-direction: row;
  align-items: center;
  justify-content: space-between;
}

.cs-wechat-label {
  font-size: 26rpx;
  color: #8A948B;
}

.cs-wechat-id {
  font-size: 30rpx;
  font-weight: 700;
  color: #18231A;
  letter-spacing: 1rpx;
}

.cs-copy-btn {
  background: linear-gradient(135deg, #B9852F, #C9973A);
  border-radius: 999rpx;
  padding: 28rpx 0;
  display: flex;
  align-items: center;
  justify-content: center;
}

.cs-copy-text {
  font-size: 30rpx;
  font-weight: 800;
  color: #ffffff;
}

.cs-tip {
  font-size: 22rpx;
  color: #C5CCC5;
  text-align: center;
  display: block;
}

/* ===== 商品不存在 ===== */
.not-found {
  display: flex;
  align-items: center;
  justify-content: center;
  height: 100vh;
}

.not-found-text {
  font-size: 28rpx;
  color: #8A948B;
}
