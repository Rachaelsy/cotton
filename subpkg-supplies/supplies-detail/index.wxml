<!-- pages/supplies-detail/index.wxml — 商品详情页 -->
<view class="page" wx:if="{{product}}">

  <!-- 滚动主体（含图片区，整体可滚动） -->
  <scroll-view class="detail-scroll" scroll-y>

    <!-- ① 商品图片区 -->
    <view class="prod-hero" style="background:{{product.imgBg}}; padding-top:{{statusBarHeight}}px">
      <view class="hero-actions">
        <view class="hero-back" bindtap="onBack">
          <text class="hero-back-icon">‹</text>
        </view>
      </view>
      <view class="hero-img-wrap">
        <block wx:if="{{product.image_url}}">
          <image class="hero-photo" src="{{product.image_url}}" mode="aspectFill"></image>
        </block>
        <block wx:else>
          <text class="hero-icon">{{product.icon || '📦'}}</text>
        </block>
      </view>
    </view>

    <!-- ② 商品名称 + 价格 -->
    <view class="name-section">
      <view class="price-row">
        <text class="price-symbol">¥</text>
        <text class="price-main">{{product.has_promotion ? product.display_price : product.price}}</text>
        <text wx:if="{{product.has_promotion}}" class="price-old">¥{{product.original_price}}</text>
        <text class="price-unit"> / {{product.unit || copy.piece}}</text>
      </view>
      <view wx:if="{{product.has_promotion}}" class="promotion-line">
        <text class="promotion-badge">优惠</text>
        <text class="promotion-name">{{product.promotion_name}}</text>
        <text class="promotion-label">{{product.promotion_label}}</text>
      </view>
      <text class="prod-name">{{product.name}}</text>
      <view class="stats-row">
        <text class="stat-item">{{copy.monthly}} <text class="stat-bold">{{product.sold}}</text></text>
        <text class="stat-item">⭐ <text class="stat-bold">{{product.rating || 5.0}}{{copy.score}}</text></text>
        <text class="stat-item">⚡ <text class="stat-bold">{{copy.ship48}}</text></text>
      </view>
    </view>

    <view class="coupon-row" bindtap="onCoupons">
      <text class="coupon-label">领券</text>
      <text class="coupon-copy">{{product.coupon_count > 0 ? product.coupon_count + ' 张优惠券可领' : '查看店铺优惠券'}}</text>
      <text class="coupon-arrow">›</text>
    </view>

    <!-- ③ 商品简介 -->
    <view class="brief-section" wx:if="{{product.description}}">
      <text class="brief-text">{{product.description}}</text>
    </view>

    <!-- ④ 送至地址 -->
    <view class="delivery-card">
      <view class="delivery-row">
        <text class="dlv-label">{{copy.deliverTo}}</text>
        <text class="dlv-addr">{{copy.address}}</text>
        <view class="dlv-right">
          <text class="dlv-way">{{copy.express}}</text>
          <text class="dlv-arrow">›</text>
        </view>
      </view>
      <view class="delivery-line"></view>
      <view class="delivery-row">
        <text class="dlv-label">{{copy.service}}</text>
        <view class="dlv-tags">
          <text class="dlv-tag">{{copy.return7}}</text>
          <text class="dlv-tag">{{copy.tenfold}}</text>
          <text class="dlv-tag">{{copy.genuine}}</text>
        </view>
      </view>
      <view class="delivery-line"></view>
      <view class="delivery-row" bindtap="onGoStore">
        <text class="dlv-label">{{copy.store}}</text>
        <text class="dlv-store-name">{{product.store || copy.verifiedMerchant}}</text>
        <text class="dlv-arrow">›</text>
      </view>
    </view>

    <!-- ⑤ 买家评价 -->
    <view class="section">
      <view class="section-head">
        <text class="section-title">{{copy.reviews}}</text>
        <text wx:if="{{reviewTotal > 0}}" class="section-more" bindtap="onShowReviews">{{copy.all}}{{reviewTotal}}{{copy.reviewUnit}} ›</text>
      </view>

      <!-- 有评价 -->
      <view wx:if="{{reviews.length > 0}}">
        <view class="review-summary">
          <text class="review-score">{{avgRating}}</text>
          <view class="review-stars">
            <text class="star">★</text><text class="star">★</text><text class="star">★</text><text class="star">★</text><text class="star">★</text>
          </view>
          <text class="review-pct">{{copy.reviewCount}} {{reviewTotal}} {{copy.reviewUnit}}</text>
        </view>
        <view wx:for="{{reviews}}" wx:key="id">
          <view class="review-item">
            <view class="review-top">
              <text class="reviewer-avatar">{{item.farmer_name.slice(0,1) || copy.buyerMark}}</text>
              <view class="reviewer-info">
                <text class="reviewer-name">{{item.farmer_name.length > 1 ? item.farmer_name.slice(0,1) + '**' + item.farmer_name.slice(-1) : item.farmer_name + '**'}}</text>
                <text class="review-stars-row">{{item.rating >= 1 ? '★' : '☆'}}{{item.rating >= 2 ? '★' : '☆'}}{{item.rating >= 3 ? '★' : '☆'}}{{item.rating >= 4 ? '★' : '☆'}}{{item.rating >= 5 ? '★' : '☆'}}</text>
              </view>
              <text class="review-date">{{item.month}}</text>
            </view>
            <text wx:if="{{item.content}}" class="review-content">{{item.content}}</text>
            <text wx:else class="review-content review-no-content">{{copy.noReviewText}}</text>
            <view wx:if="{{item.reply}}" class="review-reply">
              <text class="review-reply-text">🏪 {{copy.reply}}{{item.reply}}</text>
            </view>
          </view>
          <view wx:if="{{index < reviews.length - 1}}" class="review-divider"></view>
        </view>
      </view>

      <!-- 暂无评价 -->
      <view wx:elif="{{reviewsLoaded}}" class="review-empty">
        <text class="review-empty-text">{{copy.noReviews}}</text>
      </view>
    </view>

    <!-- ⑥ 商品介绍（规格 + 详情文字） -->
    <view class="section">
      <text class="section-title">{{copy.intro}}</text>
      <view class="spec-row">
        <text class="spec-label">{{copy.spec}}</text>
        <text class="spec-val">{{product.spec || product.unit || '—'}}</text>
      </view>
      <view class="spec-row">
        <text class="spec-label">{{copy.category}}</text>
        <text class="spec-val">{{product.cat || product.category || '—'}}</text>
      </view>
      <view class="spec-row">
        <text class="spec-label">{{copy.unit}}</text>
        <text class="spec-val">{{product.unit || '—'}}</text>
      </view>
      <view class="spec-row">
        <text class="spec-label">{{copy.stock}}</text>
        <text class="spec-val">{{product.stock || 0}} {{product.unit || copy.piece}}</text>
      </view>
      <view wx:if="{{product.detail}}" class="desc-block">
        <view class="desc-divider"></view>
        <text class="desc-text">{{product.detail}}</text>
      </view>
      <view wx:else class="desc-placeholder">
        <text class="desc-placeholder-icon">{{product.icon || '📦'}}</text>
        <text class="desc-placeholder-name">{{product.name}}</text>
        <text class="desc-placeholder-sub">{{copy.direct}}</text>
      </view>
    </view>

    <view style="height: 180rpx"></view>
  </scroll-view>

  <!-- 底部固定操作栏 -->
  <view class="action-bar">
    <view class="action-icon" bindtap="onGoStore">
      <text class="ai-icon">🏪</text>
      <text class="ai-label">{{copy.store}}</text>
    </view>
    <view class="action-icon" bindtap="onCustomerService">
      <text class="ai-icon">💬</text>
      <text class="ai-label">{{copy.customerService}}</text>
    </view>
    <view class="action-icon" bindtap="onQualityGuarantee">
      <text class="ai-icon">🛡</text>
      <text class="ai-label">{{copy.quality}}</text>
    </view>
    <view class="action-icon" bindtap="onFavorite">
      <text class="ai-icon {{favorited ? 'icon-fav' : ''}}">{{favorited ? '♥' : '♡'}}</text>
      <text class="ai-label">{{copy.favorite}}</text>
    </view>
    <view class="action-divider"></view>
    <view class="btn-cart" bindtap="onAddToCart">
      <text class="btn-text">{{copy.addCart}}</text>
    </view>
    <view class="btn-buy" bindtap="onBuyNow">
      <text class="btn-text">{{copy.buy}}</text>
    </view>
  </view>

  <!-- 质量保证弹窗 -->
  <view wx:if="{{showQualityPopup}}" class="cs-overlay" bindtap="onCloseQualityPopup">
    <view class="cs-popup" catchtap="">
      <view class="cs-header">
        <text class="cs-title">{{copy.quality}}</text>
        <view class="cs-close" bindtap="onCloseQualityPopup"><text class="cs-close-icon">✕</text></view>
      </view>
      <view class="quality-item"><text class="quality-icon">✅</text><view><text class="quality-title">{{copy.genuine}}</text><text class="quality-desc">{{copy.genuineDesc}}</text></view></view>
      <view class="quality-item"><text class="quality-icon">🔄</text><view><text class="quality-title">{{copy.return7}}</text><text class="quality-desc">{{copy.returnDesc}}</text></view></view>
      <view class="quality-item"><text class="quality-icon">🚚</text><view><text class="quality-title">{{copy.transport}}</text><text class="quality-desc">{{copy.transportDesc}}</text></view></view>
      <view class="quality-item"><text class="quality-icon">📋</text><view><text class="quality-title">{{copy.compliance}}</text><text class="quality-desc">{{copy.complianceDesc}}</text></view></view>
      <view class="cs-copy-btn" bindtap="onCloseQualityPopup">
        <text class="cs-copy-text">{{copy.know}}</text>
      </view>
    </view>
  </view>

  <!-- 客服弹窗遮罩 -->
  <view wx:if="{{showCsPopup}}" class="cs-overlay" bindtap="onCloseCsPopup">
    <view class="cs-popup" catchtap="">
      <view class="cs-header">
        <text class="cs-title">{{copy.contact}}</text>
        <view class="cs-close" bindtap="onCloseCsPopup"><text class="cs-close-icon">✕</text></view>
      </view>
      <view class="cs-avatar-row">
        <view class="cs-avatar"><text class="cs-avatar-icon">🏪</text></view>
        <view class="cs-store-info">
          <text class="cs-store-name">{{product.store || copy.verifiedMerchant}}</text>
          <text class="cs-store-sub">{{copy.contactSub}}</text>
        </view>
      </view>
      <view class="cs-wechat-card">
        <text class="cs-wechat-label">{{copy.wechat}}</text>
        <text class="cs-wechat-id">{{product.merchant_wechat}}</text>
      </view>
      <view class="cs-copy-btn" bindtap="onCopyWechat">
        <text class="cs-copy-text">{{copy.copyWechat}}</text>
      </view>
      <text class="cs-tip">{{copy.copyTip}}</text>
    </view>
  </view>

</view>

<!-- 商品不存在时 -->
<view wx:else class="not-found">
  <text class="not-found-text">{{copy.loading}}</text>
</view>
