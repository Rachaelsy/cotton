/* pages/supplies-store/index.wxss */

.page {
  display: flex;
  flex-direction: column;
  height: 100vh;
  background: #F6F8F3;
  overflow: hidden;
}

/* ── Header ── */
.header {
  background: linear-gradient(135deg, #5C3A1E 0%, #8B5E3C 60%, #B9852F 100%);
  padding-left: 28rpx;
  padding-right: 28rpx;
  padding-bottom: 0;
  flex-shrink: 0;
}

.header-row {
  display: flex;
  align-items: center;
  gap: 16rpx;
  padding-bottom: 16rpx;
}

.back-btn {
  width: 64rpx;
  height: 64rpx;
  background: rgba(255,255,255,0.18);
  border-radius: 26rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  flex-shrink: 0;
}

.back-icon {
  font-size: 40rpx;
  color: #fff;
  font-weight: 300;
  line-height: 1;
  margin-top: -4rpx;
}

.store-info {
  flex: 1;
  display: flex;
  flex-direction: column;
  gap: 4rpx;
}

.store-name {
  font-size: 34rpx;
  font-weight: 800;
  color: #fff;
  line-height: 1.2;
}

.store-sub {
  font-size: 22rpx;
  color: rgba(255,255,255,0.65);
}

.cart-btn {
  position: relative;
  width: 64rpx;
  height: 64rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  flex-shrink: 0;
}

.cart-icon {
  font-size: 44rpx;
}

.cart-badge {
  position: absolute;
  top: 0;
  right: 0;
  background: #C93D35;
  color: #fff;
  font-size: 18rpx;
  font-weight: 700;
  min-width: 34rpx;
  height: 34rpx;
  border-radius: 17rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  padding: 0 6rpx;
}

/* ── 分类 Tab ── */
.cat-scroll {
  white-space: nowrap;
  margin: 4rpx -28rpx 0;
}

.cat-row {
  display: flex;
  padding: 0 20rpx;
  gap: 0;
}

.cat-item {
  display: inline-flex;
  align-items: center;
  padding: 16rpx 24rpx 12rpx;
  font-size: 26rpx;
  color: rgba(255,255,255,0.65);
  font-weight: 600;
  border-bottom: 4rpx solid transparent;
  white-space: nowrap;
  flex-shrink: 0;
}

.cat-active {
  color: #fff;
  border-bottom-color: #fff;
}

/* ── 中心提示 ── */
.center-wrap {
  flex: 1;
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
  gap: 20rpx;
}

.empty-icon {
  font-size: 100rpx;
}

.tip-text {
  font-size: 28rpx;
  color: #8A948B;
}

/* ── 商品列表 ── */
.prod-scroll {
  flex: 1;
  height: 0;
}

.prod-grid {
  display: flex;
  flex-wrap: wrap;
  gap: 16rpx;
  padding: 20rpx 20rpx 0;
}

.prod-card {
  width: 337rpx;
  background: #fff;
  border-radius: 16rpx;
  overflow: hidden;
  box-shadow: 0 2rpx 14rpx rgba(33,61,42,0.06);
}

.prod-img-wrap {
  width: 337rpx;
  height: 280rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  overflow: hidden;
}

.prod-photo {
  width: 337rpx;
  height: 280rpx;
}

.prod-icon {
  font-size: 100rpx;
}

.prod-info {
  padding: 16rpx 16rpx 14rpx;
}

.prod-name {
  display: block;
  font-size: 26rpx;
  font-weight: 600;
  color: #18231A;
  line-height: 1.45;
  max-height: 76rpx;
  overflow: hidden;
}

.prod-unit {
  display: block;
  font-size: 22rpx;
  color: #8A948B;
  margin-top: 4rpx;
}

.prod-bottom {
  display: flex;
  align-items: center;
  justify-content: space-between;
  margin-top: 14rpx;
}

.price-wrap {
  display: flex;
  align-items: baseline;
  gap: 2rpx;
}

.price-symbol {
  font-size: 24rpx;
  font-weight: 800;
  color: #B9852F;
}

.price-main {
  font-size: 36rpx;
  font-weight: 900;
  color: #B9852F;
}

.add-btn {
  width: 56rpx;
  height: 56rpx;
  background: linear-gradient(135deg, #B9852F, #C9973A);
  border-radius: 22rpx;
  display: flex;
  align-items: center;
  justify-content: center;
}

.add-icon {
  color: #fff;
  font-size: 40rpx;
  font-weight: 300;
  line-height: 1;
  margin-top: -2rpx;
}
