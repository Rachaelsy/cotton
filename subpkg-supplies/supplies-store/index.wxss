/* pages/supplies-store/index.wxss */

.page {
  display: flex;
  flex-direction: column;
  height: 100vh;
  background: #F6F8F3;
  overflow: hidden;
}

/* ── Header ── */
.header {
  background: linear-gradient(135deg, #5C3A1E 0%, #8B5E3C 60%, #B9852F 100%);
  padding-left: 28rpx;
  padding-right: 28rpx;
  padding-bottom: 0;
  flex-shrink: 0;
}

.header-row {
  display: flex;
  align-items: center;
  gap: 16rpx;
  padding-bottom: 16rpx;
}

.back-btn {
  width: 64rpx;
  height: 64rpx;
  background: rgba(255,255,255,0.18);
  border-radius: 26rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  flex-shrink: 0;
}

.back-icon {
  font-size: 40rpx;
  color: #fff;
  font-weight: 300;
  line-height: 1;
  margin-top: -4rpx;
}

.store-info {
  flex: 1;
  display: flex;
  flex-direction: column;
  gap: 4rpx;
}

.store-name {
  font-size: 34rpx;
  font-weight: 800;
  color: #fff;
  line-height: 1.2;
}

.store-sub {
  font-size: 22rpx;
  color: rgba(255,255,255,0.65);
}

.cart-btn {
  position: relative;
  width: 64rpx;
  height: 64rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  flex-shrink: 0;
}

.coupon-btn {
  width: 54rpx;
  height: 54rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  flex-shrink: 0;
  color: #7D321F;
  background: #FFE7BA;
  border-radius: 8rpx;
  font-size: 24rpx;
  font-weight: 800;
}

.cart-icon {
  font-size: 44rpx;
}

.cart-badge {
  position: absolute;
  top: 0;
  right: 0;
  background: #C93D35;
  color: #fff;
  font-size: 18rpx;
  font-weight: 700;
  min-width: 34rpx;
  height: 34rpx;
  border-radius: 17rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  padding: 0 6rpx;
}

/* ── 分类 Tab ── */
.cat-scroll {
  white-space: nowrap;
  margin: 4rpx -28rpx 0;
}

.cat-row {
  display: flex;
  padding: 0 20rpx;
  gap: 0;
}

.cat-item {
  display: inline-flex;
  align-items: center;
  padding: 16rpx 24rpx 12rpx;
  font-size: 26rpx;
  color: rgba(255,255,255,0.65);
  font-weight: 600;
  border-bottom: 4rpx solid transparent;
  white-space: nowrap;
  flex-shrink: 0;
}

.cat-active {
  color: #fff;
  border-bottom-color: #fff;
}

/* ── 中心提示 ── */
.center-wrap {
  flex: 1;
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
  gap: 20rpx;
}

.empty-icon {
  font-size: 100rpx;
}

.tip-text {
  font-size: 28rpx;
  color: #8A948B;
}

/* ── 商品列表 ── */
.prod-scroll {
  flex: 1;
  height: 0;
}

.prod-grid {
  display: flex;
  flex-wrap: wrap;
  gap: 16rpx;
  padding: 20rpx 20rpx 0;
}

.prod-card {
  width: 337rpx;
  background: #fff;
  border-radius: 16rpx;
  overflow: hidden;
  box-shadow: 0 2rpx 14rpx rgba(33,61,42,0.06);
}

.prod-img-wrap {
  width: 337rpx;
  height: 280rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  overflow: hidden;
}

.prod-photo {
  width: 337rpx;
  height: 280rpx;
}

.prod-icon {
  font-size: 100rpx;
}

.prod-info {
  padding: 16rpx 16rpx 14rpx;
}

.prod-name {
  display: block;
  font-size: 26rpx;
  font-weight: 600;
  color: #18231A;
  line-height: 1.45;
  max-height: 76rpx;
  overflow: hidden;
}

.prod-unit {
  display: block;
  font-size: 22rpx;
  color: #8A948B;
  margin-top: 4rpx;
}

.prod-bottom {
  display: flex;
  align-items: center;
  justify-content: space-between;
  margin-top: 14rpx;
}

.price-wrap {
  display: flex;
  align-items: baseline;
  gap: 2rpx;
}

.price-symbol {
  font-size: 24rpx;
  font-weight: 800;
  color: #B9852F;
}

.price-main {
  font-size: 36rpx;
  font-weight: 900;
  color: #B9852F;
}

.price-old { margin-left: 7rpx; color: #9AA19B; font-size: 19rpx; text-decoration: line-through; }

.add-btn {
  width: 56rpx;
  height: 56rpx;
  background: linear-gradient(135deg, #B9852F, #C9973A);
  border-radius: 22rpx;
  display: flex;
  align-items: center;
  justify-content: center;
}

.add-icon {
  color: #fff;
  font-size: 40rpx;
  font-weight: 300;
  line-height: 1;
  margin-top: -2rpx;
}

.qty-stepper {
  width: 150rpx;
  height: 56rpx;
  display: flex;
  align-items: center;
  justify-content: space-between;
  flex-shrink: 0;
}

.qty-step-btn {
  width: 50rpx;
  height: 50rpx;
  border-radius: 50%;
  background: #B9852F;
  display: flex;
  align-items: center;
  justify-content: center;
}

.qty-step-minus {
  box-sizing: border-box;
  border: 2rpx solid #D9C292;
  background: #ffffff;
}

.qty-step-icon {
  color: #ffffff;
  font-size: 30rpx;
  font-weight: 700;
  line-height: 1;
}

.qty-step-minus .qty-step-icon { color: #8A6A25; }

.qty-step-num {
  width: 42rpx;
  color: #18231A;
  font-size: 24rpx;
  font-weight: 800;
  text-align: center;
}

.quick-cart {
  min-height: 112rpx;
  padding: 14rpx 24rpx calc(14rpx + env(safe-area-inset-bottom));
  box-sizing: border-box;
  border-top: 1rpx solid #E1E7DD;
  background: #ffffff;
  display: flex;
  align-items: center;
  gap: 18rpx;
  flex-shrink: 0;
  box-shadow: 0 -8rpx 24rpx rgba(33, 61, 42, 0.08);
}

.quick-cart-summary {
  min-width: 0;
  flex: 1;
  display: flex;
  align-items: center;
  gap: 16rpx;
}

.quick-cart-icon-wrap {
  position: relative;
  width: 72rpx;
  height: 72rpx;
  border-radius: 50%;
  background: #EEF4E9;
  display: flex;
  align-items: center;
  justify-content: center;
  flex-shrink: 0;
}

.quick-cart-icon { font-size: 34rpx; }

.quick-cart-count {
  position: absolute;
  top: -6rpx;
  right: -8rpx;
  min-width: 30rpx;
  height: 30rpx;
  padding: 0 5rpx;
  box-sizing: border-box;
  border-radius: 15rpx;
  background: #D6453D;
  color: #ffffff;
  font-size: 18rpx;
  font-weight: 700;
  line-height: 30rpx;
  text-align: center;
}

.quick-cart-copy {
  min-width: 0;
  display: flex;
  flex-direction: column;
  gap: 2rpx;
}

.quick-cart-selected { color: #667067; font-size: 21rpx; }
.quick-cart-price-row { display: flex; align-items: baseline; gap: 8rpx; }
.quick-cart-estimate { color: #8A948B; font-size: 20rpx; }
.quick-cart-price { color: #D6453D; font-size: 34rpx; font-weight: 900; }

.quick-cart-action {
  width: 190rpx;
  height: 72rpx;
  border-radius: 8rpx;
  background: #2F7D4A;
  display: flex;
  align-items: center;
  justify-content: center;
  flex-shrink: 0;
}

.quick-cart-action-text { color: #ffffff; font-size: 27rpx; font-weight: 800; }
