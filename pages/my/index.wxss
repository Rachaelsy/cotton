/* pages/my/index.wxss — 我的 */

.page {
  display: flex;
  flex-direction: column;
  height: 100vh;
  background: #F6F8F3;
}

/* ===== 顶部渐变 ===== */
.my-header {
  background: linear-gradient(180deg, #D0E8F5 0%, #E8DFD0 100%);
  padding-left: 28rpx;
  padding-right: 28rpx;
  padding-bottom: 28rpx;
  flex-shrink: 0;
}

.header-topbar {
  display: flex;
  flex-direction: row;
  justify-content: flex-end;
  padding-top: 10rpx;
  padding-bottom: 12rpx;
}

.settings-btn {
  width: 64rpx;
  height: 64rpx;
  background: rgba(255, 255, 255, 0.7);
  border-radius: 50%;
  display: flex;
  align-items: center;
  justify-content: center;
}

.settings-icon { font-size: 36rpx; }

/* ===== 用户卡片 ===== */
.user-card {
  background: rgba(255, 255, 255, 0.88);
  border-radius: 26rpx;
  padding: 28rpx;
  box-shadow: 0 4rpx 24rpx rgba(33, 61, 42, 0.06);
}

.uc-top {
  display: flex;
  flex-direction: row;
  align-items: center;
  gap: 20rpx;
  margin-bottom: 24rpx;
}

.uc-avatar {
  width: 100rpx;
  height: 100rpx;
  background: linear-gradient(135deg, #F5A623, #E8901A);
  border-radius: 50%;
  display: flex;
  align-items: center;
  justify-content: center;
  flex-shrink: 0;
}

.uc-avatar-text {
  font-size: 44rpx;
  font-weight: 800;
  color: #ffffff;
}

.uc-info { flex: 1; }

.uc-name-row {
  display: flex;
  flex-direction: row;
  align-items: center;
  gap: 12rpx;
  margin-bottom: 12rpx;
}

.uc-name {
  font-size: 36rpx;
  font-weight: 800;
  color: #18231A;
}

.verified-chip {
  background: #E8F5E9;
  border-radius: 999rpx;
  padding: 4rpx 16rpx;
}

.verified-text {
  font-size: 20rpx;
  color: #2F8A52;
  font-weight: 700;
}

.uc-tags {
  display: flex;
  flex-direction: row;
  gap: 10rpx;
  flex-wrap: wrap;
}

.uc-tag {
  background: rgba(200, 144, 46, 0.12);
  border-radius: 999rpx;
  padding: 4rpx 16rpx;
}

.uc-tag-text {
  font-size: 22rpx;
  color: #B9852F;
  font-weight: 600;
}

.uc-arr {
  font-size: 40rpx;
  color: #C5CCC5;
  flex-shrink: 0;
}

/* 统计 */
.uc-stats {
  display: flex;
  flex-direction: row;
  align-items: center;
  padding-top: 24rpx;
  border-top: 1rpx solid #EAF0E6;
}

.uc-stat {
  flex: 1;
  display: flex;
  flex-direction: column;
  align-items: center;
  gap: 6rpx;
}

.uc-stat-val-row {
  display: flex;
  flex-direction: row;
  align-items: baseline;
  gap: 4rpx;
}

.uc-stat-val {
  font-size: 40rpx;
  font-weight: 800;
  color: #18231A;
  line-height: 1;
}

.uc-stat-unit {
  font-size: 20rpx;
  color: #8A948B;
}

.uc-stat-label {
  font-size: 22rpx;
  color: #8A948B;
}

.uc-divider {
  width: 1rpx;
  height: 48rpx;
  background: #EAF0E6;
}

/* ===== 滚动区 ===== */
.my-scroll {
  flex: 1;
  height: 0;
}

/* ===== 菜单组 ===== */
.menu-group {
  background: rgba(255, 255, 255, 0.95);
  border-radius: 22rpx;
  margin: 24rpx 28rpx 0;
  overflow: hidden;
  box-shadow: 0 4rpx 20rpx rgba(33, 61, 42, 0.045);
}

.menu-item {
  display: flex;
  flex-direction: row;
  align-items: center;
  gap: 20rpx;
  padding: 28rpx;
}

.mi-icon {
  width: 72rpx;
  height: 72rpx;
  border-radius: 20rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  flex-shrink: 0;
}

.mi-icon.blue   { background: #EBF3FB; }
.mi-icon.red    { background: #FDE8EE; }
.mi-icon.orange { background: #FFF3E0; }
.mi-icon.green  { background: #E8F5E9; }

.mi-emoji { font-size: 36rpx; }

.mi-body { flex: 1; }

.mi-title {
  font-size: 30rpx;
  font-weight: 600;
  color: #18231A;
  display: block;
  margin-bottom: 4rpx;
}

.mi-sub {
  font-size: 22rpx;
  color: #8A948B;
  display: block;
}

.mi-right {
  display: flex;
  flex-direction: row;
  align-items: center;
  gap: 8rpx;
  flex-shrink: 0;
}

.mi-verified {
  font-size: 24rpx;
  color: #2F8A52;
  font-weight: 600;
}

.mi-count {
  font-size: 28rpx;
  color: #8A948B;
  font-weight: 600;
}

.mi-badge-warn {
  background: #FFF3E6;
  border-radius: 999rpx;
  padding: 4rpx 16rpx;
}

.mi-badge-text {
  font-size: 22rpx;
  color: #D97918;
  font-weight: 700;
}

.mi-version {
  font-size: 24rpx;
  color: #8A948B;
}

.mi-arr {
  font-size: 36rpx;
  color: #C5CCC5;
}

.mi-div {
  height: 1rpx;
  background: #EAF0E6;
  margin: 0 28rpx;
}

/* ===== 游客卡片 ===== */
.guest-card {
  background: rgba(255, 255, 255, 0.88);
  border-radius: 26rpx;
  padding: 32rpx 28rpx;
  box-shadow: 0 4rpx 24rpx rgba(33, 61, 42, 0.06);
  display: flex;
  flex-direction: column;
  gap: 24rpx;
}

.guest-avatar-wrap {
  display: flex;
  flex-direction: row;
  align-items: center;
  gap: 24rpx;
}

.guest-avatar {
  width: 100rpx;
  height: 100rpx;
  background: #EEE8DF;
  border-radius: 50%;
  display: flex;
  align-items: center;
  justify-content: center;
  flex-shrink: 0;
}

.guest-avatar-icon { font-size: 52rpx; }

.guest-text {
  display: flex;
  flex-direction: column;
  gap: 6rpx;
}

.guest-title {
  font-size: 34rpx;
  font-weight: 800;
  color: #18231A;
}

.guest-sub {
  font-size: 24rpx;
  color: #8A948B;
}

/* 微信登录按钮 */
.wx-login-btn {
  background: #07C160 !important;
  border-radius: 999rpx !important;
  padding: 28rpx 0 !important;
  display: flex !important;
  flex-direction: row !important;
  align-items: center !important;
  justify-content: center !important;
  gap: 12rpx !important;
  border: none !important;
  margin: 0 !important;
}

.wx-btn-icon { font-size: 32rpx; }

.wx-btn-text {
  font-size: 30rpx;
  font-weight: 700;
  color: #ffffff;
}

.phone-login-row {
  display: flex;
  flex-direction: row;
  align-items: center;
  justify-content: center;
  gap: 8rpx;
  padding: 4rpx 0;
}

.phone-login-text {
  font-size: 26rpx;
  color: #8A948B;
}

.phone-login-arr {
  font-size: 26rpx;
  color: #8A948B;
}

/* 未登录时菜单项置灰 */
.item-dim .mi-title { color: #B7C0B8; }
.item-dim .mi-sub   { color: #CCCCCC; }
.item-dim .mi-emoji { opacity: 0.4; }

/* ===== 退出登录 ===== */
.logout-wrap {
  background: rgba(255, 255, 255, 0.95);
  border-radius: 22rpx;
  margin: 20rpx 28rpx 0;
  padding: 32rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  box-shadow: 0 4rpx 20rpx rgba(33, 61, 42, 0.045);
}

.logout-text {
  font-size: 30rpx;
  color: #D6453D;
  font-weight: 600;
}
