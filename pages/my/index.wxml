<!-- pages/my/index.wxml — 我的 -->
<view class="page">

  <!-- 顶部区域 -->
  <view class="my-header" style="padding-top: {{statusBarHeight}}px">
    <view class="header-topbar" style="padding-right: {{capsuleSafeRight}}px">
      <view style="flex: 1"></view>
      <view class="settings-btn" bindtap="onSettings">
        <text class="settings-icon">⚙️</text>
      </view>
    </view>

    <!-- ── 已登录：用户卡片 ── -->
    <view wx:if="{{isLoggedIn}}" class="user-card" bindtap="onProfile">
      <view class="uc-top">
        <view class="uc-avatar">
          <text class="uc-avatar-text">{{userInitial}}</text>
        </view>
        <view class="uc-info">
          <view class="uc-name-row">
            <text class="uc-name">{{userInfo.name}}</text>
            <view wx:if="{{userInfo.verified}}" class="verified-chip">
              <text class="verified-text">{{copy.verified}}</text>
            </view>
          </view>
          <view class="uc-tags">
            <view class="uc-tag" wx:for="{{userInfo.tags}}" wx:key="index">
              <text class="uc-tag-text">{{item}}</text>
            </view>
          </view>
        </view>
        <text class="uc-arr">›</text>
      </view>
      <view class="uc-stats">
        <view class="uc-stat">
          <view class="uc-stat-val-row">
            <text class="uc-stat-val">{{userInfo.landSize || 0}}</text>
            <text class="uc-stat-unit">{{common.mu}}</text>
          </view>
          <text class="uc-stat-label">{{copy.landSize}}</text>
        </view>
        <view class="uc-divider"></view>
        <view class="uc-stat">
          <text class="uc-stat-val">12</text>
          <text class="uc-stat-label">{{copy.orders}}</text>
        </view>
        <view class="uc-divider"></view>
        <view class="uc-stat">
          <text class="uc-stat-val">8</text>
          <text class="uc-stat-label">{{copy.favoritesCount}}</text>
        </view>
      </view>
    </view>

    <!-- ── 未登录：游客卡片 ── -->
    <view wx:else class="guest-card">
      <view class="guest-avatar-wrap">
        <view class="guest-avatar">
          <text class="guest-avatar-icon">👤</text>
        </view>
        <view class="guest-text">
          <text class="guest-title">{{copy.guestTitle}}</text>
          <text class="guest-sub">{{copy.guestSub}}</text>
        </view>
      </view>

      <!-- 微信一键登录 -->
      <button
        class="wx-login-btn"
        open-type="getPhoneNumber"
        bindgetphonenumber="onWxPhoneLogin"
        loading="{{wxLoading}}"
      >
        <text class="wx-btn-icon">🟢</text>
        <text class="wx-btn-text">{{copy.wxLogin}}</text>
      </button>

      <!-- 手机号登录入口 -->
      <view class="phone-login-row" bindtap="onGoPhoneLogin">
        <text class="phone-login-text">{{copy.phoneLogin}}</text>
        <text class="phone-login-arr">›</text>
      </view>
    </view>
  </view>

  <!-- 菜单列表 -->
  <scroll-view class="my-scroll" scroll-y>

    <view class="menu-group">

      <view class="menu-item {{!isLoggedIn ? 'item-dim' : ''}}" bindtap="onRealName">
        <view class="mi-icon blue">
          <text class="mi-emoji">🪪</text>
        </view>
        <view class="mi-body">
          <text class="mi-title">{{copy.realName}}</text>
          <text class="mi-sub">{{copy.realNameSub}}</text>
        </view>
        <view class="mi-right">
          <text wx:if="{{isLoggedIn && userInfo.verified}}" class="mi-verified">{{copy.verified}}</text>
          <text class="mi-arr">›</text>
        </view>
      </view>

      <view class="mi-div"></view>

      <view class="menu-item {{!isLoggedIn ? 'item-dim' : ''}}" bindtap="onFavorites">
        <view class="mi-icon red">
          <text class="mi-emoji">❤️</text>
        </view>
        <view class="mi-body">
          <text class="mi-title">{{copy.favorites}}</text>
          <text class="mi-sub">{{copy.favoritesSub}}</text>
        </view>
        <view class="mi-right">
          <text wx:if="{{favCount > 0}}" class="mi-count">{{favCount}}</text>
          <text class="mi-arr">›</text>
        </view>
      </view>

      <view class="mi-div"></view>

      <view class="menu-item {{!isLoggedIn ? 'item-dim' : ''}}" bindtap="onMyOrders">
        <view class="mi-icon orange">
          <text class="mi-emoji">📋</text>
        </view>
        <view class="mi-body">
          <text class="mi-title">{{copy.myOrders}}</text>
          <text class="mi-sub">{{copy.myOrdersSub}}</text>
        </view>
        <view class="mi-right">
          <view wx:if="{{isLoggedIn && orderCount > 0}}" class="mi-badge-warn">
            <text class="mi-badge-text">{{orderCount}}{{copy.running}}</text>
          </view>
          <text class="mi-arr">›</text>
        </view>
      </view>

      <view class="mi-div"></view>

      <view class="menu-item" bindtap="onLanguage">
        <view class="mi-icon orange">
          <text class="mi-emoji">🌐</text>
        </view>
        <view class="mi-body">
          <text class="mi-title">{{copy.language}}</text>
          <text class="mi-sub">{{copy.languageSub}}</text>
        </view>
        <view class="mi-right">
          <text class="mi-version">{{lang === 'ug' ? 'ئۇيغۇرچە' : '中文'}}</text>
          <text class="mi-arr">›</text>
        </view>
      </view>

      <view class="mi-div"></view>

      <view class="menu-item" bindtap="onAbout">
        <view class="mi-icon blue">
          <text class="mi-emoji">ℹ️</text>
        </view>
        <view class="mi-body">
          <text class="mi-title">{{copy.about}}</text>
          <text class="mi-sub">{{copy.aboutSub}}</text>
        </view>
        <view class="mi-right">
          <text class="mi-version">v1.2.0</text>
          <text class="mi-arr">›</text>
        </view>
      </view>

    </view>

    <!-- 退出登录（仅登录时显示） -->
    <view wx:if="{{isLoggedIn}}" class="logout-wrap" bindtap="onLogout">
      <text class="logout-text">{{copy.logout}}</text>
    </view>

    <view style="height: 40rpx"></view>
  </scroll-view>
  <tab-bar selected="{{2}}" copy="{{tabCopy}}"></tab-bar>
</view>
