<!-- pages/my/index.wxml — 我的 -->
<view class="page">

  <!-- 顶部区域 -->
  <view class="my-header" style="padding-top: {{statusBarHeight}}px">
    <view class="header-topbar">
      <view style="flex: 1"></view>
      <view class="settings-btn" bindtap="onSettings">
        <text class="settings-icon">⚙️</text>
      </view>
    </view>

    <!-- 用户卡片 -->
    <view class="user-card" bindtap="onProfile">
      <view class="uc-top">
        <view class="uc-avatar">
          <text class="uc-avatar-text">{{userInitial}}</text>
        </view>
        <view class="uc-info">
          <view class="uc-name-row">
            <text class="uc-name">{{userInfo.name}}</text>
            <view class="verified-chip">
              <text class="verified-text">✓ 已认证</text>
            </view>
          </view>
          <view class="uc-tags">
            <view class="uc-tag" wx:for="{{userInfo.tags}}" wx:key="index">
              <text class="uc-tag-text">{{item}}</text>
            </view>
          </view>
        </view>
        <text class="uc-arr">›</text>
      </view>

      <view class="uc-stats">
        <view class="uc-stat">
          <view class="uc-stat-val-row">
            <text class="uc-stat-val">486</text>
            <text class="uc-stat-unit">亩</text>
          </view>
          <text class="uc-stat-label">承包面积</text>
        </view>
        <view class="uc-divider"></view>
        <view class="uc-stat">
          <text class="uc-stat-val">12</text>
          <text class="uc-stat-label">累计订单</text>
        </view>
        <view class="uc-divider"></view>
        <view class="uc-stat">
          <text class="uc-stat-val">8</text>
          <text class="uc-stat-label">收藏农机</text>
        </view>
      </view>
    </view>
  </view>

  <!-- 菜单列表 -->
  <scroll-view class="my-scroll" scroll-y>

    <!-- 菜单组 -->
    <view class="menu-group">

      <view class="menu-item" bindtap="onRealName">
        <view class="mi-icon blue">
          <text class="mi-emoji">🪪</text>
        </view>
        <view class="mi-body">
          <text class="mi-title">实名认证</text>
          <text class="mi-sub">享受补贴、贷款等专属权益</text>
        </view>
        <view class="mi-right">
          <text class="mi-verified">✓已认证</text>
          <text class="mi-arr">›</text>
        </view>
      </view>

      <view class="mi-div"></view>

      <view class="menu-item" bindtap="onFavorites">
        <view class="mi-icon red">
          <text class="mi-emoji">❤️</text>
        </view>
        <view class="mi-body">
          <text class="mi-title">我的收藏</text>
          <text class="mi-sub">收藏的农机、农资和服务</text>
        </view>
        <view class="mi-right">
          <text class="mi-count">8</text>
          <text class="mi-arr">›</text>
        </view>
      </view>

      <view class="mi-div"></view>

      <view class="menu-item" bindtap="onMyOrders">
        <view class="mi-icon orange">
          <text class="mi-emoji">📋</text>
        </view>
        <view class="mi-body">
          <text class="mi-title">我的订单</text>
          <text class="mi-sub">查看预约中、进行中、已完成订单</text>
        </view>
        <view class="mi-right">
          <view class="mi-badge-warn">
            <text class="mi-badge-text">2进行中</text>
          </view>
          <text class="mi-arr">›</text>
        </view>
      </view>

      <view class="mi-div"></view>

      <view class="menu-item" bindtap="onAbout">
        <view class="mi-icon blue">
          <text class="mi-emoji">ℹ️</text>
        </view>
        <view class="mi-body">
          <text class="mi-title">关于我们</text>
          <text class="mi-sub">版本信息 · 用户协议 · 联系客服</text>
        </view>
        <view class="mi-right">
          <text class="mi-version">v1.2.0</text>
          <text class="mi-arr">›</text>
        </view>
      </view>

    </view>

    <!-- 退出登录 -->
    <view class="logout-wrap" bindtap="onLogout">
      <text class="logout-text">退出登录</text>
    </view>

    <view style="height: 40rpx"></view>
  </scroll-view>

</view>
