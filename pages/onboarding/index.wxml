<view class="page">
  <view class="nav" style="padding-top:{{statusBarHeight}}px"><text>{{copy.title}}</text></view>
  <scroll-view class="content" scroll-y>
    <view class="hero"><view class="cotton">☁</view><text class="title">{{copy.title}}</text><text class="subtitle">{{copy.subtitle}}</text></view>
    <view class="step-card">
      <view class="step-no">1</view><view class="step-copy"><text class="step-title">{{copy.language}}</text><text class="step-sub">{{copy.languageSub}}</text></view>
      <view class="segments"><view class="segment {{lang==='zh'?'active':''}}" data-lang="zh" bindtap="selectLanguage">{{copy.chinese}}</view><view class="segment {{lang==='ug'?'active':''}}" data-lang="ug" bindtap="selectLanguage">{{copy.uyghur}}</view></view>
    </view>
    <view class="step-card">
      <view class="step-no">2</view><view class="step-copy"><text class="step-title">{{copy.location}}</text><text class="step-sub">{{copy.locationSub}}</text></view>
      <button class="secondary" bindtap="locate">{{located ? copy.located : copy.locate}}</button>
    </view>
    <view class="step-card">
      <view class="step-no">3</view><view class="step-copy"><text class="step-title">{{copy.plot}}</text><text class="step-sub">{{copy.plotSub}}</text></view>
      <button class="primary" loading="{{saving}}" bindtap="createPlot">{{copy.createPlot}}</button>
    </view>
    <button class="skip" disabled="{{saving}}" bindtap="enterHome">{{saving ? copy.saving : copy.enter}}</button>
  </scroll-view>
</view>
