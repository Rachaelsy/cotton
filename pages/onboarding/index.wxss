.page{height:100vh;background:#f5f8f3;color:#183526}.nav{height:88rpx;display:flex;align-items:center;justify-content:center;font-size:32rpx;font-weight:700;background:#fff}.content{height:calc(100vh - 88rpx);box-sizing:border-box;padding:36rpx 32rpx 70rpx}.hero{display:flex;flex-direction:column;align-items:center;padding:22rpx 20rpx 34rpx}.cotton{width:112rpx;height:112rpx;border-radius:56rpx;background:#fff;display:flex;align-items:center;justify-content:center;font-size:64rpx;color:#2c8952;box-shadow:0 10rpx 30rpx rgba(28,78,48,.12)}.title{margin-top:24rpx;font-size:42rpx;font-weight:800}.subtitle{margin-top:12rpx;color:#718077;font-size:26rpx;text-align:center;line-height:1.6}.step-card{position:relative;background:#fff;border:1rpx solid #dfe8df;border-radius:16rpx;padding:30rpx 28rpx 28rpx;margin-bottom:20rpx}.step-no{position:absolute;left:24rpx;top:28rpx;width:46rpx;height:46rpx;border-radius:23rpx;background:#236e43;color:#fff;display:flex;align-items:center;justify-content:center;font-weight:700}.step-copy{padding-left:64rpx;display:flex;flex-direction:column}.step-title{font-size:31rpx;font-weight:700}.step-sub{margin-top:8rpx;color:#78847d;font-size:24rpx;line-height:1.55}.segments{display:grid;grid-template-columns:1fr 1fr;gap:12rpx;margin-top:24rpx;background:#edf2ed;padding:8rpx;border-radius:12rpx}.segment{height:74rpx;display:flex;align-items:center;justify-content:center;font-size:27rpx;font-weight:600;border-radius:8rpx}.segment.active{background:#fff;color:#1f7a46;box-shadow:0 4rpx 14rpx rgba(31,89,50,.12)}button{margin-top:24rpx;border-radius:10rpx;font-size:28rpx;font-weight:700}button::after{border:0}.primary{background:#23864d;color:#fff}.secondary{background:#eaf5ed;color:#237344}.skip{background:transparent;color:#67746c;margin-top:8rpx;font-weight:500}
