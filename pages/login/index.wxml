<!-- pages/login/index.wxml — 登录/注册页 -->
<view class="page">

  <!-- 顶部装饰区 -->
  <view class="hero" style="padding-top: {{statusBarHeight}}px">

    <!-- 返回（非 select 步骤显示） -->
    <view wx:if="{{step !== 'select'}}" class="back-btn" bindtap="goBack">
      <text class="back-icon">‹</text>
    </view>

    <!-- Logo + 品牌 -->
    <view class="logo-wrap">
      <view class="logo-circle">
        <text class="logo-emoji">🌾</text>
      </view>
      <text class="brand-name">棉花智能体</text>
      <text class="brand-sub">智慧棉花管理平台</text>
    </view>
  </view>

  <!-- 白色内容卡 -->
  <scroll-view class="card-scroll" scroll-y>

    <!-- ═══ STEP 1：身份选择 ═══ -->
    <view wx:if="{{step === 'select'}}" class="step-wrap">
      <text class="step-title">农户登录</text>
      <text class="step-sub">棉花种植农户专用平台</text>

      <view class="role-card" bindtap="onSelectRole" data-role="farmer">
        <view class="role-icon-wrap farmer-bg">
          <text class="role-icon">👨‍🌾</text>
        </view>
        <view class="role-info">
          <text class="role-name">农 户</text>
          <text class="role-desc">管理地块、记录农事、购买农资</text>
        </view>
        <text class="role-arr">›</text>
      </view>

    </view>

    <!-- ═══ STEP 2：登录 ═══ -->
    <view wx:if="{{step === 'login'}}" class="step-wrap">
      <view class="role-tag">
        <text class="role-tag-text">{{roleLabel}}</text>
      </view>
      <text class="step-title">欢迎回来</text>

      <!-- 微信一键登录 -->
      <button
        class="wx-login-btn"
        open-type="getPhoneNumber"
        bindgetphonenumber="onWxPhoneLogin"
        loading="{{wxLoading}}"
      >
        <text class="wx-btn-icon">🟢</text>
        <text class="wx-btn-text">微信一键登录</text>
      </button>

      <view class="divider-or">
        <view class="divider-line"></view>
        <text class="divider-text">或手机号登录</text>
        <view class="divider-line"></view>
      </view>

      <text class="step-sub">手机号 + 密码</text>

      <!-- 手机号 -->
      <view class="field-wrap">
        <text class="field-label">手机号</text>
        <view class="input-box">
          <text class="input-prefix">+86</text>
          <input class="field-input" type="number" maxlength="11"
                 placeholder="请输入手机号"
                 value="{{loginPhone}}"
                 data-field="loginPhone" bindinput="onInput" />
        </view>
      </view>

      <!-- 密码 -->
      <view class="field-wrap">
        <text class="field-label">密码</text>
        <view class="input-box">
          <input class="field-input" password="{{!loginPwdVisible}}"
                 placeholder="请输入密码"
                 value="{{loginPwd}}"
                 data-field="loginPwd" bindinput="onInput" />
          <text class="eye-btn" bindtap="toggleLoginPwd">{{loginPwdVisible ? '🙈' : '👁'}}</text>
        </view>
      </view>

      <!-- 登录按钮 -->
      <view class="submit-btn {{loginLoading ? 'loading' : ''}}" bindtap="onLogin">
        <text class="submit-text">{{loginLoading ? '登录中...' : '立即登录'}}</text>
      </view>

      <!-- 切换注册 -->
      <view class="switch-row">
        <text class="switch-text">还没有账号？</text>
        <text class="switch-link" bindtap="goRegister">立即注册</text>
      </view>
    </view>

    <!-- ═══ STEP 3：注册 ═══ -->
    <view wx:if="{{step === 'register'}}" class="step-wrap">
      <view class="role-tag">
        <text class="role-tag-text">{{roleLabel}}</text>
      </view>
      <text class="step-title">创建账号</text>
      <text class="step-sub">填写基础信息完成注册</text>

      <!-- ── 公共字段 ── -->
      <view class="section-title">基本信息</view>

      <view class="field-wrap">
        <text class="field-label">手机号 <text class="required">*</text></text>
        <view class="input-box">
          <text class="input-prefix">+86</text>
          <input class="field-input" type="number" maxlength="11"
                 placeholder="手机号即登录账号"
                 value="{{regPhone}}"
                 data-field="regPhone" bindinput="onInput" />
        </view>
      </view>

      <view class="field-wrap">
        <text class="field-label">真实姓名 <text class="required">*</text></text>
        <view class="input-box">
          <input class="field-input"
                 placeholder="请输入真实姓名"
                 value="{{regRealName}}"
                 data-field="regRealName" bindinput="onInput" />
        </view>
      </view>

      <view class="field-wrap">
        <text class="field-label">设置密码 <text class="required">*</text></text>
        <view class="input-box">
          <input class="field-input" password="{{!regPwdVisible}}"
                 placeholder="6-20位密码"
                 value="{{regPwd}}"
                 data-field="regPwd" bindinput="onInput" />
          <text class="eye-btn" bindtap="toggleRegPwd">{{regPwdVisible ? '🙈' : '👁'}}</text>
        </view>
      </view>

      <view class="field-wrap">
        <text class="field-label">确认密码 <text class="required">*</text></text>
        <view class="input-box">
          <input class="field-input" password="{{!regPwdVisible}}"
                 placeholder="再次输入密码"
                 value="{{regPwdConfirm}}"
                 data-field="regPwdConfirm" bindinput="onInput" />
        </view>
      </view>

      <!-- ── 农户专属字段 ── -->
      <block wx:if="{{role === 'farmer'}}">
        <view class="section-title">农户信息</view>
        <view class="field-wrap">
          <text class="field-label">所在地区 <text class="required">*</text></text>
          <view class="input-box">
            <input class="field-input" placeholder="如：喀什·疏附县"
                   value="{{regLocation}}"
                   data-field="regLocation" bindinput="onInput" />
          </view>
        </view>
        <view class="field-wrap">
          <text class="field-label">承包面积（亩）</text>
          <view class="input-box">
            <input class="field-input" type="digit" placeholder="如：486"
                   value="{{regLandSize}}"
                   data-field="regLandSize" bindinput="onInput" />
          </view>
        </view>
      </block>


      <!-- 注册按钮 -->
      <view class="submit-btn {{regLoading ? 'loading' : ''}}" bindtap="onRegister">
        <text class="submit-text">{{regLoading ? '注册中...' : '完成注册'}}</text>
      </view>

      <view class="switch-row">
        <text class="switch-text">已有账号？</text>
        <text class="switch-link" bindtap="goLogin">立即登录</text>
      </view>

      <view style="height: 40rpx"></view>
    </view>

  </scroll-view>
</view>
