<!-- pages/supplies-pay-success/index.wxml -->
<view class="page">

  <!-- 顶部成功区域 -->
  <view class="hero" style="padding-top: {{statusBarHeight}}px">
    <view class="check-wrap">
      <view class="check-circle">
        <text class="check-icon">✓</text>
      </view>
    </view>
    <text class="success-title">支付成功</text>
    <text class="success-sub">商家已收到您的订单，正在备货中</text>
  </view>

  <!-- 订单摘要卡片 -->
  <view class="summary-card">

    <!-- 商品缩略 -->
    <view class="item-row">
      <view class="item-thumb" style="background: {{firstItem.imgBg || '#FBF5EA'}}">
        <text class="item-thumb-icon">{{firstItem.icon || '📦'}}</text>
      </view>
      <view class="item-info">
        <text class="item-name">{{firstItem.name}}</text>
        <text class="item-more" wx:if="{{moreCount > 0}}">等共 {{moreCount + 1}} 件商品</text>
        <text class="item-spec" wx:else>{{firstItem.spec}}</text>
      </view>
    </view>

    <view class="divider"></view>

    <view class="kv-row">
      <text class="kv-k">订单号</text>
      <view class="kv-no-wrap">
        <text class="kv-v kv-no">{{orderNo}}</text>
        <text class="kv-copy" bindtap="onCopyNo">复制</text>
      </view>
    </view>
    <view class="kv-row">
      <text class="kv-k">实付金额</text>
      <text class="kv-v-red">¥{{totalAmount}}</text>
    </view>
    <view class="kv-row">
      <text class="kv-k">支付方式</text>
      <text class="kv-v">{{payMethodLabel}}</text>
    </view>
    <view class="kv-row">
      <text class="kv-k">下单时间</text>
      <text class="kv-v">{{createTimeStr}}</text>
    </view>
  </view>

  <!-- 操作按钮 -->
  <view class="btn-group">
    <view class="btn-primary" bindtap="onViewOrder">
      <text class="btn-text-white">查看订单</text>
    </view>
    <view class="btn-ghost" bindtap="onHome">
      <text class="btn-text-gray">返回首页</text>
    </view>
  </view>

  <!-- 温馨提示 -->
  <view class="tips-row">
    <text class="tips-text">📌 商家确认发货后，您将收到通知</text>
  </view>

</view>
