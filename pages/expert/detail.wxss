.page { display: flex; flex-direction: column; height: 100vh; background: #F6F8F3; color: #18231A; }
.detail-hero { background: linear-gradient(160deg, #4F4636, #7B6A52); padding: 0 28rpx 34rpx; flex-shrink: 0; }
.detail-topbar { height: 88rpx; display: flex; align-items: center; justify-content: space-between; gap: 16rpx; }
.detail-back, .detail-share { width: 68rpx; height: 64rpx; display: flex; align-items: center; justify-content: center; border-radius: 999rpx; background: rgba(255,255,255,.16); color: #fff; flex-shrink: 0; }
.detail-back { font-size: 52rpx; line-height: 1; }
.detail-share { font-size: 30rpx; font-weight: 900; }
.detail-top-title { flex: 1; min-width: 0; text-align: center; color: #fff; font-size: 32rpx; font-weight: 900; }
.expert-block { display: flex; align-items: center; gap: 20rpx; margin-top: 18rpx; }
.expert-avatar { width: 112rpx; height: 112rpx; border-radius: 22rpx; background: rgba(255,255,255,.18); display: flex; align-items: center; justify-content: center; font-size: 58rpx; flex-shrink: 0; }
.expert-main { flex: 1; min-width: 0; display: flex; flex-direction: column; gap: 8rpx; }
.expert-name { color: #fff; font-size: 36rpx; font-weight: 900; }
.expert-org { color: rgba(255,255,255,.78); font-size: 23rpx; }
.expert-tags { display: flex; gap: 10rpx; flex-wrap: wrap; }
.expert-tag { background: rgba(255,255,255,.18); color: #fff; border-radius: 8rpx; padding: 5rpx 12rpx; font-size: 20rpx; font-weight: 800; }
.detail-scroll { flex: 1; height: 0; }
.course-hero-card, .card { background: #fff; border-radius: 26rpx; margin: 24rpx 28rpx 0; padding: 28rpx; box-shadow: 0 4rpx 20rpx rgba(33,61,42,.05); }
.course-hero-card { display: flex; align-items: center; gap: 18rpx; }
.course-icon { width: 88rpx; height: 88rpx; border-radius: 22rpx; background: linear-gradient(135deg, #F1E2BF, #B9852F); display: flex; align-items: center; justify-content: center; font-size: 46rpx; flex-shrink: 0; }
.course-main { flex: 1; min-width: 0; display: flex; flex-direction: column; gap: 7rpx; }
.course-title { font-size: 30rpx; font-weight: 900; color: #18231A; line-height: 1.35; }
.course-meta { font-size: 22rpx; color: #8A948B; }
.play-btn { flex-shrink: 0; border-radius: 999rpx; background: #B9852F; color: #fff; padding: 13rpx 24rpx; font-size: 24rpx; font-weight: 900; }
.card-title { display: block; border-left: 6rpx solid #B9852F; padding-left: 16rpx; margin-bottom: 18rpx; font-size: 29rpx; font-weight: 900; color: #18231A; }
.card-text { display: block; color: #58655B; font-size: 25rpx; line-height: 1.75; }
.point-row { display: flex; align-items: flex-start; gap: 16rpx; padding: 16rpx 0; border-bottom: 1rpx solid #EAF0E6; }
.point-row:last-child { border-bottom: 0; }
.point-num { width: 42rpx; height: 42rpx; border-radius: 50%; background: #FFF8EA; color: #B9852F; display: flex; align-items: center; justify-content: center; font-size: 22rpx; font-weight: 900; flex-shrink: 0; }
.point-text { flex: 1; color: #333; font-size: 25rpx; line-height: 1.55; font-weight: 700; }
.qa-card { border: 2rpx solid rgba(200,144,46,.25); }
.ask-btn { margin-top: 22rpx; height: 82rpx; border-radius: 20rpx; background: linear-gradient(135deg, #B9852F, #D7A248); color: #fff; display: flex; align-items: center; justify-content: center; font-size: 28rpx; font-weight: 900; }
.bottom-gap { height: 40rpx; }
