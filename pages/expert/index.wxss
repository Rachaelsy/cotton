.page { display: flex; flex-direction: column; height: 100vh; background: #F6F8F3; color: #18231A; }
.exp-hero { background: linear-gradient(160deg, #4F4636, #7B6A52); padding: 0 28rpx 28rpx; flex-shrink: 0; }
.exp-topbar { height: 88rpx; display: flex; align-items: center; justify-content: space-between; gap: 16rpx; }
.exp-back, .exp-ask { width: 68rpx; height: 64rpx; border-radius: 999rpx; background: rgba(255,255,255,.16); color: #fff; display: flex; align-items: center; justify-content: center; flex-shrink: 0; }
.exp-back { font-size: 52rpx; line-height: 1; }
.exp-ask text { font-size: 24rpx; font-weight: 800; }
.exp-title-wrap { flex: 1; min-width: 0; display: flex; flex-direction: column; align-items: center; }
.exp-title { color: #fff; font-size: 36rpx; font-weight: 900; }
.exp-sub { color: rgba(255,255,255,.66); font-size: 18rpx; letter-spacing: 3rpx; }
.exp-slogan { display: block; color: #fff; font-size: 38rpx; font-weight: 900; line-height: 1.35; margin: 16rpx 0 18rpx; }
.exp-stats { display: flex; gap: 18rpx; color: rgba(255,255,255,.86); font-size: 22rpx; font-weight: 700; }
.exp-scroll { flex: 1; height: 0; }
.section { margin: 24rpx 28rpx 0; }
.section-head { display: flex; align-items: center; justify-content: space-between; margin-bottom: 18rpx; }
.section-title { font-size: 30rpx; font-weight: 900; color: #18231A; }
.section-more { font-size: 23rpx; color: #B9852F; font-weight: 800; }
.expert-row { white-space: nowrap; height: 190rpx; }
.expert-card { display: inline-flex; width: 600rpx; height: 170rpx; box-sizing: border-box; align-items: center; gap: 18rpx; background: #fff; border-radius: 22rpx; padding: 22rpx; margin-right: 18rpx; box-shadow: 0 4rpx 20rpx rgba(33,61,42,.05); vertical-align: top; }
.expert-avatar { width: 82rpx; height: 82rpx; display: flex; align-items: center; justify-content: center; background: #EFEBE9; border-radius: 22rpx; font-size: 44rpx; flex-shrink: 0; }
.expert-info { flex: 1; min-width: 0; display: flex; flex-direction: column; gap: 5rpx; }
.expert-name { font-size: 27rpx; font-weight: 900; color: #18231A; }
.expert-org { font-size: 21rpx; color: #8A948B; }
.expert-tags { display: flex; gap: 8rpx; }
.expert-tag { background: #FFF8EA; color: #8A5C20; border-radius: 8rpx; padding: 4rpx 10rpx; font-size: 19rpx; font-weight: 700; }
.expert-online { font-size: 21rpx; color: #9BA49C; font-weight: 800; }
.expert-online.on { color: #2F7D4B; }
.feature-card, .course-card { display: flex; align-items: center; gap: 18rpx; background: #fff; border-radius: 22rpx; padding: 22rpx; margin-bottom: 18rpx; box-shadow: 0 4rpx 20rpx rgba(33,61,42,.05); }
.feature-icon, .course-icon { width: 82rpx; height: 82rpx; border-radius: 22rpx; background: linear-gradient(135deg, #F1E2BF, #B9852F); display: flex; align-items: center; justify-content: center; font-size: 42rpx; flex-shrink: 0; }
.feature-main, .course-main { flex: 1; min-width: 0; display: flex; flex-direction: column; gap: 6rpx; }
.feature-title, .course-title { font-size: 27rpx; font-weight: 900; color: #18231A; line-height: 1.35; }
.feature-meta, .course-meta, .course-desc { font-size: 21rpx; color: #8A948B; line-height: 1.45; }
.feature-play { background: #B9852F; color: #fff; border-radius: 999rpx; padding: 10rpx 20rpx; font-size: 22rpx; font-weight: 900; flex-shrink: 0; }
.category-wrap { background: #fff; margin-top: 20rpx; padding: 18rpx 0; }
.category-scroll { white-space: nowrap; height: 60rpx; }
.category-chip { display: inline-flex; align-items: center; justify-content: center; height: 54rpx; padding: 0 26rpx; margin-left: 18rpx; background: #F6F8F3; border: 2rpx solid #E3E9DE; border-radius: 999rpx; color: #58655B; font-size: 23rpx; font-weight: 800; vertical-align: top; }
.category-chip.on { background: #4F4636; border-color: #4F4636; color: #fff; }
.course-section { margin-top: 20rpx; }
.course-title-row { display: flex; align-items: flex-start; gap: 12rpx; }
.course-title { flex: 1; min-width: 0; }
.course-tag { background: #E8F5E9; color: #2F7D4B; border-radius: 8rpx; padding: 4rpx 10rpx; font-size: 19rpx; font-weight: 900; flex-shrink: 0; }
.course-foot { display: flex; gap: 18rpx; flex-wrap: wrap; color: #A06C28; font-size: 20rpx; font-weight: 800; margin-top: 5rpx; }
.bottom-gap { height: 40rpx; }
