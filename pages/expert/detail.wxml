<view class="page">
  <view class="detail-hero" style="padding-top: {{statusBarHeight}}px">
    <view class="detail-topbar" style="padding-right: {{capsuleSafeRight}}px">
      <view class="detail-back" bindtap="onBack"><text>‹</text></view>
      <text class="detail-top-title">{{isExpertOnly ? copy.expertHome : copy.courseDetail}}</text>
      <view class="detail-share"><text>···</text></view>
    </view>

    <view class="expert-block">
      <text class="expert-avatar">{{expert.avatar}}</text>
      <view class="expert-main">
        <text class="expert-name">{{expert.name}}</text>
        <text class="expert-org">{{expert.org}}</text>
        <view class="expert-tags"><text wx:for="{{expert.tags}}" wx:key="*this" class="expert-tag">{{item}}</text></view>
      </view>
    </view>
  </view>

  <scroll-view class="detail-scroll" scroll-y enhanced show-scrollbar="{{false}}">
    <view wx:if="{{!isExpertOnly}}" class="course-hero-card">
      <view class="course-icon"><text>{{course.icon}}</text></view>
      <view class="course-main">
        <text class="course-title">{{course.title}}</text>
        <text class="course-meta">{{course.category}} · {{course.duration}}</text>
      </view>
      <view class="play-btn" bindtap="onPlay"><text>{{copy.play}}</text></view>
    </view>

    <view class="card">
      <text class="card-title">{{isExpertOnly ? copy.expertIntro : copy.courseIntro}}</text>
      <text class="card-text">{{isExpertOnly ? expert.bio : course.intro}}</text>
    </view>

    <view wx:if="{{!isExpertOnly}}" class="card">
      <text class="card-title">{{copy.points}}</text>
      <view class="point-row" wx:for="{{course.points}}" wx:key="*this">
        <text class="point-num">{{index + 1}}</text>
        <text class="point-text">{{item}}</text>
      </view>
    </view>

    <view class="card qa-card">
      <text class="card-title">{{copy.askTitle}}</text>
      <text class="card-text">{{copy.askDesc}}</text>
      <view class="ask-btn" bindtap="onAsk"><text>{{copy.askAction}}</text></view>
    </view>

    <view class="bottom-gap"></view>
  </scroll-view>
</view>
