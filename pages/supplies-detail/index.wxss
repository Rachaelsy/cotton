/* pages/supplies-detail/index.wxss — 商品详情页样式 */

.page {
  display: flex;
  flex-direction: column;
  min-height: 100vh;
  background: #F5EEE6;
}

/* ===== 商品图区 ===== */
.prod-hero {
  position: relative;
  height: 520rpx;
  display: flex;
  flex-direction: column;
  flex-shrink: 0;
}

.hero-actions {
  display: flex;
  flex-direction: row;
  align-items: center;
  justify-content: space-between;
  padding: 10rpx 28rpx;
  position: absolute;
  left: 0;
  right: 0;
  z-index: 10;
}

.hero-back {
  width: 64rpx;
  height: 64rpx;
  background: rgba(0, 0, 0, 0.35);
  border-radius: 50%;
  display: flex;
  align-items: center;
  justify-content: center;
}

.hero-back-icon {
  color: #ffffff;
  font-size: 44rpx;
  font-weight: 300;
}

.hero-right-btns {
  display: flex;
  flex-direction: row;
  gap: 16rpx;
}

.hero-icon-btn {
  width: 64rpx;
  height: 64rpx;
  background: rgba(0, 0, 0, 0.35);
  border-radius: 50%;
  display: flex;
  align-items: center;
  justify-content: center;
  font-size: 30rpx;
  color: #ffffff;
}

.hero-img-wrap {
  flex: 1;
  display: flex;
  align-items: center;
  justify-content: center;
}

.hero-icon { font-size: 160rpx; }

.hero-pager {
  position: absolute;
  bottom: 24rpx;
  right: 28rpx;
  background: rgba(0, 0, 0, 0.45);
  border-radius: 999rpx;
  padding: 6rpx 18rpx;
}

.pager-text {
  color: #ffffff;
  font-size: 22rpx;
}

/* ===== 滚动主体 ===== */
.detail-scroll {
  flex: 1;
}

/* ===== 价格区 ===== */
.price-section {
  background: #ffffff;
  padding: 24rpx 28rpx 20rpx;
}

.price-row {
  display: flex;
  flex-direction: row;
  align-items: baseline;
  gap: 4rpx;
  margin-bottom: 12rpx;
}

.price-symbol {
  font-size: 28rpx;
  font-weight: 700;
  color: #FF3B30;
}

.price-main {
  font-size: 56rpx;
  font-weight: 900;
  color: #FF3B30;
  line-height: 1;
}

.price-orig {
  font-size: 26rpx;
  color: #888888;
  text-decoration: line-through;
  margin-left: 8rpx;
}

.tags-row {
  display: flex;
  flex-direction: row;
  flex-wrap: wrap;
  gap: 12rpx;
  margin-bottom: 16rpx;
}

.det-tag {
  background: #FFF3E0;
  color: #E65100;
  font-size: 22rpx;
  font-weight: 700;
  padding: 6rpx 16rpx;
  border-radius: 8rpx;
  border: 1rpx solid #FFCC80;
}

.prod-name {
  font-size: 30rpx;
  font-weight: 800;
  color: #1A1A1A;
  line-height: 1.5;
  margin-bottom: 16rpx;
}

.stats-row {
  display: flex;
  flex-direction: row;
  gap: 28rpx;
  padding-top: 16rpx;
  border-top: 1rpx solid #F2EBE0;
}

.stat-item {
  font-size: 24rpx;
  color: #555555;
}

.stat-bold {
  font-weight: 700;
  color: #1A1A1A;
}

/* ===== 各区块通用 ===== */
.section {
  background: #ffffff;
  margin-top: 16rpx;
  padding: 24rpx 28rpx;
}

.section-title {
  font-size: 26rpx;
  font-weight: 700;
  color: #1A1A1A;
  margin-bottom: 20rpx;
  display: block;
}

/* ===== 配送方式 ===== */
.delivery-opts {
  display: flex;
  flex-direction: row;
  gap: 20rpx;
}

.del-opt {
  flex: 1;
  border: 3rpx solid #EEE5D8;
  border-radius: 24rpx;
  padding: 20rpx;
  display: flex;
  flex-direction: column;
  align-items: center;
  gap: 6rpx;
}

.del-opt-on {
  border-color: #C8902E;
  background: #FBF5EA;
}

.del-opt-icon { font-size: 44rpx; }

.del-opt-name {
  font-size: 26rpx;
  font-weight: 700;
  color: #1A1A1A;
}

.del-opt-desc {
  font-size: 20rpx;
  color: #888888;
}

/* ===== 到达时间 ===== */
.eta-row {
  background: #ffffff;
  margin-top: 2rpx;
  padding: 20rpx 28rpx;
  display: flex;
  flex-direction: row;
  align-items: center;
  gap: 16rpx;
}

.eta-label {
  font-size: 26rpx;
  color: #555555;
}

.eta-val {
  font-size: 26rpx;
  font-weight: 700;
  color: #1A1A1A;
}

/* ===== 店铺信息 ===== */
.store-row {
  background: #ffffff;
  margin-top: 16rpx;
  padding: 24rpx 28rpx;
  display: flex;
  flex-direction: row;
  align-items: center;
  gap: 20rpx;
}

.store-icon { font-size: 44rpx; }

.store-info {
  flex: 1;
  display: flex;
  flex-direction: column;
  gap: 4rpx;
}

.store-name {
  font-size: 26rpx;
  font-weight: 700;
  color: #1A1A1A;
}

.store-sub {
  font-size: 22rpx;
  color: #888888;
}

.store-enter {
  font-size: 24rpx;
  color: #C8902E;
  font-weight: 600;
}

/* ===== 规格 ===== */
.spec-row {
  display: flex;
  flex-direction: row;
  justify-content: space-between;
  padding: 16rpx 0;
  border-bottom: 1rpx solid #F2EBE0;
}

.spec-row:last-child { border-bottom: none; }

.spec-label {
  font-size: 26rpx;
  color: #888888;
}

.spec-val {
  font-size: 26rpx;
  color: #1A1A1A;
  font-weight: 600;
}

/* ===== 服务承诺 ===== */
.promise-row {
  background: #FBF5EA;
  margin: 16rpx 28rpx;
  border-radius: 20rpx;
  padding: 20rpx;
  display: flex;
  flex-direction: row;
  align-items: center;
  gap: 16rpx;
}

.promise-icon { font-size: 36rpx; }

.promise-text {
  font-size: 24rpx;
  color: #7A5020;
  line-height: 1.6;
  flex: 1;
}

/* ===== 底部操作栏 ===== */
.action-bar {
  position: fixed;
  bottom: 0;
  left: 0;
  right: 0;
  background: #ffffff;
  border-top: 1rpx solid #F2EBE0;
  padding: 20rpx 28rpx;
  padding-bottom: calc(20rpx + env(safe-area-inset-bottom));
  display: flex;
  flex-direction: row;
  align-items: center;
  gap: 16rpx;
}

.action-icons {
  display: flex;
  flex-direction: row;
  gap: 24rpx;
}

.action-icon {
  display: flex;
  flex-direction: column;
  align-items: center;
  gap: 4rpx;
  position: relative;
}

.ai-icon { font-size: 40rpx; }

.ai-label {
  font-size: 18rpx;
  color: #888888;
}

.action-badge {
  position: absolute;
  top: -6rpx;
  right: -10rpx;
  min-width: 28rpx;
  height: 28rpx;
  background: #F5222D;
  border-radius: 14rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  padding: 0 4rpx;
}

.action-badge-text {
  color: #ffffff;
  font-size: 16rpx;
  font-weight: 700;
}

.action-divider {
  width: 1rpx;
  height: 72rpx;
  background: #F2EBE0;
  flex-shrink: 0;
}

.btn-cart {
  flex: 1;
  background: #FBF5EA;
  border: 3rpx solid #C8902E;
  border-radius: 999rpx;
  padding: 24rpx;
  display: flex;
  align-items: center;
  justify-content: center;
}

.btn-buy {
  flex: 1;
  background: linear-gradient(135deg, #FF6B00, #FF3B30);
  border-radius: 999rpx;
  padding: 24rpx;
  display: flex;
  align-items: center;
  justify-content: center;
}

.btn-cart .btn-text {
  font-size: 26rpx;
  font-weight: 800;
  color: #C8902E;
}

.btn-buy .btn-text {
  font-size: 26rpx;
  font-weight: 800;
  color: #ffffff;
}

/* ===== 商品不存在 ===== */
.not-found {
  display: flex;
  align-items: center;
  justify-content: center;
  height: 100vh;
}

.not-found-text {
  font-size: 28rpx;
  color: #888888;
}
