/* pages/supplies-detail/index.wxss — 商品详情页样式 */

.page {
  display: flex;
  flex-direction: column;
  height: 100vh;
  background: #F5EEE6;
  overflow: hidden;
}

/* ===== 商品图区 ===== */
.prod-hero {
  position: relative;
  height: 520rpx;
  display: flex;
  flex-direction: column;
  flex-shrink: 0;
}

.hero-actions {
  position: absolute;
  top: 0;
  left: 0;
  right: 0;
  padding: 10rpx 28rpx;
  z-index: 10;
}

.hero-back {
  width: 64rpx;
  height: 64rpx;
  background: rgba(0, 0, 0, 0.35);
  border-radius: 50%;
  display: flex;
  align-items: center;
  justify-content: center;
}

.hero-back-icon {
  color: #ffffff;
  font-size: 44rpx;
  font-weight: 300;
}

.hero-img-wrap {
  flex: 1;
  display: flex;
  align-items: center;
  justify-content: center;
}

.hero-icon { font-size: 160rpx; }

.hero-photo {
  width: 100%;
  height: 100%;
  display: block;
}

/* ===== 滚动主体 ===== */
.detail-scroll {
  flex: 1;
  height: 0;
}

/* ===== ② 商品名称区 ===== */
.name-section {
  background: #ffffff;
  padding: 24rpx 28rpx 20rpx;
}

.price-row {
  display: flex;
  flex-direction: row;
  align-items: baseline;
  gap: 2rpx;
  margin-bottom: 16rpx;
}

.price-symbol {
  font-size: 28rpx;
  font-weight: 700;
  color: #FF3B30;
}

.price-main {
  font-size: 60rpx;
  font-weight: 900;
  color: #FF3B30;
  line-height: 1;
}

.price-unit {
  font-size: 24rpx;
  color: #888888;
  margin-left: 4rpx;
}

.prod-name {
  font-size: 30rpx;
  font-weight: 800;
  color: #1A1A1A;
  line-height: 1.5;
  margin-bottom: 16rpx;
  display: block;
}

.stats-row {
  display: flex;
  flex-direction: row;
  gap: 28rpx;
  padding-top: 16rpx;
  border-top: 1rpx solid #F2EBE0;
}

.stat-item {
  font-size: 24rpx;
  color: #888888;
}

.stat-bold {
  font-weight: 700;
  color: #1A1A1A;
}

/* ===== ③ 商品简介 ===== */
.brief-section {
  background: #FBF5EA;
  margin-top: 2rpx;
  padding: 20rpx 28rpx;
  border-left: 6rpx solid #C8902E;
}

.brief-text {
  font-size: 26rpx;
  color: #5A3A0A;
  line-height: 1.7;
  display: block;
}

/* ===== ④ 送至地址 ===== */
.delivery-card {
  background: #ffffff;
  margin-top: 16rpx;
}

.delivery-row {
  display: flex;
  flex-direction: row;
  align-items: center;
  padding: 20rpx 28rpx;
  gap: 16rpx;
}

.dlv-label {
  font-size: 24rpx;
  color: #888888;
  width: 60rpx;
  flex-shrink: 0;
}

.dlv-addr {
  flex: 1;
  font-size: 26rpx;
  color: #1A1A1A;
  font-weight: 600;
}

.dlv-right {
  display: flex;
  flex-direction: row;
  align-items: center;
  gap: 8rpx;
}

.dlv-way {
  font-size: 24rpx;
  color: #555555;
}

.dlv-arrow {
  font-size: 28rpx;
  color: #BBBBBB;
}

.dlv-tags {
  flex: 1;
  display: flex;
  flex-direction: row;
  flex-wrap: wrap;
  gap: 12rpx;
}

.dlv-tag {
  font-size: 20rpx;
  color: #C8902E;
  background: #FBF5EA;
  padding: 4rpx 14rpx;
  border-radius: 999rpx;
  border: 1rpx solid #E8C87A;
}

.dlv-store-name {
  flex: 1;
  font-size: 26rpx;
  color: #C8902E;
  font-weight: 600;
}

.delivery-line {
  height: 1rpx;
  background: #F2EBE0;
  margin: 0 28rpx;
}

/* ===== 通用区块 ===== */
.section {
  background: #ffffff;
  margin-top: 16rpx;
  padding: 28rpx 28rpx 20rpx;
}

.section-head {
  display: flex;
  flex-direction: row;
  align-items: center;
  justify-content: space-between;
  margin-bottom: 20rpx;
}

.section-title {
  font-size: 28rpx;
  font-weight: 800;
  color: #1A1A1A;
}

.section-more {
  font-size: 24rpx;
  color: #888888;
}

/* ===== ⑤ 评价 ===== */
.review-summary {
  display: flex;
  flex-direction: row;
  align-items: center;
  gap: 12rpx;
  padding: 16rpx 0 20rpx;
  border-bottom: 1rpx solid #F2EBE0;
  margin-bottom: 24rpx;
}

.review-score {
  font-size: 52rpx;
  font-weight: 900;
  color: #FF6B00;
  line-height: 1;
}

.review-stars {
  display: flex;
  flex-direction: row;
}

.star {
  font-size: 28rpx;
  color: #FF6B00;
}

.review-pct {
  font-size: 22rpx;
  color: #888888;
  margin-left: 4rpx;
}

.review-item {
  padding: 4rpx 0 16rpx;
}

.review-top {
  display: flex;
  flex-direction: row;
  align-items: center;
  gap: 16rpx;
  margin-bottom: 12rpx;
}

.reviewer-avatar {
  width: 60rpx;
  height: 60rpx;
  background: linear-gradient(135deg, #C8902E, #D4A043);
  border-radius: 50%;
  display: flex;
  align-items: center;
  justify-content: center;
  font-size: 26rpx;
  color: #ffffff;
  font-weight: 700;
  flex-shrink: 0;
}

.reviewer-info {
  flex: 1;
  display: flex;
  flex-direction: column;
  gap: 4rpx;
}

.reviewer-name {
  font-size: 26rpx;
  font-weight: 600;
  color: #1A1A1A;
}

.review-stars-row {
  font-size: 22rpx;
  color: #FF6B00;
}

.review-date {
  font-size: 22rpx;
  color: #BBBBBB;
}

.review-content {
  font-size: 26rpx;
  color: #333333;
  line-height: 1.7;
  display: block;
  margin-bottom: 8rpx;
}

.review-spec {
  font-size: 22rpx;
  color: #AAAAAA;
  display: block;
}

.review-divider {
  height: 1rpx;
  background: #F2EBE0;
  margin: 16rpx 0;
}

/* ===== ⑥ 店内推荐 ===== */
.store-scroll {
  width: 100%;
}

.store-prods-row {
  display: flex;
  flex-direction: row;
  gap: 20rpx;
  padding-bottom: 4rpx;
}

.store-prod-card {
  width: 200rpx;
  flex-shrink: 0;
  display: flex;
  flex-direction: column;
  gap: 8rpx;
}

.store-prod-img {
  width: 200rpx;
  height: 200rpx;
  border-radius: 16rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  overflow: hidden;
}

.store-prod-photo {
  width: 100%;
  height: 100%;
  display: block;
}

.store-prod-icon { font-size: 72rpx; }

.store-prod-name {
  font-size: 22rpx;
  color: #1A1A1A;
  line-height: 1.4;
  display: -webkit-box;
  -webkit-line-clamp: 2;
  -webkit-box-orient: vertical;
  overflow: hidden;
}

.store-prod-price {
  font-size: 26rpx;
  font-weight: 800;
  color: #FF3B30;
}

/* ===== ⑦ 商品介绍：规格 ===== */
.spec-row {
  display: flex;
  flex-direction: row;
  justify-content: space-between;
  padding: 16rpx 0;
  border-bottom: 1rpx solid #F2EBE0;
}

.spec-label {
  font-size: 26rpx;
  color: #888888;
}

.spec-val {
  font-size: 26rpx;
  color: #1A1A1A;
  font-weight: 600;
}

.desc-block {
  margin-top: 24rpx;
}

.desc-divider {
  height: 1rpx;
  background: #F2EBE0;
  margin-bottom: 24rpx;
}

.desc-text {
  font-size: 26rpx;
  color: #444444;
  line-height: 1.9;
  white-space: pre-wrap;
  display: block;
}

.desc-placeholder {
  display: flex;
  flex-direction: column;
  align-items: center;
  padding: 40rpx 0 20rpx;
  gap: 12rpx;
}

.desc-placeholder-icon { font-size: 120rpx; }

.desc-placeholder-name {
  font-size: 28rpx;
  font-weight: 700;
  color: #1A1A1A;
}

.desc-placeholder-sub {
  font-size: 22rpx;
  color: #888888;
}

/* ===== 底部操作栏 ===== */
.action-bar {
  position: fixed;
  bottom: 0;
  left: 0;
  right: 0;
  background: #ffffff;
  border-top: 1rpx solid #F2EBE0;
  padding: 16rpx 24rpx;
  padding-bottom: calc(16rpx + env(safe-area-inset-bottom));
  display: flex;
  flex-direction: row;
  align-items: center;
  gap: 8rpx;
}

.action-icon {
  display: flex;
  flex-direction: column;
  align-items: center;
  gap: 4rpx;
  padding: 0 12rpx;
}

.ai-icon {
  font-size: 40rpx;
  color: #555555;
}

.icon-fav {
  color: #FF3B30;
}

.ai-label {
  font-size: 18rpx;
  color: #888888;
}

.action-divider {
  width: 1rpx;
  height: 64rpx;
  background: #F2EBE0;
  flex-shrink: 0;
  margin: 0 4rpx;
}

.btn-cart {
  flex: 1;
  background: #FBF5EA;
  border: 3rpx solid #C8902E;
  border-radius: 999rpx;
  padding: 20rpx 0;
  display: flex;
  align-items: center;
  justify-content: center;
}

.btn-buy {
  flex: 1;
  background: linear-gradient(135deg, #FF6B00, #FF3B30);
  border-radius: 999rpx;
  padding: 20rpx 0;
  display: flex;
  align-items: center;
  justify-content: center;
}

.btn-cart .btn-text {
  font-size: 26rpx;
  font-weight: 800;
  color: #C8902E;
}

.btn-buy .btn-text {
  font-size: 26rpx;
  font-weight: 800;
  color: #ffffff;
}

/* ===== 商品不存在 ===== */
.not-found {
  display: flex;
  align-items: center;
  justify-content: center;
  height: 100vh;
}

.not-found-text {
  font-size: 28rpx;
  color: #888888;
}
