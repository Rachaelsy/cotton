.page {
  display: flex;
  flex-direction: column;
  height: 100vh;
  background: linear-gradient(180deg, #D9ECF7 0%, #F5EEE6 38%, #F5EEE6 100%);
}

.wx-hd {
  background: linear-gradient(160deg, #1E6B8E, #2196F3);
  padding: 0 28rpx 18rpx;
  flex-shrink: 0;
  box-shadow: 0 4rpx 18rpx rgba(0, 0, 0, 0.08);
  overflow: hidden;
}

.wx-hd-top {
  display: flex;
  align-items: flex-start;
  justify-content: space-between;
  gap: 16rpx;
  padding-bottom: 16rpx;
}

.wx-hd-title-wrap {
  display: flex;
  flex-direction: column;
  gap: 6rpx;
}

.wx-title {
  font-size: 36rpx;
  font-weight: 800;
  color: #fff;
}

.wx-subtitle {
  font-size: 22rpx;
  color: rgba(255, 255, 255, 0.84);
}

.wx-hd-action {
  background: rgba(255, 255, 255, 0.18);
  color: #fff;
  border: 1rpx solid rgba(255, 255, 255, 0.28);
  border-radius: 999rpx;
  padding: 10rpx 22rpx;
  font-size: 24rpx;
  font-weight: 600;
  flex-shrink: 0;
}

.field-chips {
  display: block;
  width: 100%;
  height: 66rpx;
  white-space: nowrap;
  overflow: hidden;
}

.field-chip-row {
  height: 66rpx;
  min-width: 100%;
  display: block;
  white-space: nowrap;
}

.fchip {
  background: rgba(255, 255, 255, 0.2);
  border-radius: 999rpx;
  padding: 10rpx 26rpx;
  margin-right: 16rpx;
  height: 54rpx;
  flex-shrink: 0;
  display: inline-flex;
  align-items: center;
  justify-content: center;
  vertical-align: top;
  box-sizing: border-box;
}

.fchip.on {
  background: #fff;
}

.fchip-text {
  font-size: 24rpx;
  color: #fff;
  font-weight: 600;
}

.fchip.on .fchip-text {
  color: #1E6B8E;
}

.wx-scroll {
  flex: 1;
  height: 0;
}

.wx-state {
  margin: 28rpx;
  padding: 52rpx 32rpx;
  background: rgba(255, 255, 255, 0.84);
  border-radius: 28rpx;
  display: flex;
  flex-direction: column;
  align-items: center;
  gap: 14rpx;
  text-align: center;
  box-shadow: 0 4rpx 24rpx rgba(0, 0, 0, 0.06);
}

.wx-state-title {
  font-size: 32rpx;
  font-weight: 700;
  color: #1A1A1A;
}

.wx-state-desc {
  font-size: 24rpx;
  color: #666;
  line-height: 1.6;
}

.wx-state-btn {
  margin-top: 8rpx;
  background: #C8902E;
  color: #fff;
  border-radius: 999rpx;
  padding: 14rpx 28rpx;
  font-size: 24rpx;
  font-weight: 700;
}

.wx-main-card {
  background: #fff;
  border-radius: 32rpx;
  margin: 24rpx 28rpx 0;
  padding: 28rpx;
  box-shadow: 0 4rpx 24rpx rgba(0, 0, 0, 0.07);
  overflow: hidden;
}

.wx-main-top {
  display: flex;
  align-items: center;
  justify-content: space-between;
  gap: 18rpx;
  margin-bottom: 22rpx;
}

.wx-main-info {
  flex: 1;
  min-width: 0;
}

.wx-chip-row {
  display: flex;
  align-items: center;
  flex-wrap: wrap;
  gap: 10rpx;
  margin-bottom: 16rpx;
}

.wx-main-chip {
  display: flex;
  align-items: center;
  background: #F0F7FF;
  border-radius: 999rpx;
  padding: 6rpx 18rpx;
  font-size: 20rpx;
  color: #1890FF;
  font-weight: 600;
  max-width: 280rpx;
  overflow: hidden;
  white-space: nowrap;
  text-overflow: ellipsis;
}

.wx-source-chip {
  height: 38rpx;
  padding: 0 14rpx;
  border-radius: 999rpx;
  display: flex;
  align-items: center;
  gap: 8rpx;
  font-size: 19rpx;
  font-weight: 800;
  box-sizing: border-box;
}

.wx-source-chip.real {
  color: #1F7A49;
  background: #E8F6EE;
}

.wx-source-chip.mock {
  color: #9A5B16;
  background: #FFF4E0;
}

.source-dot {
  width: 12rpx;
  height: 12rpx;
  border-radius: 50%;
  background: currentColor;
  flex-shrink: 0;
}

.wx-big-temp {
  display: block;
  font-size: 112rpx;
  font-weight: 800;
  color: #1A1A1A;
  line-height: 1;
}

.wx-desc {
  display: block;
  font-size: 30rpx;
  font-weight: 700;
  color: #1A1A1A;
  margin-top: 6rpx;
}

.wx-hl {
  display: block;
  font-size: 24rpx;
  color: #888;
  margin-top: 8rpx;
}

.wx-icon-big {
  font-size: 96rpx;
  line-height: 1;
  flex-shrink: 0;
}

.wx-detail-grid {
  display: flex;
  flex-wrap: wrap;
  gap: 16rpx;
  margin-top: 8rpx;
}

.wx-di {
  flex: 1;
  min-width: calc(33.333% - 12rpx);
  background: #F5EEE6;
  border-radius: 20rpx;
  padding: 18rpx 10rpx;
  display: flex;
  flex-direction: column;
  align-items: center;
  gap: 8rpx;
}

.wdi-icon {
  font-size: 44rpx;
}

.wdi-val {
  font-size: 25rpx;
  font-weight: 700;
  color: #1A1A1A;
}

.wdi-lbl {
  font-size: 20rpx;
  color: #888;
}

.wx-tip {
  margin-top: 18rpx;
  background: #FBF5EA;
  border-radius: 20rpx;
  padding: 18rpx 20rpx;
}

.wx-tip-text {
  font-size: 24rpx;
  color: #7A5020;
  line-height: 1.6;
}

.wx-alert-banner {
  background: linear-gradient(135deg, #FF6B00, #FF8C3A);
  border-radius: 28rpx;
  margin: 20rpx 28rpx 0;
  padding: 24rpx 28rpx;
  display: flex;
  align-items: center;
  gap: 20rpx;
}

.wx-alert-banner.safe {
  background: linear-gradient(135deg, #2D8B57, #42B87B);
}

.wa-icon {
  font-size: 48rpx;
  flex-shrink: 0;
}

.wa-txt {
  flex: 1;
}

.wa-title {
  display: block;
  font-size: 28rpx;
  font-weight: 700;
  color: #fff;
}

.wa-sub {
  display: block;
  font-size: 22rpx;
  color: rgba(255, 255, 255, 0.88);
  margin-top: 4rpx;
  line-height: 1.5;
}

.wa-arr {
  font-size: 36rpx;
  color: #fff;
  flex-shrink: 0;
}

.wx-card,
.wx-advice-card {
  background: #fff;
  border-radius: 28rpx;
  margin: 20rpx 28rpx 0;
  padding: 28rpx;
  box-shadow: 0 4rpx 24rpx rgba(0, 0, 0, 0.07);
}

.wx-card-head {
  display: flex;
  align-items: center;
  gap: 12rpx;
  margin-bottom: 20rpx;
}

.wx-card-bar {
  width: 8rpx;
  height: 32rpx;
  background: #C8902E;
  border-radius: 4rpx;
}

.wx-card-title {
  font-size: 30rpx;
  font-weight: 700;
  color: #1A1A1A;
}

.hourly-scroll,
.forecast-scroll {
  width: 100%;
  white-space: nowrap;
}

.hourly-row {
  display: flex;
  gap: 12rpx;
  padding-bottom: 4rpx;
}

.hourly-item {
  width: 108rpx;
  flex-shrink: 0;
  padding: 14rpx 8rpx;
  border-radius: 20rpx;
  display: flex;
  flex-direction: column;
  align-items: center;
  gap: 7rpx;
  background: #F5EEE6;
  box-sizing: border-box;
}

.hourly-now {
  background: linear-gradient(160deg, #1E6B8E, #2196F3);
}

.hour-time,
.hour-meta,
.hour-rain {
  font-size: 19rpx;
  color: #888;
  line-height: 1.2;
}

.hour-icon {
  font-size: 40rpx;
  line-height: 1;
}

.hour-temp {
  font-size: 26rpx;
  font-weight: 800;
  color: #1A1A1A;
  line-height: 1.1;
}

.hour-rain {
  color: #1E88C8;
}

.hourly-now .hour-time,
.hourly-now .hour-meta,
.hourly-now .hour-rain,
.hourly-now .hour-temp {
  color: #FFFFFF;
}

.forecast-row {
  display: flex;
  gap: 12rpx;
}

.forecast-item {
  width: 112rpx;
  flex-shrink: 0;
  display: flex;
  flex-direction: column;
  align-items: center;
  gap: 8rpx;
  min-width: 0;
}

.fc-day {
  font-size: 20rpx;
  color: #888;
}

.fc-icon {
  font-size: 44rpx;
}

.fc-hl {
  font-size: 22rpx;
  font-weight: 700;
  color: #1A1A1A;
}

.fc-wind {
  font-size: 18rpx;
  color: #888;
  text-align: center;
  line-height: 1.4;
}

.adv-item {
  display: flex;
  align-items: flex-start;
  gap: 20rpx;
  padding: 16rpx 0;
  border-bottom: 2rpx solid #F2EBE0;
}

.adv-item:last-child {
  border-bottom: none;
}

.adv-icon {
  width: 72rpx;
  height: 72rpx;
  border-radius: 20rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  flex-shrink: 0;
}

.adv-icon-emoji {
  font-size: 36rpx;
}

.adv-body {
  flex: 1;
}

.adv-title {
  display: block;
  font-size: 28rpx;
  font-weight: 700;
  color: #1A1A1A;
  margin-bottom: 6rpx;
}

.adv-sub {
  display: block;
  font-size: 22rpx;
  color: #555;
  line-height: 1.55;
}

.modal-mask {
  position: fixed;
  top: 0;
  right: 0;
  bottom: 0;
  left: 0;
  z-index: 20;
  background: rgba(19, 30, 38, .46);
}

.alert-sheet {
  position: fixed;
  right: 0;
  bottom: 0;
  left: 0;
  z-index: 21;
  padding: 0 30rpx 34rpx;
  border-radius: 34rpx 34rpx 0 0;
  background: #FFFFFF;
  box-shadow: 0 -8rpx 30rpx rgba(0, 0, 0, .16);
}

.sheet-handle {
  width: 74rpx;
  height: 8rpx;
  margin: 18rpx auto 0;
  border-radius: 999rpx;
  background: #D8E0E6;
}

.sheet-head {
  padding: 22rpx 0 20rpx;
  display: flex;
  align-items: center;
  border-bottom: 1rpx solid #EEF2F4;
}

.sheet-title-wrap {
  flex: 1;
  min-width: 0;
  display: flex;
  align-items: center;
  gap: 18rpx;
}

.sheet-icon {
  width: 72rpx;
  height: 72rpx;
  border-radius: 22rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  background: #FFF3E6;
  font-size: 38rpx;
}

.sheet-title-main {
  flex: 1;
  min-width: 0;
  display: flex;
  flex-direction: column;
}

.sheet-title {
  color: #17212B;
  font-size: 31rpx;
  font-weight: 900;
}

.sheet-sub {
  margin-top: 5rpx;
  color: #71808D;
  font-size: 21rpx;
}

.sheet-close {
  width: 58rpx;
  height: 58rpx;
  border-radius: 50%;
  display: flex;
  align-items: center;
  justify-content: center;
  background: #F2F5F7;
}

.alert-info-grid {
  display: flex;
  gap: 16rpx;
  margin-top: 22rpx;
}

.alert-info-item {
  flex: 1;
  min-width: 0;
  padding: 18rpx;
  border-radius: 20rpx;
  background: #F5F8FA;
}

.aii-label,
.aii-value {
  display: block;
}

.aii-label {
  color: #84919C;
  font-size: 20rpx;
}

.aii-value {
  margin-top: 7rpx;
  color: #17212B;
  font-size: 23rpx;
  font-weight: 800;
  line-height: 1.4;
}

.alert-summary {
  margin-top: 18rpx;
  padding: 20rpx;
  border-radius: 20rpx;
  color: #7A5020;
  background: #FBF5EA;
  font-size: 24rpx;
  line-height: 1.6;
}

.alert-action-list {
  margin-top: 22rpx;
}

.alert-action-title {
  display: block;
  color: #17212B;
  font-size: 27rpx;
  font-weight: 900;
  margin-bottom: 8rpx;
}

.alert-action {
  display: flex;
  align-items: flex-start;
  gap: 12rpx;
  padding: 12rpx 0;
}

.alert-action-dot {
  width: 10rpx;
  height: 10rpx;
  margin-top: 13rpx;
  border-radius: 50%;
  background: #2196F3;
  flex-shrink: 0;
}

.alert-action-text {
  flex: 1;
  color: #4F5A64;
  font-size: 23rpx;
  line-height: 1.55;
}
