.page { display:flex; flex-direction:column; height:100vh; background:#F5EEE6; }
.wx-nav {
  background:linear-gradient(160deg,#1E6B8E,#2196F3);
  padding:0 28rpx; flex-shrink:0;
}
.wx-nav-inner { display:flex; align-items:center; gap:16rpx; padding-bottom:16rpx; }
.back-btn {
  width:64rpx; height:64rpx; background:rgba(255,255,255,.2); border-radius:50%;
  display:flex; align-items:center; justify-content:center;
}
.back-icon { font-size:40rpx; color:#fff; font-weight:700; }
.wx-title { font-size:36rpx; font-weight:800; color:#fff; }
.field-chips { display:flex; flex-direction:row; padding-bottom:24rpx; white-space:nowrap; }
.fchip {
  background:rgba(255,255,255,.2); border-radius:999rpx; padding:10rpx 28rpx;
  margin-right:16rpx; flex-shrink:0;
}
.fchip.on { background:#fff; }
.fchip-text { font-size:24rpx; color:#fff; font-weight:600; }
.fchip.on .fchip-text { color:#1E6B8E; }

.wx-scroll { flex:1; height:0; }
.wx-main-card {
  background:#fff; border-radius:28rpx; margin:24rpx 28rpx 0;
  padding:28rpx; box-shadow:0 4rpx 24rpx rgba(0,0,0,.07);
}
.wx-main-top { display:flex; flex-direction:row; align-items:center; margin-bottom:24rpx; }
.wx-big-temp { font-size:112rpx; font-weight:800; color:#1A1A1A; line-height:1; }
.wx-desc { display:block; font-size:30rpx; font-weight:700; color:#1A1A1A; }
.wx-hl { display:block; font-size:24rpx; color:#888; margin-top:8rpx; }
.wx-icon-big { font-size:96rpx; }
.wx-detail-grid {
  display:flex; flex-direction:row; flex-wrap:wrap; gap:16rpx;
}
.wx-di {
  flex:1; min-width:calc(25% - 12rpx); background:#F5EEE6; border-radius:20rpx;
  padding:20rpx; display:flex; flex-direction:column; align-items:center; gap:8rpx;
}
.wdi-icon { font-size:44rpx; }
.wdi-val { font-size:28rpx; font-weight:700; color:#1A1A1A; }
.wdi-lbl { font-size:20rpx; color:#888; }

.wx-alert {
  background:linear-gradient(135deg,#FF6B00,#FF8C3A); border-radius:28rpx;
  margin:20rpx 28rpx 0; padding:24rpx 28rpx;
  display:flex; align-items:center; gap:20rpx;
}
.wx-alert-icon { font-size:48rpx; flex-shrink:0; }
.wx-alert-title { display:block; font-size:28rpx; font-weight:700; color:#fff; }
.wx-alert-sub { display:block; font-size:22rpx; color:rgba(255,255,255,.85); margin-top:4rpx; }
.wx-alert-arr { font-size:36rpx; color:#fff; flex-shrink:0; }

.hcard { background:#fff; border-radius:28rpx; margin:20rpx 28rpx 0; padding:28rpx; box-shadow:0 4rpx 24rpx rgba(0,0,0,.07); }
.hcard-hd { display:flex; align-items:center; gap:12rpx; margin-bottom:20rpx; }
.hcard-bar { width:8rpx; height:32rpx; background:#C8902E; border-radius:4rpx; }
.hcard-title { font-size:30rpx; font-weight:700; color:#1A1A1A; }

.forecast-row { display:flex; flex-direction:row; }
.forecast-item { flex:1; display:flex; flex-direction:column; align-items:center; gap:8rpx; }
.fc-day { font-size:20rpx; color:#888; }
.fc-icon { font-size:44rpx; }
.fc-hl { font-size:22rpx; font-weight:700; color:#1A1A1A; }
.fc-wind { font-size:18rpx; color:#888; text-align:center; }

.adv-item { display:flex; align-items:flex-start; gap:20rpx; padding:16rpx 0; border-bottom:2rpx solid #F2EBE0; }
.adv-item:last-child { border-bottom:none; }
.adv-icon { width:72rpx; height:72rpx; border-radius:20rpx; display:flex; align-items:center; justify-content:center; flex-shrink:0; }
.adv-icon-emoji { font-size:36rpx; }
.adv-title { display:block; font-size:28rpx; font-weight:600; color:#1A1A1A; margin-bottom:6rpx; }
.adv-sub { display:block; font-size:22rpx; color:#555; line-height:1.5; }
