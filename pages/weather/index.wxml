<!-- 地块气象 -->
<view class="page">
  <!-- 导航 -->
  <view class="wx-nav" style="padding-top: {{statusBarHeight}}px">
    <view class="wx-nav-inner">
      <view class="back-btn" bindtap="onBack"><text class="back-icon">‹</text></view>
      <view style="flex:1">
        <text class="wx-title">地块气象</text>
      </view>
    </view>
    <!-- 地块选择器 -->
    <scroll-view class="field-chips" scroll-x>
      <view
        class="fchip {{selField === item ? 'on' : ''}}"
        wx:for="{{fields}}"
        wx:key="index"
        bindtap="onSelField"
        data-f="{{item}}"
      >
        <text class="fchip-text">{{item}}</text>
      </view>
    </scroll-view>
  </view>

  <scroll-view class="wx-scroll" scroll-y>
    <!-- 主天气卡 -->
    <view class="wx-main-card">
      <view class="wx-main-top">
        <text class="wx-big-temp">{{weather.temp}}°</text>
        <view style="flex:1; margin-left:24rpx">
          <text class="wx-desc">{{weather.desc}}</text>
          <text class="wx-hl">{{weather.low}}°~ {{weather.high}}° · {{weather.wind}}</text>
        </view>
        <text class="wx-icon-big">{{weather.icon}}</text>
      </view>
      <!-- 详情网格 -->
      <view class="wx-detail-grid">
        <view class="wx-di">
          <text class="wdi-icon">🌡</text>
          <text class="wdi-val">{{weather.groundTemp}}°C</text>
          <text class="wdi-lbl">地表温度</text>
        </view>
        <view class="wx-di">
          <text class="wdi-icon">💧</text>
          <text class="wdi-val">{{weather.humidity}}%</text>
          <text class="wdi-lbl">空气湿度</text>
        </view>
        <view class="wx-di">
          <text class="wdi-icon">🌂</text>
          <text class="wdi-val">{{weather.rain}}mm</text>
          <text class="wdi-lbl">降水量</text>
        </view>
        <view class="wx-di">
          <text class="wdi-icon">☀️</text>
          <text class="wdi-val">{{weather.uv}}</text>
          <text class="wdi-lbl">紫外线</text>
        </view>
      </view>
    </view>

    <!-- 预警横幅 -->
    <view class="wx-alert">
      <text class="wx-alert-icon">⚠️</text>
      <view style="flex:1">
        <text class="wx-alert-title">后天大风预警</text>
        <text class="wx-alert-sub">预计风力6-7级，做好防风准备</text>
      </view>
      <text class="wx-alert-arr">›</text>
    </view>

    <!-- 5日预报 -->
    <view class="hcard">
      <view class="hcard-hd">
        <view class="hcard-bar"></view>
        <text class="hcard-title">5日预报</text>
      </view>
      <view class="forecast-row">
        <view class="forecast-item" wx:for="{{forecast}}" wx:key="day">
          <text class="fc-day">{{item.day}}</text>
          <text class="fc-icon">{{item.icon}}</text>
          <text class="fc-hl">{{item.high}}°/{{item.low}}°</text>
          <text class="fc-wind">{{item.wind}}</text>
        </view>
      </view>
    </view>

    <!-- 农事建议 -->
    <view class="hcard" style="margin-bottom:32rpx">
      <view class="hcard-hd">
        <view class="hcard-bar"></view>
        <text class="hcard-title">农事建议</text>
      </view>
      <view class="adv-item" wx:for="{{advices}}" wx:key="title">
        <view class="adv-icon" style="background: {{item.bg}}">
          <text class="adv-icon-emoji">{{item.icon}}</text>
        </view>
        <view style="flex:1">
          <text class="adv-title">{{item.title}}</text>
          <text class="adv-sub">{{item.sub}}</text>
        </view>
      </view>
    </view>

    <view style="height:40rpx"></view>
  </scroll-view>
</view>
