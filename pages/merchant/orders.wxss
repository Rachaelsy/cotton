/* pages/merchant/orders.wxss */
.header-title-row { display: flex; align-items: center; justify-content: space-between; }
.export-btn { display: flex; align-items: center; background: rgba(255,255,255,0.25); border-radius: 20rpx; padding: 6rpx 20rpx; }
.export-icon { font-size: 28rpx; margin-right: 6rpx; }
.export-label { font-size: 24rpx; color: #fff; }

.page { display: flex; flex-direction: column; height: 100vh; background: #F5F6FA; }
.scroll { flex: 1; height: 0; }

.header {
  background: linear-gradient(135deg, #C8902E, #D4A043);
  padding: 8rpx 32rpx 28rpx;
}
.header-tag {
  font-size: 20rpx;
  color: rgba(255,255,255,0.65);
  display: block;
  margin-bottom: 10rpx;
  padding-right: 200rpx;
}
.header-title { font-size: 36rpx; font-weight: 700; color: #fff; display: block; }

/* Tab */
.tab-scroll { background: #fff; border-bottom: 1rpx solid #F0F0F0; }
.tab-bar { display: flex; flex-direction: row; white-space: nowrap; }
.tab-item {
  padding: 24rpx 40rpx;
  font-size: 26rpx;
  color: #888;
  flex-shrink: 0;
}
.tab-item.active { color: #C8902E; font-weight: 700; border-bottom: 4rpx solid #C8902E; }

/* Order cards */
.order-list { padding: 20rpx 24rpx; display: flex; flex-direction: column; gap: 16rpx; }
.order-card {
  background: #fff;
  border-radius: 16rpx;
  padding: 24rpx;
  box-shadow: 0 2rpx 12rpx rgba(0,0,0,0.06);
}
.order-hd {
  display: flex;
  flex-direction: row;
  align-items: center;
  justify-content: space-between;
  margin-bottom: 16rpx;
}
.order-id { font-size: 22rpx; color: #AAAAAA; }

.status-tag {
  padding: 4rpx 16rpx;
  border-radius: 20rpx;
  background: #F5F5F5;
}
.status-tag.pending { background: #FFF7ED; }
.status-tag.done    { background: #F0FDF4; }
.status-tag.refund  { background: #FEF2F2; }
.status-tag text { font-size: 20rpx; color: #666; }
.status-tag.pending text { color: #D97706; }
.status-tag.done text    { color: #16A34A; }
.status-tag.refund text  { color: #DC2626; }

.order-buyer {
  display: flex;
  flex-direction: row;
  align-items: center;
  margin-bottom: 12rpx;
}
.buyer-lbl { font-size: 24rpx; color: #AAAAAA; }
.buyer-name { font-size: 24rpx; color: #333; font-weight: 600; flex: 1; }
.order-time { font-size: 22rpx; color: #BBBBBB; }

.order-goods-row {
  display: flex;
  flex-direction: row;
  align-items: center;
  gap: 10rpx;
  background: #F5F6FA;
  border-radius: 10rpx;
  padding: 16rpx;
  margin-bottom: 16rpx;
}
.goods-icon { font-size: 30rpx; }
.goods-name { font-size: 26rpx; color: #333; flex: 1; }

.order-ft {
  display: flex;
  flex-direction: row;
  align-items: center;
  justify-content: space-between;
}
.order-amount { font-size: 28rpx; font-weight: 700; color: #C8902E; }
.order-actions { display: flex; flex-direction: row; gap: 12rpx; }
.action-btn {
  padding: 10rpx 24rpx;
  border-radius: 10rpx;
  font-size: 24rpx;
}
.action-btn.detail { background: #F5F6FA; color: #555; }
.action-btn.ship   { background: #C8902E; color: #fff; }
.action-btn.refund { background: #FEF2F2; color: #DC2626; }

.empty { display: flex; flex-direction: column; align-items: center; padding: 80rpx 0; gap: 16rpx; }
.empty-icon { font-size: 80rpx; }
.empty-text { font-size: 26rpx; color: #AAAAAA; }

/* 发货弹窗 */
.ship-overlay { position: fixed; top: 0; left: 0; right: 0; bottom: 0; background: rgba(0,0,0,0.45); display: flex; align-items: center; justify-content: center; z-index: 999; }
.ship-modal { background: #fff; border-radius: 24rpx; padding: 48rpx 40rpx 36rpx; width: 600rpx; }
.ship-title { display: block; font-size: 32rpx; font-weight: 700; color: #1A1A1A; margin-bottom: 12rpx; text-align: center; }
.ship-desc { display: block; font-size: 24rpx; color: #888; margin-bottom: 32rpx; text-align: center; }
.ship-input { border: 2rpx solid #E5E7EB; border-radius: 12rpx; padding: 20rpx 24rpx; font-size: 28rpx; color: #1A1A1A; margin-bottom: 36rpx; }
.ship-actions { display: flex; flex-direction: row; gap: 20rpx; }
.ship-btn { flex: 1; height: 80rpx; border-radius: 16rpx; display: flex; align-items: center; justify-content: center; font-size: 28rpx; }
.ship-cancel-btn { background: #F5F6FA; color: #666; }
.ship-confirm-btn { background: #C8902E; color: #fff; font-weight: 600; }

/* 已发货状态色 */
.status-tag.shipped { background: #EFF6FF; }
.status-tag.shipped text { color: #2563EB; }
