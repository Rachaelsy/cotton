/* pages/merchant/orders.wxss */

.page { display: flex; flex-direction: column; height: 100vh; background: #F5F6FA; }
.scroll { flex: 1; height: 0; }

.header {
  background: linear-gradient(135deg, #C8902E, #D4A043);
  padding: 8rpx 32rpx 28rpx;
}
.header-tag {
  font-size: 20rpx;
  color: rgba(255,255,255,0.65);
  display: block;
  margin-bottom: 10rpx;
  padding-right: 200rpx;
}
.header-title { font-size: 36rpx; font-weight: 700; color: #fff; display: block; }

/* Tab */
.tab-scroll { background: #fff; border-bottom: 1rpx solid #F0F0F0; }
.tab-bar { display: flex; flex-direction: row; white-space: nowrap; }
.tab-item {
  padding: 24rpx 40rpx;
  font-size: 26rpx;
  color: #888;
  flex-shrink: 0;
}
.tab-item.active { color: #C8902E; font-weight: 700; border-bottom: 4rpx solid #C8902E; }

/* Order cards */
.order-list { padding: 20rpx 24rpx; display: flex; flex-direction: column; gap: 16rpx; }
.order-card {
  background: #fff;
  border-radius: 16rpx;
  padding: 24rpx;
  box-shadow: 0 2rpx 12rpx rgba(0,0,0,0.06);
}
.order-hd {
  display: flex;
  flex-direction: row;
  align-items: center;
  justify-content: space-between;
  margin-bottom: 16rpx;
}
.order-id { font-size: 22rpx; color: #AAAAAA; }

.status-tag {
  padding: 4rpx 16rpx;
  border-radius: 20rpx;
  background: #F5F5F5;
}
.status-tag.pending { background: #FFF7ED; }
.status-tag.done    { background: #F0FDF4; }
.status-tag.refund  { background: #FEF2F2; }
.status-tag text { font-size: 20rpx; color: #666; }
.status-tag.pending text { color: #D97706; }
.status-tag.done text    { color: #16A34A; }
.status-tag.refund text  { color: #DC2626; }

.order-buyer {
  display: flex;
  flex-direction: row;
  align-items: center;
  margin-bottom: 12rpx;
}
.buyer-lbl { font-size: 24rpx; color: #AAAAAA; }
.buyer-name { font-size: 24rpx; color: #333; font-weight: 600; flex: 1; }
.order-time { font-size: 22rpx; color: #BBBBBB; }

.order-goods-row {
  display: flex;
  flex-direction: row;
  align-items: center;
  gap: 10rpx;
  background: #F5F6FA;
  border-radius: 10rpx;
  padding: 16rpx;
  margin-bottom: 16rpx;
}
.goods-icon { font-size: 30rpx; }
.goods-name { font-size: 26rpx; color: #333; flex: 1; }

.order-ft {
  display: flex;
  flex-direction: row;
  align-items: center;
  justify-content: space-between;
}
.order-amount { font-size: 28rpx; font-weight: 700; color: #C8902E; }
.order-actions { display: flex; flex-direction: row; gap: 12rpx; }
.action-btn {
  padding: 10rpx 24rpx;
  border-radius: 10rpx;
  font-size: 24rpx;
}
.action-btn.detail { background: #F5F6FA; color: #555; }
.action-btn.ship   { background: #C8902E; color: #fff; }
.action-btn.refund { background: #FEF2F2; color: #DC2626; }

.empty { display: flex; flex-direction: column; align-items: center; padding: 80rpx 0; gap: 16rpx; }
.empty-icon { font-size: 80rpx; }
.empty-text { font-size: 26rpx; color: #AAAAAA; }
