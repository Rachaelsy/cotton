/* pages/merchant/profile.wxss */

.page { display: flex; flex-direction: column; height: 100vh; background: #F5F6FA; }
.scroll { flex: 1; height: 0; }

.header {
  background: linear-gradient(135deg, #C8902E, #D4A043);
  padding: 8rpx 32rpx 48rpx;
}
.header-tag {
  font-size: 20rpx;
  color: rgba(255,255,255,0.65);
  display: block;
  margin-bottom: 16rpx;
  padding-right: 200rpx;
}
.store-card {
  display: flex;
  flex-direction: row;
  align-items: center;
  gap: 20rpx;
  margin-top: 8rpx;
}
.store-avatar {
  width: 100rpx;
  height: 100rpx;
  background: rgba(255,255,255,0.25);
  border-radius: 50%;
  display: flex;
  align-items: center;
  justify-content: center;
  flex-shrink: 0;
}
.avatar-text { font-size: 40rpx; color: #fff; font-weight: 700; }
.store-info { flex: 1; }
.store-name { font-size: 32rpx; font-weight: 700; color: #fff; display: block; }
.store-owner { font-size: 22rpx; color: rgba(255,255,255,0.8); display: block; margin-top: 4rpx; }
.store-phone { font-size: 22rpx; color: rgba(255,255,255,0.7); display: block; margin-top: 2rpx; }
.edit-btn {
  background: rgba(255,255,255,0.25);
  border-radius: 20rpx;
  padding: 8rpx 24rpx;
}
.edit-text { font-size: 24rpx; color: #fff; }

/* Sections */
.section { margin: -24rpx 24rpx 24rpx; }
.section-title { font-size: 26rpx; color: #888; margin-bottom: 12rpx; }

.info-card {
  background: #fff;
  border-radius: 20rpx;
  overflow: hidden;
  box-shadow: 0 2rpx 12rpx rgba(0,0,0,0.06);
}
.info-row {
  display: flex;
  flex-direction: row;
  align-items: center;
  padding: 24rpx 28rpx;
  border-bottom: 1rpx solid #F5F5F5;
}
.info-row.noborder { border-bottom: none; }
.info-lbl { font-size: 26rpx; color: #555; width: 160rpx; flex-shrink: 0; }
.info-val { font-size: 26rpx; color: #1A1A1A; flex: 1; }
.verified-tag {
  background: #F0FDF4;
  border-radius: 20rpx;
  padding: 4rpx 16rpx;
}
.verified-text { font-size: 22rpx; color: #16A34A; }

.menu-card {
  background: #fff;
  border-radius: 20rpx;
  overflow: hidden;
  box-shadow: 0 2rpx 12rpx rgba(0,0,0,0.06);
}
.menu-item {
  display: flex;
  flex-direction: row;
  align-items: center;
  padding: 28rpx;
  border-bottom: 1rpx solid #F5F5F5;
  gap: 16rpx;
}
.menu-item.noborder { border-bottom: none; }
.menu-icon { font-size: 36rpx; }
.menu-lbl { font-size: 28rpx; color: #1A1A1A; flex: 1; }
.menu-arrow { font-size: 32rpx; color: #CCCCCC; }

.logout-wrap {
  margin: 0 24rpx;
  background: #fff;
  border-radius: 20rpx;
  height: 96rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  box-shadow: 0 2rpx 12rpx rgba(0,0,0,0.06);
}
.logout-text { font-size: 28rpx; color: #F5222D; font-weight: 600; }

/* Modal */
.modal-mask {
  position: fixed;
  top: 0; left: 0; right: 0; bottom: 0;
  background: rgba(0,0,0,0.5);
  z-index: 100;
}
.modal {
  position: fixed;
  left: 0; right: 0; bottom: 0;
  background: #fff;
  border-radius: 32rpx 32rpx 0 0;
  padding: 40rpx 32rpx;
  z-index: 101;
}
.modal-title { font-size: 32rpx; font-weight: 700; color: #1A1A1A; display: block; margin-bottom: 32rpx; }
.form-item { margin-bottom: 24rpx; }
.form-label { font-size: 24rpx; color: #555; display: block; margin-bottom: 10rpx; }
.form-input {
  width: 100%;
  height: 80rpx;
  background: #F5F6FA;
  border-radius: 12rpx;
  padding: 0 20rpx;
  font-size: 26rpx;
  box-sizing: border-box;
}
.modal-btns { display: flex; flex-direction: row; gap: 20rpx; margin-top: 16rpx; }
.modal-btn {
  flex: 1;
  height: 88rpx;
  border-radius: 16rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  font-size: 28rpx;
  font-weight: 600;
}
.modal-btn.cancel  { background: #F5F6FA; color: #666; }
.modal-btn.confirm { background: #C8902E; color: #fff; }
