/* pages/merchant/index.wxss */

.page {
  display: flex;
  flex-direction: column;
  height: 100vh;
  background: #F5F6FA;
}

.scroll { flex: 1; height: 0; }

/* Header */
.header {
  background: linear-gradient(135deg, #B9852F, #C9973A);
  padding: 8rpx 32rpx 36rpx;
}
.header-tag {
  font-size: 20rpx;
  color: rgba(255,255,255,0.65);
  display: block;
  margin-bottom: 16rpx;
  padding-right: 200rpx; /* 避开右上角胶囊按钮 */
}
.store-block {
  display: flex;
  flex-direction: row;
  align-items: center;
  gap: 20rpx;
}
.store-avatar {
  width: 88rpx;
  height: 88rpx;
  background: rgba(255,255,255,0.25);
  border-radius: 50%;
  display: flex;
  align-items: center;
  justify-content: center;
  flex-shrink: 0;
}
.avatar-text {
  font-size: 38rpx;
  color: #ffffff;
  font-weight: 700;
}
.store-info { flex: 1; }
.store-name {
  font-size: 34rpx;
  font-weight: 700;
  color: #ffffff;
  display: block;
}
.store-sub {
  font-size: 22rpx;
  color: rgba(255,255,255,0.75);
  margin-top: 4rpx;
  display: block;
}

/* Section */
.section {
  margin: -20rpx 24rpx 0;
  margin-bottom: 24rpx;
}
.section-hd {
  display: flex;
  flex-direction: row;
  align-items: center;
  justify-content: space-between;
  margin-bottom: 16rpx;
}
.section-title {
  font-size: 28rpx;
  font-weight: 700;
  color: #18231A;
  margin-bottom: 16rpx;
}
.section-more {
  font-size: 24rpx;
  color: #B9852F;
}

/* Stat grid */
.stat-grid {
  display: flex;
  flex-direction: row;
  flex-wrap: wrap;
  gap: 16rpx;
  background: #ffffff;
  border-radius: 20rpx;
  padding: 24rpx;
  box-shadow: 0 4rpx 20rpx rgba(33,61,42,0.07);
}
.stat-card {
  width: 300rpx;
  display: flex;
  flex-direction: column;
  align-items: flex-start;
  padding: 20rpx;
  background: #F5F6FA;
  border-radius: 14rpx;
  gap: 4rpx;
}
.stat-card.warn { background: #FFF7ED; }
.stat-card.ok   { background: #F0FDF4; }
.stat-card.gold { background: #FFFBEB; }

.stat-val {
  font-size: 32rpx;
  font-weight: 800;
  color: #18231A;
}
.stat-lbl {
  font-size: 22rpx;
  color: #687468;
}
.stat-unit {
  font-size: 18rpx;
  color: #B7C0B8;
}

/* Quick actions */
.quick-row {
  display: flex;
  flex-direction: row;
  background: #ffffff;
  border-radius: 20rpx;
  padding: 24rpx 16rpx;
  box-shadow: 0 4rpx 20rpx rgba(33,61,42,0.05);
}
.quick-item {
  flex: 1;
  display: flex;
  flex-direction: column;
  align-items: center;
  gap: 10rpx;
}
.quick-icon {
  width: 88rpx;
  height: 88rpx;
  border-radius: 22rpx;
  display: flex;
  align-items: center;
  justify-content: center;
}
.quick-icon.blue   { background: #EFF6FF; }
.quick-icon.orange { background: #FFF7ED; }
.quick-icon.green  { background: #F0FDF4; }
.quick-icon.red    { background: #FEF2F2; }
.quick-emoji { font-size: 40rpx; }
.quick-lbl {
  font-size: 22rpx;
  color: #58655B;
}

/* Order list */
.order-list {
  background: #ffffff;
  border-radius: 20rpx;
  box-shadow: 0 4rpx 20rpx rgba(33,61,42,0.05);
  overflow: hidden;
}
.order-item {
  display: flex;
  flex-direction: row;
  align-items: center;
  justify-content: space-between;
  padding: 24rpx 28rpx;
  border-bottom: 1rpx solid #F5F5F5;
}
.order-left { flex: 1; }
.order-id {
  font-size: 20rpx;
  color: #B7C0B8;
  display: block;
}
.order-goods {
  font-size: 26rpx;
  color: #333333;
  margin-top: 4rpx;
  display: block;
}
.order-right {
  display: flex;
  flex-direction: column;
  align-items: flex-end;
  gap: 8rpx;
}
.order-amount {
  font-size: 28rpx;
  font-weight: 700;
  color: #B9852F;
}
.order-status {
  padding: 4rpx 14rpx;
  border-radius: 20rpx;
  background: #F5F5F5;
}
.order-status.pending { background: #FFF7ED; }
.order-status.done    { background: #F0FDF4; }
.order-status-text {
  font-size: 20rpx;
  color: #687468;
}
.order-status.pending .order-status-text { color: #D97706; }
.order-status.done .order-status-text    { color: #2F8A52; }
