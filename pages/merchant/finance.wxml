<!-- pages/merchant/finance.wxml — 资金结算 -->
<view class="page">
  <scroll-view class="scroll" scroll-y>

    <view class="header" style="padding-top: {{statusBarHeight}}px">
      <text class="header-tag">棉管家·商户版</text>
      <text class="header-title">资金结算</text>
    </view>

    <!-- 资金概览卡 -->
    <view class="fund-card">
      <view class="fund-main">
        <view class="fund-item">
          <text class="fund-val pending">¥{{summary.pending}}</text>
          <text class="fund-lbl">待结算</text>
        </view>
        <view class="fund-divider"></view>
        <view class="fund-item">
          <text class="fund-val settled">¥{{summary.settled}}</text>
          <text class="fund-lbl">已到账</text>
        </view>
        <view class="fund-divider"></view>
        <view class="fund-item">
          <text class="fund-val frozen">¥{{summary.frozen}}</text>
          <text class="fund-lbl">冻结中</text>
        </view>
      </view>
      <view class="withdraw-btn" bindtap="onWithdraw">
        <text class="withdraw-text">申请提现</text>
      </view>
    </view>

    <!-- 收支明细 -->
    <view class="section-title">收支明细</view>
    <view class="record-list">
      <view class="record-item" wx:for="{{records}}" wx:key="id">
        <view class="record-icon-wrap {{item.type}}">
          <text class="record-icon">
            {{item.type==='income'?'↑':item.type==='refund'?'↓':'→'}}
          </text>
        </view>
        <view class="record-info">
          <view class="record-top">
            <text class="record-type">{{item.typeLabel}}</text>
            <text class="record-amount {{item.type}}">{{item.amount}}</text>
          </view>
          <view class="record-bottom">
            <text class="record-desc">{{item.desc}}</text>
            <text class="record-time">{{item.time}}</text>
          </view>
          <text class="record-balance">余额 ¥{{item.balance}}</text>
        </view>
      </view>
    </view>

    <view style="height: 30rpx"></view>
  </scroll-view>

  <merchant-tab-bar selected="{{3}}"></merchant-tab-bar>
</view>
