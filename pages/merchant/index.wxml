<!-- pages/merchant/index.wxml — 商户首页数据看板 -->
<view class="page">
  <scroll-view class="scroll" scroll-y>

    <!-- 顶部Header -->
    <view class="header" style="padding-top: {{statusBarHeight}}px">
      <text class="header-tag">棉花智能体·商户版</text>
      <view class="store-block">
        <view class="store-avatar">
          <text class="avatar-text">{{user.real_name ? user.real_name[0] : '商'}}</text>
        </view>
        <view class="store-info">
          <text class="store-name">{{user.company_name || '我的店铺'}}</text>
          <text class="store-sub">负责人：{{user.real_name || '--'}}</text>
        </view>
      </view>
    </view>

    <!-- 数据统计卡片 -->
    <view class="section">
      <view class="stat-grid">
        <view class="stat-card" bindtap="goOrders">
          <text class="stat-val">{{stats.todayOrders}}</text>
          <text class="stat-lbl">今日订单</text>
          <text class="stat-unit">单</text>
        </view>
        <view class="stat-card warn" bindtap="goFinance">
          <text class="stat-val">¥{{stats.pendingAmount}}</text>
          <text class="stat-lbl">待收款</text>
          <text class="stat-unit">元</text>
        </view>
        <view class="stat-card ok" bindtap="goProducts">
          <text class="stat-val">{{stats.onSaleCount}}</text>
          <text class="stat-lbl">在售商品</text>
          <text class="stat-unit">种</text>
        </view>
        <view class="stat-card gold" bindtap="goFinance">
          <text class="stat-val">¥{{stats.monthRevenue}}</text>
          <text class="stat-lbl">本月营收</text>
          <text class="stat-unit">元</text>
        </view>
      </view>
    </view>

    <!-- 快捷操作 -->
    <view class="section">
      <view class="section-title">快捷操作</view>
      <view class="quick-row">
        <view class="quick-item" bindtap="goProducts">
          <view class="quick-icon blue"><text class="quick-emoji">📦</text></view>
          <text class="quick-lbl">发布商品</text>
        </view>
        <view class="quick-item" bindtap="goOrders">
          <view class="quick-icon orange"><text class="quick-emoji">📋</text></view>
          <text class="quick-lbl">订单管理</text>
        </view>
        <view class="quick-item" bindtap="goFinance">
          <view class="quick-icon green"><text class="quick-emoji">💰</text></view>
          <text class="quick-lbl">资金结算</text>
        </view>
        <view class="quick-item" bindtap="goOrders">
          <view class="quick-icon red"><text class="quick-emoji">🔔</text></view>
          <text class="quick-lbl">待处理</text>
        </view>
      </view>
    </view>

    <!-- 最近订单 -->
    <view class="section">
      <view class="section-hd">
        <text class="section-title">最近订单</text>
        <text class="section-more" bindtap="goOrders">查看全部 ›</text>
      </view>
      <view class="order-list">
        <view
          class="order-item"
          wx:for="{{recentOrders}}"
          wx:key="id"
          bindtap="goOrderDetail"
          data-id="{{item.id}}"
        >
          <view class="order-left">
            <text class="order-id">{{item.id}}</text>
            <text class="order-goods">{{item.goods}}</text>
          </view>
          <view class="order-right">
            <text class="order-amount">¥{{item.amount}}</text>
            <view class="order-status {{item.status}}">
              <text class="order-status-text">{{item.statusLabel}}</text>
            </view>
          </view>
        </view>
      </view>
    </view>

    <view style="height: 30rpx"></view>
  </scroll-view>

  <merchant-tab-bar selected="{{0}}"></merchant-tab-bar>
</view>
