<!-- pages/merchant/profile.wxml — 商户个人中心 -->
<view class="page">
  <scroll-view class="scroll" scroll-y>

    <!-- 顶部店铺信息 -->
    <view class="header" style="padding-top: {{statusBarHeight}}px">
      <text class="header-tag">棉花智能体·商户版</text>
      <view class="store-card">
        <view class="store-avatar">
          <text class="avatar-text">{{user.real_name?user.real_name[0]:'商'}}</text>
        </view>
        <view class="store-info">
          <text class="store-name">{{user.company_name || '我的店铺'}}</text>
          <text class="store-owner">负责人：{{user.real_name || '--'}}</text>
          <text class="store-phone">{{user.phone || '--'}}</text>
        </view>
      </view>
    </view>

    <!-- 店铺详情 -->
    <view class="section">
      <view class="section-title">店铺信息</view>
      <view class="info-card">
        <view class="info-row">
          <text class="info-lbl">营业执照</text>
          <text class="info-val">{{user.business_license || '未填写'}}</text>
        </view>
        <view class="info-row">
          <text class="info-lbl">经营品类</text>
          <text class="info-val">{{user.product_category || '未填写'}}</text>
        </view>
        <view class="info-row noborder">
          <text class="info-lbl">账号状态</text>
          <view class="verified-tag"><text class="verified-text">✓ 已认证</text></view>
        </view>
      </view>
    </view>

    <view class="section pay-section">
      <view class="section-title">微信支付入驻</view>
      <view class="info-card">
        <view class="info-row">
          <text class="info-lbl">支付状态</text>
          <view class="pay-status {{applyment.payment_enabled ? 'enabled' : 'disabled'}}">
            <text class="pay-status-text">{{applyment.payment_enabled ? '可收款' : '未开通'}}</text>
          </view>
        </view>
        <view class="info-row">
          <text class="info-lbl">子商户号</text>
          <text class="info-val">{{applyment.sub_mchid || '未绑定'}}</text>
        </view>
        <view class="info-row">
          <text class="info-lbl">审核状态</text>
          <text class="info-val">{{applyment.state_label || '未提交'}}</text>
        </view>
        <view class="info-row" wx:if="{{applyment.message}}">
          <text class="info-lbl">状态说明</text>
          <text class="info-val">{{applyment.message}}</text>
        </view>
        <view class="info-actions">
          <view class="small-btn primary" bindtap="openPayModal"><text>入驻资料</text></view>
          <view class="small-btn" bindtap="syncApplyment"><text>同步状态</text></view>
        </view>
      </view>
    </view>

    <!-- 功能列表 -->
    <view class="section">
      <view class="section-title">账号设置</view>
      <view class="menu-card">
        <view class="menu-item" bindtap="onChangePwd">
          <text class="menu-icon">🔐</text>
          <text class="menu-lbl">修改密码</text>
          <text class="menu-arrow">›</text>
        </view>
        <view class="menu-item" bindtap="onEditStore">
          <text class="menu-icon">🏪</text>
          <text class="menu-lbl">店铺资料</text>
          <text class="menu-arrow">›</text>
        </view>
        <view class="menu-item noborder" bindtap="onAbout">
          <text class="menu-icon">ℹ️</text>
          <text class="menu-lbl">关于我们</text>
          <text class="menu-arrow">›</text>
        </view>
      </view>
    </view>

    <!-- 退出按钮 -->
    <view class="logout-wrap" bindtap="onLogout">
      <text class="logout-text">退出登录</text>
    </view>

    <view style="height: 30rpx"></view>
  </scroll-view>

  <merchant-tab-bar selected="{{4}}"></merchant-tab-bar>

  <!-- 修改密码弹窗 -->
  <view class="modal-mask" wx:if="{{showPwdModal}}" bindtap="closePwdModal"></view>
  <view class="modal" wx:if="{{showPwdModal}}">
    <text class="modal-title">修改密码</text>
    <view class="form-item">
      <text class="form-label">原密码</text>
      <input class="form-input" placeholder="请输入原密码" password value="{{pwdForm.oldPwd}}" bindinput="onPwdInput" data-field="oldPwd"/>
    </view>
    <view class="form-item">
      <text class="form-label">新密码</text>
      <input class="form-input" placeholder="新密码（6位以上）" password value="{{pwdForm.newPwd}}" bindinput="onPwdInput" data-field="newPwd"/>
    </view>
    <view class="form-item">
      <text class="form-label">确认新密码</text>
      <input class="form-input" placeholder="再次输入新密码" password value="{{pwdForm.confirmPwd}}" bindinput="onPwdInput" data-field="confirmPwd"/>
    </view>
    <view class="modal-btns">
      <view class="modal-btn cancel" bindtap="closePwdModal"><text>取消</text></view>
      <view class="modal-btn confirm" bindtap="onSubmitPwd"><text>确认修改</text></view>
    </view>
  </view>

  <view class="modal-mask" wx:if="{{showPayModal}}" bindtap="closePayModal"></view>
  <view class="modal pay-modal" wx:if="{{showPayModal}}">
    <text class="modal-title">微信支付入驻</text>
    <view class="form-item">
      <text class="form-label">子商户号</text>
      <input class="form-input" placeholder="微信审核完成后填写" value="{{payForm.sub_mchid}}" bindinput="onPayInput" data-field="sub_mchid"/>
    </view>
    <view class="form-item">
      <text class="form-label">业务申请编号</text>
      <input class="form-input" placeholder="自动生成，可留空" value="{{payForm.business_code}}" bindinput="onPayInput" data-field="business_code"/>
    </view>
    <view class="form-item">
      <text class="form-label">联系人姓名</text>
      <input class="form-input" placeholder="商户联系人姓名" value="{{payForm.contact_name}}" bindinput="onPayInput" data-field="contact_name"/>
    </view>
    <view class="form-item">
      <text class="form-label">联系人手机</text>
      <input class="form-input" type="number" maxlength="11" placeholder="商户联系人手机号" value="{{payForm.contact_mobile}}" bindinput="onPayInput" data-field="contact_mobile"/>
    </view>
    <view class="form-item">
      <text class="form-label">联系人邮箱</text>
      <input class="form-input" placeholder="选填" value="{{payForm.contact_email}}" bindinput="onPayInput" data-field="contact_email"/>
    </view>
    <view class="form-item">
      <text class="form-label">客服电话</text>
      <input class="form-input" type="number" placeholder="对外服务电话" value="{{payForm.service_phone}}" bindinput="onPayInput" data-field="service_phone"/>
    </view>
    <view class="modal-btns three">
      <view class="modal-btn cancel" bindtap="closePayModal"><text>取消</text></view>
      <view class="modal-btn" bindtap="savePayDraft"><text>保存资料</text></view>
      <view class="modal-btn confirm" bindtap="bindSubMchid"><text>绑定号</text></view>
    </view>
    <view class="submit-applyment {{paySubmitting ? 'disabled' : ''}}" bindtap="submitApplyment">
      <text>{{paySubmitting ? '处理中...' : '提交微信审核'}}</text>
    </view>
  </view>
</view>
