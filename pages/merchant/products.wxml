<!-- pages/merchant/products.wxml — 商品管理 -->
<view class="page">
  <scroll-view class="scroll" scroll-y>

    <!-- 顶部 -->
    <view class="header" style="padding-top: {{statusBarHeight}}px">
      <text class="header-tag">棉花智能体·商户版</text>
      <view class="header-row">
        <text class="header-title">商品管理</text>
        <view class="add-btn" bindtap="onAdd">
          <text class="add-icon">＋</text>
          <text class="add-text">发布商品</text>
        </view>
      </view>
    </view>

    <!-- Tab 切换 -->
    <view class="tab-bar">
      <view class="tab-item {{tab==='on'?'active':''}}" bindtap="switchTab" data-tab="on">
        <text>在售商品</text>
      </view>
      <view class="tab-item {{tab==='off'?'active':''}}" bindtap="switchTab" data-tab="off">
        <text>已下架</text>
      </view>
    </view>

    <!-- 商品列表 -->
    <view class="prod-list">
      <view class="prod-card" wx:for="{{products}}" wx:key="id">
        <view class="prod-info">
          <view class="prod-icon"><text class="prod-emoji">📦</text></view>
          <view class="prod-detail">
            <text class="prod-name">{{item.name}}</text>
            <text class="prod-cat">{{item.category}}</text>
            <view class="prod-meta">
              <text class="prod-price">¥{{item.price}}</text>
              <text class="prod-unit">/{{item.unit}}</text>
              <text class="prod-stock {{item.stock===0?'out':''}}">
                库存{{item.stock===0?'：售罄':'：'+item.stock}}
              </text>
            </view>
          </view>
        </view>
        <view class="prod-actions">
          <view class="action-btn edit" bindtap="onEdit" data-id="{{item.id}}">
            <text>编辑</text>
          </view>
          <view class="action-btn {{item.status==='on'?'off-btn':'on-btn'}}" bindtap="onToggleStatus" data-id="{{item.id}}">
            <text>{{item.status==='on'?'下架':'上架'}}</text>
          </view>
          <view class="action-btn del" bindtap="onDelete" data-id="{{item.id}}">
            <text>删除</text>
          </view>
        </view>
      </view>

      <view class="empty" wx:if="{{products.length===0}}">
        <text class="empty-icon">📭</text>
        <text class="empty-text">{{tab==='on'?'暂无在售商品，点击发布商品':'暂无已下架商品'}}</text>
      </view>
    </view>

    <view style="height: 30rpx"></view>
  </scroll-view>

  <merchant-tab-bar selected="{{1}}"></merchant-tab-bar>

  <!-- 发布/编辑弹窗 -->
  <view class="modal-mask" wx:if="{{showAddModal}}" bindtap="closeModal"></view>
  <view class="modal" wx:if="{{showAddModal}}">
    <text class="modal-title">{{editProduct?'编辑商品':'发布商品'}}</text>
    <view class="form-item">
      <text class="form-label">商品名称 *</text>
      <input class="form-input" placeholder="请输入商品名称" value="{{form.name}}" bindinput="onInput" data-field="name"/>
    </view>
    <view class="form-item">
      <text class="form-label">商品分类</text>
      <input class="form-input" placeholder="如：化肥、农药" value="{{form.category}}" bindinput="onInput" data-field="category"/>
    </view>
    <view class="form-row">
      <view class="form-item half">
        <text class="form-label">价格（元）*</text>
        <input class="form-input" placeholder="0.00" type="digit" value="{{form.price}}" bindinput="onInput" data-field="price"/>
      </view>
      <view class="form-item half">
        <text class="form-label">单位</text>
        <input class="form-input" placeholder="如：袋/50kg" value="{{form.unit}}" bindinput="onInput" data-field="unit"/>
      </view>
    </view>
    <view class="form-item">
      <text class="form-label">库存数量</text>
      <input class="form-input" placeholder="0" type="number" value="{{form.stock}}" bindinput="onInput" data-field="stock"/>
    </view>
    <view class="modal-btns">
      <view class="modal-btn cancel" bindtap="closeModal"><text>取消</text></view>
      <view class="modal-btn confirm" bindtap="onSave"><text>{{editProduct?'保存修改':'立即上架'}}</text></view>
    </view>
  </view>
</view>
