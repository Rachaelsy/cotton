.page { display:flex; flex-direction:column; height:100vh; background:#F5EEE6; }

.rec-hd { background:linear-gradient(160deg,#4527A0,#7E57C2); padding:0 28rpx; flex-shrink:0; }
.rec-nav { display:flex; align-items:center; padding-bottom:16rpx; }
.back-btn { width:64rpx; height:64rpx; background:rgba(255,255,255,.2); border-radius:50%; display:flex; align-items:center; justify-content:center; }
.back-icon { font-size:40rpx; color:#fff; font-weight:700; }
.rec-title { flex:1; text-align:center; font-size:34rpx; font-weight:800; color:#fff; }
.rec-stats { display:flex; background:rgba(255,255,255,.15); border-radius:20rpx; padding:20rpx 0; margin-bottom:16rpx; }
.rec-stat { flex:1; display:flex; flex-direction:column; align-items:center; gap:4rpx; }
.rec-sdiv { width:2rpx; background:rgba(255,255,255,.25); }
.rs-v { font-size:44rpx; font-weight:800; color:#fff; line-height:1; }
.rs-l { font-size:20rpx; color:rgba(255,255,255,.8); }
.view-toggle { display:flex; background:rgba(255,255,255,.15); border-radius:20rpx; padding:6rpx; margin-bottom:24rpx; }
.vt-btn { flex:1; text-align:center; padding:14rpx; border-radius:16rpx; }
.vt-btn.on { background:#fff; }
.vt-text { font-size:24rpx; font-weight:600; color:rgba(255,255,255,.7); }
.vt-btn.on .vt-text { color:#4527A0; }

.type-filter-row { background:#fff; padding:20rpx 28rpx; white-space:nowrap; flex-shrink:0; }
.tfchip { display:inline-flex; background:#F5EEE6; border:2rpx solid #EEE5D8; border-radius:999rpx; padding:10rpx 28rpx; margin-right:16rpx; }
.tfchip.on { background:#C8902E; border-color:#C8902E; }
.tfchip-text { font-size:24rpx; color:#555; font-weight:600; white-space:nowrap; }
.tfchip.on .tfchip-text { color:#fff; }

.rec-scroll { flex:1; height:0; padding:20rpx 28rpx; }

.tl-item { display:flex; gap:24rpx; padding-bottom:24rpx; position:relative; }
.tl-item::before { content:''; position:absolute; left:39rpx; top:80rpx; bottom:0; width:4rpx; background:#F2EBE0; }
.tl-item:last-child::before { display:none; }
.tl-dot { width:80rpx; height:80rpx; border-radius:24rpx; display:flex; align-items:center; justify-content:center; flex-shrink:0; z-index:1; }
.tl-dot-emoji { font-size:44rpx; }
.tl-body { flex:1; background:#fff; border-radius:20rpx; padding:20rpx 24rpx; box-shadow:0 4rpx 20rpx rgba(0,0,0,.06); }
.tl-title-row { display:flex; align-items:center; justify-content:space-between; margin-bottom:8rpx; }
.tl-title { font-size:28rpx; font-weight:700; color:#1A1A1A; }
.tl-field-tag { background:#F5EEE6; border-radius:8rpx; padding:4rpx 12rpx; }
.tl-field-text { font-size:20rpx; color:#888; }
.tl-meta { display:block; font-size:22rpx; color:#888; margin-bottom:8rpx; }
.tl-detail { display:block; font-size:24rpx; color:#555; line-height:1.55; }

.rec-fab { position:fixed; bottom:176rpx; right:40rpx; width:100rpx; height:100rpx; background:#C8902E; border-radius:50%; display:flex; align-items:center; justify-content:center; box-shadow:0 8rpx 32rpx rgba(200,144,46,.45); }
.rec-fab-icon { font-size:60rpx; color:#fff; font-weight:300; line-height:1; }
