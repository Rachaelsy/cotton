.page {
  display: flex;
  flex-direction: column;
  height: 100vh;
  background: #F5EEE6;
  color: #1A1A1A;
}

.rec-hd {
  background: linear-gradient(160deg, #4527A0, #7E57C2);
  padding-left: 28rpx;
  padding-right: 28rpx;
  flex-shrink: 0;
}

.rec-nav {
  display: flex;
  align-items: center;
  padding-bottom: 16rpx;
}

.back-btn,
.manage-btn {
  width: 72rpx;
  height: 64rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  flex-shrink: 0;
}

.back-btn {
  background: rgba(255, 255, 255, .18);
  border-radius: 50%;
}

.back-icon {
  font-size: 46rpx;
  color: #fff;
  font-weight: 700;
  line-height: 1;
}

.rec-title-wrap {
  flex: 1;
  display: flex;
  flex-direction: column;
  align-items: center;
  min-width: 0;
}

.rec-title {
  font-size: 34rpx;
  font-weight: 800;
  color: #fff;
  line-height: 1.2;
}

.rec-subtitle {
  font-size: 18rpx;
  color: rgba(255, 255, 255, .72);
  margin-top: 4rpx;
  line-height: 1;
}

.manage-btn {
  background: rgba(255, 255, 255, .18);
  border-radius: 999rpx;
}

.manage-btn.done {
  background: #fff;
}

.manage-text {
  font-size: 24rpx;
  color: #fff;
  font-weight: 700;
}

.manage-btn.done .manage-text {
  color: #4527A0;
}

.rec-stats {
  display: flex;
  background: rgba(255, 255, 255, .15);
  border-radius: 20rpx;
  padding: 20rpx 0;
  margin-bottom: 16rpx;
}

.rec-stat {
  flex: 1;
  display: flex;
  flex-direction: column;
  align-items: center;
  gap: 4rpx;
  min-width: 0;
}

.rec-sdiv {
  width: 2rpx;
  background: rgba(255, 255, 255, .25);
}

.rs-v {
  font-size: 42rpx;
  font-weight: 800;
  color: #fff;
  line-height: 1;
}

.rs-l {
  font-size: 20rpx;
  color: rgba(255, 255, 255, .8);
}

.view-toggle {
  display: flex;
  background: rgba(255, 255, 255, .15);
  border-radius: 20rpx;
  padding: 6rpx;
  margin-bottom: 24rpx;
}

.vt-btn {
  flex: 1;
  height: 64rpx;
  border-radius: 16rpx;
  display: flex;
  align-items: center;
  justify-content: center;
}

.vt-btn.on {
  background: #fff;
}

.vt-text {
  font-size: 24rpx;
  font-weight: 700;
  color: rgba(255, 255, 255, .75);
}

.vt-btn.on .vt-text {
  color: #4527A0;
}

.edit-mode-tip {
  background: rgba(69, 39, 160, .08);
  border-bottom: 1rpx solid rgba(69, 39, 160, .18);
  padding: 16rpx 28rpx;
  flex-shrink: 0;
}

.edit-tip-text {
  font-size: 24rpx;
  color: #4527A0;
  font-weight: 700;
}

.filters {
  background: #fff;
  padding: 18rpx 0 16rpx;
  flex-shrink: 0;
}

.field-picker-filter {
  margin: 0 28rpx 18rpx;
  padding: 18rpx 22rpx;
  border-radius: 18rpx;
  background: #F8F3EC;
  border: 2rpx solid #EEE5D8;
  display: flex;
  align-items: center;
  justify-content: space-between;
  gap: 18rpx;
}

.field-picker-main {
  flex: 1;
  min-width: 0;
  display: flex;
  flex-direction: column;
  gap: 4rpx;
}

.field-picker-label {
  font-size: 20rpx;
  color: #8A7F72;
  font-weight: 700;
}

.field-picker-value {
  font-size: 27rpx;
  color: #1A1A1A;
  font-weight: 900;
  overflow: hidden;
  text-overflow: ellipsis;
  white-space: nowrap;
}

.field-picker-action {
  flex-shrink: 0;
  font-size: 23rpx;
  color: #C8902E;
  font-weight: 900;
}

.filter-row {
  width: 100%;
  white-space: nowrap;
  box-sizing: border-box;
  padding-left: 28rpx;
}

.field-row {
  margin-top: 14rpx;
}

.filter-chip,
.field-chip {
  display: inline-flex;
  align-items: center;
  justify-content: center;
  height: 56rpx;
  border-radius: 999rpx;
  padding: 0 28rpx;
  margin-right: 16rpx;
  box-sizing: border-box;
  border: 2rpx solid #EEE5D8;
  background: #F5EEE6;
}

.filter-chip.on {
  background: #4527A0;
  border-color: #4527A0;
}

.field-chip.on {
  background: #C8902E;
  border-color: #C8902E;
}

.filter-text,
.field-text {
  font-size: 24rpx;
  color: #555;
  font-weight: 700;
  white-space: nowrap;
}

.filter-chip.on .filter-text,
.field-chip.on .field-text {
  color: #fff;
}

.rec-scroll {
  flex: 1;
  height: 0;
  box-sizing: border-box;
  padding: 22rpx 28rpx 0;
}

.calendar-scroll {
  padding-top: 24rpx;
}

.tl-item {
  display: flex;
  gap: 24rpx;
  padding-bottom: 24rpx;
  position: relative;
}

.tl-item::before {
  content: '';
  position: absolute;
  left: 39rpx;
  top: 80rpx;
  bottom: 0;
  width: 4rpx;
  background: #EFE4D7;
}

.tl-item:last-child::before {
  display: none;
}

.tl-item.selected .tl-body {
  border-color: #7E57C2;
  box-shadow: 0 0 0 4rpx rgba(126, 87, 194, .14);
}

.select-dot {
  position: absolute;
  left: -4rpx;
  top: -4rpx;
  z-index: 4;
  width: 42rpx;
  height: 42rpx;
  border-radius: 50%;
  border: 4rpx solid #D6CABD;
  background: #fff;
  display: flex;
  align-items: center;
  justify-content: center;
  box-sizing: border-box;
}

.select-dot.on {
  background: #4527A0;
  border-color: #4527A0;
}

.select-check {
  font-size: 22rpx;
  color: #fff;
  font-weight: 900;
}

.tl-dot {
  width: 80rpx;
  height: 80rpx;
  border-radius: 24rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  flex-shrink: 0;
  z-index: 1;
}

.tl-dot-emoji {
  font-size: 42rpx;
}

.tl-body {
  flex: 1;
  background: #fff;
  border: 2rpx solid transparent;
  border-radius: 20rpx;
  padding: 20rpx 24rpx;
  box-shadow: 0 4rpx 20rpx rgba(0, 0, 0, .06);
  min-width: 0;
}

.tl-title-row {
  display: flex;
  align-items: center;
  justify-content: space-between;
  gap: 12rpx;
  margin-bottom: 8rpx;
}

.tl-title {
  flex: 1;
  min-width: 0;
  font-size: 28rpx;
  font-weight: 800;
  color: #1A1A1A;
}

.tl-field-tag {
  background: #F5EEE6;
  border-radius: 8rpx;
  padding: 4rpx 12rpx;
  flex-shrink: 0;
}

.tl-field-text {
  font-size: 20rpx;
  color: #7A5020;
  font-weight: 700;
}

.tl-meta {
  display: block;
  font-size: 22rpx;
  color: #888;
  margin-bottom: 8rpx;
}

.tl-detail {
  display: block;
  font-size: 24rpx;
  color: #555;
  line-height: 1.55;
}

.record-tags {
  display: flex;
  flex-wrap: wrap;
  gap: 10rpx;
  margin-top: 14rpx;
}

.record-tag {
  background: #F8F3EC;
  border-radius: 8rpx;
  padding: 6rpx 12rpx;
  font-size: 21rpx;
  color: #666;
  font-weight: 700;
}

.record-tag.cost {
  color: #C8902E;
}

.calendar-card {
  background: #fff;
  border-radius: 20rpx;
  padding: 22rpx;
  box-shadow: 0 4rpx 20rpx rgba(0, 0, 0, .05);
  margin-bottom: 24rpx;
}

.cal-nav {
  display: flex;
  align-items: center;
  justify-content: space-between;
  margin-bottom: 20rpx;
}

.cal-arr {
  width: 56rpx;
  height: 56rpx;
  border-radius: 50%;
  background: #F5EEE6;
  display: flex;
  align-items: center;
  justify-content: center;
}

.cal-arr text {
  font-size: 38rpx;
  color: #4527A0;
  font-weight: 800;
  line-height: 1;
}

.cal-month {
  font-size: 30rpx;
  font-weight: 800;
  color: #1A1A1A;
}

.cal-grid {
  display: flex;
  flex-direction: row;
  flex-wrap: wrap;
}

.cal-dow {
  width: 14.28%;
  box-sizing: border-box;
  text-align: center;
  font-size: 22rpx;
  color: #999;
  font-weight: 700;
  padding-bottom: 4rpx;
}

.cal-day {
  width: 14.28%;
  box-sizing: border-box;
  height: 72rpx;
  border: 5rpx solid transparent;
  background-clip: padding-box;
  border-radius: 16rpx;
  background-color: #FAF7F2;
  display: flex;
  align-items: center;
  justify-content: center;
  position: relative;
}

.cal-day.is-blank {
  background-color: transparent;
  border-color: transparent;
}

.cal-day.has-records {
  background-color: rgba(69, 39, 160, .08);
}

.cal-day.today {
  border-color: #C8902E;
}

.cal-day.selected {
  background-color: #4527A0;
}

.cal-day-num {
  font-size: 24rpx;
  color: #555;
  font-weight: 700;
}

.cal-day.selected .cal-day-num {
  color: #fff;
}

.cal-day.has-records::after {
  content: '';
  position: absolute;
  left: 50%;
  bottom: 8rpx;
  width: 8rpx;
  height: 8rpx;
  transform: translateX(-50%);
  background: #7E57C2;
  border-radius: 50%;
}

.cal-day.selected::after {
  background: #fff;
}

.cal-count {
  position: absolute;
  right: 8rpx;
  top: 6rpx;
  min-width: 24rpx;
  height: 24rpx;
  border-radius: 999rpx;
  background: #C8902E;
  color: #fff;
  font-size: 16rpx;
  text-align: center;
  line-height: 24rpx;
  font-weight: 800;
}

.calendar-list-title {
  font-size: 26rpx;
  font-weight: 800;
  color: #1A1A1A;
  margin: 0 0 16rpx;
}

.empty {
  display: flex;
  flex-direction: column;
  align-items: center;
  padding: 80rpx 20rpx;
  color: #888;
}

.empty.compact {
  padding: 40rpx 20rpx;
}

.empty-icon {
  font-size: 60rpx;
  line-height: 1;
}

.empty-title {
  font-size: 28rpx;
  font-weight: 800;
  color: #555;
  margin-top: 16rpx;
}

.empty-desc {
  font-size: 23rpx;
  color: #999;
  margin-top: 6rpx;
}

.rec-fab {
  position: fixed;
  right: 40rpx;
  bottom: 176rpx;
  width: 104rpx;
  height: 104rpx;
  background: #C8902E;
  border-radius: 50%;
  display: flex;
  align-items: center;
  justify-content: center;
  box-shadow: 0 8rpx 32rpx rgba(200, 144, 46, .45);
  z-index: 20;
}

.rec-fab-icon {
  font-size: 56rpx;
  color: #fff;
  font-weight: 400;
  line-height: 1;
}

.edit-act-bar {
  position: fixed;
  left: 0;
  right: 0;
  bottom: 0;
  padding: 18rpx 28rpx 42rpx;
  background: #fff;
  box-shadow: 0 -4rpx 24rpx rgba(0, 0, 0, .08);
  display: flex;
  gap: 18rpx;
  z-index: 30;
}

.select-all-btn,
.delete-btn {
  height: 88rpx;
  border-radius: 20rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  font-size: 28rpx;
  font-weight: 800;
}

.select-all-btn {
  width: 220rpx;
  background: #F5EEE6;
  color: #7A5020;
}

.delete-btn {
  flex: 1;
  background: #DC2626;
  color: #fff;
}

.delete-btn.off {
  background: #E8E1D8;
  color: #A49B91;
}

.modal-mask {
  position: fixed;
  top: 0;
  left: 0;
  right: 0;
  bottom: 0;
  background: rgba(0, 0, 0, .5);
  z-index: 100;
  display: flex;
  align-items: flex-end;
  justify-content: center;
}

.record-modal,
.detail-modal {
  width: 100%;
  background: #fff;
  border-radius: 36rpx 36rpx 0 0;
  padding: 34rpx 34rpx 52rpx;
  box-sizing: border-box;
  max-height: 88vh;
}

.modal-step-bar {
  display: flex;
  justify-content: center;
  gap: 12rpx;
  margin-bottom: 24rpx;
}

.step-dot {
  width: 44rpx;
  height: 8rpx;
  border-radius: 999rpx;
  background: #E8E1D8;
}

.step-dot.on {
  background: #4527A0;
}

.modal-title {
  display: block;
  font-size: 34rpx;
  font-weight: 900;
  color: #1A1A1A;
  text-align: center;
}

.modal-subtitle {
  display: block;
  font-size: 24rpx;
  color: #888;
  text-align: center;
  margin-top: 8rpx;
  margin-bottom: 26rpx;
}

.type-grid {
  display: flex;
  flex-direction: row;
  flex-wrap: wrap;
  justify-content: space-between;
}

.type-card {
  width: 48%;
  margin-bottom: 18rpx;
  box-sizing: border-box;
  height: 138rpx;
  border-radius: 20rpx;
  background: #F8F3EC;
  border: 3rpx solid transparent;
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
  gap: 8rpx;
}

.type-card.on {
  background: rgba(69, 39, 160, .08);
  border-color: #7E57C2;
}

.type-icon {
  font-size: 42rpx;
  line-height: 1;
}

.type-name {
  font-size: 26rpx;
  color: #1A1A1A;
  font-weight: 800;
}

.modal-cancel {
  height: 82rpx;
  border-radius: 20rpx;
  background: #F5EEE6;
  color: #7A5020;
  display: flex;
  align-items: center;
  justify-content: center;
  margin-top: 22rpx;
  font-size: 28rpx;
  font-weight: 800;
}

.form-row {
  margin-bottom: 20rpx;
}

.form-row.two {
  display: flex;
  gap: 18rpx;
}

.form-half {
  flex: 1;
  min-width: 0;
}

.form-label {
  display: block;
  font-size: 24rpx;
  color: #555;
  font-weight: 800;
  margin-bottom: 10rpx;
}

.form-picker,
.form-input,
.form-textarea {
  width: 100%;
  box-sizing: border-box;
  background: #F8F3EC;
  border: 2rpx solid #EEE5D8;
  border-radius: 16rpx;
  color: #1A1A1A;
  font-size: 26rpx;
}

.form-picker,
.form-input {
  height: 76rpx;
  line-height: 76rpx;
  padding: 0 22rpx;
}

.form-textarea {
  min-height: 136rpx;
  padding: 18rpx 22rpx;
  line-height: 1.45;
}

.modal-actions,
.detail-actions {
  display: flex;
  gap: 18rpx;
  margin-top: 26rpx;
}

.modal-btn,
.detail-btn {
  flex: 1;
  height: 88rpx;
  border-radius: 20rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  font-size: 28rpx;
  font-weight: 900;
}

.modal-btn.secondary {
  background: #F5EEE6;
  color: #7A5020;
}

.modal-btn.primary,
.detail-btn.primary {
  background: linear-gradient(135deg, #4527A0, #7E57C2);
  color: #fff;
}

.detail-head {
  display: flex;
  align-items: center;
  gap: 18rpx;
  margin-bottom: 28rpx;
}

.detail-icon {
  width: 82rpx;
  height: 82rpx;
  border-radius: 24rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  flex-shrink: 0;
}

.detail-icon text {
  font-size: 42rpx;
}

.detail-title-wrap {
  flex: 1;
  min-width: 0;
  display: flex;
  flex-direction: column;
}

.detail-title {
  font-size: 32rpx;
  font-weight: 900;
  color: #1A1A1A;
}

.detail-sub {
  font-size: 23rpx;
  color: #888;
  margin-top: 4rpx;
}

.detail-close {
  width: 56rpx;
  height: 56rpx;
  border-radius: 50%;
  background: #F5EEE6;
  display: flex;
  align-items: center;
  justify-content: center;
  color: #888;
  font-size: 34rpx;
  flex-shrink: 0;
}

.detail-grid {
  display: flex;
  flex-direction: row;
  flex-wrap: wrap;
  justify-content: space-between;
}

.detail-kv {
  width: 48%;
  margin-bottom: 16rpx;
  box-sizing: border-box;
}

.detail-kv,
.detail-note {
  background: #F8F3EC;
  border-radius: 16rpx;
  padding: 18rpx;
}

.detail-note {
  margin-top: 16rpx;
}

.kv-label {
  display: block;
  font-size: 22rpx;
  color: #999;
  font-weight: 700;
  margin-bottom: 8rpx;
}

.kv-value,
.note-text {
  display: block;
  font-size: 26rpx;
  color: #1A1A1A;
  font-weight: 800;
  line-height: 1.45;
}

.note-text {
  font-weight: 600;
  color: #555;
}

.detail-btn.danger {
  background: #FEF2F2;
  color: #DC2626;
}

.bottom-space {
  height: 180rpx;
}
