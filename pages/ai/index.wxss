/* pages/ai/index.wxss — AI问答 */

.page {
  display: flex;
  flex-direction: column;
  height: 100vh;
  background: #F5EEE6;
}

/* ===== 导航栏 ===== */
.ai-nav {
  background: #ffffff;
  border-bottom: 1rpx solid #F2EBE0;
  flex-shrink: 0;
  box-shadow: 0 2rpx 12rpx rgba(0,0,0,0.05);
}

.ai-nav-inner {
  display: flex;
  flex-direction: row;
  align-items: center;
  gap: 20rpx;
  padding: 16rpx 28rpx 20rpx;
}

.ai-avatar-wrap {
  position: relative;
  flex-shrink: 0;
}

.ai-avatar {
  width: 80rpx;
  height: 80rpx;
  background: linear-gradient(135deg, #C8902E, #D4A043);
  border-radius: 24rpx;
  display: flex;
  align-items: center;
  justify-content: center;
}

.ai-avatar-emoji { font-size: 44rpx; }

.ai-online-dot {
  position: absolute;
  bottom: -2rpx;
  right: -2rpx;
  width: 20rpx;
  height: 20rpx;
  background: #4ADE80;
  border-radius: 50%;
  border: 3rpx solid #ffffff;
}

.ai-nav-center { flex: 1; }

.ai-title-row {
  display: flex;
  flex-direction: row;
  align-items: center;
  gap: 12rpx;
  margin-bottom: 6rpx;
}

.ai-name {
  font-size: 32rpx;
  font-weight: 800;
  color: #1A1A1A;
}

.ai-badge {
  background: #1890FF;
  border-radius: 8rpx;
  padding: 3rpx 12rpx;
}

.ai-badge-text {
  font-size: 18rpx;
  font-weight: 700;
  color: #ffffff;
}

.ai-status-row {
  display: flex;
  flex-direction: row;
  align-items: center;
  gap: 8rpx;
}

.ai-status-dot {
  width: 12rpx;
  height: 12rpx;
  background: #4ADE80;
  border-radius: 50%;
}

.ai-status-text {
  font-size: 22rpx;
  color: #4CAF50;
}

.ai-more-btn {
  width: 64rpx;
  height: 64rpx;
  background: #F5EEE6;
  border-radius: 50%;
  display: flex;
  align-items: center;
  justify-content: center;
  flex-shrink: 0;
}

.ai-more-icon {
  font-size: 28rpx;
  color: #888888;
  letter-spacing: -4rpx;
  font-weight: 800;
}

/* ===== 聊天区 ===== */
.chat-scroll {
  flex: 1;
  height: 0;
  width: 100%;
}

.chat-inner {
  padding: 24rpx 28rpx 8rpx;
}

.chat-date-line {
  text-align: center;
  margin-bottom: 24rpx;
}

.chat-date-text {
  font-size: 22rpx;
  color: #888888;
  background: rgba(0,0,0,0.06);
  border-radius: 999rpx;
  padding: 6rpx 24rpx;
}

/* ===== 欢迎卡片 ===== */
.chat-ai-card {
  background: #ffffff;
  border-radius: 28rpx;
  padding: 24rpx;
  box-shadow: 0 4rpx 20rpx rgba(0,0,0,0.07);
  margin-bottom: 8rpx;
}

.cac-head {
  display: flex;
  flex-direction: row;
  align-items: center;
  gap: 16rpx;
  margin-bottom: 16rpx;
}

.cac-avatar {
  width: 72rpx;
  height: 72rpx;
  background: linear-gradient(135deg, #C8902E, #D4A043);
  border-radius: 20rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  flex-shrink: 0;
}

.cac-avatar.sm {
  width: 56rpx;
  height: 56rpx;
  border-radius: 16rpx;
}

.cac-avatar-emoji { font-size: 36rpx; }

.cac-name-row {
  display: flex;
  flex-direction: row;
  align-items: center;
  gap: 10rpx;
  margin-bottom: 4rpx;
}

.cac-name {
  font-size: 28rpx;
  font-weight: 700;
  color: #1A1A1A;
}

.cac-ai-chip {
  background: #1890FF;
  border-radius: 6rpx;
  padding: 2rpx 10rpx;
}

.cac-ai-text {
  font-size: 17rpx;
  font-weight: 700;
  color: #ffffff;
}

.cac-sub {
  font-size: 22rpx;
  color: #888888;
}

.cac-body {
  font-size: 28rpx;
  color: #1A1A1A;
  line-height: 1.7;
  margin-bottom: 20rpx;
}

.cac-bold { color: #C8902E; font-weight: 700; }

.quick-grid {
  display: flex;
  flex-direction: row;
  flex-wrap: wrap;
  gap: 16rpx;
}

.quick-item {
  width: 47%;
  background: #FBF5EA;
  border: 1rpx solid #EEE5D8;
  border-radius: 20rpx;
  padding: 20rpx;
  display: flex;
  flex-direction: row;
  align-items: center;
  gap: 12rpx;
}

.quick-icon { font-size: 32rpx; }

.quick-text {
  font-size: 24rpx;
  color: #555555;
}

/* ===== 消息 ===== */
.msg-row {
  display: flex;
  flex-direction: row;
  gap: 16rpx;
  margin-bottom: 24rpx;
  margin-top: 16rpx;
}

.ai-row { flex-direction: row; }

.user-row {
  flex-direction: row-reverse;
}

.user-avatar {
  width: 56rpx;
  height: 56rpx;
  background: linear-gradient(135deg, #1890FF, #40A9FF);
  border-radius: 16rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  flex-shrink: 0;
}

.user-avatar-text {
  font-size: 22rpx;
  font-weight: 700;
  color: #ffffff;
}

.msg-body {
  max-width: 74%;
  display: flex;
  flex-direction: column;
}

.msg-nm-left {
  font-size: 20rpx;
  color: #888888;
  margin-bottom: 6rpx;
}

.msg-nm-right {
  font-size: 20rpx;
  color: #888888;
  margin-bottom: 6rpx;
  text-align: right;
}

.bubble {
  padding: 20rpx 24rpx;
  border-radius: 24rpx;
}

.bubble-text {
  font-size: 28rpx;
  line-height: 1.65;
}

.ai-bubble {
  background: #ffffff;
  border-top-left-radius: 8rpx;
  box-shadow: 0 4rpx 16rpx rgba(0,0,0,0.07);
}

.ai-bubble .bubble-text { color: #1A1A1A; }

.user-bubble {
  background: #C8902E;
  border-top-right-radius: 8rpx;
}

.user-bubble .bubble-text { color: #ffffff; }

.bubble-img {
  width: 360rpx;
  border-radius: 16rpx;
  display: block;
  margin-bottom: 8rpx;
}

/* 打字动画 */
.typing-bubble {
  display: flex;
  flex-direction: row;
  align-items: center;
  gap: 8rpx;
  padding: 20rpx 28rpx;
}

.tdot {
  width: 12rpx;
  height: 12rpx;
  background: #888888;
  border-radius: 50%;
}

/* ===== 底部输入 ===== */
.chat-bottom {
  background: #ffffff;
  border-top: 1rpx solid #F2EBE0;
  flex-shrink: 0;
  padding-bottom: env(safe-area-inset-bottom);
}

.quick-row {
  padding: 16rpx 0 0;
  width: 100%;
}

.quick-chips-inner {
  display: flex;
  flex-direction: row;
  padding: 0 28rpx;
}

.quick-chip {
  background: #F5EEE6;
  border: 1rpx solid #EEE5D8;
  border-radius: 999rpx;
  padding: 10rpx 24rpx;
  margin-right: 16rpx;
  flex-shrink: 0;
}

.quick-chip-text {
  font-size: 24rpx;
  color: #555555;
  white-space: nowrap;
}

.input-row {
  display: flex;
  flex-direction: row;
  align-items: center;
  gap: 16rpx;
  padding: 16rpx 28rpx 20rpx;
}

.kbd-btn {
  width: 68rpx;
  height: 68rpx;
  background: #F5EEE6;
  border-radius: 50%;
  display: flex;
  align-items: center;
  justify-content: center;
  flex-shrink: 0;
}

.kbd-icon { font-size: 36rpx; }

.voice-btn {
  flex: 1;
  background: linear-gradient(135deg, #C8902E, #D4A043);
  border-radius: 999rpx;
  padding: 22rpx;
  display: flex;
  flex-direction: row;
  align-items: center;
  justify-content: center;
  gap: 16rpx;
  box-shadow: 0 6rpx 24rpx rgba(200, 144, 46, 0.4);
}

.voice-btn-icon { font-size: 36rpx; }

.voice-btn-text {
  font-size: 28rpx;
  font-weight: 700;
  color: #ffffff;
}

.txt-input {
  flex: 1;
  background: #F5EEE6;
  border: 3rpx solid #EEE5D8;
  border-radius: 40rpx;
  padding: 16rpx 28rpx;
  font-size: 28rpx;
  color: #1A1A1A;
}

.send-btn {
  width: 68rpx;
  height: 68rpx;
  background: #C8902E;
  border-radius: 50%;
  display: flex;
  align-items: center;
  justify-content: center;
  flex-shrink: 0;
}

.send-btn.off { background: #BBBBBB; }

.send-icon {
  font-size: 28rpx;
  color: #ffffff;
  font-weight: 700;
}
