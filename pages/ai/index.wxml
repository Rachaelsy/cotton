<!-- pages/ai/index.wxml — AI问答 -->
<view class="page" bindtouchend="onVoiceGlobalEnd" bindtouchcancel="onVoiceGlobalCancel">

  <!-- 顶部导航 -->
  <view class="ai-nav" style="padding-top: {{statusBarHeight}}px">
    <view class="ai-nav-inner" style="padding-right: {{capsuleSafeRight}}px">
      <view class="ai-avatar-wrap">
        <view class="ai-avatar">
          <text class="ai-avatar-emoji">🤖</text>
        </view>
        <view class="ai-online-dot"></view>
      </view>
      <view class="ai-nav-center">
        <view class="ai-title-row">
          <text class="ai-name">{{copy.title}}</text>
          <view class="ai-badge"><text class="ai-badge-text">AI</text></view>
        </view>
        <view class="ai-status-row">
          <view class="ai-status-dot {{(recording || recordingStarting) ? 'recording' : ((recognizing || speaking) ? 'speaking' : '')}}"></view>
          <text class="ai-status-text">{{recordingStarting ? copy.voicePreparing : (recording ? copy.voiceListening : (recognizing ? copy.voiceRecognizing : (speaking ? copy.speaking : copy.status)))}}</text>
        </view>
      </view>
      <view class="ai-more-btn" bindtap="onMore">
        <text class="ai-more-icon">···</text>
      </view>
    </view>
  </view>

  <!-- 聊天区域 -->
  <scroll-view class="chat-scroll" scroll-y scroll-into-view="{{scrollToId}}" scroll-with-animation>
  <view class="chat-inner">

    <view class="chat-date-line">
      <text class="chat-date-text">{{copy.today}} {{timeStr}}</text>
    </view>

    <!-- AI 欢迎卡片 -->
    <view class="chat-ai-card">
      <view class="cac-head">
        <view class="cac-avatar"><text class="cac-avatar-emoji">🤖</text></view>
        <view class="cac-info">
          <view class="cac-name-row">
            <text class="cac-name">{{copy.assistantName}}</text>
            <view class="cac-ai-chip"><text class="cac-ai-text">AI</text></view>
          </view>
          <text class="cac-sub">{{copy.assistantSub}}</text>
        </view>
      </view>
      <text class="cac-body">{{copy.welcome}}</text>
      <view class="quick-grid">
        <view class="quick-item" wx:for="{{quickList}}" wx:key="index" bindtap="onQuick" data-q="{{item.t}}">
          <text class="quick-icon">{{item.i}}</text>
          <text class="quick-text">{{item.t}}</text>
        </view>
      </view>
    </view>

    <!-- 消息列表 -->
    <view wx:for="{{messages}}" wx:key="id" id="msg{{item.id}}">
      <!-- 用户消息 -->
      <view wx:if="{{item.role === 'user'}}" class="msg-row user-row">
        <view class="user-avatar"><text class="user-avatar-text">{{copy.farmerShort}}</text></view>
        <view class="msg-body">
          <text class="msg-nm-right">{{copy.me}}</text>
          <view class="bubble user-bubble">
            <image
              wx:if="{{item.image}}"
              class="bubble-img"
              src="{{item.image}}"
              mode="widthFix"
              show-menu-by-longpress
            ></image>
            <text wx:if="{{item.text}}" class="bubble-text">{{item.text}}</text>
          </view>
        </view>
      </view>
      <!-- AI 消息 -->
      <view wx:else class="msg-row ai-row">
        <view class="cac-avatar sm"><text class="cac-avatar-emoji">🤖</text></view>
        <view class="msg-body">
          <text class="msg-nm-left">{{copy.assistantName}} · {{item.time}}</text>
          <view class="bubble ai-bubble">
            <rich-text wx:if="{{item.richTextNodes}}" class="bubble-text" nodes="{{item.richTextNodes}}"></rich-text>
            <text wx:else class="bubble-text">{{item.text}}</text>
          </view>
          <view wx:if="{{item.speakable}}" class="message-actions">
            <view
              class="replay-answer {{speaking && speakingMessageId === item.id ? 'active' : ''}}"
              bindtap="onReplayAnswer"
              data-id="{{item.id}}"
            >
              <text class="replay-answer-icon">{{speaking && speakingMessageId === item.id ? '■' : '🔊'}}</text>
              <text class="replay-answer-text">{{copy.replayAnswer}}</text>
            </view>
          </view>
          <view
            wx:if="{{item.jump}}"
            class="jump-card"
            bindtap="onJump"
            data-url="{{item.jump.url}}"
            data-method="{{item.jump.method}}"
          >
            <view class="jump-icon"><text>{{item.jump.icon}}</text></view>
            <view class="jump-main">
              <text class="jump-kicker">{{copy.jumpForYou}}</text>
              <text class="jump-title">{{item.jump.title}}</text>
              <text class="jump-desc">{{item.jump.desc}}</text>
            </view>
            <view class="jump-enter"><text>{{copy.jumpEnter}}</text></view>
          </view>
        </view>
      </view>
    </view>

    <!-- 打字中 -->
    <view wx:if="{{typing}}" class="msg-row ai-row">
      <view class="cac-avatar sm"><text class="cac-avatar-emoji">🤖</text></view>
      <view class="msg-body">
        <text class="msg-nm-left">{{copy.assistantName}}</text>
        <view class="bubble ai-bubble typing-bubble">
          <view class="tdot"></view>
          <view class="tdot"></view>
          <view class="tdot"></view>
        </view>
      </view>
    </view>

    <view id="bottom" style="height: 20rpx"></view>
  </view>
  </scroll-view>

  <!-- 底部输入区 -->
  <view class="chat-bottom">
    <scroll-view class="quick-row" scroll-x>
      <view class="quick-chips-inner">
        <view class="quick-chip" wx:for="{{chips}}" wx:key="index" bindtap="onQuick" data-q="{{item}}">
          <text class="quick-chip-text">{{item}}</text>
        </view>
      </view>
    </scroll-view>
    <view class="answer-mode-row">
      <view class="voice-answer-toggle {{voiceAnswerEnabled ? 'on' : ''}}" bindtap="onToggleVoiceAnswer">
        <view class="voice-answer-switch">
          <view class="voice-answer-knob"></view>
        </view>
        <text class="voice-answer-label">{{copy.voiceAnswer}}</text>
        <text class="voice-answer-state">{{voiceAnswerEnabled ? copy.voiceAnswerOn : copy.voiceAnswerOff}}</text>
      </view>
    </view>
    <view class="input-row">
      <view class="kbd-btn" bindtap="onToggleInput">
        <text class="kbd-icon">{{voiceMode ? '⌨️' : '🎤'}}</text>
      </view>
      <view
        wx:if="{{voiceMode}}"
        class="voice-wrap"
      >
        <view
          class="voice-btn {{(recording || recordingStarting) ? 'recording' : ''}}"
          bindtouchstart="onVoiceStart"
          bindtouchend="onVoiceEnd"
          bindtouchcancel="onVoiceCancel"
          bindtap="onVoiceTapFallback"
        >
          <text class="voice-btn-icon">🎤</text>
          <text class="voice-btn-text">{{recognizing ? copy.voiceRecognizing : ((recording || recordingStarting) ? copy.voiceRelease : copy.voiceHold)}}</text>
        </view>
        <text wx:if="{{(recording || recordingStarting || recognizing) && voiceLiveText}}" class="voice-live-text">{{voiceLiveText}}</text>
      </view>
      <input
        wx:else
        class="txt-input"
        value="{{inputText}}"
        bindinput="onInput"
        placeholder="{{copy.inputPh}}"
        confirm-type="send"
        bindconfirm="onSend"
      />
      <view wx:if="{{!voiceMode}}" class="send-btn {{inputText ? '' : 'off'}}" bindtap="onSend">
        <text class="send-icon">▲</text>
      </view>
    </view>
  </view>
  <tab-bar selected="{{1}}"></tab-bar>
</view>
