.page { display:flex; flex-direction:column; height:100vh; background:#F5EEE6; }

.trade-hd {
  background:linear-gradient(160deg,#1A0A00,#3D2000);
  padding:0 28rpx 0; flex-shrink:0;
}
.trade-nav { display:flex; align-items:center; padding-bottom:20rpx; }
.back-btn {
  width:64rpx; height:64rpx; background:rgba(255,255,255,.15); border-radius:50%;
  display:flex; align-items:center; justify-content:center;
}
.back-icon { font-size:40rpx; color:#fff; font-weight:700; }
.trade-nav-title { flex:1; text-align:center; font-size:34rpx; font-weight:800; color:#fff; }

.price-tabs { display:flex; background:rgba(255,255,255,.12); border-radius:20rpx; padding:6rpx; margin-bottom:16rpx; }
.ptab { flex:1; text-align:center; padding:16rpx; border-radius:16rpx; }
.ptab.on { background:linear-gradient(135deg,#D4A043,#C8902E); }
.ptab-text { font-size:26rpx; font-weight:600; color:rgba(255,255,255,.6); }
.ptab.on .ptab-text { color:#fff; }

.price-main { display:flex; align-items:baseline; gap:12rpx; }
.price-big { font-size:112rpx; font-weight:800; color:#fff; line-height:1; }
.price-unit { font-size:28rpx; color:rgba(255,255,255,.7); }
.price-change { display:flex; align-items:center; margin:8rpx 0 28rpx; }
.price-change.up { }
.price-change-text { background:#EF4444; color:#fff; font-size:24rpx; font-weight:700; padding:8rpx 20rpx; border-radius:12rpx; }

.trade-scroll { flex:1; height:0; }

.trade-quick-card { background:#fff; border-radius:40rpx 40rpx 0 0; padding:36rpx 28rpx 0; margin-top:-28rpx; }
.trade-quick-grid { display:flex; flex-direction:row; margin-bottom:8rpx; }
.trade-quick-item { flex:1; display:flex; flex-direction:column; align-items:center; gap:12rpx; padding:12rpx 0; }
.tqi-ico { width:104rpx; height:104rpx; border-radius:32rpx; display:flex; align-items:center; justify-content:center; }
.tqi-emoji { font-size:52rpx; }
.tqi-lbl { font-size:22rpx; color:#555; font-weight:600; }

.trade-tabs { display:flex; flex-direction:row; margin:0 28rpx 0; background:#fff; border-radius:28rpx; padding:8rpx; box-shadow:0 4rpx 20rpx rgba(0,0,0,.05); }
.ttab { flex:1; text-align:center; padding:18rpx; border-radius:20rpx; }
.ttab.on { background:#F5EEE6; }
.ttab-text { font-size:26rpx; font-weight:600; color:#888; }
.ttab.on .ttab-text { color:#C8902E; font-weight:800; }

.hcard { background:#fff; border-radius:28rpx; margin:20rpx 28rpx 0; padding:28rpx; box-shadow:0 4rpx 20rpx rgba(0,0,0,.05); }

.region-row { display:flex; align-items:center; gap:16rpx; padding:22rpx 0; border-bottom:2rpx solid #F2EBE0; }
.region-row:last-child { border-bottom:none; }
.rank-num { width:44rpx; height:44rpx; border-radius:50%; background:#F5EEE6; display:flex; align-items:center; justify-content:center; }
.rank-num.top { background:#1A0A00; }
.rank-text { font-size:22rpx; font-weight:800; color:#888; }
.rank-num.top .rank-text { color:#FFCC02; }
.region-name { flex:1; font-size:28rpx; font-weight:600; color:#1A1A1A; }
.region-price { font-size:28rpx; font-weight:800; color:#1A1A1A; }
.region-change { font-size:24rpx; font-weight:700; min-width:80rpx; text-align:right; }
.region-change.up { color:#EF4444; }
.region-change.dn { color:#22C55E; }

.chart-placeholder { display:block; font-size:24rpx; color:#888; margin-bottom:16rpx; }
.chart-mock { display:flex; align-items:flex-end; gap:8rpx; height:160rpx; border-bottom:2rpx solid #EEE5D8; }
.chart-bar { flex:1; background:linear-gradient(180deg,#C8902E,#F5C842); border-radius:8rpx 8rpx 0 0; }
.chart-labels { display:flex; margin-top:8rpx; }
.chart-lbl { flex:1; font-size:18rpx; color:#888; text-align:center; }

.my-trade-item { display:flex; align-items:center; gap:16rpx; padding:20rpx 0; }
.mti-status { border-radius:999rpx; padding:6rpx 16rpx; }
.mti-status.done { background:#E8F5E9; }
.mti-status.prog { background:#FFF3E6; }
.mti-status-text { font-size:22rpx; font-weight:700; color:#4CAF50; }
.mti-status.prog .mti-status-text { color:#FF6B00; }
.mti-name { display:block; font-size:28rpx; font-weight:600; color:#1A1A1A; }
.mti-meta { display:block; font-size:22rpx; color:#888; margin-top:4rpx; }
.mti-price { font-size:30rpx; font-weight:800; color:#C8902E; }
.mi-div { height:2rpx; background:#F2EBE0; }
