<!-- pages/fields/draw.wxml — 地块边界绘制 -->
<view class="page">

  <!-- 顶部导航（三种模式共用，标题随状态切换） -->
  <view class="nav" style="padding-top: {{statusBarHeight}}px">
    <view class="nav-back" bindtap="onBack">
      <text class="nav-back-icon">‹</text>
    </view>
    <view class="nav-center">
      <text class="nav-title">{{showForm ? '填写地块信息' : '绘制地块边界'}}</text>
      <text class="nav-sub">{{showForm ? '已绘制约 ' + area + ' 亩' : tipText}}</text>
    </view>
    <view class="nav-help">
      <text class="nav-help-text">?</text>
    </view>
  </view>

  <!-- ══════════ 绘制模式 ══════════ -->
  <view wx:if="{{!showForm}}" class="draw-container">

    <map
      id="mymap"
      class="map"
      latitude="{{mapLat}}"
      longitude="{{mapLng}}"
      scale="16"
      markers="{{markers}}"
      polylines="{{polylines}}"
      polygons="{{polygons}}"
      enable-satellite="{{isSatellite}}"
      show-location
      enable-zoom
      enable-scroll
      enable-rotate="{{false}}"
      bindtap="onMapTap"
      bindmarkertap="onMarkerTap"
      bindcallouttap="onCalloutTap"
    ></map>

    <!-- 右侧工具栏 -->
    <view class="toolbar">
      <view class="tool-btn" bindtap="onLocate">
        <text class="tool-icon">📍</text>
        <text class="tool-lbl">定位</text>
      </view>
      <view class="tool-btn {{isSatellite ? 'tool-active' : ''}}" bindtap="onToggleSatellite">
        <text class="tool-icon">🛰</text>
        <text class="tool-lbl">{{isSatellite ? '卫星' : '地图'}}</text>
      </view>
      <view class="tool-btn {{points.length === 0 ? 'tool-disabled' : ''}}" bindtap="onUndo">
        <text class="tool-icon">↩</text>
        <text class="tool-lbl">撤销</text>
      </view>
      <view class="tool-btn {{points.length === 0 ? 'tool-disabled' : ''}}" bindtap="onClear">
        <text class="tool-icon">🗑</text>
        <text class="tool-lbl">清空</text>
      </view>
    </view>

    <!-- 面积浮层 -->
    <view wx:if="{{points.length >= 3}}" class="area-float">
      <text class="area-label">当前面积</text>
      <view class="area-row">
        <text class="area-val">{{area}}</text>
        <text class="area-unit">亩</text>
      </view>
    </view>

    <!-- 底部信息 + 按钮 -->
    <view class="bottom-bar">
      <view class="stats-row">
        <view class="stat">
          <text class="stat-val">{{points.length}}</text>
          <text class="stat-lbl">顶点</text>
        </view>
        <view class="stat-div"></view>
        <view class="stat">
          <text class="stat-val">{{area}}</text>
          <text class="stat-lbl">亩</text>
        </view>
        <view class="stat-div"></view>
        <view class="stat">
          <text class="stat-val">{{perimeter}}</text>
          <text class="stat-lbl">米周长</text>
        </view>
      </view>
      <view class="btn-row">
        <view class="cancel-btn" bindtap="onBack">
          <text class="cancel-text">✕ 取消</text>
        </view>
        <view
          class="finish-btn {{points.length < 3 ? 'finish-disabled' : ''}}"
          bindtap="onFinishDraw"
        >
          <text class="finish-text">✓ 完成绘制</text>
        </view>
      </view>
    </view>

  </view><!-- /draw-container -->

  <!-- ══════════ 表单模式（普通流，无 fixed，Skyline 安全）══════════ -->
  <view wx:if="{{showForm}}" class="form-container">

    <scroll-view class="form-scroll" scroll-y>

      <view class="field-row">
        <text class="field-label">地块名称 <text class="req">*</text></text>
        <input
          class="field-input"
          placeholder="如：3号地·主力田"
          value="{{form.name}}"
          bindinput="onNameInput"
          maxlength="20"
        />
      </view>

      <view class="field-row">
        <text class="field-label">种植品种</text>
        <input
          class="field-input"
          placeholder="如：新陆早57号"
          value="{{form.variety}}"
          bindinput="onVarietyInput"
          maxlength="30"
        />
      </view>

      <view class="field-row">
        <text class="field-label">播种日期</text>
        <picker mode="date" value="{{form.sowDate}}" bindchange="onSowDateChange">
          <view class="field-picker">
            <text class="{{form.sowDate ? 'picker-val' : 'picker-placeholder'}}">
              {{form.sowDate || '选择日期'}}
            </text>
            <text class="picker-arrow">›</text>
          </view>
        </picker>
      </view>

      <view class="field-row">
        <text class="field-label">灌溉方式</text>
        <picker mode="selector" range="{{irrigationOptions}}" value="{{irrigationIndex}}" bindchange="onIrrChange">
          <view class="field-picker">
            <text class="picker-val">{{form.irrigation}}</text>
            <text class="picker-arrow">›</text>
          </view>
        </picker>
      </view>

      <view class="field-row">
        <text class="field-label">土壤类型</text>
        <picker mode="selector" range="{{soilOptions}}" value="{{soilIndex}}" bindchange="onSoilChange">
          <view class="field-picker">
            <text class="{{form.soilType ? 'picker-val' : 'picker-placeholder'}}">
              {{form.soilType || '选择土壤类型'}}
            </text>
            <text class="picker-arrow">›</text>
          </view>
        </picker>
      </view>

      <view style="height: 20rpx"></view>
    </scroll-view>

    <view class="form-save-btn {{saving ? 'save-disabled' : ''}}" bindtap="onSave">
      <text class="form-save-text">{{saving ? '保存中...' : '💾 保存地块'}}</text>
    </view>

  </view><!-- /form-container -->

</view>
