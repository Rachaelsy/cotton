.page {
  display: flex;
  flex-direction: column;
  height: 100vh;
  color: #18231A;
  background: #F6F8F3;
}

.nav {
  flex-shrink: 0;
  min-height: 84rpx;
  padding-left: 24rpx;
  padding-right: 24rpx;
  padding-bottom: 14rpx;
  display: flex;
  align-items: center;
  background: rgba(255, 255, 255, .98);
  box-shadow: 0 3rpx 16rpx rgba(55, 40, 28, .10);
  z-index: 12;
}

.nav-side {
  min-width: 76rpx;
  height: 56rpx;
  padding: 0 14rpx;
  border-radius: 999rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  color: #5D554E;
  background: #F8FAF5;
  font-size: 22rpx;
  font-weight: 700;
  box-sizing: border-box;
}

.nav-help {
  color: #B9852F;
  background: #FFF8EA;
}

.nav-center {
  flex: 1;
  display: flex;
  flex-direction: column;
  align-items: center;
}

.nav-title {
  color: #18231A;
  font-size: 29rpx;
  font-weight: 900;
}

.nav-sub {
  margin-top: 3rpx;
  color: #8A948B;
  font-size: 19rpx;
}

.draw-container {
  position: relative;
  flex: 1;
  display: flex;
  flex-direction: column;
  min-height: 0;
}

.map {
  flex: 1;
  width: 100%;
}

.toolbar {
  position: absolute;
  top: 26rpx;
  right: 22rpx;
  z-index: 10;
  display: flex;
  flex-direction: column;
  gap: 14rpx;
}

.tool-btn {
  width: 98rpx;
  min-height: 82rpx;
  padding: 9rpx 6rpx;
  border-radius: 18rpx;
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
  background: #FFFFFF;
  box-shadow: 0 5rpx 18rpx rgba(33, 61, 42, .14);
  box-sizing: border-box;
}

.tool-primary { background: #2D86B8; }
.tool-primary .tool-title,
.tool-primary .tool-sub { color: #FFFFFF; }

.tool-active {
  background: #FFF8EA;
  border: 2rpx solid #D7AD59;
}

.tool-title {
  color: #18231A;
  font-size: 22rpx;
  font-weight: 800;
}

.tool-sub {
  margin-top: 3rpx;
  color: #8A948B;
  font-size: 16rpx;
}

.tool-disabled {
  opacity: .42;
  pointer-events: none;
}

.walk-track-card {
  position: absolute;
  top: 26rpx;
  left: 22rpx;
  right: 138rpx;
  z-index: 9;
  padding: 18rpx;
  border-radius: 22rpx;
  background: rgba(255, 255, 255, .96);
  box-shadow: 0 6rpx 24rpx rgba(33, 61, 42, .14);
  box-sizing: border-box;
}

.walk-track-active {
  border: 2rpx solid rgba(47, 125, 75, .25);
  background: rgba(246, 252, 247, .98);
}

.walk-track-head {
  display: flex;
  align-items: center;
  justify-content: space-between;
  gap: 16rpx;
}

.walk-track-title-wrap {
  flex: 1;
  min-width: 0;
  display: flex;
  flex-direction: column;
  gap: 5rpx;
}

.walk-track-title {
  color: #18231A;
  font-size: 25rpx;
  font-weight: 900;
}

.walk-track-sub {
  color: #7C887D;
  font-size: 19rpx;
  line-height: 1.35;
}

.walk-track-action {
  flex-shrink: 0;
  min-width: 130rpx;
  height: 58rpx;
  padding: 0 18rpx;
  border-radius: 999rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  color: #FFFFFF;
  background: #2F7D4B;
  font-size: 22rpx;
  font-weight: 900;
  box-shadow: 0 5rpx 15rpx rgba(47, 125, 75, .22);
}

.walk-track-stop {
  background: #C56C2D;
  box-shadow: 0 5rpx 15rpx rgba(197, 108, 45, .22);
}

.walk-track-metrics {
  margin-top: 16rpx;
  display: flex;
  gap: 10rpx;
}

.walk-track-metric {
  flex: 1;
  min-width: 0;
  padding: 12rpx 8rpx;
  border-radius: 16rpx;
  display: flex;
  flex-direction: column;
  align-items: center;
  background: #F8FAF5;
}

.walk-track-value {
  color: #2F7D4B;
  font-size: 25rpx;
  font-weight: 900;
  line-height: 1.15;
}

.walk-track-label {
  margin-top: 4rpx;
  color: #8A948B;
  font-size: 17rpx;
}

.walk-track-status {
  display: block;
  margin-top: 12rpx;
  color: #9B6738;
  font-size: 19rpx;
  line-height: 1.35;
}

.coord-panel {
  position: absolute;
  top: 26rpx;
  left: 22rpx;
  right: 138rpx;
  z-index: 11;
  padding: 18rpx;
  border-radius: 22rpx;
  background: rgba(255, 255, 255, .96);
  box-shadow: 0 6rpx 24rpx rgba(33, 61, 42, .14);
}

.coord-head {
  display: flex;
  align-items: flex-start;
  justify-content: space-between;
  gap: 16rpx;
}

.coord-title {
  display: block;
  color: #18231A;
  font-size: 25rpx;
  font-weight: 900;
}

.coord-hint {
  display: block;
  margin-top: 5rpx;
  color: #8A948B;
  font-size: 19rpx;
  line-height: 1.45;
}

.coord-close {
  flex-shrink: 0;
  color: #2F7D4B;
  font-size: 21rpx;
  font-weight: 800;
}

.coord-input-row {
  display: flex;
  gap: 12rpx;
  margin-top: 16rpx;
}

.coord-input-wrap {
  flex: 1;
  min-width: 0;
  padding: 10rpx 12rpx;
  border-radius: 14rpx;
  background: #F8FAF5;
}

.coord-label {
  display: block;
  color: #58655B;
  font-size: 18rpx;
}

.coord-input {
  margin-top: 4rpx;
  width: 100%;
  height: 42rpx;
  color: #18231A;
  font-size: 23rpx;
}

.coord-picked {
  display: block;
  margin-top: 12rpx;
  color: #2D86B8;
  font-size: 20rpx;
  font-weight: 700;
  line-height: 1.35;
}

.coord-actions {
  display: flex;
  gap: 12rpx;
  margin-top: 14rpx;
}

.coord-btn {
  flex: 1;
  height: 58rpx;
  border-radius: 999rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  font-size: 22rpx;
  font-weight: 800;
}

.coord-btn.secondary {
  color: #58655B;
  background: #EAF0E6;
}

.coord-btn.primary {
  color: #FFFFFF;
  background: #2F7D4B;
}

.draw-empty-tip {
  position: absolute;
  top: 42%;
  left: 50%;
  transform: translate(-50%, -50%);
  padding: 22rpx 30rpx;
  border-radius: 20rpx;
  display: flex;
  flex-direction: column;
  align-items: center;
  background: rgba(255, 255, 255, .92);
  box-shadow: 0 5rpx 20rpx rgba(60, 45, 32, .12);
  pointer-events: none;
}

.draw-empty-title {
  color: #18231A;
  font-size: 24rpx;
  font-weight: 800;
}

.draw-empty-sub {
  margin-top: 6rpx;
  color: #8A948B;
  font-size: 19rpx;
  white-space: nowrap;
}

.area-float {
  position: absolute;
  top: 48%;
  left: 50%;
  transform: translate(-50%, -50%);
  z-index: 6;
  min-width: 190rpx;
  padding: 20rpx 30rpx;
  border-radius: 22rpx;
  display: flex;
  flex-direction: column;
  align-items: center;
  background: rgba(255, 255, 255, .96);
  box-shadow: 0 8rpx 28rpx rgba(49, 37, 26, .20);
  pointer-events: none;
}

.area-label {
  color: #8A948B;
  font-size: 19rpx;
}

.area-row {
  margin-top: 3rpx;
  display: flex;
  align-items: baseline;
  gap: 7rpx;
}

.area-val {
  color: #18231A;
  font-size: 58rpx;
  font-weight: 900;
  line-height: 1;
}

.area-unit {
  color: #766C63;
  font-size: 22rpx;
}

.draw-hint {
  position: absolute;
  right: 24rpx;
  bottom: 222rpx;
  left: 24rpx;
  z-index: 8;
  padding: 17rpx 20rpx;
  border-radius: 18rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  gap: 12rpx;
  color: rgba(255, 255, 255, .92);
  background: rgba(37, 32, 27, .91);
  font-size: 21rpx;
  pointer-events: none;
}

.draw-hint-done { background: rgba(31, 105, 64, .94); }

.bottom-bar {
  position: absolute;
  right: 0;
  bottom: 0;
  left: 0;
  z-index: 9;
  padding: 20rpx 30rpx 30rpx;
  border-radius: 30rpx 30rpx 0 0;
  background: #FFFFFF;
  box-shadow: 0 -8rpx 26rpx rgba(54, 41, 28, .12);
}

.stats-row {
  padding-bottom: 18rpx;
  display: flex;
  align-items: center;
  justify-content: space-around;
  border-bottom: 1rpx solid #EAF0E6;
}

.stat {
  flex: 1;
  display: flex;
  flex-direction: column;
  align-items: center;
}

.stat-val {
  color: #2F7D4B;
  font-size: 40rpx;
  font-weight: 900;
  line-height: 1;
}

.stat-lbl {
  margin-top: 6rpx;
  color: #8A948B;
  font-size: 18rpx;
}

.stat-div {
  width: 1rpx;
  height: 50rpx;
  background: #EAF0E6;
}

.btn-row {
  margin-top: 18rpx;
  display: flex;
  gap: 16rpx;
}

.cancel-btn,
.finish-btn {
  height: 78rpx;
  border-radius: 999rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  font-size: 25rpx;
  font-weight: 800;
}

.cancel-btn {
  flex: 1;
  color: #58655B;
  background: #F8FAF5;
  border: 1rpx solid #E3E9DE;
}

.finish-btn {
  flex: 2;
  color: #FFFFFF;
  background: #B9852F;
  box-shadow: 0 5rpx 16rpx rgba(126, 75, 34, .25);
}

.finish-disabled {
  color: #B7C0B8;
  background: #EAF0E6;
  box-shadow: none;
  pointer-events: none;
}

.form-container {
  flex: 1;
  min-height: 0;
  padding: 0 28rpx 30rpx;
  display: flex;
  flex-direction: column;
  background: #F6F8F3;
}

.form-scroll {
  flex: 1;
  height: 0;
}

.draw-summary {
  margin-top: 22rpx;
  padding: 22rpx;
  border-radius: 22rpx;
  display: flex;
  align-items: center;
  gap: 18rpx;
  background: #FFFFFF;
  box-shadow: 0 4rpx 15rpx rgba(61, 45, 30, .06);
}

.summary-icon {
  width: 70rpx;
  height: 70rpx;
  border-radius: 20rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  background: #EAF6EF;
}

.summary-body {
  flex: 1;
  display: flex;
  flex-direction: column;
}

.summary-title {
  color: #2D382F;
  font-size: 27rpx;
  font-weight: 800;
}

.summary-desc {
  margin-top: 6rpx;
  color: #2F8A52;
  font-size: 20rpx;
  font-weight: 700;
}

.reference-images-card {
  margin-top: 18rpx;
  padding: 22rpx;
  border-radius: 22rpx;
  background: #FFFFFF;
  box-shadow: 0 4rpx 15rpx rgba(61, 45, 30, .06);
}

.reference-head {
  display: flex;
  align-items: center;
  justify-content: space-between;
  gap: 18rpx;
}

.reference-title-wrap {
  flex: 1;
  min-width: 0;
  display: flex;
  flex-direction: column;
  gap: 6rpx;
}

.reference-title {
  color: #18231A;
  font-size: 26rpx;
  font-weight: 900;
}

.reference-sub {
  color: #8A948B;
  font-size: 20rpx;
  line-height: 1.35;
}

.reference-add {
  flex-shrink: 0;
  min-width: 146rpx;
  height: 58rpx;
  padding: 0 20rpx;
  border-radius: 999rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  color: #FFFFFF;
  background: #2F7D4B;
  font-size: 22rpx;
  font-weight: 800;
}

.reference-add-disabled {
  opacity: .55;
  pointer-events: none;
}

.reference-grid {
  margin-top: 18rpx;
  display: flex;
  flex-wrap: wrap;
  gap: 14rpx;
}

.reference-item {
  position: relative;
  width: 148rpx;
  height: 118rpx;
  border-radius: 18rpx;
  overflow: hidden;
  background: #EAF0E6;
}

.reference-img {
  width: 100%;
  height: 100%;
  display: block;
}

.reference-remove {
  position: absolute;
  top: 8rpx;
  right: 8rpx;
  width: 34rpx;
  height: 34rpx;
  border-radius: 50%;
  display: flex;
  align-items: center;
  justify-content: center;
  color: #FFFFFF;
  background: rgba(24, 35, 26, .72);
  font-size: 28rpx;
  line-height: 1;
}

.reference-empty {
  margin-top: 18rpx;
  min-height: 112rpx;
  border: 2rpx dashed #D8E1D5;
  border-radius: 18rpx;
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
  gap: 6rpx;
  background: #F8FAF5;
}

.reference-empty-main {
  color: #2F7D4B;
  font-size: 24rpx;
  font-weight: 800;
}

.reference-empty-sub {
  color: #8A948B;
  font-size: 20rpx;
}

.form-card {
  margin-top: 18rpx;
  padding: 0 24rpx;
  border-radius: 22rpx;
  background: #FFFFFF;
  box-shadow: 0 4rpx 15rpx rgba(61, 45, 30, .06);
}

.field-row {
  min-height: 88rpx;
  display: flex;
  align-items: center;
  gap: 18rpx;
  border-bottom: 1rpx solid #EAF0E6;
}

.field-row:last-child { border-bottom: none; }

.field-label {
  width: 172rpx;
  flex-shrink: 0;
  color: #5D554E;
  font-size: 24rpx;
  font-weight: 700;
}

.req { color: #D6453D; }

.field-input {
  flex: 1;
  color: #18231A;
  font-size: 24rpx;
  text-align: right;
}

.field-picker {
  min-width: 300rpx;
  display: flex;
  align-items: center;
  justify-content: flex-end;
  gap: 15rpx;
}

.picker-val,
.picker-placeholder,
.picker-more {
  font-size: 23rpx;
}

.picker-val { color: #18231A; }
.picker-placeholder { color: #B7C0B8; }
.picker-more { color: #B9852F; font-weight: 700; }

.field-row-note {
  min-height: 150rpx;
  align-items: flex-start;
  padding: 24rpx 0;
}

.field-textarea {
  flex: 1;
  height: 104rpx;
  color: #18231A;
  font-size: 23rpx;
  line-height: 1.5;
  text-align: right;
}

.form-bottom-space { height: 28rpx; }

.form-save-btn {
  flex-shrink: 0;
  height: 88rpx;
  border-radius: 999rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  color: #FFFFFF;
  background: #2F7D4B;
  box-shadow: 0 7rpx 18rpx rgba(126, 75, 34, .28);
  font-size: 28rpx;
  font-weight: 900;
}

.save-disabled {
  opacity: .55;
  pointer-events: none;
}
