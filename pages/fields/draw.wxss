.page {
  display: flex;
  flex-direction: column;
  height: 100vh;
  color: #302A24;
  background: #F4EFE7;
}

.nav {
  flex-shrink: 0;
  min-height: 84rpx;
  padding-left: 24rpx;
  padding-right: 24rpx;
  padding-bottom: 14rpx;
  display: flex;
  align-items: center;
  background: rgba(255, 255, 255, .98);
  box-shadow: 0 3rpx 16rpx rgba(55, 40, 28, .10);
  z-index: 12;
}

.nav-side {
  min-width: 76rpx;
  height: 56rpx;
  padding: 0 14rpx;
  border-radius: 999rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  color: #5D554E;
  background: #F4F0EB;
  font-size: 22rpx;
  font-weight: 700;
  box-sizing: border-box;
}

.nav-help {
  color: #86572F;
  background: #FFF2E2;
}

.nav-center {
  flex: 1;
  display: flex;
  flex-direction: column;
  align-items: center;
}

.nav-title {
  color: #29241F;
  font-size: 29rpx;
  font-weight: 900;
}

.nav-sub {
  margin-top: 3rpx;
  color: #91877E;
  font-size: 19rpx;
}

.draw-container {
  position: relative;
  flex: 1;
  display: flex;
  flex-direction: column;
  min-height: 0;
}

.map {
  flex: 1;
  width: 100%;
}

.toolbar {
  position: absolute;
  top: 26rpx;
  right: 22rpx;
  z-index: 10;
  display: flex;
  flex-direction: column;
  gap: 14rpx;
}

.tool-btn {
  width: 98rpx;
  min-height: 82rpx;
  padding: 9rpx 6rpx;
  border-radius: 18rpx;
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
  background: #FFFFFF;
  box-shadow: 0 5rpx 18rpx rgba(48, 38, 29, .17);
  box-sizing: border-box;
}

.tool-primary { background: #3C82B3; }
.tool-primary .tool-title,
.tool-primary .tool-sub { color: #FFFFFF; }

.tool-title {
  color: #49413A;
  font-size: 22rpx;
  font-weight: 800;
}

.tool-sub {
  margin-top: 3rpx;
  color: #9A9087;
  font-size: 16rpx;
}

.tool-disabled {
  opacity: .42;
  pointer-events: none;
}

.draw-empty-tip {
  position: absolute;
  top: 42%;
  left: 50%;
  transform: translate(-50%, -50%);
  padding: 22rpx 30rpx;
  border-radius: 20rpx;
  display: flex;
  flex-direction: column;
  align-items: center;
  background: rgba(255, 255, 255, .92);
  box-shadow: 0 5rpx 20rpx rgba(60, 45, 32, .12);
  pointer-events: none;
}

.draw-empty-title {
  color: #4A423A;
  font-size: 24rpx;
  font-weight: 800;
}

.draw-empty-sub {
  margin-top: 6rpx;
  color: #988E84;
  font-size: 19rpx;
  white-space: nowrap;
}

.area-float {
  position: absolute;
  top: 48%;
  left: 50%;
  transform: translate(-50%, -50%);
  z-index: 6;
  min-width: 190rpx;
  padding: 20rpx 30rpx;
  border-radius: 28rpx;
  display: flex;
  flex-direction: column;
  align-items: center;
  background: rgba(255, 255, 255, .96);
  box-shadow: 0 8rpx 28rpx rgba(49, 37, 26, .20);
  pointer-events: none;
}

.area-label {
  color: #8C8278;
  font-size: 19rpx;
}

.area-row {
  margin-top: 3rpx;
  display: flex;
  align-items: baseline;
  gap: 7rpx;
}

.area-val {
  color: #352E27;
  font-size: 58rpx;
  font-weight: 900;
  line-height: 1;
}

.area-unit {
  color: #766C63;
  font-size: 22rpx;
}

.draw-hint {
  position: absolute;
  right: 24rpx;
  bottom: 222rpx;
  left: 24rpx;
  z-index: 8;
  padding: 17rpx 20rpx;
  border-radius: 18rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  gap: 12rpx;
  color: rgba(255, 255, 255, .92);
  background: rgba(37, 32, 27, .91);
  font-size: 21rpx;
  pointer-events: none;
}

.draw-hint-done { background: rgba(31, 105, 64, .94); }

.bottom-bar {
  position: absolute;
  right: 0;
  bottom: 0;
  left: 0;
  z-index: 9;
  padding: 20rpx 30rpx 30rpx;
  border-radius: 34rpx 34rpx 0 0;
  background: #FFFFFF;
  box-shadow: 0 -8rpx 26rpx rgba(54, 41, 28, .12);
}

.stats-row {
  padding-bottom: 18rpx;
  display: flex;
  align-items: center;
  justify-content: space-around;
  border-bottom: 1rpx solid #EEE7DE;
}

.stat {
  flex: 1;
  display: flex;
  flex-direction: column;
  align-items: center;
}

.stat-val {
  color: #9B6738;
  font-size: 40rpx;
  font-weight: 900;
  line-height: 1;
}

.stat-lbl {
  margin-top: 6rpx;
  color: #91877E;
  font-size: 18rpx;
}

.stat-div {
  width: 1rpx;
  height: 50rpx;
  background: #E5DDD3;
}

.btn-row {
  margin-top: 18rpx;
  display: flex;
  gap: 16rpx;
}

.cancel-btn,
.finish-btn {
  height: 78rpx;
  border-radius: 999rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  font-size: 25rpx;
  font-weight: 800;
}

.cancel-btn {
  flex: 1;
  color: #6D645B;
  background: #F5F1EC;
  border: 1rpx solid #DDD5CC;
}

.finish-btn {
  flex: 2;
  color: #FFFFFF;
  background: #A46836;
  box-shadow: 0 5rpx 16rpx rgba(126, 75, 34, .25);
}

.finish-disabled {
  color: #A9A19A;
  background: #E8E4DF;
  box-shadow: none;
  pointer-events: none;
}

.form-container {
  flex: 1;
  min-height: 0;
  padding: 0 28rpx 30rpx;
  display: flex;
  flex-direction: column;
  background: #F4EFE7;
}

.form-scroll {
  flex: 1;
  height: 0;
}

.draw-summary {
  margin-top: 22rpx;
  padding: 22rpx;
  border-radius: 24rpx;
  display: flex;
  align-items: center;
  gap: 18rpx;
  background: #FFFFFF;
  box-shadow: 0 4rpx 15rpx rgba(61, 45, 30, .06);
}

.summary-icon {
  width: 70rpx;
  height: 70rpx;
  border-radius: 20rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  background: #E9F6EE;
}

.summary-body {
  flex: 1;
  display: flex;
  flex-direction: column;
}

.summary-title {
  color: #2D382F;
  font-size: 27rpx;
  font-weight: 800;
}

.summary-desc {
  margin-top: 6rpx;
  color: #2D8B57;
  font-size: 20rpx;
  font-weight: 700;
}

.form-card {
  margin-top: 18rpx;
  padding: 0 24rpx;
  border-radius: 24rpx;
  background: #FFFFFF;
  box-shadow: 0 4rpx 15rpx rgba(61, 45, 30, .06);
}

.field-row {
  min-height: 88rpx;
  display: flex;
  align-items: center;
  gap: 18rpx;
  border-bottom: 1rpx solid #EEE8E1;
}

.field-row:last-child { border-bottom: none; }

.field-label {
  width: 172rpx;
  flex-shrink: 0;
  color: #5D554E;
  font-size: 24rpx;
  font-weight: 700;
}

.req { color: #C7473A; }

.field-input {
  flex: 1;
  color: #2D2823;
  font-size: 24rpx;
  text-align: right;
}

.field-picker {
  min-width: 300rpx;
  display: flex;
  align-items: center;
  justify-content: flex-end;
  gap: 15rpx;
}

.picker-val,
.picker-placeholder,
.picker-more {
  font-size: 23rpx;
}

.picker-val { color: #2F2A25; }
.picker-placeholder { color: #AAA198; }
.picker-more { color: #A46836; font-weight: 700; }

.field-row-note {
  min-height: 150rpx;
  align-items: flex-start;
  padding: 24rpx 0;
}

.field-textarea {
  flex: 1;
  height: 104rpx;
  color: #2F2A25;
  font-size: 23rpx;
  line-height: 1.5;
  text-align: right;
}

.form-bottom-space { height: 28rpx; }

.form-save-btn {
  flex-shrink: 0;
  height: 88rpx;
  border-radius: 999rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  color: #FFFFFF;
  background: #9B6738;
  box-shadow: 0 7rpx 18rpx rgba(126, 75, 34, .28);
  font-size: 28rpx;
  font-weight: 900;
}

.save-disabled {
  opacity: .55;
  pointer-events: none;
}
