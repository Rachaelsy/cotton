/* pages/fields/draw.wxss */
.page { display:flex; flex-direction:column; height:100vh; }

.draw-nav {
  display:flex; flex-direction:row; align-items:center; gap:0;
  padding: 0 28rpx 20rpx; background:#fff;
  box-shadow:0 2rpx 16rpx rgba(0,0,0,.08); flex-shrink:0;
}
.draw-back {
  width:68rpx; height:68rpx; background:#F5EEE6; border-radius:50%;
  display:flex; align-items:center; justify-content:center; flex-shrink:0;
}
.db-icon { font-size:40rpx; color:#1A1A1A; font-weight:700; }
.draw-nav-center { flex:1; text-align:center; }
.draw-title { display:block; font-size:30rpx; font-weight:700; color:#1A1A1A; }
.draw-sub { display:block; font-size:22rpx; color:#888; margin-top:4rpx; }
.draw-help {
  width:68rpx; height:68rpx; background:#F5EEE6; border-radius:50%;
  display:flex; align-items:center; justify-content:center; flex-shrink:0;
}
.draw-help-text { font-size:28rpx; font-weight:700; color:#555; }

.map-area {
  flex:1; position:relative; overflow:hidden; background:#EAE2D4;
}
.map-bg { position:absolute; inset:0; background:#EAE2D4; }
.map-road-h {
  position:absolute; height:32rpx; background:#F4EEE2;
  border-top:3rpx solid #DDD5C5; border-bottom:3rpx solid #DDD5C5;
  left:0; right:0; top:22%;
}
.map-road-v {
  position:absolute; width:20rpx; background:#EDE7DC;
  border-left:3rpx solid #D8D0C0; border-right:3rpx solid #D8D0C0;
  top:0; bottom:0; left:65%;
}
.map-lbl {
  position:absolute; top:15%; left:8%;
  font-size:22rpx; font-weight:700; color:#B8AFA0;
}

.draw-svg-wrap { position:absolute; inset:0; }

.pts-hint {
  position:absolute; top:50%; left:50%; transform:translate(-50%,-50%);
  display:flex; flex-direction:column; align-items:center; gap:12rpx;
}
.pts-hint-icon { font-size:72rpx; }
.pts-hint-text { font-size:26rpx; color:#888; font-weight:600; }

.pt-dot {
  position:absolute; width:24rpx; height:24rpx;
  background:#C8902E; border-radius:50%; border:4rpx solid #fff;
  box-shadow:0 2rpx 8rpx rgba(0,0,0,.3);
}
.pt-dot.first {
  background:#4CAF50; width:32rpx; height:32rpx;
  border:4rpx solid #fff;
}

.draw-toolbar {
  position:absolute; right:28rpx; top:32rpx;
  display:flex; flex-direction:column; gap:20rpx;
}
.draw-tool {
  width:104rpx; background:#fff; border-radius:24rpx;
  box-shadow:0 4rpx 20rpx rgba(0,0,0,.1);
  display:flex; flex-direction:column; align-items:center;
  padding:16rpx 8rpx 12rpx; gap:6rpx;
}
.dt-icon { font-size:40rpx; line-height:1; }
.dt-lbl { font-size:20rpx; color:#555; font-weight:600; }

.draw-hint {
  position:absolute; bottom:28rpx; left:28rpx; right:28rpx;
  background:#1A1A1A; border-radius:24rpx; padding:20rpx 28rpx;
}
.dh-text { font-size:26rpx; color:rgba(255,255,255,.9); }
.dh-bold { color:#FFD666; font-weight:700; }

.draw-panel {
  background:#fff; border-radius:44rpx 44rpx 0 0; padding:28rpx 40rpx;
  box-shadow:0 -6rpx 40rpx rgba(0,0,0,.1); flex-shrink:0;
  padding-bottom:calc(28rpx + env(safe-area-inset-bottom));
}
.draw-stats {
  display:flex; flex-direction:row; align-items:center;
  justify-content:space-around; padding-bottom:24rpx;
  border-bottom:2rpx solid #F2EBE0; margin-bottom:24rpx;
}
.draw-stat { text-align:center; }
.ds-val { display:block; font-size:60rpx; font-weight:800; color:#C8902E; line-height:1; }
.ds-lbl { display:block; font-size:22rpx; color:#888; margin-top:6rpx; }
.ds-div { width:2rpx; height:72rpx; background:#F2EBE0; }

.draw-btns { display:flex; flex-direction:row; gap:24rpx; }
.draw-cancel-btn {
  flex:1; text-align:center; padding:26rpx; border-radius:999rpx;
  border:2rpx solid #EEE5D8;
}
.draw-cancel-text { font-size:28rpx; font-weight:600; color:#555; }
.draw-confirm-btn {
  flex:2; text-align:center; padding:26rpx; border-radius:999rpx;
  background:#C8902E; box-shadow:0 6rpx 24rpx rgba(200,144,46,.4);
}
.draw-confirm-btn.disabled { background:#BBBBBB; box-shadow:none; }
.draw-confirm-text { font-size:28rpx; font-weight:700; color:#fff; }
