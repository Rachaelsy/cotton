<!-- pages/fields/detail.wxml — 地块详情 -->
<view class="page">

  <!-- 顶部 -->
  <view class="header" style="padding-top: {{statusBarHeight}}px">
    <view class="topbar">
      <view class="back-btn" bindtap="onBack">
        <text class="back-icon">‹</text>
      </view>
      <text class="header-title">{{plot.name || '地块详情'}}</text>
      <view class="edit-btn" bindtap="onEdit">
        <text class="edit-text">编辑</text>
      </view>
    </view>
  </view>

  <scroll-view class="scroll" scroll-y>
    <view class="body">

      <!-- 地图展示 -->
      <view class="map-card">
        <map
          class="detail-map"
          latitude="{{mapLat}}"
          longitude="{{mapLng}}"
          scale="15"
          polygons="{{polygons}}"
          enable-satellite="{{isSatellite}}"
          show-location
          enable-zoom
          enable-scroll
        ></map>
        <view wx:if="{{polygons.length === 0}}" class="no-map-tip">
          <text class="no-map-text">暂无地块边界数据</text>
        </view>
        <!-- 卫星/地图切换 -->
        <view class="map-layer-btn" bindtap="onToggleSatellite">
          <text class="map-layer-text">{{isSatellite ? '🛰 卫星' : '🗺 地图'}}</text>
        </view>
      </view>

      <!-- 健康状态卡片 -->
      <view class="info-card">
        <view class="health-row">
          <view class="health-score-wrap">
            <text class="health-score {{plot.status === 'attention' ? 'score-warn' : 'score-ok'}}">
              {{plot.health_score || 100}}
            </text>
            <text class="health-score-unit">分</text>
          </view>
          <view class="health-right">
            <view class="status-tag {{plot.status === 'attention' ? 'tag-warn' : 'tag-ok'}}">
              <text class="status-tag-text">
                {{plot.status === 'attention' ? '⚠ ' + (plot.health_issue || '需关注') : '✓ 正常种植'}}
              </text>
            </view>
            <text class="health-label">健康评分</text>
          </view>
        </view>
      </view>

      <!-- 基础信息卡片 -->
      <view class="info-card">
        <view class="card-title-row">
          <text class="card-title">📋 基础信息</text>
        </view>
        <view class="kv-row">
          <text class="kv-k">地块名称</text>
          <text class="kv-v">{{plot.name}}</text>
        </view>
        <view class="kv-row">
          <text class="kv-k">种植面积</text>
          <text class="kv-v">{{plot.area}} 亩</text>
        </view>
        <view class="kv-row">
          <text class="kv-k">地块周长</text>
          <text class="kv-v">{{plot.perimeter}} 米</text>
        </view>
        <view class="kv-row">
          <text class="kv-k">种植品种</text>
          <text class="kv-v {{!plot.variety ? 'kv-empty' : ''}}">{{plot.variety || '未填写'}}</text>
        </view>
        <view class="kv-row">
          <text class="kv-k">播种日期</text>
          <text class="kv-v {{!plot.sow_date ? 'kv-empty' : ''}}">
            {{plot.sow_date ? plot.sow_date.slice(0,10) : '未填写'}}
          </text>
        </view>
        <view class="kv-row">
          <text class="kv-k">灌溉方式</text>
          <text class="kv-v">{{plot.irrigation || '滴灌'}}</text>
        </view>
        <view class="kv-row kv-last">
          <text class="kv-k">土壤类型</text>
          <text class="kv-v {{!plot.soil_type ? 'kv-empty' : ''}}">{{plot.soil_type || '未填写'}}</text>
        </view>
      </view>

      <!-- 删除按钮 -->
      <view class="delete-btn" bindtap="onDelete">
        <text class="delete-text">🗑 删除该地块</text>
      </view>

      <view style="height: 60rpx"></view>
    </view>
  </scroll-view>

  <!-- 编辑弹窗 -->
  <view wx:if="{{showEdit}}" class="modal-mask" bindtap="onCloseEdit"></view>
  <view wx:if="{{showEdit}}" class="modal">
    <view class="modal-handle"></view>
    <view class="modal-head">
      <text class="modal-title">编辑地块信息</text>
      <view class="modal-close" bindtap="onCloseEdit">
        <text class="modal-close-text">✕</text>
      </view>
    </view>
    <scroll-view class="modal-scroll" scroll-y>
      <view class="field-row">
        <text class="field-label">地块名称 <text class="req">*</text></text>
        <input class="field-input" value="{{form.name}}" bindinput="onNameInput" maxlength="20"/>
      </view>
      <view class="field-row">
        <text class="field-label">种植品种</text>
        <input class="field-input" value="{{form.variety}}" bindinput="onVarietyInput" maxlength="30"/>
      </view>
      <view class="field-row">
        <text class="field-label">播种日期</text>
        <picker mode="date" value="{{form.sowDate}}" bindchange="onSowChange">
          <view class="field-picker">
            <text class="{{form.sowDate ? 'picker-val' : 'picker-ph'}}">{{form.sowDate || '选择日期'}}</text>
            <text class="picker-arr">›</text>
          </view>
        </picker>
      </view>
      <view class="field-row">
        <text class="field-label">灌溉方式</text>
        <picker mode="selector" range="{{irrigationOptions}}" value="{{irrigationIndex}}" bindchange="onIrrChange">
          <view class="field-picker">
            <text class="picker-val">{{form.irrigation}}</text>
            <text class="picker-arr">›</text>
          </view>
        </picker>
      </view>
      <view class="field-row">
        <text class="field-label">地块状态</text>
        <picker mode="selector" range="{{statusOptions}}" value="{{statusIndex}}" bindchange="onStatusChange">
          <view class="field-picker">
            <text class="picker-val">{{statusOptions[statusIndex]}}</text>
            <text class="picker-arr">›</text>
          </view>
        </picker>
      </view>
      <view class="field-row" wx:if="{{form.status === 'attention'}}">
        <text class="field-label">问题描述</text>
        <input class="field-input" value="{{form.healthIssue}}" bindinput="onIssueInput" placeholder="如：蚜虫、缺水" maxlength="20"/>
      </view>
      <view class="field-row">
        <text class="field-label">健康评分</text>
        <input class="field-input" type="number" value="{{form.healthScore}}" bindinput="onScoreInput" maxlength="3"/>
      </view>
      <view style="height: 20rpx"></view>
    </scroll-view>
    <view class="modal-save {{saving ? 'modal-save-off' : ''}}" bindtap="onSave">
      <text class="modal-save-text">{{saving ? '保存中...' : '保存'}}</text>
    </view>
  </view>

</view>
