<!-- pages/fields/detail.wxml — 地块详情 -->
<view class="page">
  <view class="header" style="padding-top: {{statusBarHeight}}px">
    <view class="topbar">
      <view class="header-action" bindtap="onBack"><text>{{common.back}}</text></view>
      <text class="header-title">{{plot.name || copy.fallbackTitle}}</text>
      <view class="header-action header-edit" bindtap="onEdit"><text>{{common.edit}}</text></view>
    </view>
  </view>

  <view wx:if="{{loading}}" class="state-wrap">
    <text class="state-title">{{copy.loading}}</text>
  </view>

  <view wx:elif="{{loadError}}" class="state-wrap">
    <icon type="warn" size="40" color="#C67C31"></icon>
    <text class="state-title">{{copy.loadFail}}</text>
    <text class="state-desc">{{loadError}}</text>
    <view class="state-action" bindtap="onRetry"><text>{{common.retry}}</text></view>
  </view>

  <scroll-view wx:else class="scroll" scroll-y enhanced show-scrollbar="{{false}}">
    <view class="body">
      <view class="map-card">
        <map
          wx:if="{{polygons.length}}"
          class="detail-map"
          latitude="{{mapLat}}"
          longitude="{{mapLng}}"
          scale="15"
          polygons="{{polygons}}"
          enable-satellite="{{isSatellite}}"
          enable-zoom
          enable-scroll
          enable-rotate="{{false}}"
        ></map>
        <view wx:else class="no-map-tip"><text>{{copy.noBoundary}}</text></view>
        <view class="map-layer-btn" bindtap="onToggleSatellite"><text>{{isSatellite ? copy.standardMap : copy.satelliteMap}}</text></view>
      </view>

      <view class="overview-card {{plot.status === 'attention' ? 'overview-attention' : ''}}">
        <view class="score-block">
          <view class="score-row"><text class="score-value">{{plot.health_score}}</text><text class="score-unit">{{copy.scoreUnit}}</text></view>
          <text class="score-label">{{copy.healthScore}}</text>
        </view>
        <view class="overview-divider"></view>
        <view class="overview-main">
          <view class="growth-tag {{plot.status === 'attention' ? 'growth-tag-warn' : ''}}">
            <icon type="{{plot.status === 'attention' ? 'warn' : 'success_no_circle'}}" size="13" color="{{plot.status === 'attention' ? '#B6542D' : '#24794A'}}"></icon>
            <text>{{plot.growthLabel}}</text>
          </view>
          <text class="overview-line">{{plot.areaText}} {{common.mu}} · {{plot.variety || copy.noVariety}}</text>
          <text class="overview-line">{{plot.plantingStatusText}} · {{plot.irrigationText || copy.noIrrigation}}</text>
        </view>
      </view>

      <view class="section-card">
        <view class="section-head"><text class="section-title">{{copy.dataCenter}}</text><text class="section-sub">{{copy.dataCenterSub}}</text></view>
        <view class="module-grid">
          <view class="module-item" data-module="water" bindtap="onOpenModule"><text class="module-name">{{copy.water}}</text><text class="module-desc">{{copy.waterSub}}</text></view>
          <view class="module-item" data-module="fert" bindtap="onOpenModule"><text class="module-name">{{copy.fert}}</text><text class="module-desc">{{copy.fertSub}}</text></view>
          <view class="module-item" data-module="weather" bindtap="onOpenModule"><text class="module-name">{{copy.weather}}</text><text class="module-desc">{{copy.weatherSub}}</text></view>
          <view class="module-item" data-module="records" bindtap="onOpenModule"><text class="module-name">{{copy.records}}</text><text class="module-desc">{{recordsSubText}}</text></view>
          <view class="module-item" data-module="pest" bindtap="onOpenModule"><text class="module-name">{{copy.pest}}</text><text class="module-desc">{{copy.pestSub}}</text></view>
        </view>
      </view>

      <view class="section-card">
        <view class="section-head"><text class="section-title">{{copy.baseInfo}}</text><text class="section-sub">{{copy.baseInfoSub}}</text></view>
        <view class="kv-row"><text class="kv-key">{{copy.name}}</text><text class="kv-value">{{plot.name}}</text></view>
        <view class="kv-row"><text class="kv-key">{{copy.area}}</text><text class="kv-value">{{plot.areaText}} {{common.mu}}</text></view>
        <view class="kv-row"><text class="kv-key">{{copy.perimeter}}</text><text class="kv-value">{{plot.perimeterText}} {{copy.meter}}</text></view>
        <view class="kv-row"><text class="kv-key">{{copy.variety}}</text><text class="kv-value {{!plot.variety ? 'kv-empty' : ''}}">{{plot.variety || copy.notFilled}}</text></view>
        <view class="kv-row"><text class="kv-key">{{copy.sowDate}}</text><text class="kv-value {{!plot.sow_date ? 'kv-empty' : ''}}">{{plot.sowDateText}}</text></view>
        <view class="kv-row"><text class="kv-key">{{copy.irrigation}}</text><text class="kv-value">{{plot.irrigationText || copy.notFilled}}</text></view>
        <view class="kv-row"><text class="kv-key">{{copy.soil}}</text><text class="kv-value {{!plot.soil_type ? 'kv-empty' : ''}}">{{plot.soilTypeText || copy.notFilled}}</text></view>
        <view class="kv-row"><text class="kv-key">{{copy.planting}}</text><text class="kv-value">{{plot.plantingStatusText}}</text></view>
        <view class="kv-row kv-row-note"><text class="kv-key">{{copy.note}}</text><text class="kv-value {{!plot.note ? 'kv-empty' : ''}}">{{plot.note || copy.notFilled}}</text></view>
      </view>

      <view class="section-card">
        <view class="section-head"><text class="section-title">{{copy.recentRecords}}</text><text class="section-sub">{{totalRecordsText}}</text></view>
        <view wx:if="{{recentRecords.length}}">
          <view class="record-row" wx:for="{{recentRecords}}" wx:key="id" data-module="records" bindtap="onOpenModule">
            <view class="record-type"><text>{{item.typeText}}</text></view>
            <view class="record-main"><text class="record-title">{{item.title}}</text><text class="record-meta">{{item.workDateText}}{{item.work_time ? ' · ' + item.work_time : ''}}</text></view>
            <text class="record-more">{{copy.view}}</text>
          </view>
        </view>
        <view wx:else class="record-empty"><text>{{copy.noRecords}}</text></view>
        <view class="section-link" data-module="records" bindtap="onOpenModule"><text>{{recordCount ? copy.viewAllRecords : copy.addFirstRecord}}</text></view>
      </view>

      <view class="danger-zone">
        <text class="danger-title">{{copy.deleteTitle}}</text>
        <text class="danger-desc">{{copy.deleteDesc}}</text>
        <view class="delete-btn" bindtap="onDelete"><text>{{copy.deleteThis}}</text></view>
      </view>
      <view class="bottom-space"></view>
    </view>
  </scroll-view>

  <view wx:if="{{showEdit}}" class="modal-mask" bindtap="onCloseEdit"></view>
  <view wx:if="{{showEdit}}" class="modal" catchtap="noop">
    <view class="modal-handle"></view>
    <view class="modal-head"><text class="modal-title">{{copy.editTitle}}</text><view class="modal-close" bindtap="onCloseEdit"><icon type="cancel" size="23" color="#81766C"></icon></view></view>
    <scroll-view class="modal-scroll" scroll-y enhanced show-scrollbar="{{false}}">
      <view class="field-row"><text class="field-label">{{copy.name}} <text class="req">*</text></text><input class="field-input" value="{{form.name}}" bindinput="onNameInput" maxlength="20"/></view>
      <view class="field-row"><text class="field-label">{{copy.variety}} <text class="req">*</text></text><input class="field-input" value="{{form.variety}}" bindinput="onVarietyInput" maxlength="30"/></view>
      <view class="field-row"><text class="field-label">{{copy.sowDate}}</text><picker mode="date" value="{{form.sowDate}}" bindchange="onSowChange"><view class="field-picker"><text class="{{form.sowDate ? 'picker-value' : 'picker-empty'}}">{{form.sowDate || copy.chooseDate}}</text><text class="picker-change">{{copy.change}}</text></view></picker></view>
      <view class="field-row"><text class="field-label">{{copy.irrigation}}</text><picker mode="selector" range="{{irrigationOptions}}" value="{{irrigationIndex}}" bindchange="onIrrChange"><view class="field-picker"><text class="picker-value">{{irrigationLabel}}</text><text class="picker-change">{{copy.change}}</text></view></picker></view>
      <view class="field-row"><text class="field-label">{{copy.soil}}</text><picker mode="selector" range="{{soilOptions}}" value="{{soilIndex}}" bindchange="onSoilChange"><view class="field-picker"><text class="picker-value">{{soilLabel}}</text><text class="picker-change">{{copy.change}}</text></view></picker></view>
      <view class="field-row"><text class="field-label">{{copy.planting}}</text><picker mode="selector" range="{{plantingOptions}}" value="{{plantingIndex}}" bindchange="onPlantingChange"><view class="field-picker"><text class="picker-value">{{plantingLabel}}</text><text class="picker-change">{{copy.change}}</text></view></picker></view>
      <view class="field-row field-note"><text class="field-label">{{copy.note}}</text><textarea class="field-textarea" value="{{form.note}}" bindinput="onNoteInput" maxlength="200" placeholder="{{copy.notePh}}"></textarea></view>
      <view class="modal-bottom-space"></view>
    </scroll-view>
    <view class="modal-save {{saving ? 'modal-save-disabled' : ''}}" bindtap="onSave"><text>{{saving ? copy.saving : copy.saveEdit}}</text></view>
  </view>
</view>
