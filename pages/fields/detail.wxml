<!-- pages/fields/detail.wxml — 地块详情 -->
<view class="page">
  <view class="header" style="padding-top: {{statusBarHeight}}px">
    <view class="topbar">
      <view class="header-action" bindtap="onBack"><text>返回</text></view>
      <text class="header-title">{{plot.name || '地块详情'}}</text>
      <view class="header-action header-edit" bindtap="onEdit"><text>编辑</text></view>
    </view>
  </view>

  <view wx:if="{{loading}}" class="state-wrap">
    <text class="state-title">正在汇总地块数据…</text>
  </view>

  <view wx:elif="{{loadError}}" class="state-wrap">
    <icon type="warn" size="40" color="#C67C31"></icon>
    <text class="state-title">暂时无法加载详情</text>
    <text class="state-desc">{{loadError}}</text>
    <view class="state-action" bindtap="onRetry"><text>重新加载</text></view>
  </view>

  <scroll-view wx:else class="scroll" scroll-y enhanced show-scrollbar="{{false}}">
    <view class="body">
      <view class="map-card">
        <map
          wx:if="{{polygons.length}}"
          class="detail-map"
          latitude="{{mapLat}}"
          longitude="{{mapLng}}"
          scale="15"
          polygons="{{polygons}}"
          enable-satellite="{{isSatellite}}"
          enable-zoom
          enable-scroll
          enable-rotate="{{false}}"
        ></map>
        <view wx:else class="no-map-tip"><text>该地块暂无边界数据</text></view>
        <view class="map-layer-btn" bindtap="onToggleSatellite"><text>{{isSatellite ? '标准地图' : '卫星影像'}}</text></view>
      </view>

      <view class="overview-card {{plot.status === 'attention' ? 'overview-attention' : ''}}">
        <view class="score-block">
          <view class="score-row"><text class="score-value">{{plot.health_score}}</text><text class="score-unit">分</text></view>
          <text class="score-label">长势健康评分</text>
        </view>
        <view class="overview-divider"></view>
        <view class="overview-main">
          <view class="growth-tag {{plot.status === 'attention' ? 'growth-tag-warn' : ''}}">
            <icon type="{{plot.status === 'attention' ? 'warn' : 'success_no_circle'}}" size="13" color="{{plot.status === 'attention' ? '#B6542D' : '#24794A'}}"></icon>
            <text>{{plot.growthLabel}}</text>
          </view>
          <text class="overview-line">{{plot.areaText}} 亩 · {{plot.variety || '未填品种'}}</text>
          <text class="overview-line">{{plot.planting_status}} · {{plot.irrigation || '未填灌溉方式'}}</text>
        </view>
      </view>

      <view class="section-card">
        <view class="section-head"><text class="section-title">地块数据中心</text><text class="section-sub">所有服务按此地块查看</text></view>
        <view class="module-grid">
          <view class="module-item" data-module="remote" bindtap="onOpenModule"><text class="module-name">遥感监测</text><text class="module-desc">长势与影像</text></view>
          <view class="module-item" data-module="weather" bindtap="onOpenModule"><text class="module-name">地块气象</text><text class="module-desc">预报与预警</text></view>
          <view class="module-item" data-module="records" bindtap="onOpenModule"><text class="module-name">农事记录</text><text class="module-desc">{{recordCount}} 条记录</text></view>
          <view class="module-item" data-module="pest" bindtap="onOpenModule"><text class="module-name">病虫识别</text><text class="module-desc">拍照诊断</text></view>
        </view>
      </view>

      <view class="section-card">
        <view class="section-head"><text class="section-title">基础信息</text><text class="section-sub">录入与边界数据</text></view>
        <view class="kv-row"><text class="kv-key">地块名称</text><text class="kv-value">{{plot.name}}</text></view>
        <view class="kv-row"><text class="kv-key">种植面积</text><text class="kv-value">{{plot.areaText}} 亩</text></view>
        <view class="kv-row"><text class="kv-key">地块周长</text><text class="kv-value">{{plot.perimeterText}} 米</text></view>
        <view class="kv-row"><text class="kv-key">棉花品种</text><text class="kv-value {{!plot.variety ? 'kv-empty' : ''}}">{{plot.variety || '未填写'}}</text></view>
        <view class="kv-row"><text class="kv-key">播种日期</text><text class="kv-value {{!plot.sow_date ? 'kv-empty' : ''}}">{{plot.sowDateText}}</text></view>
        <view class="kv-row"><text class="kv-key">灌溉方式</text><text class="kv-value">{{plot.irrigation || '未填写'}}</text></view>
        <view class="kv-row"><text class="kv-key">土壤类型</text><text class="kv-value {{!plot.soil_type ? 'kv-empty' : ''}}">{{plot.soil_type || '未填写'}}</text></view>
        <view class="kv-row"><text class="kv-key">种植状态</text><text class="kv-value">{{plot.planting_status}}</text></view>
        <view class="kv-row kv-row-note"><text class="kv-key">备注</text><text class="kv-value {{!plot.note ? 'kv-empty' : ''}}">{{plot.note || '未填写'}}</text></view>
      </view>

      <view class="section-card">
        <view class="section-head"><text class="section-title">最近农事</text><text class="section-sub">共 {{recordCount}} 条</text></view>
        <view wx:if="{{recentRecords.length}}">
          <view class="record-row" wx:for="{{recentRecords}}" wx:key="id" data-module="records" bindtap="onOpenModule">
            <view class="record-type"><text>{{item.type}}</text></view>
            <view class="record-main"><text class="record-title">{{item.title}}</text><text class="record-meta">{{item.workDateText}}{{item.work_time ? ' · ' + item.work_time : ''}}</text></view>
            <text class="record-more">查看</text>
          </view>
        </view>
        <view wx:else class="record-empty"><text>这块地还没有农事记录</text></view>
        <view class="section-link" data-module="records" bindtap="onOpenModule"><text>{{recordCount ? '查看全部农事记录' : '去添加第一条记录'}}</text></view>
      </view>

      <view class="danger-zone">
        <text class="danger-title">删除地块</text>
        <text class="danger-desc">删除后无法恢复，关联农事记录将保留为历史快照。</text>
        <view class="delete-btn" bindtap="onDelete"><text>删除该地块</text></view>
      </view>
      <view class="bottom-space"></view>
    </view>
  </scroll-view>

  <view wx:if="{{showEdit}}" class="modal-mask" bindtap="onCloseEdit"></view>
  <view wx:if="{{showEdit}}" class="modal" catchtap="noop">
    <view class="modal-handle"></view>
    <view class="modal-head"><text class="modal-title">编辑地块信息</text><view class="modal-close" bindtap="onCloseEdit"><icon type="cancel" size="23" color="#81766C"></icon></view></view>
    <scroll-view class="modal-scroll" scroll-y enhanced show-scrollbar="{{false}}">
      <view class="field-row"><text class="field-label">地块名称 <text class="req">*</text></text><input class="field-input" value="{{form.name}}" bindinput="onNameInput" maxlength="20"/></view>
      <view class="field-row"><text class="field-label">棉花品种 <text class="req">*</text></text><input class="field-input" value="{{form.variety}}" bindinput="onVarietyInput" maxlength="30"/></view>
      <view class="field-row"><text class="field-label">播种日期</text><picker mode="date" value="{{form.sowDate}}" bindchange="onSowChange"><view class="field-picker"><text class="{{form.sowDate ? 'picker-value' : 'picker-empty'}}">{{form.sowDate || '选择日期'}}</text><text class="picker-change">更改</text></view></picker></view>
      <view class="field-row"><text class="field-label">灌溉方式</text><picker mode="selector" range="{{irrigationOptions}}" value="{{irrigationIndex}}" bindchange="onIrrChange"><view class="field-picker"><text class="picker-value">{{form.irrigation}}</text><text class="picker-change">更改</text></view></picker></view>
      <view class="field-row"><text class="field-label">土壤类型</text><picker mode="selector" range="{{soilOptions}}" value="{{soilIndex}}" bindchange="onSoilChange"><view class="field-picker"><text class="picker-value">{{form.soilType}}</text><text class="picker-change">更改</text></view></picker></view>
      <view class="field-row"><text class="field-label">种植状态</text><picker mode="selector" range="{{plantingOptions}}" value="{{plantingIndex}}" bindchange="onPlantingChange"><view class="field-picker"><text class="picker-value">{{form.plantingStatus}}</text><text class="picker-change">更改</text></view></picker></view>
      <view class="field-row field-note"><text class="field-label">备注</text><textarea class="field-textarea" value="{{form.note}}" bindinput="onNoteInput" maxlength="200" placeholder="填写地块特殊情况或管理要点"></textarea></view>
      <view class="modal-bottom-space"></view>
    </scroll-view>
    <view class="modal-save {{saving ? 'modal-save-disabled' : ''}}" bindtap="onSave"><text>{{saving ? '正在保存…' : '保存修改'}}</text></view>
  </view>
</view>
