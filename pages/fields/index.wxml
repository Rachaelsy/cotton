<!-- pages/fields/index.wxml — 地块管理 -->
<view class="page">

  <!-- 顶部 -->
  <view class="header" style="padding-top: {{statusBarHeight}}px">
    <view class="topbar">
      <view class="back-btn" bindtap="onBack">
        <text class="back-icon">‹</text>
      </view>
      <view class="header-center">
        <text class="header-title">我的棉田</text>
        <text class="header-sub">MYCOTTONLAND</text>
      </view>
      <view style="width: 64rpx"></view>
    </view>

    <!-- 统计栏 -->
    <view class="stats-bar">
      <view class="stat-item">
        <text class="stat-val">{{totalCount}}</text>
        <text class="stat-lbl">块</text>
        <text class="stat-desc">承包地块</text>
      </view>
      <view class="stat-div"></view>
      <view class="stat-item">
        <text class="stat-val">{{totalArea}}</text>
        <text class="stat-lbl">亩</text>
        <text class="stat-desc">种植面积</text>
      </view>
      <view class="stat-div"></view>
      <view class="stat-item warn-stat">
        <text class="stat-val warn-val">{{attentionCount}}</text>
        <text class="stat-lbl warn-lbl">块</text>
        <text class="stat-desc warn-desc">需要关注</text>
      </view>
    </view>

    <!-- 标签页 -->
    <view class="tabs">
      <view class="tab tab-active">
        <text class="tab-text">🗺 地块列表</text>
      </view>
      <view class="tab" bindtap="onAddField">
        <text class="tab-text">✏️ 新增地块</text>
      </view>
    </view>
  </view>

  <!-- 内容区 -->
  <scroll-view class="scroll" scroll-y>

    <!-- 加载中 -->
    <view wx:if="{{loading}}" class="loading-wrap">
      <text class="loading-text">加载中...</text>
    </view>

    <view wx:else>

      <!-- 需要关注 -->
      <view wx:if="{{warnFields.length > 0}}">
        <view class="section-header">
          <view class="section-dot warn-dot"></view>
          <text class="section-title">需要关注</text>
          <text class="section-count">{{warnFields.length}}</text>
        </view>
        <view
          class="field-card warn-card"
          wx:for="{{warnFields}}"
          wx:key="id"
          bindtap="onFieldDetail"
          data-id="{{item.id}}"
        >
          <view class="card-thumb warn-thumb">
            <text class="thumb-icon">🌿</text>
          </view>
          <view class="card-body">
            <view class="card-row1">
              <text class="field-name">{{item.name}}</text>
              <view class="score-wrap">
                <text class="score {{item.scoreCls}}">{{item.health_score}}</text>
                <text class="score-unit">/100</text>
              </view>
            </view>
            <text class="field-meta">{{item.area}}亩 · {{item.variety || '未填品种'}} · {{item.irrigation}}</text>
            <view class="card-row3">
              <view class="tag warn-tag">
                <text class="tag-text">⚠ {{item.tagText}}</text>
              </view>
              <text class="field-date">{{item.date}}</text>
            </view>
          </view>
        </view>
      </view>

      <!-- 正常种植 -->
      <view wx:if="{{okFields.length > 0}}">
        <view class="section-header">
          <view class="section-dot ok-dot"></view>
          <text class="section-title">正常种植</text>
          <text class="section-count">{{okFields.length}}</text>
        </view>
        <view
          class="field-card ok-card"
          wx:for="{{okFields}}"
          wx:key="id"
          bindtap="onFieldDetail"
          data-id="{{item.id}}"
        >
          <view class="card-thumb ok-thumb">
            <text class="thumb-icon">🌱</text>
          </view>
          <view class="card-body">
            <view class="card-row1">
              <text class="field-name">{{item.name}}</text>
              <view class="score-wrap">
                <text class="score {{item.scoreCls}}">{{item.health_score}}</text>
                <text class="score-unit">/100</text>
              </view>
            </view>
            <text class="field-meta">{{item.area}}亩 · {{item.variety || '未填品种'}} · {{item.irrigation}}</text>
            <view class="card-row3">
              <view class="tag ok-tag">
                <text class="tag-text">✓ {{item.tagText}}</text>
              </view>
              <text class="field-date">{{item.date}}</text>
            </view>
          </view>
        </view>
      </view>

      <!-- 空状态 -->
      <view wx:if="{{!loading && totalCount === 0}}" class="empty-wrap">
        <text class="empty-icon">🗺</text>
        <text class="empty-title">还没有地块</text>
        <text class="empty-sub">点击下方按钮，在地图上绘制您的第一块棉田</text>
        <view class="empty-btn" bindtap="onAddField">
          <text class="empty-btn-text">+ 新增地块</text>
        </view>
      </view>

      <view style="height: 160rpx"></view>
    </view>
  </scroll-view>

  <!-- FAB -->
  <view wx:if="{{totalCount > 0}}" class="fab" bindtap="onAddField">
    <text class="fab-icon">+</text>
  </view>

</view>
