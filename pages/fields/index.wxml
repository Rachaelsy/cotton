<!-- pages/fields/index.wxml — 地块管理 -->
<view class="page">
  <view class="header" style="padding-top: {{statusBarHeight}}px">
    <view class="topbar" style="padding-right: {{capsuleSafeRight}}px">
      <view class="back-btn" bindtap="onBack"><text class="back-text">{{common.back}}</text></view>
      <view class="header-center">
        <text class="header-title">{{copy.title}}</text>
        <text class="header-sub">{{copy.subtitle}}</text>
      </view>
      <view class="manage-btn {{manageMode ? 'manage-btn-active' : ''}}" bindtap="onToggleManage">
        <text>{{manageMode ? common.done : common.manage}}</text>
      </view>
    </view>

    <view class="stats-bar">
      <view class="stat-item">
        <view class="stat-value-row"><text class="stat-val">{{totalCount}}</text><text class="stat-unit">{{common.block}}</text></view>
        <text class="stat-desc">{{copy.contractFields}}</text>
      </view>
      <view class="stat-div"></view>
      <view class="stat-item">
        <view class="stat-value-row"><text class="stat-val">{{totalArea}}</text><text class="stat-unit">{{common.mu}}</text></view>
        <text class="stat-desc">{{copy.area}}</text>
      </view>
      <view class="stat-div"></view>
      <view class="stat-item attention-stat">
        <view class="stat-value-row"><text class="stat-val">{{attentionCount}}</text><text class="stat-unit">{{common.block}}</text></view>
        <text class="stat-desc">{{copy.needAttention}}</text>
      </view>
    </view>

    <view class="tabs">
      <view class="tab tab-active"><text>{{copy.list}}</text></view>
      <view class="tab" bindtap="onAddField"><text>{{copy.add}}</text></view>
    </view>
  </view>

  <view wx:if="{{manageMode}}" class="manage-tip">
    <text>{{copy.manageTip}}</text>
  </view>

  <view class="filter-panel">
    <view class="search-box">
      <icon type="search" size="16" color="#8B8278"></icon>
      <input
        class="search-input"
        value="{{keyword}}"
        placeholder="{{copy.searchPlaceholder}}"
        confirm-type="search"
        bindinput="onSearchInput"
        bindconfirm="onSearchConfirm"
      />
      <icon wx:if="{{keyword}}" type="clear" size="17" color="#AAA198" bindtap="onClearSearch"></icon>
    </view>
    <view class="filter-row">
      <picker class="filter-picker" mode="selector" range="{{statusOptions}}" value="{{statusIndex}}" bindchange="onStatusChange">
        <view class="filter-pill {{statusIndex ? 'filter-pill-active' : ''}}">
          <text>{{statusOptions[statusIndex]}}</text><text class="filter-caret">⌄</text>
        </view>
      </picker>
      <picker class="filter-picker" mode="selector" range="{{areaOptions}}" value="{{areaIndex}}" bindchange="onAreaChange">
        <view class="filter-pill {{areaIndex ? 'filter-pill-active' : ''}}">
          <text>{{areaOptions[areaIndex]}}</text><text class="filter-caret">⌄</text>
        </view>
      </picker>
      <text wx:if="{{hasActiveFilter}}" class="reset-filter" bindtap="onResetFilters">{{common.reset}}</text>
      <text class="result-count">{{resultCount}} {{copy.resultUnit}}</text>
    </view>
  </view>

  <scroll-view
    class="scroll"
    scroll-y
    enhanced
    show-scrollbar="{{false}}"
    refresher-enabled
    refresher-triggered="{{refreshing}}"
    bindrefresherrefresh="onRefresh"
  >
    <view wx:if="{{loading}}" class="loading-wrap">
      <view class="loading-card"></view>
      <view class="loading-card"></view>
      <view class="loading-card"></view>
      <text class="loading-text">{{copy.loading}}</text>
    </view>

    <view wx:elif="{{loadError}}" class="state-wrap">
      <icon type="warn" size="38" color="#C67C31"></icon>
      <text class="state-title">{{copy.loadFail}}</text>
      <text class="state-desc">{{loadError}}</text>
      <view class="state-action" bindtap="onRetry"><text>{{common.retry}}</text></view>
    </view>

    <view wx:else>
      <view wx:if="{{warnFields.length}}" class="field-section">
        <view class="section-header">
          <view class="section-mark section-mark-warn"></view>
          <text class="section-title">{{copy.attention}}</text>
          <text class="section-count">{{warnFields.length}} {{copy.resultUnit}}</text>
        </view>
        <view
          class="field-card field-card-warn {{item.selected ? 'field-card-selected' : ''}}"
          wx:for="{{warnFields}}"
          wx:key="id"
          data-id="{{item.id}}"
          bindtap="onFieldTap"
        >
          <view class="preview-wrap">
            <image
              wx:if="{{item.hasReferenceImage}}"
              class="preview-image"
              src="{{item.firstReferenceImage}}"
              mode="aspectFill"
              lazy-load
            ></image>
            <map
              wx:elif="{{item.hasBoundary}}"
              class="preview-map"
              latitude="{{item.mapLat}}"
              longitude="{{item.mapLng}}"
              scale="15"
              polygons="{{item.previewPolygons}}"
              enable-zoom="{{false}}"
              enable-scroll="{{false}}"
              enable-rotate="{{false}}"
              show-location="{{false}}"
              data-id="{{item.id}}"
              catchtap="onFieldTap"
            ></map>
            <view wx:else class="preview-empty"><text>{{item.areaText}}</text><text>{{common.mu}}</text></view>
            <view wx:if="{{manageMode}}" class="select-badge {{item.selected ? 'select-badge-active' : ''}}">
              <icon wx:if="{{item.selected}}" type="success_no_circle" size="18" color="#FFFFFF"></icon>
            </view>
          </view>
          <view class="card-body">
            <view class="card-title-row">
              <text class="field-name">{{item.name}}</text>
              <view class="score-wrap"><text class="score {{item.scoreCls}}">{{item.health_score}}</text><text class="score-unit">/100</text></view>
            </view>
            <text class="field-meta">{{item.areaText}}{{common.mu}} · {{item.plantingStatusText}} · {{item.varietyText}} · {{item.irrigationText}}</text>
            <view class="card-foot">
              <view class="status-tag status-tag-warn"><icon type="warn" size="12" color="#C35D2E"></icon><text>{{item.tagText}}</text></view>
              <view class="foot-right">
                <text class="field-date">{{item.date}}</text>
                <view wx:if="{{!manageMode}}" class="weather-mini-btn" data-id="{{item.id}}" data-name="{{item.name}}" catchtap="onFieldWeather"><text>{{copy.weather}}</text></view>
              </view>
            </view>
          </view>
        </view>
      </view>

      <view wx:if="{{okFields.length}}" class="field-section">
        <view class="section-header">
          <view class="section-mark section-mark-ok"></view>
          <text class="section-title">{{copy.normal}}</text>
          <text class="section-count">{{okFields.length}} {{copy.resultUnit}}</text>
        </view>
        <view
          class="field-card field-card-ok {{item.selected ? 'field-card-selected' : ''}}"
          wx:for="{{okFields}}"
          wx:key="id"
          data-id="{{item.id}}"
          bindtap="onFieldTap"
        >
          <view class="preview-wrap">
            <image
              wx:if="{{item.hasReferenceImage}}"
              class="preview-image"
              src="{{item.firstReferenceImage}}"
              mode="aspectFill"
              lazy-load
            ></image>
            <map
              wx:elif="{{item.hasBoundary}}"
              class="preview-map"
              latitude="{{item.mapLat}}"
              longitude="{{item.mapLng}}"
              scale="15"
              polygons="{{item.previewPolygons}}"
              enable-zoom="{{false}}"
              enable-scroll="{{false}}"
              enable-rotate="{{false}}"
              show-location="{{false}}"
              data-id="{{item.id}}"
              catchtap="onFieldTap"
            ></map>
            <view wx:else class="preview-empty"><text>{{item.areaText}}</text><text>{{common.mu}}</text></view>
            <view wx:if="{{manageMode}}" class="select-badge {{item.selected ? 'select-badge-active' : ''}}">
              <icon wx:if="{{item.selected}}" type="success_no_circle" size="18" color="#FFFFFF"></icon>
            </view>
          </view>
          <view class="card-body">
            <view class="card-title-row">
              <text class="field-name">{{item.name}}</text>
              <view class="score-wrap"><text class="score {{item.scoreCls}}">{{item.health_score}}</text><text class="score-unit">/100</text></view>
            </view>
            <text class="field-meta">{{item.areaText}}{{common.mu}} · {{item.plantingStatusText}} · {{item.varietyText}} · {{item.irrigationText}}</text>
            <view class="card-foot">
              <view class="status-tag status-tag-ok"><icon type="success_no_circle" size="12" color="#2D8B57"></icon><text>{{item.tagText}}</text></view>
              <view class="foot-right">
                <text class="field-date">{{item.date}}</text>
                <view wx:if="{{!manageMode}}" class="weather-mini-btn" data-id="{{item.id}}" data-name="{{item.name}}" catchtap="onFieldWeather"><text>{{copy.weather}}</text></view>
              </view>
            </view>
          </view>
        </view>
      </view>

      <view wx:if="{{totalCount === 0}}" class="state-wrap empty-state">
        <text class="empty-monogram">{{copy.emptyMonogram}}</text>
        <text class="state-title">{{copy.emptyTitle}}</text>
        <text class="state-desc">{{copy.emptyDesc}}</text>
        <view class="state-action" bindtap="onAddField"><text>{{copy.addFirst}}</text></view>
      </view>

      <view wx:elif="{{resultCount === 0}}" class="state-wrap empty-state">
        <icon type="search" size="38" color="#A59B90"></icon>
        <text class="state-title">{{copy.noMatch}}</text>
        <text class="state-desc">{{copy.noMatchDesc}}</text>
        <view class="state-action state-action-light" bindtap="onResetFilters"><text>{{copy.clearFilter}}</text></view>
      </view>

      <view class="scroll-bottom-space"></view>
    </view>
  </scroll-view>

  <view wx:if="{{!manageMode && totalCount > 0}}" class="add-fab" bindtap="onAddField"><text>{{copy.addFab}}</text></view>

  <view wx:if="{{manageMode}}" class="manage-bar">
    <view class="select-all-btn" bindtap="onSelectAll"><text>{{allVisibleSelected ? copy.cancelAll : copy.selectAll}}</text></view>
    <view class="batch-delete-btn {{selectedIds.length ? '' : 'batch-delete-disabled'}}" bindtap="onBatchDelete">
      <text>{{batchActionText}}</text>
    </view>
  </view>
</view>
