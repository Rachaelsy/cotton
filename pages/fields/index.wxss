/* pages/fields/index.wxss */

.page {
  display: flex;
  flex-direction: column;
  height: 100vh;
  background: #F5EEE6;
}

/* ===== 顶部 ===== */
.header {
  background: linear-gradient(160deg, #3d2b1a, #6b4c2a);
  flex-shrink: 0;
  padding-left: 28rpx;
  padding-right: 28rpx;
  padding-bottom: 0;
}

.topbar {
  display: flex;
  flex-direction: row;
  align-items: center;
  padding-top: 10rpx;
  padding-bottom: 16rpx;
}

.back-btn {
  width: 64rpx;
  height: 64rpx;
  background: rgba(255,255,255,0.15);
  border-radius: 50%;
  display: flex;
  align-items: center;
  justify-content: center;
}

.back-icon { color: #fff; font-size: 44rpx; }

.header-center {
  flex: 1;
  display: flex;
  flex-direction: column;
  align-items: center;
}

.header-title {
  font-size: 34rpx;
  font-weight: 900;
  color: #fff;
}

.header-sub {
  font-size: 18rpx;
  color: rgba(255,255,255,0.5);
  letter-spacing: 4rpx;
  margin-top: 2rpx;
}

/* ===== 统计栏 ===== */
.stats-bar {
  display: flex;
  flex-direction: row;
  align-items: center;
  justify-content: space-around;
  padding: 20rpx 0 24rpx;
}

.stat-item {
  display: flex;
  flex-direction: row;
  align-items: baseline;
  flex-wrap: wrap;
  justify-content: center;
  gap: 4rpx;
}

.stat-val {
  font-size: 52rpx;
  font-weight: 900;
  color: #fff;
  line-height: 1;
}

.stat-lbl {
  font-size: 22rpx;
  color: rgba(255,255,255,0.8);
  font-weight: 600;
}

.stat-desc {
  width: 100%;
  text-align: center;
  font-size: 20rpx;
  color: rgba(255,255,255,0.55);
  margin-top: 4rpx;
}

.warn-val  { color: #FBBF24; }
.warn-lbl  { color: rgba(251,191,36,0.8); }
.warn-desc { color: rgba(251,191,36,0.7); }

.stat-div {
  width: 1rpx;
  height: 60rpx;
  background: rgba(255,255,255,0.2);
}

/* ===== 标签页 ===== */
.tabs {
  display: flex;
  flex-direction: row;
}

.tab {
  flex: 1;
  display: flex;
  align-items: center;
  justify-content: center;
  padding: 18rpx 0;
  border-bottom: 4rpx solid transparent;
}

.tab-active { border-bottom-color: #FBBF24; }

.tab-text {
  font-size: 26rpx;
  font-weight: 600;
  color: rgba(255,255,255,0.6);
}

.tab-active .tab-text { color: #fff; font-weight: 800; }

/* ===== 滚动区 ===== */
.scroll { flex: 1; height: 0; }

/* ===== 分组标题 ===== */
.section-header {
  display: flex;
  flex-direction: row;
  align-items: center;
  gap: 12rpx;
  padding: 24rpx 28rpx 12rpx;
}

.section-dot {
  width: 14rpx;
  height: 14rpx;
  border-radius: 50%;
}

.warn-dot { background: #EF4444; }
.ok-dot   { background: #22C55E; }

.section-title {
  font-size: 26rpx;
  font-weight: 700;
  color: #333;
  flex: 1;
}

.section-count {
  font-size: 22rpx;
  color: #999;
  background: #EEE;
  border-radius: 999rpx;
  padding: 2rpx 14rpx;
}

/* ===== 地块卡片 ===== */
.field-card {
  display: flex;
  flex-direction: row;
  align-items: center;
  background: #fff;
  border-radius: 20rpx;
  margin: 0 20rpx 16rpx;
  padding: 20rpx;
  box-shadow: 0 2rpx 12rpx rgba(0,0,0,0.06);
  border-left: 8rpx solid transparent;
}

.warn-card { border-left-color: #EF4444; }
.ok-card   { border-left-color: #22C55E; }

.card-thumb {
  width: 88rpx;
  height: 88rpx;
  border-radius: 18rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  flex-shrink: 0;
  margin-right: 20rpx;
}

.warn-thumb { background: linear-gradient(135deg, #7f4b1a, #a05c28); }
.ok-thumb   { background: linear-gradient(135deg, #2d6a4f, #3d8f6b); }

.thumb-icon { font-size: 40rpx; }

.card-body {
  flex: 1;
  display: flex;
  flex-direction: column;
  gap: 8rpx;
}

.card-row1 {
  display: flex;
  flex-direction: row;
  align-items: center;
  justify-content: space-between;
}

.field-name {
  font-size: 28rpx;
  font-weight: 700;
  color: #1A1A1A;
}

.score-wrap {
  display: flex;
  flex-direction: row;
  align-items: baseline;
  gap: 2rpx;
}

.score {
  font-size: 36rpx;
  font-weight: 900;
}

.excel { color: #16A34A; }
.good  { color: #C8902E; }
.warn  { color: #DC2626; }

.score-unit {
  font-size: 20rpx;
  color: #AAAAAA;
}

.field-meta {
  font-size: 22rpx;
  color: #888;
}

.card-row3 {
  display: flex;
  flex-direction: row;
  align-items: center;
  justify-content: space-between;
}

.tag {
  border-radius: 999rpx;
  padding: 4rpx 16rpx;
}

.warn-tag { background: #FEF2F2; }
.ok-tag   { background: #F0FDF4; }

.tag-text {
  font-size: 20rpx;
  font-weight: 600;
}

.warn-tag .tag-text { color: #DC2626; }
.ok-tag   .tag-text { color: #16A34A; }

.field-date {
  font-size: 20rpx;
  color: #BBBBBB;
}

/* ===== 加载 / 空状态 ===== */
.loading-wrap {
  display: flex;
  align-items: center;
  justify-content: center;
  padding-top: 120rpx;
}

.loading-text { font-size: 28rpx; color: #AAAAAA; }

.empty-wrap {
  display: flex;
  flex-direction: column;
  align-items: center;
  padding-top: 100rpx;
  gap: 16rpx;
}

.empty-icon { font-size: 100rpx; }

.empty-title {
  font-size: 34rpx;
  font-weight: 800;
  color: #555;
}

.empty-sub {
  font-size: 24rpx;
  color: #AAAAAA;
  text-align: center;
  padding: 0 60rpx;
  line-height: 1.7;
}

.empty-btn {
  margin-top: 24rpx;
  background: linear-gradient(135deg, #6b4c2a, #8b6035);
  border-radius: 999rpx;
  padding: 22rpx 64rpx;
}

.empty-btn-text {
  font-size: 28rpx;
  font-weight: 800;
  color: #fff;
}

/* ===== FAB ===== */
.fab {
  position: fixed;
  right: 40rpx;
  bottom: 60rpx;
  width: 100rpx;
  height: 100rpx;
  background: linear-gradient(135deg, #6b4c2a, #C8902E);
  border-radius: 50%;
  display: flex;
  align-items: center;
  justify-content: center;
  box-shadow: 0 8rpx 32rpx rgba(107,76,42,0.45);
}

.fab-icon {
  color: #fff;
  font-size: 60rpx;
  font-weight: 300;
  line-height: 1;
}
