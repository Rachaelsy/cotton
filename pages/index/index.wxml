<!-- pages/index/index.wxml — 首页 -->
<view class="page">
  <scroll-view class="home-scroll" scroll-y enable-back-to-top>

    <!-- 顶部渐变区 -->
    <view class="home-top" style="padding-top: {{statusBarHeight}}px">
      <view class="home-topbar" style="padding-right: {{capsuleSafeRight}}px">
        <view class="home-topbar-left" wx:if="{{isLoggedIn}}">
          <text class="home-greeting">{{name}} · {{copy.loggedGreetingSuffix}}</text>
          <text class="home-title">{{location}}</text>
        </view>
        <view class="home-topbar-left guest-left" wx:else bindtap="onGoLogin">
          <text class="home-greeting">{{copy.guestGreeting}}</text>
          <view class="login-hint-row">
            <text class="login-hint-text">{{copy.loginHint}}</text>
            <text class="login-hint-arr">›</text>
          </view>
        </view>
        <view class="home-actions">
          <view class="lang-pill" bindtap="onLang">
            <text class="lang-pill-text">{{copy.langPill}}</text>
          </view>
          <view class="notif-btn" bindtap="onNotification">
            <text class="notif-icon">🔔</text>
            <view class="notif-dot"></view>
          </view>
        </view>
      </view>

      <!-- 天气卡片 -->
      <view class="weather-card" bindtap="onGoWeather">
        <view class="wc-top">
          <view class="wc-loc-pill" catchtap="onRefreshWeatherLocation">
            <text class="wc-loc-text">📍 {{weatherPreview.locationLabel}}</text>
            <text class="wc-loc-change">{{copy.refreshWeather}}</text>
          </view>
        </view>
        <view class="wc-main">
          <view class="wc-info">
            <view class="wc-temp-row">
              <text class="wc-temp">{{weatherPreview.weather.temp}}{{weatherPreview.weather.temp === '--' ? '' : '°'}}</text>
              <text class="wc-desc">{{weatherPreview.weather.desc}}</text>
            </view>
            <text class="wc-sub">{{weatherPreview.weather.low}}°~ {{weatherPreview.weather.high}}° · {{weatherPreview.weather.wind}}</text>
          </view>
          <text class="wc-icon">{{weatherPreview.weather.icon}}</text>
        </view>
        <view class="wc-tip">
          <text class="wc-tip-text">🌿 <text class="tip-bold">{{weatherPreview.tipText}}</text></text>
        </view>
      </view>
    </view>

    <!-- 主体内容区 -->
    <view class="home-body">

      <!-- 我的地块 -->
      <view class="hcard">
        <view class="hcard-hd">
          <view class="hcard-title-wrap">
            <view class="hcard-bar"></view>
            <text class="hcard-title">{{copy.myFields}}</text>
          </view>
          <text class="hcard-more" bindtap="onGoFields">{{copy.viewAll}}</text>
        </view>
        <picker mode="selector" range="{{homePlotOptions}}" value="{{homePlotIndex}}" bindchange="onHomePlotChange">
          <view class="home-plot-picker">
            <view class="home-plot-main">
              <text class="home-plot-k">{{copy.currentDisplay}}</text>
              <text class="home-plot-v">{{homePlotLabel}}</text>
            </view>
            <text class="home-plot-arr">{{copy.switchPlot}}</text>
          </view>
        </picker>
        <view class="stat3">
          <view class="stat3-i">
            <text class="stat3-v">{{plotStats.count}}</text>
            <text class="stat3-l">{{copy.contractFields}}</text>
          </view>
          <view class="stat3-div"></view>
          <view class="stat3-i">
            <text class="stat3-v ok">{{plotStats.area}}</text>
            <view class="stat3-l-wrap">
              <text class="stat3-unit">{{common.mu}}</text>
              <text class="stat3-l">{{copy.totalArea}}</text>
            </view>
          </view>
          <view class="stat3-div"></view>
          <view class="stat3-i">
            <text class="stat3-v warn">{{plotStats.attention}}</text>
            <text class="stat3-l">{{copy.needAttention}}</text>
          </view>
        </view>
      </view>

      <!-- 拍照识别 banner -->
      <view class="photo-banner" bindtap="onPhotoBanner">
        <view class="pb-new"><text class="pb-new-text">NEW</text></view>
        <view class="pb-inner">
          <view class="pb-icon-box">
            <text class="pb-cam">📷</text>
          </view>
          <view class="pb-txt">
            <view class="pb-title-row">
              <text class="pb-title">{{copy.photoTitle}}</text>
              <view class="pb-ai"><text class="pb-ai-text">AI</text></view>
            </view>
            <text class="pb-sub">{{copy.photoSub}}</text>
          </view>
          <view class="pb-btn">
            <text class="pb-btn-text">{{copy.photoAction}}</text>
          </view>
        </view>
      </view>

      <!-- 农事管家 -->
      <view class="hcard hcard-last">
        <view class="hcard-hd">
          <view class="hcard-title-wrap">
            <view class="hcard-bar"></view>
            <text class="hcard-title">{{copy.steward}}</text>
          </view>
        </view>
        <view class="mod-grid">
          <view
            class="mod-i"
            wx:for="{{modules}}"
            wx:key="id"
            bindtap="onModule"
            data-action="{{item.action}}"
          >
            <view class="mod-icon" style="background: {{item.bg}}">
              <text class="mod-emoji">{{item.icon}}</text>
              <view wx:if="{{item.newTag}}" class="mod-new">
                <text class="mod-new-text">NEW</text>
              </view>
            </view>
            <text class="mod-name">{{item.name}}</text>
          </view>
        </view>
      </view>

    </view>

    <view style="height: 40rpx"></view>
  </scroll-view>
  <tab-bar selected="{{0}}"></tab-bar>
</view>
