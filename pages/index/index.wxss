/* pages/index/index.wxss — 首页 */

.page {
  display: flex;
  flex-direction: column;
  height: 100vh;
  background: #F6F8F3;
  overflow: hidden;
}

.home-scroll {
  flex: 1;
  height: 0;
}

/* ===== 顶部渐变区 ===== */
.home-top {
  background: linear-gradient(180deg, #EAF5EF 0%, #F6F8F3 100%);
  padding: 12rpx 32rpx 0;
}

.home-topbar {
  display: flex;
  flex-direction: row;
  align-items: flex-start;
  justify-content: space-between;
  padding-bottom: 24rpx;
}

.home-topbar-left {
  display: flex;
  flex-direction: column;
  gap: 4rpx;
  flex: 1;
}

.home-greeting {
  font-size: 24rpx;
  color: #58655B;
}

.home-title {
  font-size: 40rpx;
  font-weight: 800;
  color: #18231A;
  line-height: 1.25;
}

.login-hint-row {
  display: flex;
  flex-direction: row;
  align-items: center;
  gap: 6rpx;
  margin-top: 4rpx;
}

.login-hint-text {
  font-size: 26rpx;
  font-weight: 700;
  color: #B9852F;
}

.login-hint-arr {
  font-size: 26rpx;
  color: #B9852F;
}

.home-actions {
  display: flex;
  flex-direction: row;
  align-items: center;
  gap: 16rpx;
  margin-top: 12rpx;
  flex-shrink: 0;
}

.lang-pill {
  background: rgba(255, 255, 255, 0.8);
  border: 1rpx solid rgba(200, 144, 46, 0.3);
  border-radius: 999rpx;
  padding: 8rpx 20rpx;
  display: flex;
  align-items: center;
}

.lang-pill-text {
  font-size: 22rpx;
  color: #B9852F;
  font-weight: 600;
}

.notif-btn {
  position: relative;
  width: 64rpx;
  height: 64rpx;
  background: rgba(255, 255, 255, 0.8);
  border-radius: 50%;
  display: flex;
  align-items: center;
  justify-content: center;
}

.notif-icon { font-size: 32rpx; }

.notif-dot {
  position: absolute;
  top: 8rpx;
  right: 8rpx;
  width: 16rpx;
  height: 16rpx;
  background: #D6453D;
  border-radius: 50%;
  border: 3rpx solid rgba(216, 234, 245, 0.9);
}

/* ===== 天气卡片 ===== */
.weather-card {
  background: #ffffff;
  border-radius: 26rpx;
  margin: 0 0 24rpx;
  padding: 24rpx 26rpx;
  border: 1rpx solid rgba(227, 233, 222, 0.75);
  box-shadow: 0 4rpx 20rpx rgba(33, 61, 42, 0.045);
  overflow: hidden;
}

.wc-top {
  display: flex;
  flex-direction: row;
  align-items: center;
  justify-content: space-between;
  margin-bottom: 14rpx;
}

.wc-loc-pill {
  background: #EEF7F4;
  border-radius: 999rpx;
  padding: 6rpx 10rpx 6rpx 18rpx;
  display: flex;
  align-items: center;
  gap: 10rpx;
  max-width: 100%;
}

.wc-loc-text {
  font-size: 22rpx;
  color: #2D86B8;
  font-weight: 600;
  max-width: 430rpx;
  overflow: hidden;
  white-space: nowrap;
  text-overflow: ellipsis;
}

.wc-loc-change {
  flex-shrink: 0;
  padding: 4rpx 12rpx;
  border-radius: 999rpx;
  background: rgba(255, 255, 255, 0.75);
  color: #B9852F;
  font-size: 20rpx;
  font-weight: 700;
}

.wc-main {
  display: flex;
  flex-direction: row;
  align-items: center;
  justify-content: space-between;
  gap: 12rpx;
  margin-bottom: 14rpx;
}

.wc-icon {
  flex-shrink: 0;
  font-size: 72rpx;
  line-height: 1;
}

.wc-temp {
  font-size: 76rpx;
  font-weight: 800;
  color: #18231A;
  line-height: 1;
}

.wc-info {
  flex: 1;
  min-width: 0;
  display: flex;
  flex-direction: column;
  gap: 8rpx;
}

.wc-temp-row {
  display: flex;
  flex-direction: row;
  align-items: baseline;
  gap: 14rpx;
}

.wc-desc {
  font-size: 28rpx;
  font-weight: 700;
  color: #18231A;
  overflow: hidden;
  white-space: nowrap;
  text-overflow: ellipsis;
}

.wc-sub {
  font-size: 22rpx;
  color: #8A948B;
}

.wc-tip {
  background: #FFF8EA;
  border-radius: 18rpx;
  padding: 14rpx 18rpx;
}

.wc-tip-text {
  font-size: 23rpx;
  color: #6F552B;
  line-height: 1.45;
}

.tip-bold {
  color: #B9852F;
  font-weight: 700;
}

/* ===== 主体内容 ===== */
.home-body {
  background: #F6F8F3;
}

/* ===== 通用卡片 ===== */
.hcard {
  background: #ffffff;
  border-radius: 26rpx;
  margin: 24rpx 32rpx 0;
  padding: 28rpx;
  box-shadow: 0 4rpx 24rpx rgba(33, 61, 42, 0.045);
}

.hcard-last {
  margin-bottom: 0;
}

.hcard-hd {
  display: flex;
  flex-direction: row;
  align-items: center;
  justify-content: space-between;
  margin-bottom: 24rpx;
}

.hcard-title-wrap {
  display: flex;
  flex-direction: row;
  align-items: center;
  gap: 12rpx;
}

.hcard-bar {
  width: 8rpx;
  height: 32rpx;
  background: #B9852F;
  border-radius: 4rpx;
}

.hcard-title {
  font-size: 30rpx;
  font-weight: 700;
  color: #18231A;
}

.hcard-more {
  font-size: 24rpx;
  color: #8A948B;
}

/* ===== 地块统计 ===== */
.home-plot-picker {
  display: flex;
  flex-direction: row;
  align-items: center;
  justify-content: space-between;
  gap: 18rpx;
  background: #F8FAF5;
  border: 2rpx solid #E3E9DE;
  border-radius: 18rpx;
  padding: 18rpx 22rpx;
  margin-bottom: 22rpx;
}

.home-plot-main {
  flex: 1;
  min-width: 0;
  display: flex;
  flex-direction: column;
  gap: 4rpx;
}

.home-plot-k {
  font-size: 20rpx;
  color: #8A7F72;
  font-weight: 600;
}

.home-plot-v {
  font-size: 28rpx;
  color: #18231A;
  font-weight: 800;
  overflow: hidden;
  text-overflow: ellipsis;
  white-space: nowrap;
}

.home-plot-arr {
  flex-shrink: 0;
  font-size: 23rpx;
  color: #B9852F;
  font-weight: 800;
}

.stat3 {
  display: flex;
  flex-direction: row;
  align-items: center;
}

.stat3-i {
  flex: 1;
  display: flex;
  flex-direction: column;
  align-items: center;
  gap: 6rpx;
}

.stat3-div {
  width: 2rpx;
  height: 48rpx;
  background: #EAF0E6;
}

.stat3-v {
  font-size: 44rpx;
  font-weight: 800;
  color: #18231A;
  line-height: 1;
}

.stat3-v.ok  { color: #2F8A52; }
.stat3-v.warn { color: #D97918; }

.stat3-l {
  font-size: 22rpx;
  color: #8A948B;
}

.stat3-l-wrap {
  display: flex;
  flex-direction: row;
  align-items: baseline;
  gap: 2rpx;
}

.stat3-unit {
  font-size: 18rpx;
  color: #8A948B;
}

/* ===== 拍照识别横幅 ===== */
.photo-banner {
  background: linear-gradient(135deg, #F1E2BF, #D6BA72);
  border-radius: 26rpx;
  margin: 24rpx 32rpx 0;
  padding: 28rpx;
  position: relative;
  overflow: hidden;
}

.pb-new {
  position: absolute;
  top: 16rpx;
  left: 24rpx;
  background: #D6453D;
  border-radius: 999rpx;
  padding: 4rpx 14rpx;
}

.pb-new-text {
  font-size: 18rpx;
  font-weight: 700;
  color: #ffffff;
}

.pb-inner {
  display: flex;
  flex-direction: row;
  align-items: center;
  gap: 24rpx;
  margin-top: 28rpx;
}

.pb-icon-box {
  width: 96rpx;
  height: 96rpx;
  background: rgba(255, 255, 255, 0.6);
  border-radius: 22rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  flex-shrink: 0;
}

.pb-cam { font-size: 48rpx; }

.pb-txt { flex: 1; }

.pb-title-row {
  display: flex;
  flex-direction: row;
  align-items: center;
  gap: 12rpx;
  margin-bottom: 8rpx;
}

.pb-title {
  font-size: 30rpx;
  font-weight: 800;
  color: #4D3B21;
}

.pb-ai {
  background: #2D86B8;
  border-radius: 8rpx;
  padding: 4rpx 12rpx;
}

.pb-ai-text {
  font-size: 18rpx;
  font-weight: 700;
  color: #ffffff;
}

.pb-sub {
  font-size: 22rpx;
  color: #7A5520;
}

.pb-btn {
  background: #B9852F;
  border-radius: 999rpx;
  padding: 16rpx 28rpx;
  flex-shrink: 0;
}

.pb-btn-text {
  font-size: 24rpx;
  font-weight: 700;
  color: #ffffff;
  white-space: nowrap;
}

/* ===== 功能模块网格 ===== */
.mod-grid {
  display: flex;
  flex-direction: row;
  flex-wrap: wrap;
}

.mod-i {
  width: 25%;
  display: flex;
  flex-direction: column;
  align-items: center;
  gap: 10rpx;
  padding-bottom: 28rpx;
}

.mod-icon {
  width: 104rpx;
  height: 104rpx;
  border-radius: 22rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  position: relative;
}

.mod-emoji { font-size: 52rpx; }

.mod-new {
  position: absolute;
  top: -8rpx;
  right: -8rpx;
  background: #2D86B8;
  border-radius: 999rpx;
  padding: 2rpx 10rpx;
}

.mod-new-text {
  font-size: 16rpx;
  font-weight: 700;
  color: #ffffff;
}

.mod-name {
  font-size: 22rpx;
  color: #58655B;
  text-align: center;
  line-height: 1.3;
}
