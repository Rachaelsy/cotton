<view class="page wf-water">
  <view class="wf-head" style="padding-top: {{statusBarHeight}}px">
    <view class="wf-nav">
      <view class="wf-back" bindtap="onBack"><text>‹</text></view>
      <text class="wf-title">💧 {{copy.title}}</text>
      <view class="wf-action" bindtap="onReminder"><text>🔔</text></view>
    </view>
    <view class="wf-hero">
      <picker mode="selector" range="{{plotOptions}}" value="{{plotIndex}}" bindchange="onPlotChange">
        <view class="wf-field-sel">📍 {{plotOptions[plotIndex] || copy.selectPlot}} ▼</view>
      </picker>
      <view class="wf-stat-row">
        <view class="wf-stat"><text class="wf-stat-v">{{model.moisture}}%</text><text class="wf-stat-l">{{copy.moisture}}</text></view>
        <view class="wf-stat"><text class="wf-stat-v">{{model.days}}</text><text class="wf-stat-l">{{copy.lastWater}}</text></view>
        <view class="wf-stat"><text class="wf-stat-v {{model.stateClass}}">{{model.state}}</text><text class="wf-stat-l">{{copy.soilState}}</text></view>
      </view>
    </view>
  </view>

  <scroll-view class="wf-scroll" scroll-y enhanced show-scrollbar="{{false}}">
    <view wx:if="{{loading}}" class="wf-empty">{{copy.loading}}</view>
    <block wx:else>
      <view class="wf-card">
        <view class="wf-sec-hd">💧 {{copy.advice}}</view>
        <view class="wf-ai-box">
          <text class="wf-ai-tag">🌿 {{copy.analysis}}</text>
          <text class="wf-ai-txt">{{model.advice}}</text>
        </view>
        <view class="wf-soil-row">
          <view class="wf-soil-item"><text class="wf-soil-icon">💧</text><text class="wf-soil-val">{{model.moisture}}%</text><text class="wf-soil-lbl">{{copy.currentMoisture}}</text></view>
          <view class="wf-soil-item"><text class="wf-soil-icon">🎯</text><text class="wf-soil-val">55~70%</text><text class="wf-soil-lbl">{{copy.target}}</text></view>
          <view class="wf-soil-item"><text class="wf-soil-icon">⛅</text><text class="wf-soil-val">0mm</text><text class="wf-soil-lbl">{{copy.rain3}}</text></view>
        </view>
        <text class="wf-small-title">{{copy.index}}</text>
        <view class="wf-progress-bar"><view class="wf-progress-fill water" style="width: {{model.moisture}}%"></view></view>
        <view class="wf-scale"><text>{{copy.dry}}</text><text>{{copy.fit}}</text><text>{{copy.wet}}</text></view>
        <view class="wf-quick-row">
          <view class="wf-quick-btn primary" bindtap="onRecord">💧 {{copy.record}}</view>
          <view class="wf-quick-btn sec" bindtap="onReminder">⏰ {{copy.reminder}}</view>
        </view>
      </view>

      <view class="wf-card">
        <view class="wf-sec-hd">📅 {{copy.plan}}</view>
        <view class="wf-plan-item" wx:for="{{model.plans}}" wx:key="name">
          <view class="wf-plan-dot water-dot"><text>{{item.icon}}</text></view>
          <view class="wf-plan-main"><text class="wf-plan-name">{{item.name}}</text><text class="wf-plan-meta">{{item.meta}}</text><text class="wf-status {{item.cls}}">{{item.status}}</text></view>
          <view class="wf-plan-val"><text>{{item.value}}</text><text class="wf-plan-sub">{{item.sub}}</text></view>
        </view>
      </view>

      <view class="wf-card">
        <view class="wf-sec-hd">📊 {{copy.history}}</view>
        <view class="wf-chart-bar-wrap">
          <view class="wf-bar-col" wx:for="{{model.bars}}" wx:key="label">
            <view class="wf-bar" style="height: {{item.height}}%"></view>
            <text class="wf-bar-lbl">{{item.label}}</text>
          </view>
        </view>
      </view>

      <view class="wf-card">
        <view class="wf-sec-hd">📖 {{copy.tips}}</view>
        <view class="wf-tip-row"><text class="wf-tip-icon">🌱</text><view><text class="wf-tip-title">{{copy.tip1}}</text><text class="wf-tip-desc">{{copy.tip1d}}</text></view></view>
        <view class="wf-tip-row"><text class="wf-tip-icon">🌸</text><view><text class="wf-tip-title">{{copy.tip2}}</text><text class="wf-tip-desc">{{copy.tip2d}}</text></view></view>
        <view class="wf-tip-row"><text class="wf-tip-icon warn">⚠️</text><view><text class="wf-tip-title">{{copy.tip3}}</text><text class="wf-tip-desc">{{copy.tip3d}}</text></view></view>
      </view>
    </block>
    <view class="wf-bottom"></view>
  </scroll-view>
</view>
