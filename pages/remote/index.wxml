<!-- 遥感监测 -->
<view class="page">
  <!-- 地图区域 -->
  <view class="rmt-map-wrap">
    <!-- 背景层 -->
    <view class="rmt-map-bg"></view>
    <!-- 网格线 -->
    <view class="rmt-grid-h" wx:for="{{[1,2,3,4,5]}}" wx:key="index" style="top:{{item*16}}%"></view>
    <view class="rmt-grid-v" wx:for="{{[1,2,3,4,5]}}" wx:key="index" style="left:{{item*16}}%"></view>
    <!-- 地块轮廓（用 view 模拟） -->
    <view class="rmt-field-outline">
      <text class="rmt-field-label">{{selField}}</text>
      <view class="rmt-score-chip">
        <text class="rmt-score-text">{{analysis.score}}分</text>
      </view>
    </view>
    <!-- 顶部导航 -->
    <view class="rmt-topbar" style="padding-top: {{statusBarHeight}}px">
      <view class="rmt-back-btn" bindtap="onBack"><text class="rmt-back-icon">‹</text></view>
      <!-- 地块选择 -->
      <scroll-view class="rmt-field-chips" scroll-x>
        <view
          class="rmt-fchip {{selField === item ? 'on' : ''}}"
          wx:for="{{fields}}"
          wx:key="index"
          bindtap="onSelField"
          data-f="{{item}}"
        >
          <text class="rmt-fchip-text">{{item}}</text>
        </view>
      </scroll-view>
      <view class="rmt-more-btn"><text class="rmt-more-text">···</text></view>
    </view>
    <!-- 无人机徽章 -->
    <view class="rmt-drone-pill">
      <text class="rmt-drone-icon">🚁</text>
      <text class="rmt-drone-text">{{analysis.updateTime}}</text>
    </view>
  </view>

  <!-- 分析卡片（从底部滑上来） -->
  <view class="rmt-card">
    <!-- AI 分析头 -->
    <view class="rmt-ai-hd">
      <view class="rmt-ai-icon">
        <text class="rmt-ai-emoji">🤖</text>
        <view class="rmt-ai-online"></view>
      </view>
      <view style="flex:1">
        <text class="rmt-ai-title">AI 遥感分析<text class="rmt-new">NEW</text></text>
        <text class="rmt-ai-sub">基于多光谱+NDVI数据实时分析</text>
      </view>
      <view class="rmt-score-ring" style="border-color:{{analysis.score >= 85 ? '#4CAF50' : '#FF9800'}}">
        <text class="rmt-ring-val">{{analysis.score}}</text>
        <text class="rmt-ring-lbl">{{analysis.scoreLabel}}</text>
      </view>
    </view>

    <!-- 指标栏 -->
    <view class="rmt-metrics">
      <view class="rmt-met">
        <text class="rmt-met-v" style="color:{{analysis.ndviColor}}">{{analysis.ndvi}}</text>
        <text class="rmt-met-l">NDVI长势</text>
      </view>
      <view class="rmt-met-div"></view>
      <view class="rmt-met">
        <text class="rmt-met-v" style="color:{{analysis.droughtColor}}">{{analysis.drought}}</text>
        <text class="rmt-met-l">旱情风险</text>
      </view>
      <view class="rmt-met-div"></view>
      <view class="rmt-met">
        <text class="rmt-met-v" style="color:{{analysis.pestColor}}">{{analysis.pest}}</text>
        <text class="rmt-met-l">病虫风险</text>
      </view>
    </view>

    <!-- 建议列表 -->
    <scroll-view class="rmt-recs-scroll" scroll-y>
      <view class="rmt-rec" wx:for="{{recs}}" wx:key="name">
        <view class="rmt-rec-ico" style="background:{{item.bg}}">
          <text class="rmt-rec-emoji">{{item.icon}}</text>
        </view>
        <view style="flex:1">
          <view style="display:flex;align-items:center;gap:12rpx;margin-bottom:8rpx">
            <text class="rmt-rec-name">{{item.name}}</text>
            <view class="rmt-prio" style="background:{{item.priority === '关注' ? '#FFF3E6' : '#E8F5E9'}}">
              <text class="rmt-prio-text" style="color:{{item.priorityColor}}">{{item.priority}}</text>
            </view>
          </view>
          <text class="rmt-rec-desc">{{item.desc}}</text>
        </view>
      </view>

      <!-- 询问 AI -->
      <view class="rmt-ask-row" bindtap="onAsk">
        <text class="rmt-ask-text">有疑问？<text class="rmt-ask-bold">问问小棉 AI ›</text></text>
      </view>
    </scroll-view>
  </view>
</view>
