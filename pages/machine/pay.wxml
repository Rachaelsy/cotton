<!-- pages/machine/pay.wxml — 农机预约支付 -->
<view class="page">
  <view class="nav" style="padding-top: {{statusBarHeight}}px">
    <view class="back-btn" bindtap="onBack"><text class="back-icon">‹</text></view>
      <text class="nav-title">{{copy.title}}</text>
    <view style="width:60rpx"></view>
  </view>

  <view class="scroll">
    <view wx:if="{{order}}" class="pay-amount">
      <text class="pa-label">{{copy.amount}}</text>
      <text class="pa-num">¥{{paymentStage === 'deposit' ? order.deposit : (paymentStage === 'balance' ? balanceAmount : order.total_price)}}</text>
      <text class="pa-order">{{copy.orderNo}} {{order.order_no}}</text>
    </view>

    <view wx:if="{{order}}" class="order-card">
      <view class="oc-row">
        <view class="oc-icon"><text>{{order.machine_icon}}</text></view>
        <text class="oc-name">{{order.machine_name}}</text>
      </view>
      <view class="oc-line"><text class="oc-k">{{copy.total}}</text><text class="oc-v">¥{{order.total_price}}</text></view>
      <view class="oc-line"><text class="oc-k">{{copy.deposit}}</text><text class="oc-v">¥{{order.deposit}}</text></view>
    </view>

    <!-- 支付方式 -->
    <view wx:if="{{paymentStage === 'balance'}}" class="mode-card">
      <view class="mode-item on">
        <view class="mode-info">
          <text class="mode-name">{{copy.balance}}</text>
          <text class="mode-sub">{{copy.balanceSub}}</text>
        </view>
        <text class="mode-amt">¥{{balanceAmount}}</text>
        <view class="radio radio-on"></view>
      </view>
    </view>
    <view wx:else class="mode-card">
      <view class="mode-item {{payMode === 'deposit' ? 'on' : ''}}" bindtap="onPayMode" data-mode="deposit">
        <view class="mode-info">
          <text class="mode-name">{{copy.depositPay}} <text class="mode-badge">{{copy.recommend}}</text></text>
          <text class="mode-sub">{{copy.depositSub}}</text>
        </view>
        <text class="mode-amt">¥{{order.deposit}}</text>
        <view class="radio {{payMode === 'deposit' ? 'radio-on' : ''}}"></view>
      </view>
      <view class="mode-item {{payMode === 'full' ? 'on' : ''}}" bindtap="onPayMode" data-mode="full">
        <view class="mode-info">
          <text class="mode-name">{{copy.full}}</text>
          <text class="mode-sub">{{copy.fullSub}}</text>
        </view>
        <text class="mode-amt">¥{{order.total_price}}</text>
        <view class="radio {{payMode === 'full' ? 'radio-on' : ''}}"></view>
      </view>
    </view>

    <view class="trust">{{copy.trust}}</view>
  </view>

  <view class="action-bar">
    <view class="bar-btn {{paying ? 'disabled' : ''}}" bindtap="onPay">
      <text class="bar-btn-text">{{paying ? copy.paying : copy.confirm + ' ¥' + (paymentStage === 'deposit' ? order.deposit : (paymentStage === 'balance' ? balanceAmount : order.total_price))}}</text>
    </view>
  </view>
</view>
