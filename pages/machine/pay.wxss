/* pages/machine/pay.wxss — 农机预约支付 */
.page { display: flex; flex-direction: column; height: 100vh; background: #F5EEE6; }
.nav { display: flex; flex-direction: row; align-items: center; justify-content: space-between;
  background: linear-gradient(160deg, #006064, #00ACC1); padding: 0 24rpx 16rpx; flex-shrink: 0; }
.back-btn { width: 60rpx; height: 60rpx; background: rgba(255,255,255,0.18); border-radius: 50%;
  display: flex; align-items: center; justify-content: center; }
.back-icon { color: #fff; font-size: 44rpx; line-height: 1; }
.nav-title { color: #fff; font-size: 32rpx; font-weight: 800; }
.scroll { flex: 1; height: 0; }

.pay-amount { background: linear-gradient(160deg, #00838F, #00ACC1); padding: 30rpx 28rpx 44rpx;
  display: flex; flex-direction: column; align-items: center; gap: 10rpx; }
.pa-label { font-size: 24rpx; color: rgba(255,255,255,0.85); }
.pa-num { font-size: 72rpx; font-weight: 900; color: #fff; }
.pa-order { font-size: 22rpx; color: rgba(255,255,255,0.7); }

.order-card { background: #fff; margin: 20rpx; border-radius: 20rpx; padding: 24rpx; }
.oc-row { display: flex; flex-direction: row; align-items: center; gap: 16rpx; padding-bottom: 18rpx; border-bottom: 1rpx solid #F2F2F2; }
.oc-icon { width: 70rpx; height: 70rpx; background: #E0F7FA; border-radius: 16rpx; display: flex; align-items: center; justify-content: center; font-size: 40rpx; }
.oc-name { font-size: 28rpx; font-weight: 700; color: #1A1A1A; flex: 1; }
.oc-line { display: flex; flex-direction: row; align-items: center; justify-content: space-between; padding-top: 16rpx; }
.oc-k { font-size: 26rpx; color: #888; }
.oc-v { font-size: 26rpx; color: #1A1A1A; font-weight: 600; }

.mode-card { background: #fff; margin: 0 20rpx; border-radius: 20rpx; padding: 8rpx 24rpx; }
.mode-item { display: flex; flex-direction: row; align-items: center; gap: 16rpx; padding: 26rpx 0; border-bottom: 1rpx solid #F2F2F2; }
.mode-item:last-child { border-bottom: none; }
.mode-info { flex: 1; display: flex; flex-direction: column; gap: 6rpx; }
.mode-name { font-size: 28rpx; font-weight: 700; color: #1A1A1A; }
.mode-badge { font-size: 18rpx; color: #fff; background: #E65100; border-radius: 6rpx; padding: 2rpx 10rpx; }
.mode-sub { font-size: 22rpx; color: #999; }
.mode-amt { font-size: 30rpx; font-weight: 800; color: #E65100; }
.radio { width: 36rpx; height: 36rpx; border-radius: 50%; border: 3rpx solid #DDD; flex-shrink: 0; }
.radio-on { border-color: #00838F; background: radial-gradient(circle, #00838F 40%, #fff 44%); }

.trust { font-size: 22rpx; color: #00838F; background: #F0F7F7; border-radius: 14rpx;
  margin: 20rpx; padding: 18rpx 20rpx; line-height: 1.7; }

.action-bar { position: absolute; left: 0; right: 0; bottom: 0; background: #fff;
  padding: 18rpx 28rpx 40rpx; box-shadow: 0 -4rpx 20rpx rgba(0,0,0,0.06); }
.bar-btn { background: linear-gradient(135deg, #006064, #00ACC1); border-radius: 999rpx;
  padding: 26rpx 0; display: flex; align-items: center; justify-content: center; }
.bar-btn.disabled { opacity: 0.6; }
.bar-btn-text { font-size: 30rpx; font-weight: 800; color: #fff; }
