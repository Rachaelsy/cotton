<!-- pages/machine/track.wxml — 订单跟踪 -->
<view class="page">
  <view class="nav" style="padding-top: {{statusBarHeight}}px">
    <view class="back-btn" bindtap="onBack"><text class="back-icon">‹</text></view>
    <text class="nav-title">订单跟踪</text>
    <view style="width:60rpx"></view>
  </view>

  <scroll-view wx:if="{{order}}" class="scroll" scroll-y style="flex:1;height:0;">
    <!-- 状态头 -->
    <view class="status-hero {{cancelled ? 'cancelled' : ''}}">
      <text class="sh-status">{{order.status_label}}</text>
      <text wx:if="{{cancelled}}" class="sh-sub">{{order.reject_reason || '订单已取消'}}</text>
      <text wx:elif="{{order.status === 'completed'}}" class="sh-sub">作业已完成，感谢使用</text>
      <text wx:elif="{{order.distance_km}}" class="sh-sub">机手距地块约 {{order.distance_km}}km</text>
      <text wx:else class="sh-sub">订单号 {{order.order_no}}</text>
    </view>

    <!-- 进度条 -->
    <view wx:if="{{!cancelled}}" class="progress-card">
      <view class="step" wx:for="{{steps}}" wx:key="key">
        <view class="step-dot {{index <= stepIndex ? 'done' : ''}} {{index === stepIndex ? 'cur' : ''}}">
          <text wx:if="{{index < stepIndex}}" class="dot-check">✓</text>
          <text wx:else class="dot-num">{{index + 1}}</text>
        </view>
        <text class="step-label {{index <= stepIndex ? 'done' : ''}}">{{item.label}}</text>
        <view wx:if="{{index < steps.length - 1}}" class="step-line {{index < stepIndex ? 'done' : ''}}"></view>
      </view>
    </view>

    <!-- 机手信息 -->
    <view class="info-card">
      <view class="ic-row">
        <text class="ic-icon">🏢</text>
        <view class="ic-info">
          <text class="ic-name">{{order.org_name}}</text>
          <text class="ic-sub">{{order.op_location || ''}} · 响应{{order.response_time}}</text>
        </view>
        <view class="ic-call" bindtap="onContact"><text class="ic-call-text">📞 联系</text></view>
      </view>
    </view>

    <!-- 订单详情 -->
    <view class="detail-card">
      <view class="dc-row"><text class="dc-icon">{{order.machine_icon}}</text><text class="dc-name">{{order.machine_name}}</text></view>
      <view class="dc-line"><text class="dc-k">作业地块</text><text class="dc-v">{{order.plot_name || '不指定'}}</text></view>
      <view wx:if="{{order.work_address}}" class="dc-line"><text class="dc-k">作业地址</text><text class="dc-v">{{order.work_address}}</text></view>
      <view class="dc-line"><text class="dc-k">作业面积</text><text class="dc-v">{{order.work_area}} 亩</text></view>
      <view class="dc-line"><text class="dc-k">作业日期</text><text class="dc-v">{{order.work_date}}</text></view>
      <view class="dc-line"><text class="dc-k">作业总价</text><text class="dc-v">¥{{order.total_price}}</text></view>
      <view class="dc-line"><text class="dc-k">已支付</text><text class="dc-v hl">¥{{order.paid_amount || (order.pay_mode === 'full' ? order.total_price : order.deposit)}}</text></view>
      <view class="dc-line"><text class="dc-k">支付状态</text><text class="dc-v">{{order.pay_status === 'paid' ? '已支付' : '未支付'}}</text></view>
    </view>

    <view style="height:160rpx"></view>
  </scroll-view>

  <!-- 底部操作 -->
  <view wx:if="{{order}}" class="action-bar">
    <view wx:if="{{order.status === 'pending'}}" class="bar-btn outline" bindtap="onCancel"><text class="bb-out">取消预约</text></view>
    <view wx:if="{{order.status === 'completed'}}" class="bar-btn solid" bindtap="onReview"><text class="bb-text">去评价</text></view>
    <view wx:if="{{order.status !== 'pending' && order.status !== 'completed' && !cancelled}}" class="bar-btn solid" bindtap="onContact"><text class="bb-text">联系机手</text></view>
    <view wx:if="{{cancelled}}" class="bar-btn outline" bindtap="onBack"><text class="bb-out">返回</text></view>
  </view>
</view>
