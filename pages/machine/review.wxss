/* pages/machine/review.wxss — 服务评价 */
.page { display: flex; flex-direction: column; height: 100vh; background: #F6F8F3; }
.nav { display: flex; flex-direction: row; align-items: center; justify-content: space-between;
  background: linear-gradient(160deg, #1F6F63, #4AAFA7); padding: 0 24rpx 16rpx; flex-shrink: 0; }
.back-btn { width: 60rpx; height: 60rpx; background: rgba(255,255,255,0.18); border-radius: 50%;
  display: flex; align-items: center; justify-content: center; }
.back-icon { color: #fff; font-size: 44rpx; line-height: 1; }
.nav-title { color: #fff; font-size: 32rpx; font-weight: 800; }
.scroll { flex: 1; height: 0; }

.rev-card { background: #fff; margin: 20rpx; border-radius: 20rpx; padding: 8rpx 24rpx; }
.dim { display: flex; flex-direction: row; align-items: center; justify-content: space-between;
  padding: 28rpx 0; border-bottom: 1rpx solid #EAF0E6; }
.dim:last-child { border-bottom: none; }
.dim-label { font-size: 28rpx; color: #333; font-weight: 600; }
.stars { display: flex; flex-direction: row; gap: 10rpx; }
.star { font-size: 52rpx; color: #E0E0E0; line-height: 1; }
.star.on { color: #FFB300; }

.content-card { background: #fff; margin: 0 20rpx; border-radius: 20rpx; padding: 24rpx; }
.cc-label { font-size: 28rpx; color: #333; font-weight: 600; }
.cc-input { width: 100%; height: 180rpx; font-size: 26rpx; color: #18231A; margin-top: 14rpx;
  background: #F8FAF5; border-radius: 12rpx; padding: 18rpx; box-sizing: border-box; }

.action-bar { position: absolute; left: 0; right: 0; bottom: 0; background: #fff;
  padding: 18rpx 28rpx 40rpx; box-shadow: 0 -4rpx 20rpx rgba(33,61,42,0.05); }
.bar-btn { background: linear-gradient(135deg, #1F6F63, #4AAFA7); border-radius: 999rpx;
  padding: 26rpx 0; display: flex; align-items: center; justify-content: center; }
.bar-btn.disabled { opacity: 0.6; }
.bar-btn-text { font-size: 30rpx; font-weight: 800; color: #fff; }
