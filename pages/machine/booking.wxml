<!-- pages/machine/booking.wxml — 农机预约 -->
<view class="page">
  <view class="nav" style="padding-top: {{statusBarHeight}}px">
    <view class="back-btn" bindtap="onBack"><text class="back-icon">‹</text></view>
    <text class="nav-title">{{copy.title}}</text>
    <view style="width:60rpx"></view>
  </view>

  <scroll-view class="scroll" scroll-y style="flex:1;height:0;">
    <!-- 机具摘要 -->
    <view wx:if="{{machine}}" class="m-summary">
      <view class="m-icon"><text>{{machine.icon}}</text></view>
      <view class="m-info">
        <text class="m-name">{{machine.name}}</text>
        <text class="m-org">🏢 {{machine.org_name}}</text>
      </view>
      <view class="m-price"><text class="mp-num">¥{{machine.price}}</text><text class="mp-unit">/{{machine.unit}}</text></view>
    </view>

    <!-- 表单 -->
    <view class="form-card">
      <view class="form-row">
        <text class="form-label">{{copy.plot}}</text>
        <picker mode="selector" range="{{plots}}" range-key="label" value="{{plotIndex}}" bindchange="onPlotChange">
          <view class="form-picker">{{plotLabel}} ›</view>
        </picker>
      </view>
      <view class="form-row form-row-col">
        <view class="addr-label-row">
          <text class="form-label">{{copy.address}} <text class="req-star">*</text></text>
          <view class="addr-map-btn" bindtap="onChooseAddress"><text class="addr-map-text">{{copy.map}}</text></view>
        </view>
        <input class="form-input-full" placeholder="{{copy.addressPh}}" value="{{workAddress}}" bindinput="onAddrInput" />
        <text wx:if="{{workAddrDetail && workAddrDetail !== workAddress}}" class="addr-detail">📍 {{workAddrDetail}}</text>
      </view>
      <view class="form-row">
        <text class="form-label">{{copy.date}}</text>
        <picker mode="date" value="{{workDate}}" bindchange="onDateChange">
          <view class="form-picker">{{workDate}} ›</view>
        </picker>
      </view>
      <view class="form-row">
        <text class="form-label">{{copy.area}}</text>
        <view class="area-input-wrap">
          <input class="form-input" type="digit" placeholder="{{copy.areaPh}}" value="{{workArea}}" bindinput="onAreaInput" />
          <text class="area-unit">{{copy.mu}}</text>
        </view>
      </view>
      <view class="form-row">
        <text class="form-label">{{copy.phone}}</text>
        <input class="form-input" type="number" placeholder="{{copy.phonePh}}" value="{{contactPhone}}" bindinput="onPhoneInput" />
      </view>
      <view class="form-row form-row-col">
        <text class="form-label">{{copy.note}}</text>
        <textarea class="form-textarea" placeholder="{{copy.notePh}}" value="{{note}}" bindinput="onNoteInput" />
      </view>
    </view>

    <!-- 费用预估 -->
    <view class="cost-card">
      <view class="cost-row">
        <text class="cost-label">{{copy.unitPrice}}</text>
        <text class="cost-val">¥{{machine.price}} / {{machine.unit}}</text>
      </view>
      <view class="cost-row">
        <text class="cost-label">{{copy.estimated}}</text>
        <text class="cost-total">¥{{totalPrice}}</text>
      </view>
      <view class="cost-row">
        <text class="cost-label">{{copy.deposit}}</text>
        <text class="cost-deposit">¥{{deposit}}</text>
      </view>
      <view class="cost-tip">{{copy.trust}}</view>
    </view>

    <view style="height:180rpx"></view>
  </scroll-view>

  <view class="action-bar">
    <view class="bar-cost">
      <text class="bar-label">{{copy.depositLabel}}</text>
      <text class="bar-num">¥{{deposit}}</text>
    </view>
    <view class="bar-btn {{submitting ? 'disabled' : ''}}" bindtap="onSubmit">
      <text class="bar-btn-text">{{submitting ? copy.submitting : copy.submit}}</text>
    </view>
  </view>
</view>
