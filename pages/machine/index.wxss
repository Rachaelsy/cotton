/* pages/machine/index.wxss — 农机租赁列表页样式 */

.page {
  display: flex;
  flex-direction: column;
  height: 100vh;
  background: #F5EEE6;
  box-sizing: border-box;
}

/* ===== 头部 ===== */
.mach-header {
  background: linear-gradient(160deg, #006064, #00ACC1);
  flex-shrink: 0;
  padding-left: 28rpx;
  padding-right: 28rpx;
  padding-bottom: 24rpx;
}

.topbar {
  display: flex;
  flex-direction: row;
  align-items: center;
  justify-content: space-between;
  padding-top: 10rpx;
  padding-bottom: 8rpx;
}

.topbar-titles {
  display: flex;
  flex-direction: column;
  gap: 2rpx;
}

.page-title {
  font-size: 36rpx;
  font-weight: 800;
  color: #ffffff;
  line-height: 1.2;
}

.page-subtitle {
  font-size: 20rpx;
  font-weight: 600;
  color: rgba(255, 255, 255, 0.65);
  letter-spacing: 3rpx;
}

/* ===== 筛选标签（横向 scroll-view 需显式高度，否则 Skyline 真机塌陷）===== */
.filter-tabs {
  margin-top: 20rpx;
  height: 64rpx;
  white-space: nowrap;
}

.filter-tab {
  display: inline-block;
  vertical-align: top;
  background: rgba(255, 255, 255, 0.18);
  border-radius: 999rpx;
  padding: 12rpx 28rpx;
  border: 2rpx solid rgba(255, 255, 255, 0.25);
  margin-right: 16rpx;
  box-sizing: border-box;
}

.filter-tab-on {
  background: #ffffff;
  border-color: #ffffff;
}

.filter-tab-text {
  font-size: 24rpx;
  font-weight: 600;
  color: rgba(255, 255, 255, 0.9);
}

.filter-tab-on .filter-tab-text {
  color: #006064;
}

/* ===== 滚动区 ===== */
.scroll-content {
  flex: 1;
  height: 0;
}

/* ===== 农机列表 ===== */
.machine-list {
  padding: 24rpx 28rpx 0;
  display: flex;
  flex-direction: column;
  gap: 20rpx;
}

.machine-card {
  background: #ffffff;
  border-radius: 28rpx;
  padding: 24rpx;
  display: flex;
  flex-direction: row;
  align-items: flex-start;
  gap: 20rpx;
  box-shadow: 0 4rpx 24rpx rgba(0, 0, 0, 0.07);
}

/* 左侧图标 */
.card-icon-wrap {
  width: 108rpx;
  height: 108rpx;
  background: linear-gradient(135deg, #E0F7FA, #B2EBF2);
  border-radius: 24rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  flex-shrink: 0;
}

.card-icon {
  font-size: 56rpx;
}

/* 右侧信息区 */
.card-body {
  flex: 1;
  display: flex;
  flex-direction: column;
  gap: 10rpx;
  min-width: 0;
}

.card-name-row {
  display: flex;
  flex-direction: row;
  align-items: center;
  justify-content: space-between;
  gap: 8rpx;
}

.card-name {
  font-size: 28rpx;
  font-weight: 800;
  color: #1A1A1A;
  flex: 1;
  min-width: 0;
}

/* 状态 badge */
.status-badge {
  border-radius: 8rpx;
  padding: 4rpx 14rpx;
  flex-shrink: 0;
}

.badge-green {
  background: #E8F5E9;
}

.badge-orange {
  background: #FFF3E0;
}

.badge-text {
  font-size: 20rpx;
  font-weight: 700;
}

.badge-green .badge-text {
  color: #2E7D32;
}

.badge-orange .badge-text {
  color: #E65100;
}

/* 机构 */
.card-org {
  font-size: 22rpx;
  color: #888888;
}

/* 参数行 */
.card-params {
  display: flex;
  flex-direction: row;
  flex-wrap: wrap;
  gap: 10rpx;
}

.param-item {
  background: #F5EEE6;
  border-radius: 10rpx;
  padding: 6rpx 14rpx;
  display: flex;
  flex-direction: row;
  align-items: center;
  gap: 6rpx;
}

.param-label {
  font-size: 20rpx;
  color: #888888;
}

.param-value {
  font-size: 20rpx;
  font-weight: 700;
  color: #1A1A1A;
}

/* 底部：价格 + 评分 + 按钮 */
.card-bottom {
  display: flex;
  flex-direction: row;
  align-items: center;
  gap: 12rpx;
  margin-top: 4rpx;
}

.price-wrap {
  display: flex;
  flex-direction: row;
  align-items: baseline;
  gap: 2rpx;
  flex: 1;
}

.price-main {
  font-size: 36rpx;
  font-weight: 900;
  color: #006064;
}

.price-unit {
  font-size: 20rpx;
  color: #888888;
}

.card-rating {
  font-size: 22rpx;
  color: #555555;
  font-weight: 600;
}

.book-btn {
  background: linear-gradient(135deg, #006064, #00ACC1);
  border-radius: 999rpx;
  padding: 12rpx 28rpx;
}

.book-btn-text {
  font-size: 24rpx;
  font-weight: 700;
  color: #ffffff;
}

/* ===== 无结果 ===== */
.empty-tip {
  display: flex;
  flex-direction: column;
  align-items: center;
  padding: 80rpx 0;
  gap: 16rpx;
}

.empty-icon {
  font-size: 72rpx;
}

.empty-text {
  font-size: 28rpx;
  color: #888888;
}

.empty-sub {
  font-size: 24rpx;
  color: #AAAAAA;
}

.list-bottom {
  height: 40rpx;
}

/* ===== 新增：返回/我的预约/定位/排序 ===== */
.back-btn {
  width: 60rpx;
  height: 60rpx;
  background: rgba(255, 255, 255, 0.18);
  border-radius: 50%;
  display: flex;
  align-items: center;
  justify-content: center;
  flex-shrink: 0;
}
.back-icon { color: #fff; font-size: 44rpx; line-height: 1; }
.topbar-titles { flex: 1; margin-left: 16rpx; }
.orders-btn {
  background: rgba(255, 255, 255, 0.18);
  border: 2rpx solid rgba(255, 255, 255, 0.3);
  border-radius: 999rpx;
  padding: 10rpx 22rpx;
  flex-shrink: 0;
}
.orders-btn-text { font-size: 22rpx; color: #fff; font-weight: 600; }

.locate-bar {
  display: flex;
  flex-direction: row;
  align-items: center;
  gap: 8rpx;
  background: rgba(255, 255, 255, 0.15);
  border-radius: 12rpx;
  padding: 12rpx 18rpx;
  margin-top: 18rpx;
}
.locate-icon { font-size: 24rpx; }
.locate-text { font-size: 24rpx; color: #fff; font-weight: 600; }
.locate-tag { font-size: 18rpx; color: #006064; background: #fff; border-radius: 6rpx; padding: 2rpx 10rpx; margin-left: 10rpx; font-weight: 700; }
.locate-warn { font-size: 18rpx; color: #fff; background: #DC2626; border-radius: 6rpx; padding: 2rpx 12rpx; margin-left: 10rpx; font-weight: 700; }
.locate-action { flex: 1; text-align: right; font-size: 22rpx; color: #FFE082; font-weight: 700; }

/* ===== 地区选择弹窗 ===== */
.region-mask { position: fixed; top: 0; left: 0; right: 0; bottom: 0;
  background: rgba(0,0,0,0.5); z-index: 200; display: flex; flex-direction: column; justify-content: flex-end; }
.region-sheet { background: #fff; border-radius: 32rpx 32rpx 0 0; padding: 28rpx 28rpx 40rpx; max-height: 70vh; display: flex; flex-direction: column; }
.region-head { display: flex; flex-direction: row; align-items: center; justify-content: space-between; padding-bottom: 20rpx; }
.region-title { font-size: 32rpx; font-weight: 800; color: #1A1A1A; }
.region-close { width: 52rpx; height: 52rpx; background: #F2F2F2; border-radius: 50%; display: flex; align-items: center; justify-content: center; color: #888; font-size: 26rpx; }
.region-gps { display: flex; flex-direction: row; align-items: center; gap: 16rpx; background: #E0F7FA; border-radius: 16rpx; padding: 22rpx 24rpx; }
.rg-icon { font-size: 36rpx; }
.rg-info { flex: 1; display: flex; flex-direction: column; gap: 4rpx; }
.rg-text { font-size: 28rpx; font-weight: 700; color: #006064; }
.rg-sub { font-size: 20rpx; color: #00838F; }
.rg-arrow { font-size: 36rpx; color: #00838F; }
.region-divider { display: flex; align-items: center; justify-content: center; padding: 20rpx 0 12rpx; }
.region-divider-text { font-size: 22rpx; color: #aaa; }
.region-list { flex: 1; height: 0; max-height: 600rpx; }
.region-item { display: flex; flex-direction: row; align-items: center; justify-content: space-between;
  padding: 26rpx 16rpx; border-bottom: 1rpx solid #F2F2F2; }
.region-item-text { font-size: 28rpx; color: #333; }
.region-item.on .region-item-text { color: #006064; font-weight: 700; }
.region-check { font-size: 28rpx; color: #006064; font-weight: 800; }

.sort-bar {
  display: flex;
  flex-direction: row;
  background: #fff;
  flex-shrink: 0;
  border-bottom: 1rpx solid #EEE;
}
.sort-item {
  flex: 1;
  padding: 20rpx 0;
  display: flex;
  align-items: center;
  justify-content: center;
}
.sort-text { font-size: 26rpx; color: #888; font-weight: 600; }
.sort-item-on .sort-text { color: #006064; font-weight: 800; }

.card-org-row {
  display: flex;
  flex-direction: row;
  align-items: center;
  justify-content: space-between;
}
.card-dist { font-size: 22rpx; color: #00838F; font-weight: 700; }
.card-dist-out { color: #DC2626; }

.param-badge {
  background: #F0F7F7;
  border-radius: 8rpx;
  padding: 5rpx 14rpx;
  font-size: 20rpx;
  color: #00838F;
  font-weight: 600;
}
