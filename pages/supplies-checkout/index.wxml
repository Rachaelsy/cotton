<!-- pages/supplies-checkout/index.wxml — 确认订单 -->
<view class="page">

  <!-- 顶部导航 -->
  <view class="co-nav" style="padding-top: {{statusBarHeight}}px">
    <view class="nav-back-btn" bindtap="onBack">
      <text class="back-icon">‹</text>
    </view>
    <text class="co-title">确认订单</text>
    <view style="width: 64rpx"></view>
  </view>

  <!-- 内容滚动区 -->
  <scroll-view class="co-scroll" scroll-y>

    <!-- 收货信息 -->
    <view class="co-card">
      <view class="co-card-title">
        <text class="co-card-title-bar"></text>
        <text class="co-card-title-text">收货信息</text>
      </view>
      <view class="addr-row">
        <text class="addr-icon">📍</text>
        <view class="addr-info">
          <view class="addr-name-row">
            <text class="addr-name">古丽巴哈尔</text>
            <text class="addr-phone">138****5678</text>
          </view>
          <text class="addr-detail">新疆喀什地区疏附县疏附乡 3号棉田</text>
          <text class="addr-change" bindtap="onChangeAddr">切换地址 ›</text>
        </view>
      </view>
    </view>

    <!-- 订单商品 -->
    <view class="co-card">
      <view class="co-card-title">
        <text class="co-card-title-bar"></text>
        <text class="co-card-title-text">订单商品</text>
      </view>
      <view class="co-item" wx:for="{{cartItems}}" wx:key="id">
        <view class="co-item-img" style="background: {{item.imgBg}}">
          <text class="co-item-icon">{{item.icon}}</text>
        </view>
        <view class="co-item-info">
          <text class="co-item-name">{{item.name}}</text>
          <text class="co-item-spec">{{item.spec}} × {{item.qty}}</text>
        </view>
        <text class="co-item-price">¥{{item.price * item.qty}}</text>
      </view>
    </view>

    <!-- 配送方式 -->
    <view class="co-card">
      <view class="co-card-title">
        <text class="co-card-title-bar"></text>
        <text class="co-card-title-text">配送方式</text>
      </view>
      <view class="delivery-row">
        <text class="delivery-label">🚚 送货到地头</text>
        <text class="delivery-fee">¥10</text>
      </view>
    </view>

    <!-- 支付方式 -->
    <view class="co-card">
      <view class="co-card-title">
        <text class="co-card-title-bar"></text>
        <text class="co-card-title-text">支付方式</text>
      </view>
      <view class="pay-opt" bindtap="onPayMethod" data-method="alipay">
        <view class="pay-ico" style="background: #E8F4FD">
          <text>💙</text>
        </view>
        <view class="pay-info">
          <text class="pay-name">支付宝</text>
          <text class="pay-sub">余额 ¥2,380.00</text>
        </view>
        <view class="pay-radio {{payMethod === 'alipay' ? 'pay-radio-on' : ''}}"></view>
      </view>
      <view class="pay-opt" bindtap="onPayMethod" data-method="wechat">
        <view class="pay-ico" style="background: #E8F5E9">
          <text>💚</text>
        </view>
        <view class="pay-info">
          <text class="pay-name">微信支付</text>
          <text class="pay-sub">零钱 ¥156.40</text>
        </view>
        <view class="pay-radio {{payMethod === 'wechat' ? 'pay-radio-on' : ''}}"></view>
      </view>
      <view class="pay-opt" bindtap="onPayMethod" data-method="bank">
        <view class="pay-ico" style="background: #FFF3E0">
          <text>🏦</text>
        </view>
        <view class="pay-info">
          <text class="pay-name">银行卡</text>
          <text class="pay-sub">农业银行 尾号 6238</text>
        </view>
        <view class="pay-radio {{payMethod === 'bank' ? 'pay-radio-on' : ''}}"></view>
      </view>
    </view>

    <!-- 备注 -->
    <view class="co-card" style="margin-bottom: 0">
      <view class="co-card-title">
        <text class="co-card-title-bar"></text>
        <text class="co-card-title-text">订单备注</text>
      </view>
      <view class="remark-row">
        <text class="remark-placeholder">如有特殊要求请填写...</text>
        <text class="remark-arr">›</text>
      </view>
    </view>

    <view style="height: 200rpx"></view>
  </scroll-view>

  <!-- 底部结算栏 -->
  <view class="co-bottom">
    <view class="co-total-rows">
      <view class="co-total-row">
        <text class="co-total-label">商品合计</text>
        <text class="co-total-val">¥{{cartTotal}}</text>
      </view>
      <view class="co-total-row">
        <text class="co-total-label">运费</text>
        <text class="co-total-val">¥10</text>
      </view>
    </view>
    <view class="co-pay-btn" bindtap="onPay">
      <text class="co-pay-text" wx:if="{{!submitting}}">确认支付 ¥{{totalWithFee}}</text>
      <text class="co-pay-text" wx:else>处理中...</text>
    </view>
  </view>

</view>
