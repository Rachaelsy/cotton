<!-- pages/profile/index.wxml - 个人资料编辑 -->
<view class="page">

  <!-- 顶部导航 -->
  <view class="pf-nav" style="padding-top: {{statusBarHeight}}px">
    <view class="nav-back-btn cm-back-btn" bindtap="onBack">
      <text class="back-icon cm-back-text">‹</text>
    </view>
    <text class="pf-title">{{copy.title}}</text>
    <view class="cm-back-spacer"></view>
  </view>

  <scroll-view class="pf-scroll" scroll-y>

    <!-- 头像区（点击选图上传） -->
    <view class="avatar-section" bindtap="onChooseAvatar">
      <view class="avatar-circle">
        <image wx:if="{{avatarUrl}}" class="avatar-img" src="{{avatarUrl}}" mode="aspectFill"/>
        <text wx:else class="avatar-text">{{initial}}</text>
        <view class="avatar-edit-badge">
          <text class="avatar-edit-icon">📷</text>
        </view>
      </view>
      <text class="avatar-hint">{{uploading ? copy.uploading : copy.avatarHint}}</text>
    </view>

    <!-- 表单 -->
    <view class="form-card">

      <view class="field-row">
        <text class="field-label">{{copy.name}}</text>
        <input
          class="field-input"
          value="{{form.real_name}}"
          placeholder="{{copy.namePh}}"
          placeholder-class="field-ph"
          bindinput="onNameInput"
          maxlength="20"
        />
      </view>
      <view class="field-div"></view>

      <view class="field-row">
        <text class="field-label">{{copy.phone}}</text>
        <text class="field-readonly">{{form.phone}}</text>
      </view>
      <view class="field-div"></view>

      <view class="field-row">
        <text class="field-label">{{copy.location}}</text>
        <input
          class="field-input"
          value="{{form.location}}"
          placeholder="{{copy.locationPh}}"
          placeholder-class="field-ph"
          bindinput="onLocationInput"
          maxlength="40"
        />
      </view>
      <view class="field-div"></view>

      <view class="field-row">
        <text class="field-label">{{copy.landSize}}</text>
        <view class="field-input-wrap">
          <input
            class="field-input"
            value="{{form.land_size}}"
            placeholder="0"
            placeholder-class="field-ph"
            type="digit"
            bindinput="onLandSizeInput"
          />
          <text class="field-unit">{{common.mu}}</text>
        </view>
      </view>
    </view>

    <!-- 保存按钮 -->
    <view class="save-btn {{saving ? 'save-btn-off' : ''}}" bindtap="onSave">
      <text class="save-btn-text">{{saving ? copy.saving : copy.save}}</text>
    </view>

    <view style="height: 60rpx"></view>
  </scroll-view>

</view>