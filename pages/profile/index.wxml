<!-- pages/profile/index.wxml — 个人资料编辑 -->
<view class="page">

  <!-- 顶部导航 -->
  <view class="pf-nav" style="padding-top: {{statusBarHeight}}px">
    <view class="nav-back-btn" bindtap="onBack">
      <text class="back-icon">‹</text>
    </view>
    <text class="pf-title">个人资料</text>
    <view style="width: 64rpx"></view>
  </view>

  <scroll-view class="pf-scroll" scroll-y>

    <!-- 头像区 -->
    <view class="avatar-section">
      <view class="avatar-circle">
        <text class="avatar-text">{{initial}}</text>
      </view>
      <text class="avatar-hint">头像</text>
    </view>

    <!-- 表单 -->
    <view class="form-card">

      <view class="field-row">
        <text class="field-label">姓名</text>
        <input
          class="field-input"
          value="{{form.real_name}}"
          placeholder="请输入真实姓名"
          placeholder-class="field-ph"
          bindinput="onNameInput"
          maxlength="20"
        />
      </view>
      <view class="field-div"></view>

      <view class="field-row">
        <text class="field-label">手机号</text>
        <text class="field-readonly">{{form.phone}}</text>
      </view>
      <view class="field-div"></view>

      <view class="field-row">
        <text class="field-label">所在地区</text>
        <input
          class="field-input"
          value="{{form.location}}"
          placeholder="如：新疆喀什疏附县"
          placeholder-class="field-ph"
          bindinput="onLocationInput"
          maxlength="40"
        />
      </view>
      <view class="field-div"></view>

      <view class="field-row">
        <text class="field-label">承包面积</text>
        <view class="field-input-wrap">
          <input
            class="field-input"
            value="{{form.land_size}}"
            placeholder="0"
            placeholder-class="field-ph"
            type="digit"
            bindinput="onLandSizeInput"
          />
          <text class="field-unit">亩</text>
        </view>
      </view>
      <view class="field-div"></view>

      <view class="field-row">
        <text class="field-label">主种作物</text>
        <picker mode="selector" range="{{cropOptions}}" value="{{cropIndex}}" bindchange="onCropChange">
          <view class="field-picker">
            <text class="field-picker-val">{{form.crop_type}}</text>
            <text class="field-picker-arr">›</text>
          </view>
        </picker>
      </view>

    </view>

    <!-- 保存按钮 -->
    <view class="save-btn {{saving ? 'save-btn-off' : ''}}" bindtap="onSave">
      <text class="save-btn-text">{{saving ? '保存中...' : '保存'}}</text>
    </view>

    <view style="height: 60rpx"></view>
  </scroll-view>

</view>
