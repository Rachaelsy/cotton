/* app.wxss — 全局样式 */
page {
  --br: #B9852F;
  --br-d: #7A5A26;
  --br-l: #EFE0BE;
  --br-bg: #FFF8EA;
  --green: #2F7D4B;
  --green-d: #215C38;
  --green-l: #E8F3EA;
  --ok: #2F8A52;
  --ok-bg: #EAF6EF;
  --warn: #D97918;
  --warn-bg: #FFF3E3;
  --danger: #D6453D;
  --info: #2D86B8;
  --bg: #F6F8F3;
  --card: #ffffff;
  --surface: #FFFFFF;
  --surface-soft: #F8FAF5;
  --t1: #18231A;
  --t2: #58655B;
  --t3: #8A948B;
  --t4: #B7C0B8;
  --bdr: #E3E9DE;
  --div: #EAF0E6;
  --shadow-card: 0 4rpx 22rpx rgba(33, 61, 42, 0.06);
  --shadow-float: 0 10rpx 32rpx rgba(33, 61, 42, 0.10);
  --radius-card: 26rpx;
  --radius-inner: 18rpx;
  background-color: #F6F8F3;
  font-family: -apple-system, 'PingFang SC', 'Helvetica Neue', sans-serif;
  box-sizing: border-box;
}

/* 通用工具类 */
.flex-row {
  display: flex;
  flex-direction: row;
  align-items: center;
}

.flex-col {
  display: flex;
  flex-direction: column;
}

.flex1 { flex: 1; }

.text-center { text-align: center; }

/* 通用标题栏左侧返回按钮 */
.nav-back {
  width: 64rpx;
  height: 64rpx;
  background: rgba(255,255,255,0.2);
  border-radius: 50%;
  display: flex;
  align-items: center;
  justify-content: center;
  font-size: 40rpx;
  color: #fff;
  flex-shrink: 0;
}

.nav-back-dark {
  width: 64rpx;
  height: 64rpx;
  background: #F6F8F3;
  border-radius: 50%;
  display: flex;
  align-items: center;
  justify-content: center;
  font-size: 40rpx;
  color: #18231A;
  flex-shrink: 0;
}

.cm-back-btn {
  min-width: 76rpx;
  height: 56rpx;
  padding: 0 16rpx;
  border-radius: 999rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  background: rgba(255, 255, 255, 0.16);
  border: 1rpx solid rgba(255, 255, 255, 0.24);
  box-sizing: border-box;
  flex-shrink: 0;
}

.cm-back-text {
  color: #FFFFFF;
  font-size: 23rpx;
  font-weight: 700;
  line-height: 1;
}

.cm-back-spacer {
  min-width: 76rpx;
  height: 56rpx;
  flex-shrink: 0;
}

/* Tab 页底部占位块，防止 scroll-view 延伸到 fixed tab bar 区域 */
.tbar-placeholder {
  flex-shrink: 0;
  height: 152rpx;
}
