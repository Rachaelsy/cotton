# Docker Compose reads this file from the repository root.
DB_PASS=replace-with-the-current-mysql-root-password
DB_NAME=cotton
DB_HOST_PORT=3306

# Leave these blank when both services use the same public domain.
COMMUNITY_BASE_URL=
PLATFORM_BASE_URL=

# Local course uploads. Put large production videos in COS/OSS instead.
KNOWLEDGE_LOCAL_UPLOAD_MAX_MB=250

# Host paths mounted into the cotton-app container.
WECHAT_PAY_PRIVATE_KEY_HOST_PATH=./apiclient_key.pem
WECHAT_PAY_PUBLIC_KEY_HOST_PATH=./pub_key.pem
