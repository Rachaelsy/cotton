# 复制此文件为 .env 并填写真实值
# cp .env.example .env

# ── 数据库密码（MySQL root 密码，自定义） ──────────
DB_PASS=your_strong_password_here
DB_NAME=cotton

# ── JWT 密钥（运行下面命令生成：openssl rand -hex 32） ──
JWT_SECRET=your_jwt_secret_at_least_32_chars
JWT_EXPIRES=7d

# ── AI 功能（可选，不填则 AI 问答不可用） ──────────
# GROQ_API_KEY=gsk_xxxxxxxxxxxx
# SILICONFLOW_API_KEY=sk_xxxxxxxxxxxx
# DEEPSEEK_API_KEY=sk_xxxxxxxxxxxx
